  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Place pumpkin cut side up on baking tray with onion and garlic. Drizzle with oil, sprinkle with salt and pepper. Wrap garlic in foil."
    },
    {
      "order": 3,
      "instruction": "Bake for 70 - 80 minutes or until the pumpkin is soft (test with skewer)."
    },
    {
      "order": 4,
      "instruction": "Pour 2 cups of milk into a blender."
    },
    {
      "order": 5,
      "instruction": "Scoop seeds out of pumpkin and discard. Use a large spoon to scoop out pumpkin flesh from one pumpkin half and place into blender."
    },
    {
      "order": 6,
      "instruction": "Peel off most of the dark burnt outer layer of onion. Cut in half (with spoon!) and transfer to blender."
    },
    {
      "order": 7,
      "instruction": "Unwrap garlic and squeeze the flesh out of half the garlic into the blender."
    },
    {
      "order": 8,
      "instruction": "Whizz until smooth. Adjust consistency to taste with water / milk. Adjust seasoning to taste."
    },
    {
      "order": 9,
      "instruction": "Pour into bowls. Repeat with remaining pumpkin."
    },
    {
      "order": 10,
      "instruction": "Drizzle with cream, sprinkle with parsley and serve with hot garlic bread on the side."
    }
  ]
}