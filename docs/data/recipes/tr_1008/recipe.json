  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large pot over medium heat. Add garlic and onion, cook for 30 seconds or so."
    },
    {
      "order": 2,
      "instruction": "Add oregano and fennel seeds, cook for 2 minutes (lets flavour “bloom”)."
    },
    {
      "order": 3,
      "instruction": "Turn heat down to medium low. Add carrots and celery, cook, stirring regularly, for 8 minutes until onion is sweet (not browned). This step is key to the flavour base of this soup."
    },
    {
      "order": 4,
      "instruction": "Add capsicum, turn heat up to high and cook for 2 minutes, stirring constantly."
    },
    {
      "order": 5,
      "instruction": "Add remaining Soup ingredients, bring to simmer then place lid on. Turn heat down to medium low, simmer for 25 minutes."
    },
    {
      "order": 6,
      "instruction": "Remove lid, adjust salt and pepper to taste."
    },
    {
      "order": 7,
      "instruction": "Ladle soup into bowls. Grate over lemon zest, squeeze of lemon juice and sprinkle with parsley. Serve!"
    }
  ]
}