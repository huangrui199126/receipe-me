  "steps": [
    {
      "order": 1,
      "instruction": "Combine broth ingredients: Place chicken stock, soy sauce, Chinesse cooking wine, garlic and ginger in a small pot over high heat."
    },
    {
      "order": 2,
      "instruction": "Simmer to infuse: Place lid on, bring to simmer then reduce to medium and simmer for 5 minutes to allow the flavours to infuse."
    },
    {
      "order": 3,
      "instruction": "Add rice: Add rice and cook uncovered for 10 minutes - broth surface should be bubbling very gently."
    },
    {
      "order": 4,
      "instruction": "Add fish &amp; stems: Add fish and stems of choy sum, cook for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Pick garlic and ginger out of soup."
    },
    {
      "order": 6,
      "instruction": "Stir through choy sum leaves (they will wilt almost instantly), sesame oil and pepper. Serve immediately."
    }
  ]
