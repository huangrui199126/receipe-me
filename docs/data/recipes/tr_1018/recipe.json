  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta in a large pot of salted boiling water per packet directions, MINUS 1 minute. Drain. (Do this while sauce is simmering)"
    },
    {
      "order": 2,
      "instruction": "Cook chicken: Sprinkle both sides of chicken with salt and pepper. Heat 1 tbsp oil in a large skillet over high heat. Sear chicken 1 1/2 minutes on each side until golden, then remove from skillet. Shred while sauce is simmering."
    },
    {
      "order": 3,
      "instruction": "Add remaining 1 tbsp oil. Add garlic and sauté for 15 seconds."
    },
    {
      "order": 4,
      "instruction": "Add wine and let it simmer rapidly for 1 minute, stirring to dissolve brown bits on bottom of skillet into the wine, until mostly evaporated."
    },
    {
      "order": 5,
      "instruction": "Add tomato, water, olives, artichoke, red pepper flakes, salt and pepper. Stir, simmer on medium for 5 minutes."
    },
    {
      "order": 6,
      "instruction": "Stir shredded chicken into sauce."
    },
    {
      "order": 7,
      "instruction": "Add pasta into sauce, still on the stove. Toss well for 1 minute or until sauce reduces more and is clinging to pasta strands, rather than pooled in the skillet."
    },
    {
      "order": 8,
      "instruction": "Just before serving, toss through fresh basil."
    },
    {
      "order": 9,
      "instruction": "Serve immediately with parmesan!"
    }
  ]
}