  "steps": [
    {
      "order": 1,
      "instruction": "Chill glasses in the fridge."
    },
    {
      "order": 2,
      "instruction": "Place Daiquiri ingredients in the blender in the order listed (ice last, blends better)."
    },
    {
      "order": 3,
      "instruction": "Whizz until ice is blitzed. Taste test then adjust sour with lime and sweetness with sugar."
    },
    {
      "order": 4,
      "instruction": "Pour into glasses - this recipe makes the perfect amount to fill 4 martini glasses."
    },
    {
      "order": 5,
      "instruction": "Garnish with strawberries, lime and mint if desired. Serve cold."
    },
    {
      "order": 6,
      "instruction": "Puree mango using a stick blender or food processor."
    },
    {
      "order": 7,
      "instruction": "Pour into 1 litre / 1 quart or larger jar or bottle. Add bacardi, sugar syrup and 1/2 cup water (Note 3). Refrigerate until chilled. Also refrigerate the limes and glasses."
    },
    {
      "order": 8,
      "instruction": "Once chilled, add lime juice and ice cubes into the bottle. Shake well, then serve, straining the ice cubes. You can also put some crushed ice into the glasses, but remember that as the ice melts, it will dilute the cocktail."
    }
  ]
