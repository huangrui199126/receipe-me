  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Use a large empty can (800g/28oz canned tomato can) to cut out rounds from the bread. (Note 4)"
    },
    {
      "order": 3,
      "instruction": "Mould into a muffin tin."
    },
    {
      "order": 4,
      "instruction": "Place butter, garlic and salt in a microwave-proof bowl or mug and microwave in 30 second increments until the butter is melted."
    },
    {
      "order": 5,
      "instruction": "Brush cups with butter, ensuring you use the garlic too."
    },
    {
      "order": 6,
      "instruction": "Divide the pizza sauce between the cups, then top with onion and mushrooms."
    },
    {
      "order": 7,
      "instruction": "Top with cheese then with pepperoni."
    },
    {
      "order": 8,
      "instruction": "Bake for 10 to 15 minutes, or until the cheese is melted and bread is golden on the edges."
    },
    {
      "order": 9,
      "instruction": "Serve warm!"
    }
  ]
