  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/450°F (200°F fan)."
    },
    {
      "order": 2,
      "instruction": "Garlic butter: Place butter, garlic, salt and pepper in a heatproof jug. Microwave to melt butter, then stir."
    },
    {
      "order": 3,
      "instruction": "Brush with butter: Brush the mushroom cap with butter (smooth side), then place on a tray gills side up (ie stalk facing up). Brush remaining butter onto the rims and gills, being sure to scrape up all the garlic in the jug."
    },
    {
      "order": 4,
      "instruction": "Olive oil: Drizzle with olive oil."
    },
    {
      "order": 5,
      "instruction": "Roast 25 minutes, then flip mushrooms. Brush with tay juices, roast a further 10 minutes or until the centre of the mushrooms are tender. {Meanwhile, cook onion, mix Sauce)"
    },
    {
      "order": 6,
      "instruction": "Top with cheese: Place a slice of cheese on each mushroom, return to oven for 3 minutes just to melt the cheese."
    },
    {
      "order": 7,
      "instruction": "Toast buns: Place split buns in the oven at the same time - to lightly toast."
    },
    {
      "order": 8,
      "instruction": "Spread base of bun with a dollop of Pink Sauce. Top with lettuce, then tomato, then mushroom, then onion. Spread lid with a lesser smear of Pink Sauce, then place on burger. Devour!"
    },
    {
      "order": 9,
      "instruction": "Mix together, use per recipe."
    },
    {
      "order": 10,
      "instruction": "Heat oil in a large skillet over high heat. Cook onion for 5 to 7 minutes until tinged with gold and floppy. Season with a pinch of salt and pepper."
    }
  ]
