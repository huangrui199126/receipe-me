  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 160C/320F."
    },
    {
      "order": 2,
      "instruction": "Cut the corn off the cob. Tip: Use bundt pan or ramekin. in large bowl, see video. If using frozen corn, no need to thaw."
    },
    {
      "order": 3,
      "instruction": "Melt 1 tbsp butter then add 2 tsp oil in a skillet over high heat. Add half the corn and half the garlic. Cook, stirring (or tossing!) for 3 minutes or until corn is golden (golden = better flavour). Transfer corn to bowl, repeat with remaining corn."
    },
    {
      "order": 4,
      "instruction": "If the skillet looks dry, add a touch of oil. Add both capsicums and onion, cook for 2 minutes until softened. Add to bowl with corn."
    },
    {
      "order": 5,
      "instruction": "Add half the cheese into the bowl, then all the remaining ingredients. Mix, transfer to baking dish."
    },
    {
      "order": 6,
      "instruction": "Top with remaining cheese. Bake 30 minutes or until golden and bubbly on top."
    },
    {
      "order": 7,
      "instruction": "Top with garnishes if desired. Serve hot with corn chips!"
    }
  ]
}