  "steps": [
    {
      "order": 1,
      "instruction": "Prepare noodles according to packet directions (most just require soaking in hot water). Drain, rinse and set aside to cool."
    },
    {
      "order": 2,
      "instruction": "Dressing - Mix together Dressing ingredients, using water only if needed to loosen so it can be tossed through salad. If you reduce Sriracha, might need to add smidge more lime."
    },
    {
      "order": 3,
      "instruction": "Beans - Steam or boil green greens until just cooked, tender but still crisp. Drain under running water to cool."
    },
    {
      "order": 4,
      "instruction": "Toss - Place salad ingredients in a big bowl, toss with dressing.&nbsp;"
    },
    {
      "order": 5,
      "instruction": "Garnish with sesame seeds then serve at room temp. Keeps 4 days in the fridge."
    }
  ]
