  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce in a bowl."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large skillet over high heat. Add garlic, cook 10 seconds."
    },
    {
      "order": 3,
      "instruction": "Add chicken and cook until mostly changes from pink to white, then add Sauce."
    },
    {
      "order": 4,
      "instruction": "Cook for 1 minute, then add Coleslaw mix and white part of green onions."
    },
    {
      "order": 5,
      "instruction": "Cook for 1 1/2 minutes until cabbage wilts, then push everything to the side to make room for the ramen (see video &amp; photos in post)."
    },
    {
      "order": 6,
      "instruction": "Add water then squidge the ramen cakes in side by side."
    },
    {
      "order": 7,
      "instruction": "When water simmers, leave for 45 seconds. Flip, then leave for 30 seconds."
    },
    {
      "order": 8,
      "instruction": "Loosen noodles, add bean sprouts and green onion, then toss energetically for 1 1/2 - 2 minutes until sauce reduces and coats noodles. (Note 7)"
    },
    {
      "order": 9,
      "instruction": "Serve immediately!"
    }
  ]
}