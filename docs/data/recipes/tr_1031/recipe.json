  "steps": [
    {
      "order": 1,
      "instruction": "Dressing: Shake Dressing ingredients in a jar until the mayonnaise is fully emulsified. Taste and add more sugar if you want."
    },
    {
      "order": 2,
      "instruction": "Toss with salad: Place cabbage, carrot, green onion, half the edamame and half the seaweed salad in a bowl. Add about 3/4 of the dressing, toss. (Seaweed will mostly stay in clumps)."
    },
    {
      "order": 3,
      "instruction": "Wilt: Set aside for 15 minutes to let the cabbage wilt a bit."
    },
    {
      "order": 4,
      "instruction": "Serve: Toss again, then pile onto serving platter or bowl. Drape over remaining seaweed salad (in clumps) and edamame, drizzle with remaining Dressing. Serve!"
    }
