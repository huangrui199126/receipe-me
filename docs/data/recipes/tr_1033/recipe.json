  "steps": [
    {
      "order": 1,
      "instruction": "Cut the chicken in half horizontally to make 2 steaks. Optional: pound to make them even thickness around 1cm / 2/5\" thick (I do this)."
    },
    {
      "order": 2,
      "instruction": "Zest the lemons to make 1 1/2 - 2 tbsp lemon zest. Avoid grating too much of the white part - it's bitter."
    },
    {
      "order": 3,
      "instruction": "Place zest into bowl with 1 tbsp olive oil and mix to combine. Add chicken and use your hands to slather oil mixture onto chicken."
    },
    {
      "order": 4,
      "instruction": "Mix flour, salt, pepper and garlic powder in a shallow bowl."
    },
    {
      "order": 5,
      "instruction": "Dip chicken into flour mixture, shaking to remove excess."
    },
    {
      "order": 6,
      "instruction": "Heat oil in a skillet over medium high heat. Cook chicken for 2 minutes on each side, or until golden."
    },
    {
      "order": 7,
      "instruction": "Optional: Slice zested lemon and cook the slices, like pictured."
    },
    {
      "order": 8,
      "instruction": "Serve chicken, garnished with fresh parsley if using."
    }
  ]
}