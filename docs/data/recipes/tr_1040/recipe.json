  "steps": [
    {
      "order": 1,
      "instruction": "Take salmon out of the fridge to bring to room temperature."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 200°C / 390°F (180°C fan)."
    },
    {
      "order": 3,
      "instruction": "Spread panko on baking tray, spray generously with oil then bake for 3 to 5 minutes until light golden brown. (Note 6) Scrape into bowl immediately."
    },
    {
      "order": 4,
      "instruction": "Add butter and stir, then add remaining Parmesan Crumb ingredients."
    },
    {
      "order": 5,
      "instruction": "Line same tray with foil. Place salmon on foil."
    },
    {
      "order": 6,
      "instruction": "Spread Dijon on salmon using a butter knife. Just a thin coating - like buttering toast."
    },
    {
      "order": 7,
      "instruction": "Sprinkle Crumb all over."
    },
    {
      "order": 8,
      "instruction": "Bake for 20 minutes for just cooked juicy perfection, or to taste. (Note 7)"
    },
    {
      "order": 9,
      "instruction": "Remove from oven. Loosen salmon from foil using egg flip or butter knife - skin will hopefully be stuck to foil."
    },
    {
      "order": 10,
      "instruction": "Plate watercress on serving platter."
    },
    {
      "order": 11,
      "instruction": "Use foil to lift salmon onto watercress on serving plate, then slide out the foil from under it (see video under recipe). Serve with Lemon Cream Sauce and lemon wedges on the side."
    },
    {
      "order": 12,
      "instruction": "Melt butter in a saucepan over medium high heat. Add eschalots and cook for 2 minutes. Add wine and bring to boil. Leave to boil rapidly for 5 minutes or until reduced by 3/4 or so."
    },
    {
      "order": 13,
      "instruction": "Turn heat down to medium. Add cream, sugar, salt and pepper. Stir, then add lemon juice and mustard. Stir again. Simmer for 2 to 3 minutes or until thickened (see video). Adjust salt, pepper and lemon to taste. Be generous with the salt - remember the salmon is not marinated, the only salt is in the topping."
    },
    {
      "order": 14,
      "instruction": "Optional: strain. I don't bother."
    },
    {
      "order": 15,
      "instruction": "Allow to cool for 10 minutes or so. It will thicken as it cools. It can be served warm or at room temperature."
    }
  ]
}