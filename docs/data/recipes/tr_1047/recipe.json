  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Dressing ingredients in a jar and shake well. Set aside - or refrigerate up to 2 days. Bring to room temperature before using."
    },
    {
      "order": 2,
      "instruction": "Bring a large pot of salted water to boil. Add the beans, bring it back up to a boil and boil beans for 60 seconds - no more!"
    },
    {
      "order": 3,
      "instruction": "Drain and plunge in ice cold water (or run under cold tap water) to stop them from cooking."
    },
    {
      "order": 4,
      "instruction": "If making ahead, leave in the colander to dry before transferring to the fridge."
    },
    {
      "order": 5,
      "instruction": "To serve, pile the beans on a plate, top with tomato and red onion, drizzled over dressing. Sprinkle with parsley if using."
    }
  ]
