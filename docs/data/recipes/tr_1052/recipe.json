  "steps": [
    {
      "order": 1,
      "instruction": "Place Meatball ingredients in a bowl."
    },
    {
      "order": 2,
      "instruction": "Place cornflour in a bowl with 1 tbsp of the water, then mix until lump free. Then add the soy sauce, sake, mirin and sugar, mix."
    },
    {
      "order": 3,
      "instruction": "Add 2 tsp of Teriyaki Sauce into the Meatball bowl."
    },
    {
      "order": 4,
      "instruction": "Add remaining water into the Sauce and mix. Set aside."
    },
    {
      "order": 5,
      "instruction": "Mix Meatball mixture with your hands. Measure out 1 heaped tablespoon and roll into balls. See Note 3 for tips if mixture is too sticky."
    },
    {
      "order": 6,
      "instruction": "Heat oil in a large skillet over medium high heat. Add all the meatballs and cook, rolling to brown all over, for 5 minutes. They will still be a bit raw inside."
    },
    {
      "order": 7,
      "instruction": "Turn heat down. Give the Sauce a quick mix then add it into the pan. Bring to a simmer then cook for 2 - 3 minutes or until it thickens into a glossy sauce that coats the meatballs."
    },
    {
      "order": 8,
      "instruction": "Serve over rice, garnished with green onions and sesame seeds if desired."
    }
  ]
}