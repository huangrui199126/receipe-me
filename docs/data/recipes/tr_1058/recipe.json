  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce ingredients in a small bowl."
    },
    {
      "order": 2,
      "instruction": "Cut green onion into 5cm/2\" lengths. Separate white/pale green part from green part."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large skillet over high heat.&nbsp;Add mushrooms and cook for 3 minutes."
    },
    {
      "order": 4,
      "instruction": "Add the garlic and sesame oil, cook until mushrooms and garlic are golden."
    },
    {
      "order": 5,
      "instruction": "Add Sauce, give it a quick stir. Add white part of green onions. Cook 1 minute until mushrooms are caramelised."
    },
    {
      "order": 6,
      "instruction": "Push mushrooms to the side to make a big well in the centre."
    },
    {
      "order": 7,
      "instruction": "Add water then squidge noodle cakes in."
    },
    {
      "order": 8,
      "instruction": "Cook 45 seconds, then flip. Cook 30 seconds then break up the noodles."
    },
    {
      "order": 9,
      "instruction": "Add green part of green onions and toss well, adding more water if needed to make it saucy."
    },
    {
      "order": 10,
      "instruction": "Serve immediately!"
    }
  ]
}