    },
    {
      "amount": "",
      "unit": "",
      "name": "2  garlic cloves (, minced)",
      "emoji": "🧄",
      "section": "",
      "order": 3
    },
    {
      "amount": "2",
      "unit": "tsp",
      "name": "sesame oil ((or more oil) (Note 2))",
      "emoji": "🫙",
      "section": "",
      "order": 4
    },
    {
      "amount": "",
      "unit": "",
      "name": "5  green onion stems ((shallots/scallions))",
