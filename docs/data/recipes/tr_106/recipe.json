  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F. Fit the wonton wrappers into each hole of a standard size muffin / cupcake tin (not mini and not Texas muffin tins!). Spray the wontons lightly with olive oil. Bake for 8 to 12 minutes, until golden and crispy. Remove from oven and set aside to cool."
    },
    {
      "order": 2,
      "instruction": "Heat a small non stick pan over high heat. Spray with oil, add bacon and sauté until crispy, then remove and drain on absorbent paper towel."
    },
    {
      "order": 3,
      "instruction": "Return pan to stove, reduce heat to medium high and spray pan with oil. Add finely diced bread. Shake pan (or stir) to brown evenly. Remove mini croutons from pan, scatter over a pinch of salt and set aside."
    },
    {
      "order": 4,
      "instruction": "Place Dressing ingredients in a blender or food processor and whizz until smooth. If it seems too thick, use a tiny splash of milk to adjust the consistency."
    },
    {
      "order": 5,
      "instruction": "Place cos lettuce, chicken and bacon in a bowl with 6 to 8 tbsp of dressing (depending on how much dressing you want to use) and toss gently to combine."
    },
    {
      "order": 6,
      "instruction": "Divide the salad between the wonton cups, top with croutons, a pinch of parmesan and a sprinkle of parsley."
    },
    {
      "order": 7,
      "instruction": "Serve immediately."
    }
  ]
}