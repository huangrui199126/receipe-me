  "steps": [
    {
      "order": 1,
      "instruction": "Line a tray with baking paper (parchment paper)."
    },
    {
      "order": 2,
      "instruction": "Place chocolate in a microwave proof bowl."
    },
    {
      "order": 3,
      "instruction": "Microwave on high in 30 second bursts, stirring in between, until smooth (see video)."
    },
    {
      "order": 4,
      "instruction": "Pick up a strawberry by its stem, or gather up the leaves around the stem to get a grip hold on the strawberry."
    },
    {
      "order": 5,
      "instruction": "Dip into the chocolate, rolling to coat most of it (see video), the place onto the tray."
    },
    {
      "order": 6,
      "instruction": "Repeat with remaining strawberries."
    },
    {
      "order": 7,
      "instruction": "If using coconut / nuts or other coating, dip into the coating then lay on tray."
    },
    {
      "order": 8,
      "instruction": "Refrigerate for 30 minutes or until chocolate is firm."
    },
    {
      "order": 9,
      "instruction": "Best served within 12 hours of making. (Note 4)"
    }
  ]
