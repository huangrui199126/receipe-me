  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 350F/180C."
    },
    {
      "order": 2,
      "instruction": "Combine the filling ingredients and mix well."
    },
    {
      "order": 3,
      "instruction": "Place a wrapper diagonally in front of you. Place 1/4 cup of the filling on the bottom half of the wrapper and shape into a log. If you are using egg roll wrappers, use 3 tablespoons per wrapper."
    },
    {
      "order": 4,
      "instruction": "Roll up the wrapper to halfway, then fold in the left and right sides, then roll to the end, using a little water to seal."
    },
    {
      "order": 5,
      "instruction": "Spray the spring rolls lightly, then turn each spring roll and lightly spray the other side."
    },
    {
      "order": 6,
      "instruction": "Bake for 30 minutes, turning once, until golden."
    },
    {
      "order": 7,
      "instruction": "Serve with Enchilada Sauce as the dipping sauce."
    }
  ]
