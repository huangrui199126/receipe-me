  "steps": [
    {
      "order": 1,
      "instruction": "Toss pumpkin with 1 tbsp olive oil, cinnamon, all spice and salt."
    },
    {
      "order": 2,
      "instruction": "Pan roast: Heat a large non stick skillet with 1 tbsp olive oil over medium high heat. Add about half the pumpkin, spreading out into one layer. Cook for 3 minutes until golden. Turn and cook the other side for 3 minutes until golden and cooked through. Remove and let cool until just warm.Repeat with other half of the pumpkin, adding a little more oil to the pan if required."
    },
    {
      "order": 3,
      "instruction": "Toss: Place walnuts in a bowl, drizzle with honey, sprinkle with cinnamon and salt. Mix, spread on paper-lined baking tray."
    },
    {
      "order": 4,
      "instruction": "Bake: Bake at 180°C/350°F (160°C fan) for 15 minutes, tossing once halfway. Leave to cool, then use fingers to roughly break walnuts up into slightly smaller pieces."
    },
    {
      "order": 5,
      "instruction": "Dressing: Place ingredients in a jar and shake well."
    },
    {
      "order": 6,
      "instruction": "Toss: Place lentils, rocket, red onion, thyme and pumpkin in a large bowl. Pour over most of the Dressing, then gently toss."
    },
    {
      "order": 7,
      "instruction": "Plate up: Pile up on serving platter. Sprinkle with candied walnuts. Drizzle over remaining Dressing, then serve!"
    }
  ]
