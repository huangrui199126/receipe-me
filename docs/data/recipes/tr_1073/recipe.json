  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350."
    },
    {
      "order": 2,
      "instruction": "Grease a 20cm/8\" square pan and line with baking/parchment paper with overhang (so it can be lifted out once cooked)."
    },
    {
      "order": 3,
      "instruction": "Mix together butter, flour, sugar, baking powder and salt until you can no longer see white bits of flour."
    },
    {
      "order": 4,
      "instruction": "Add egg and mix."
    },
    {
      "order": 5,
      "instruction": "Lightly press 2/3 of the mixture into the bottom of the pan."
    },
    {
      "order": 6,
      "instruction": "Bake for 15 minutes until slightly golden, then remove and cool for 5 minutes."
    },
    {
      "order": 7,
      "instruction": "Apple Filling: While the base is cooking, mix together Apple Filling ingredients in a bowl."
    },
    {
      "order": 8,
      "instruction": "Add oats into reserved crumble mixture. Mix with wooden spoon / fingers until oats are mostly incorporated into the dough."
    },
    {
      "order": 9,
      "instruction": "Spread Apple Filling on base, then use hands to crumble topping all over."
    },
    {
      "order": 10,
      "instruction": "Bake for 30 - 35 minutes or until the top is deep golden."
    },
    {
      "order": 11,
      "instruction": "Remove and allow to cool in the tin before lifting out of the tin using the baking paper."
    },
    {
      "order": 12,
      "instruction": "Cut and serve! Eat with hands, or serve on plates. Take it over the top with ice cream and salted caramel sauce!"
    }
  ]
}