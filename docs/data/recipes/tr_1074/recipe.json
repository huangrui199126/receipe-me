  "steps": [
    {
      "order": 1,
      "instruction": "Place Lime Dressing ingredients in a jar, shake well."
    },
    {
      "order": 2,
      "instruction": "Put 2 tablespoons of Dressing in a ziplock bag. Add chipotle, oregano, cumin, salt and pepper, mix/squidge bag. Add chicken, seal and massage to coat. Marinate 30 min – overnight."
    },
    {
      "order": 3,
      "instruction": "Heat 1 tbsp olive oil in skillet over medium low, cook chicken to taste (2cm / 4/5” takes around 8 minutes), getting a nice brown crust on it. Rest 5 min then slice."
    },
    {
      "order": 4,
      "instruction": "Add 2 tablespoons of coriander into Dressing, shake."
    },
    {
      "order": 5,
      "instruction": "Place avocado, corn, tomato and onion in a bowl. Add remaining coriander, drizzle with a bit of Dressing, toss gently."
    },
    {
      "order": 6,
      "instruction": "Place lettuce in a bowl, drizzle with a bit of Dressing, toss."
    },
    {
      "order": 7,
      "instruction": "Assemble Salad: Place lettuce on a serving platter. Top with Salsa and sliced chicken. Drizzle with remaining Dressing. Serve."
    }
  ]
