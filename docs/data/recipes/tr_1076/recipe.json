  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 190°C/375°F (180°C/350°F fan/convection)."
    },
    {
      "order": 2,
      "instruction": "Mix Chicken Ingredients."
    },
    {
      "order": 3,
      "instruction": "Heat chicken broth and milk until hot using any method (stove, microwave). Can combine together in saucepan. (Note 5)"
    },
    {
      "order": 4,
      "instruction": "Spread rice in 23 x 33cm / 9 x 13&quot; ceramic or glass baking dish. (Note 6)"
    },
    {
      "order": 5,
      "instruction": "Sprinkle with flour, stock powder and garlic."
    },
    {
      "order": 6,
      "instruction": "Add the hot chicken broth, stir until flour dissolved (some small lumps ok)."
    },
    {
      "order": 7,
      "instruction": "Add milk, swish rice to spread out evenly."
    },
    {
      "order": 8,
      "instruction": "Spread broccoli on top, then chicken, then plonk butter on (anywhere)."
    },
    {
      "order": 9,
      "instruction": "Bake uncovered for 40 minutes. (Might get some browned skin on surface, that's ok)"
    },
    {
      "order": 10,
      "instruction": "CHECK rice before stirring - should be JUST cooked (Note 7)."
    },
    {
      "order": 11,
      "instruction": "Add half the cheese, stir through, being sure to get rice in the corners and edges of pan. Should be creamy and quite loose (see video)."
    },
    {
      "order": 12,
      "instruction": "Top with cheese, return to oven for 5 minutes until just melted."
    },
    {
      "order": 13,
      "instruction": "Sprinkle with green onion, if using, then serve!"
    }
  ]
