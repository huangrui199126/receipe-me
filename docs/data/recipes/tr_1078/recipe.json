  "steps": [
    {
      "order": 1,
      "instruction": "Heat 1 tbsp oil in a large skillet over high heat."
    },
    {
      "order": 2,
      "instruction": "Add garlic and onion, cook for 30 seconds."
    },
    {
      "order": 3,
      "instruction": "Add ham, cook for 1 minute to release flavour."
    },
    {
      "order": 4,
      "instruction": "Add frozen vegetables, cook 2 minutes until carrot is almost cooked."
    },
    {
      "order": 5,
      "instruction": "Add cauliflower and Sauce. Cook, stirring regularly, for 4 minutes until sauce is reduced and cauliflower is almost cooked - firm, tender crisp, not soft and mushy."
    },
    {
      "order": 6,
      "instruction": "Push the cauliflower to one side of the skillet. Add 1/2 tbsp oil, let it heat up briefly, then pour in egg."
    },
    {
      "order": 7,
      "instruction": "Leave for 10 seconds, then leisurely scramble it. Once almost cooked, mix egg through cauliflower."
    },
    {
      "order": 8,
      "instruction": "Toss through green onions then serve immediately!"
    }
  ]
