  "steps": [
    {
      "order": 1,
      "instruction": "Place Marinade ingredients in a ziplock bag or bowl and mix to combine."
    },
    {
      "order": 2,
      "instruction": "Add chicken and mix to coat. Marinade for 3 – 24 hours."
    },
    {
      "order": 3,
      "instruction": "Optional: Cut chicken into bite size or large pieces and thread onto skewers. Use 1 skewer for small pieces, 2 for large, like pictured in post."
    },
    {
      "order": 4,
      "instruction": "Heat half the oil in a heavy based skillet over medium high heat, or BBQ on medium (if using grill side, brush oil on bars)."
    },
    {
      "order": 5,
      "instruction": "Remove chicken from marinade (RESERVE for basting) and place in the skillet - cook in 2 batches, don't crowd the pan. Cook for 4 minutes then turn."
    },
    {
      "order": 6,
      "instruction": "Use the Marinade to baste the cooked side of the chicken. After 3 minutes, turn the chicken over so the basted side is now cooking again - cook for 1 minute."
    },
    {
      "order": 7,
      "instruction": "Baste the chicken, then turn again and cook for 45 sec - 1 min."
    },
    {
      "order": 8,
      "instruction": "Transfer chicken to a plate, cover loosely with foil and rest for 5 minutes."
    },
    {
      "order": 9,
      "instruction": "Serve, garnished with green onions / scallions if using!"
    }
  ]
}