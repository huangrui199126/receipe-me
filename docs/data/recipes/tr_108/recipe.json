  "steps": [
    {
      "order": 1,
      "instruction": "Mix dressing ingredients in a bowl until smooth."
    },
    {
      "order": 2,
      "instruction": "Prepare noodles according to packet instructions."
    },
    {
      "order": 3,
      "instruction": "Place both cabbages and carrots in a bowl, add 1/4 tsp salt, toss to combine and set aside for 5-10 minutes to wilt lightly."
    },
    {
      "order": 4,
      "instruction": "Place the Satay Chicken ingredients EXCEPT the oil in a bowl and toss to coat."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a non stick fry pan over high heat. Add the chicken and cook for 3 minutes until golden, then transfer to a plate."
    },
    {
      "order": 6,
      "instruction": "Toss noodles and remaining salad ingredients with chicken and Dressing, then serve. Serve at room temperature or warm."
    }
  ]
