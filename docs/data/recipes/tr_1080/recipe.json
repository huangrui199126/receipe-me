  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large deep skillet or pot over medium high heat. Add garlic and ginger, cook for 1 minute. Add onion and cook for 6 - 8 minutes or until golden and caramelised."
    },
    {
      "order": 2,
      "instruction": "Add coriander, turmeric, cumin and paprika. Cook for 1 minute."
    },
    {
      "order": 3,
      "instruction": "Add chicken stock and tomato. Stir to combine, bring to simmer and cook for 5 minutes."
    },
    {
      "order": 4,
      "instruction": "Add cauliflower and chickpeas. Cook for 15 minutes or until cauliflower is soft and sauce has thickened. If sauce is thickening too quickly (Note 3), put the lid on. Adjust salt to taste, and add sugar if using."
    },
    {
      "order": 5,
      "instruction": "Add peas and garam masala. Cook for 2 minutes, then remove from stove. Stir through most of the coriander."
    },
    {
      "order": 6,
      "instruction": "Serve curry with basmati rice or plain white rice, garnished with reserved coriander and yoghurt on the side."
    }
  ]
}