  "steps": [
    {
      "order": 1,
      "instruction": "Melt oil in a large non-stick skillet over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Add black mustard seeds and cook for 30 seconds – they will pop and sizzle"
    },
    {
      "order": 3,
      "instruction": "Add cumin seeds and cook for 30 seconds."
    },
    {
      "order": 4,
      "instruction": "Add eschalot and onion, cook for 3 minutes until translucent but not coloured."
    },
    {
      "order": 5,
      "instruction": "Add garlic and green chilli, cook for 2 minutes until softened but not golden."
    },
    {
      "order": 6,
      "instruction": "Add turmeric and curry leaves, cook for 30 seconds."
    },
    {
      "order": 7,
      "instruction": "Add coconut, water and salt. Cook until water mostly evaporates – about 3 minutes."
    },
    {
      "order": 8,
      "instruction": "Place carrot and cabbage in a large bowl. Add hot coconut mixture. Toss well – the cabbage should wilt from the heat."
    },
    {
      "order": 9,
      "instruction": "Taste and check if it needs more salt for your taste."
    },
    {
      "order": 10,
      "instruction": "Toss through coriander. Serve warm or at room temperature. Best eaten on the day of making. See Note 7 regarding reheating/making ahead."
    }
  ]
}