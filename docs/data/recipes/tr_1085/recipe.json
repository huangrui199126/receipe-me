  "steps": [
    {
      "order": 1,
      "instruction": "Blitz ingredients in a food processor until it becomes a smooth, bright green sauce."
    },
    {
      "order": 2,
      "instruction": "Use extra water to thin to a pourable consistency."
    },
    {
      "order": 3,
      "instruction": "Put the tomatoes in a bowl. Sprinkle with pinch of salt, mix with your hands and leave to rest for 10 minutes (extracts a bit of juice, makes them juicier)."
    },
    {
      "order": 4,
      "instruction": "Drain the tomatoes. Mix with the onion in a serving bowl."
    },
