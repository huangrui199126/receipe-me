  "steps": [
    {
      "order": 1,
      "instruction": "Pickle - In a large bowl, dissolve the salt and sugar in the hot water. Stir in vinegar. Add carrots and daikon - they should just about be covered."
    },
    {
      "order": 2,
      "instruction": "2 hours - Leave for 2 hours until slightly floppy. Drain well then use per recipe."
    },
    {
      "order": 3,
      "instruction": "Split the bread roll in half but don&#39;t cut all the way through."
    },
    {
      "order": 4,
      "instruction": "Butter - Spread the lid with butter."
    },
    {
      "order": 5,
      "instruction": "Pate then mayo - Spread the base with 1 to 2 tablespoons pate (be generous!), then 1 1/2 tbsp mayonnaise."
    },
    {
      "order": 6,
      "instruction": "Chicken &amp; Maggi - Pile on shredded chicken, drizzle with 1/4 tsp Maggi seasoning (you can always add more later)."
    },
    {
      "order": 7,
      "instruction": "Fresh stuff! Stuff with pickled vegetables, 2 slices of cucumber, 3 slices of green onion and coriander. Finally, sprinkle with as much chilli as you dare. Jam the lid down and devour!"
    }
  ]
