  "steps": [
    {
      "order": 1,
      "instruction": "Mix together Sauce ingredients. Mix together Thickener in a separate small bowl."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a wok or skillet over high heat. Add garlic and onion, cook for 1 minute."
    },
    {
      "order": 3,
      "instruction": "Add chicken and stir fry until it it is white all over but still pink inside."
    },
    {
      "order": 4,
      "instruction": "Add capsicum and stir fry for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add Sauce ingredients. Stir until sugar has dissolved and the sauce begins to bubble."
    },
    {
      "order": 6,
      "instruction": "Add Thickener. Bring to simmer, stirring constantly. Then cook until it thickens to a syrup consistency - about 3 minutes."
    },
    {
      "order": 7,
      "instruction": "Stir through pineapple pieces (just to warm) and remove from stove."
    },
    {
      "order": 8,
      "instruction": "Serve immediately with rice - or for a low carb, low cal option, try Cauliflower Rice! Garnish with shallots if desired."
    }
  ]
