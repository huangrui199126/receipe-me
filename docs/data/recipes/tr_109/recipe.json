  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the over to 350F/180C."
    },
    {
      "order": 2,
      "instruction": "Heat the oil in a large skillet over high heat."
    },
    {
      "order": 3,
      "instruction": "Add the garlic and onion, and cook until translucent."
    },
    {
      "order": 4,
      "instruction": "Add the beef and cook, breaking up into pieces, until browned. Add the Taco Seasoning and pepper about halfway through browning the beef."
    },
    {
      "order": 5,
      "instruction": "Add the tomato passata, water and beans. Cook for 5 minutes, stirring occasionally until thickened but still very saucy. Remove from heat."
    },
    {
      "order": 6,
      "instruction": "Lay a tortilla in a pie dish (24 cm / 9 inch diameter). Use a slotted spoon to top with just under 1/2 the meat. Try to avoid using too much sauce so sort of \"shake\" each spoonful to drain out sauce."
    },
    {
      "order": 7,
      "instruction": "Top with another tortilla + torn/cut pieces of another tortilla to cover completely."
    },
    {
      "order": 8,
      "instruction": "Top with the remaining meat, again avoiding the sauce."
    },
    {
      "order": 9,
      "instruction": "Top with remaining tortillas, then pour over all the sauce (and any residual meat)."
    },
    {
      "order": 10,
      "instruction": "Place in the oven and bake for 20 minutes. If you're worried about overspill, place it on a baking tray."
    },
    {
      "order": 11,
      "instruction": "Remove from the oven, cover with corn chips then scatter with cheese. Bake until the chips are a bit golden and the cheese is melted - 10 to 15 minutes."
    },
    {
      "order": 12,
      "instruction": "Serve, topped with Pico De Gallo and Sour Cream on the side, if using."
    },
    {
      "order": 13,
      "instruction": "Combine ingredients in a bowl. Toss and adjust salt/pepper to taste."
    }
  ]
}