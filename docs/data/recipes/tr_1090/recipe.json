  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (fan forced / convection) (Note 3)"
    },
    {
      "order": 2,
      "instruction": "Line tray with baking paper."
    },
    {
      "order": 3,
      "instruction": "Combine Seasoning in a small bowl. Place brown sugar in a separate bowl."
    },
    {
      "order": 4,
      "instruction": "Coat chicken in Seasoning, shaking off excess. Place on one end of bacon and roll up, finishing with the seam side down. Repeat with remaining chicken."
    },
    {
      "order": 5,
      "instruction": "Coat chicken in sugar - use your fingers to rub it on if required. Place on baking tray."
    },
    {
      "order": 6,
      "instruction": "Drizzle with olive oil (helps make it brown faster, optional)"
    },
    {
      "order": 7,
      "instruction": "Bake for 25 minutes. If the bacon is not golden enough for your taste, switch on the broiler for a few minutes."
    },
    {
      "order": 8,
      "instruction": "Brush the juices on the tray onto the bacon to make it glossy and juicy. Serve on mashed potatoes, drizzled with extra pan juices if desired!"
    }
  ]
}