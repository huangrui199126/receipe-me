      "name": "2  medium carrots ((unpeeled), cut in 3 (180g/6oz each))",
      "emoji": "🥕",
      "section": "",
      "order": 1
    },
    {
      "amount": "",
      "unit": "",
      "name": "1  onion (, quartered (~250g/8oz))",
      "emoji": "🧅",
      "section": "",
      "order": 2
    },
    {
      "amount": "",
      "unit": "",
      "name": "1  celery stem (, cut in 4 pieces (~180g/6oz))",
      "emoji": "🫑",
      "section": "",
      "order": 3
    },
    {
      "amount": "",
      "unit": "",
      "name": "2  garlic cloves, (smashed (Note 1))",
      "emoji": "🧄",
      "section": "",
      "order": 4
    },
    {
      "amount": "",
      "unit": "",
      "name": "3  parsley stems",
      "emoji": "🌿",
