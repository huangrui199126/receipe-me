  "steps": [
    {
      "order": 1,
      "instruction": "Trim the stem from the leaves, then wash the leaves very well (spinach often holds a lot of dirt)."
    },
    {
      "order": 2,
      "instruction": "Shake off excess water but do not dry (water droplets helps steam-cook the spinach)."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large skillet over medium high heat. Add garlic and cook for 20 seconds until it becomes light golden and smells amazing."
    },
    {
      "order": 4,
      "instruction": "Add spinach, then use tongs or 2 wooden spoons to toss until the spinach wilts - about 2 minutes. I like mine just wilted."
    },
    {
      "order": 5,
      "instruction": "Remove from heat immediately and sprinkle with salt and pepper and toss once more."
    },
    {
      "order": 6,
      "instruction": "Transfer to serving platter and serve."
    }
  ]
}