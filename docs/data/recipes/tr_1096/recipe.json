  "steps": [
    {
      "order": 1,
      "instruction": "Sprinkle shanks with salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Heat 1 tbsp oil in a large heavy based pot over medium high heat. Brown shanks all over, 2 at a time. Remove from pot."
    },
    {
      "order": 3,
      "instruction": "Discard excess oil, clean pot if it's very dirty."
    },
    {
      "order": 4,
      "instruction": "Add 1 tbsp oil. Cook onion and garlic for 2 minutes until translucent."
    },
    {
      "order": 5,
      "instruction": "Stir in the turmeric, cinnamon, tomatoes, and salt."
    },
    {
      "order": 6,
      "instruction": "Add chicken broth and stir well."
    },
    {
      "order": 7,
      "instruction": "Place shanks in pot, then add water as needed so the shanks are 3/4 or fully covered, but no more than 1L/4 cups water. (Note 2)"
    },
    {
      "order": 8,
      "instruction": "If shanks not fully submerged, make a cartouche (baking paper lid, Note 3)."
    },
    {
      "order": 9,
      "instruction": "Bring up to the boil. Place the cartouche snugly on surface (if using), cover pot leaving a little crack (to ensure it doesn't boil over)."
    },
    {
      "order": 10,
      "instruction": "Turn heat down so simmering very gently. Cook 1.5 hours, turning every 30 minutes."
    },
    {
      "order": 11,
      "instruction": "Add cardamom and nutmeg into liquid."
    },
    {
      "order": 12,
      "instruction": "Cook for another 1 hour until meat is very tender and falling off the bone."
    },
    {
      "order": 13,
      "instruction": "Carefully remove meat from liquid into a bowl and cover with foil."
    },
    {
      "order": 14,
      "instruction": "Simmer broth rapidly 30 - 45 min until reduced by half."
    },
    {
      "order": 15,
      "instruction": "Add saffron and remaining 1/8 tsp cinnamon."
    },
    {
      "order": 16,
      "instruction": "Simmer further 10 - 15 min until reduced to 500 ml / 2 cups.&nbsp;Should taste like a very well seasoned, intensely savoury but lightly spiced broth."
    },
    {
      "order": 17,
      "instruction": "Return meat to pot to gently reheat for a few minutes, turning and basting the meat with the liquid to keep it moist."
    },
    {
      "order": 18,
      "instruction": "Serve shanks with the braising liquid as a sauce. Pictured garnished with pomegranate seeds (leftover from salad, see Notes) or mint leaves, for visual only."
    }
  ]
}