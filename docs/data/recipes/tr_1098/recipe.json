  "steps": [
    {
      "order": 1,
      "instruction": "Beat butter, sugar and salt on medium (speed 5) using a hand held mixer for 1 minute until smooth."
    },
    {
      "order": 2,
      "instruction": "Add egg yolks and vanilla, beat for 1 minute or until smooth."
    },
    {
      "order": 3,
      "instruction": "Add baking powder, rice flour and half the plain flour. Beat with mixer on medium speed until flour is incorporated."
    },
    {
      "order": 4,
      "instruction": "Add remaining flour and beat with mixer until flour is incorporated. Add macadamia nuts and chocolate, then mix through with a wooden spoon (dough gets a bit too hard to use mixer)."
    },
    {
      "order": 5,
      "instruction": "Scrape mixture onto a work surface, press together and shape into a 22cm/9\" log."
    },
    {
      "order": 6,
      "instruction": "Roll up in baking paper or cling wrap, twist ends then refrigerate for 2 hours."
    },
    {
      "order": 7,
      "instruction": "Preheat oven to 200°C/390°F (180°C fan)."
    },
    {
      "order": 8,
      "instruction": "Line 2 trays with baking paper."
    },
    {
      "order": 9,
      "instruction": "Remove log from fridge, unwrap and slice into 1.75cm / 3/4&quot; thick slices (12 - 13 cookies)."
    },
    {
      "order": 10,
      "instruction": "Place 6 on each tray, bake for 10 minutes."
    },
    {
      "order": 11,
      "instruction": "Turn oven down to 170°C/340°F (150°C fan), switch the trays between shelves."
    },
    {
      "order": 12,
      "instruction": "Bake 15 minutes, remove from oven and cool cookies on tray."
    },
    {
      "order": 13,
      "instruction": "Cool fully before serving."
    }
  ]
}