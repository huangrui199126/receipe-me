  "steps": [
    {
      "order": 1,
      "instruction": "Cut stalks off fennel (save fronds). Shave the fennel and onion using a mandolin, or slice finely."
    },
    {
      "order": 2,
      "instruction": "Place in a bowl. Add lemon juice and 1 1/2 tbsp olive oil, salt and pepper. Toss."
    },
    {
      "order": 3,
      "instruction": "Spread out on a plate &quot;carpaccio&quot; style. Drizzle with more olive oil, top with freshly grated parmesan then sprinkle with fennel fronds."
    },
    {
      "order": 4,
      "instruction": "Serve immediately!"
