  "steps": [
    {
      "order": 1,
      "instruction": "Bring water to the boil in a large pot. Add salt and rice. Bring back up to the boil then cook for 5 minutes. Drain and leave to steam dry for 5 minutes."
    },
    {
      "order": 2,
      "instruction": "Melt butter in a small pan over medium heat. Add barberries and cook for about 1 1/2 minutes until they plump up (see video!)."
    },
    {
      "order": 3,
      "instruction": "Remove from heat (they will shrivel quickly) then stir through rose water (if using)."
    },
    {
      "order": 4,
      "instruction": "Preheat oven to 200C/390F (standard) or 180C/350F (fan)."
    },
    {
      "order": 5,
      "instruction": "Lightly grease a glass pie dish with oil."
    },
    {
      "order": 6,
      "instruction": "Ground saffron into powder (optional step). Add water and leave to seep for 10 minutes."
    },
    {
      "order": 7,
      "instruction": "Mix yogurt, egg, oil, saffron water and salt in a large bowl."
    },
    {
      "order": 8,
      "instruction": "Add rice, stir well."
    },
    {
      "order": 9,
      "instruction": "Pour half the rice in the pie dish, smooth surface. Top with 1/3 of the barberries."
    },
    {
      "order": 10,
      "instruction": "Cover with remaining rice, smooth surface, sprinkle over another 1/3 of the barberries. Press down firmly, cover with foil."
    },
    {
      "order": 11,
      "instruction": "Bake 60 - 80 minutes until the crust is deep golden all over."
    },
    {
      "order": 12,
      "instruction": "Rest for 10 minutes. Remove foil. Place serving plate on pie dish then flip upside down (it won't stick because of the oil, see video!)."
    },
    {
      "order": 13,
      "instruction": "Scatter surface with remaining barberries then serve."
    }
  ]
}