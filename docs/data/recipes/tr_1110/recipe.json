  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/430°F (all oven types)."
    },
    {
      "order": 2,
      "instruction": "Pour wine and half the butter into 9 x 13&quot; / 22 x 33cm baking pan (see Note 3 if using glass). Place in oven for 10 minutes to reduce."
    },
    {
      "order": 3,
      "instruction": "Toss prawns with remaining butter, garlic, lemon juice, salt and pepper. Butter may harden - that's ok."
    },
    {
      "order": 4,
      "instruction": "Mix Crunchy Topping ingredients."
    },
    {
      "order": 5,
      "instruction": "Remove pan from oven. Add prawns - spread out in single layer, but snug."
    },
    {
      "order": 6,
      "instruction": "Top with Crunchy Topping. Bake 12 minutes."
    },
    {
      "order": 7,
      "instruction": "Flick to broiler/grill on high, broil for 1 - 2 minutes (max) to brown top a bit more."
    },
    {
      "order": 8,
      "instruction": "Sprinkle with parsley. Serve immediately with lemon wedges and crusty bread to mop up the incredible sauce!"
    }
  ]
