  "steps": [
    {
      "order": 1,
      "instruction": "Mix Tahini Sauce ingredients until combined. It should be loose enough so it can be drizzled, but not too runny. Set aside 15 minutes to let the flavours meld."
    },
    {
      "order": 2,
      "instruction": "Sauce for Middle Eastern cooked proteins (like Chicken Shawarma, Lamb Shawarma, koftas and meatballs) and in wraps, sandwiches"
    },
    {
      "order": 3,
      "instruction": "Roasted vegetables - drizzle over roasted vegetables (carrots, cauliflower, broccoli, pumpkin, green beans and asparagus are some favourites)"
    },
    {
      "order": 4,
      "instruction": "Dip for pita bread, crisps or raw vegetable sticks, and things like Arayes (crispy Lebanese Meat Stuffed Pita Breads)."
    }
  ]
