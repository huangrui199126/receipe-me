  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Heat olive oil in a large skillet over high heat. Add garlic and onion and saute until the onion is translucent."
    },
    {
      "order": 3,
      "instruction": "Add the capsicum and cook for another 1 minute."
    },
    {
      "order": 4,
      "instruction": "Add remaining Filling ingredients. Stir then turn the heat down to medium and let it cook for 5 minutes or so until thickened. Transfer to a bowl and let it cool slightly."
    },
    {
      "order": 5,
      "instruction": "Wipe the pan clean and return to high heat. Add bacon and cook until light golden brown. Drain fat if there is excess. Turn heat down to medium Add the eggs and gently stir and fold them into the bacon mixture until the eggs almost set but are still watery."
    },
    {
      "order": 6,
      "instruction": "Remove pan from heat. The eggs will continue cooking in the residual heat."
    },
    {
      "order": 7,
      "instruction": "Lay the tortillas on a work surface. Divide the Filling mixture between them, then top with Bacon and Egg mixture. Sprinkle with cheese then roll the Enchiladas up."
    },
    {
      "order": 8,
      "instruction": "Place in a baking dish (or tray) and bake for 10 to 15 minutes, or until the top is golden brown and you can see that the cheese has melted."
    },
    {
      "order": 9,
      "instruction": "Serve with desired garnished. I highly recommend sour cream and avocado."
    }
  ]
}