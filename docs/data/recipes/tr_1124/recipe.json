  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 190C/375F (170C fan) with one shelf in the middle and another under it."
    },
    {
      "order": 2,
      "instruction": "Use a bowl at room temp, not ice cold glass/metal (butter will go hard)."
    },
    {
      "order": 3,
      "instruction": "Place butter in bowl and beat until smooth - about 30 seconds on speed 5."
    },
    {
      "order": 4,
      "instruction": "Add sugar and beat for 45 sec to 1 min until light and fluffy."
    },
    {
      "order": 5,
      "instruction": "Add yolks, beat until fully incorporated (~20 sec)."
    },
    {
      "order": 6,
      "instruction": "Add vanilla and glucose, beat until incorporated (~15 sec)."
    },
    {
      "order": 7,
      "instruction": "Add flour, baking powder and cocoa. Stir with wooden spoon until incorporated (will be a stiff dough)."
    },
    {
      "order": 8,
      "instruction": "Mix through chocolate chips."
    },
    {
      "order": 9,
      "instruction": "Scoop / roll 12 balls a touch smaller than a golf ball, then flatten to 1cm / 2/5\" thick on baking trays (2 trays)."
    },
    {
      "order": 10,
      "instruction": "Bake both trays for 10 minutes."
    },
    {
      "order": 11,
      "instruction": "Take top tray out, move tray underneath to top shelf and bake a further 1 minute then remove. The cookies will look ever so slightly undercooked in the centre - they will finish cooking on the tray (this is how we make them chewy!)"
    },
    {
      "order": 12,
      "instruction": "Leave cookies to cool on the tray for 20 minutes, then transfer to cooling rack."
    },
    {
      "order": 13,
      "instruction": "Allow to cool fully before serving (becomes chewy when cools, even better the next day!)"
    }
  ]
}