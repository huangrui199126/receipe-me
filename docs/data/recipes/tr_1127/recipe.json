  "steps": [
    {
      "order": 1,
      "instruction": "Place oil then bacon in pot. Turn stove onto medium high heat then cook until bacon is golden on both sides."
    },
    {
      "order": 2,
      "instruction": "Remove bacon and chop once cooled."
    },
    {
      "order": 3,
      "instruction": "If there's loads of excess fat in the pot, drain some."
    },
    {
      "order": 4,
      "instruction": "Add garlic and stir for 20 seconds. Add creamed corn, kernels, chicken stock, milk, potato, salt and pepper."
    },
    {
      "order": 5,
      "instruction": "Stir, bring to simmer then adjust to medium. Simmer 5 minutes until potato is just tender."
    },
    {
      "order": 6,
      "instruction": "Soup Thickener: Mix together milk and cornflour, then pour into soup."
    },
    {
      "order": 7,
      "instruction": "Stir and simmer for 1 minute until it thickens into a creamy soup (see video for thickness)."
    },
    {
      "order": 8,
      "instruction": "Add more salt if needed."
    },
    {
      "order": 9,
      "instruction": "Ladle into bowls, top with green onion and bacon. Devour!"
    }
  ]
