  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (standard) or 180C/350F (fan/convection)."
    },
    {
      "order": 2,
      "instruction": "Mix Crust ingredients in a small bowl."
    },
    {
      "order": 3,
      "instruction": "Break cauliflower into large florets. Cut very large florets into 1.5cm / 3/5\" thick slices, and the medium florets in half. You want a large flat surface area on each piece for the crust to adhere to."
    },
    {
      "order": 4,
      "instruction": "Line a baking tray (30 x 40 cm / 12 x 16\") with paper."
    },
    {
      "order": 5,
      "instruction": "Drizzle tray with oil. Use a cauliflower to spread the oil all over the paper (see video)."
    },
    {
      "order": 6,
      "instruction": "Sprinkle Crust mixture all over the tray, as evenly as possible. Don't touch it once scattered."
    },
    {
      "order": 7,
      "instruction": "Place cauliflower down on the Crust mixture, pressing down lightly. Don't jam them right up against each other (they will steam and go soggy), keep a tiny bit of space between each one."
    },
    {
      "order": 8,
      "instruction": "Spray generously with oil. Sprinkle with a bit of black pepper (optional)."
    },
    {
      "order": 9,
      "instruction": "Bake for 20 minutes until crust is deep golden."
    },
    {
      "order": 10,
      "instruction": "Use tongs to turn the cauliflower so the crust side is up. Bake for a further 5 minutes."
    },
    {
      "order": 11,
      "instruction": "Serve immediately, sprinkled with finely chopped parsley or other herb, if desired."
    }
  ]
}