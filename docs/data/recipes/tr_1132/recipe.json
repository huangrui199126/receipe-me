    },
    {
      "amount": "2",
      "unit": "tsp",
      "name": "mayonnaise ((I like whole egg mayo))",
      "emoji": "🥚",
      "section": "",
      "order": 4
    },
    {
      "amount": "",
      "unit": "",
      "name": "2 - 4 slices gruyere cheese ((or other grated or sliced melting cheese of choice))",
      "emoji": "🧀",
      "section": "",
      "order": 5
    },
    {
      "amount": "",
      "unit": "",
      "name": "Ham or turkey (, sliced or shaved)",
      "emoji": "🍗",
      "section": "",
      "order": 6
    },
    {
      "amount": "",
      "unit": "",
      "name": "1 - 2 tbsp unsalted butter",
      "emoji": "🧈",
      "section": "",
