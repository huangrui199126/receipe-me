    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Lightly whisk egg, milk and a generous pinch of salt in a flat bowl."
    },
    {
      "order": 2,
      "instruction": "Spread 2 slices of bread with mayonnaise."
    },
    {
      "order": 3,
      "instruction": "Top with ham, then cheese, then sandwich with remaining slices of bread. Press down firmly."
    },
    {
      "order": 4,
      "instruction": "Melt butter in a skillet over medium heat."
    },
    {
      "order": 5,
      "instruction": "Dip each side of the sandwiches briefly in the egg mixture, then place in skillet."
    },
    {
      "order": 6,
      "instruction": "Cook the first side, pressing down with an egg flip, for 3 minutes or until deep golden brown."
    },
    {
      "order": 7,
      "instruction": "Flip and cook the other side for 3 minutes, pressing down firmly with the egg flip, until golden brown and the cheese is melted."
    },
    {
      "order": 8,
      "instruction": "Serve immediately, while hot!"
    }
  ]
