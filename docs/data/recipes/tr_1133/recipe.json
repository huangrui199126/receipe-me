  "steps": [
    {
      "order": 1,
      "instruction": "Combine sugar, soy, rice vinegar and mirin in a jug or bowl. Whisk well until sugar is dissolved. Add oils and ginger. Whisk again and use immediately."
    },
    {
      "order": 2,
      "instruction": "Place oysters on a serving platter on ice or rock salt (Note 7)."
    },
    {
      "order": 3,
      "instruction": "Spoon dressing in each - I use 3/4 teaspoon on small oysters and 1 1/4 teaspoon for large. Or more!"
    },
    {
      "order": 4,
      "instruction": "Top with a small pile of salmon roe, sprinkle with chives. Serve!"
    }
