  "steps": [
    {
      "order": 1,
      "instruction": "Use a standard box grater to grate the zucchini. Measure out 2 cups, place in bowl, sprinkle with salt, use fingers to disperse. Leave for 20 minutes."
    },
    {
      "order": 2,
      "instruction": "Squeeze handfuls to remove excess water and place zucchini in a bowl. Set aside."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 180°C / 350°F (all oven types)."
    },
    {
      "order": 4,
      "instruction": "Butter and line a loaf pan (Note 3)"
    },
    {
      "order": 5,
      "instruction": "Place Dry ingredients in a bowl. Whisk to combine."
    },
    {
      "order": 6,
      "instruction": "Place Wet Ingredients in a bowl. Whisk to combine."
    },
    {
      "order": 7,
      "instruction": "Make a well in the centre of the Dry ingredients. Pour in Wet. Mix quickly until flour is incorporated (Note 4)."
    },
    {
      "order": 8,
      "instruction": "Quickly stir through zucchini."
    },
    {
      "order": 9,
      "instruction": "Spread 1/3 of the batter in the loaf pan. Top with 4 slices of cheese."
    },
    {
      "order": 10,
      "instruction": "Spread with batter, top with 4 slices of cheese, then finish with remaining batter. Smooth top."
    },
    {
      "order": 11,
      "instruction": "Bake for 50 minutes or until a skewer inserted into the centre comes out clean."
    },
    {
      "order": 12,
      "instruction": "Optional: Brush top with a bit of melted butter."
    },
    {
      "order": 13,
      "instruction": "Cool in the pan for 10 minutes then transfer to rack to cool. Cool for at least 20 minutes before slicing."
    },
    {
      "order": 14,
      "instruction": "Store in a container (Note 5 for humid weather warning!)"
    }
  ]
}