  "steps": [
    {
      "order": 1,
      "instruction": "Place the Marinade ingredients in a large ziplock bag and mix. Add beef and massage through the bag to coat evenly. Seal then marinate for 1- 8 hours (12 hours max, otherwise meat gets over marinated and can be mushy)."
    },
    {
      "order": 2,
      "instruction": "Take the skirt steak out of the fridge 20 - 30 minutes before cooking to bring to room temperature."
    },
    {
      "order": 3,
      "instruction": "Brush BBQ with oil and heat on high until smoking (or use a large skillet over high heat and turn the fan on!)."
    },
    {
      "order": 4,
      "instruction": "Cook skirt steak for 3 minutes each side for rare, 4 minutes for medium rare. For flank, cook for 4 minutes each side for rare and 5 minutes for medium rare. Don't cook beyond medium - chewy beef!"
    },
    {
      "order": 5,
      "instruction": "Remove onto a plate and cover loosely with foil. Rest for 5 minutes then slice thinly against the grain (Note 2)."
    },
    {
      "order": 6,
      "instruction": "Serve with tacos, in burritos or on rice!"
    }
  ]
}