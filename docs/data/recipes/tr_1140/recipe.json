  "steps": [
    {
      "order": 1,
      "instruction": "Season lamb with salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Heat 1 tbsp oil in a dutch oven or large heavy based pot over high heat. Add 2 lamb shanks and cook, turning, until browned (see photo). Remove then repeat with remaining lamb."
    },
    {
      "order": 3,
      "instruction": "Turn heat down to medium. Add remaining 1 tbsp oil, garlic, onion, carrot and celery. Sauté for 5 minutes until onion is softened."
    },
    {
      "order": 4,
      "instruction": "Add flour. Mix into onion mixture."
    },
    {
      "order": 5,
      "instruction": "Add remaining ingredients. Mix - lumps are ok, they will dissolve while cooking."
    },
    {
      "order": 6,
      "instruction": "Add lamb back in - the meat should be mostly submerged. Bring to simmer, then turn heat down to medium low and cover with lid."
    },
    {
      "order": 7,
      "instruction": "Simmer for 2 hours (Note 4) then remove lid and simmer for 30 minutes."
    },
    {
      "order": 8,
      "instruction": "Remove lamb into a bowl."
    },
    {
      "order": 9,
      "instruction": "Optional: Strain sauce in dutch oven into a bowl. Use spoon to press into onion etc to squeeze out all the flavourful liquid. Pour sauce into dutch oven. (Note 5)"
    },
    {
      "order": 10,
      "instruction": "Skim excess fat off sauce."
    },
    {
      "order": 11,
      "instruction": "Increase heat to medium high and reduce liquid by half or until it thickens to a syrup consistency."
    },
    {
      "order": 12,
      "instruction": "Return lamb shanks and juices pooled in the bowl into sauce to reheat, then serve with creamy mashed potato, garnished with parsley."
    }
  ]
}