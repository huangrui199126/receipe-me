  "steps": [
    {
      "order": 1,
      "instruction": "Melt most of the butter in a large non-stick skillet over high heat (save a dab for scrambling eggs)."
    },
    {
      "order": 2,
      "instruction": "Add garlic, cook for 10 seconds."
    },
    {
      "order": 3,
      "instruction": "Add ham, stir for 30 seconds."
    },
    {
      "order": 4,
      "instruction": "Add peas, stir for 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Rice and tomato paste - Add rice and tomato paste, cook for 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Sauces - Add fish sauce, soy and sugar, cook 1 minute to get a bit of nice caramelisation on the tomatoey rice."
    },
    {
      "order": 7,
      "instruction": "Scramble eggs - Push rice to one side of the pan. In the cleared space, melt reserved butter then pour in the egg and scramble until just set."
    },
    {
      "order": 8,
      "instruction": "Serve - Toss cooked egg through the rice. Serve!"
    }
  ]
