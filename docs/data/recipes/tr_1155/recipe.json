  "steps": [
    {
      "order": 1,
      "instruction": "Place Dressing ingredients in a jar and shake well. Set aside for 10 minutes+ (keeps for a week)."
    },
    {
      "order": 2,
      "instruction": "Place butter and sugar in a non stick skillet over medium high. When butter is melted, add nuts.&nbsp;"
    },
    {
      "order": 3,
      "instruction": "Stir 5 minutes - sugar will go sandy, then eventually melt into a caramel."
    },
    {
      "order": 4,
      "instruction": "Once sugar melts, cook for 2 minutes then spread pecans out on tray."
    },
    {
      "order": 5,
      "instruction": "Cool then break to separate."
    },
    {
      "order": 6,
      "instruction": "Place spinach and onion in a bowl, drizzle with about 3 tbsp Dressing, toss."
    },
    {
      "order": 7,
      "instruction": "Transfer 1/3 spinach in a bowl. Scatter over 1/3 of each strawberries, avocado, feta, pecans. Drizzle with a bit of dressing."
    },
    {
      "order": 8,
      "instruction": "Top with another 1/3 spinach, strawberries, avocado, feta, pecans, then a bit more Dressing. Repeat once more."
    },
    {
      "order": 9,
      "instruction": "Serve immediately!"
    }
  ]
}