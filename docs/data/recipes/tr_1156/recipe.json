      "order": 0
    },
    {
      "amount": "",
      "unit": "",
      "name": "2  garlic cloves (, minced)",
      "emoji": "🧄",
      "section": "",
      "order": 1
    },
    {
      "amount": "2.5",
      "unit": "tbsp",
      "name": "extra virgin olive oil",
