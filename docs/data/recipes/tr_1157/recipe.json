  "steps": [
    {
      "order": 1,
      "instruction": "Mix marinade in a large bowl. Add chicken and mix. Cover with cling wrap and marinate in the fridge for 24 - 48 hours (can't skip marinating for this recipe)."
    },
    {
      "order": 2,
      "instruction": "Brush BBQ with oil, or heat 1 tbsp in a skillet (I used a skillet). Use Medium heat - or Medium Low if your stove/BBQ runs hot (otherwise marinade may burn).&nbsp;"
    },
    {
      "order": 3,
      "instruction": "Remove chicken from marinade, shaking off excess. Cook the first side for around 5 minutes or until caramelised and golden. Turn then cook the other side for 4 minutes until caramelised."
    },
    {
      "order": 4,
      "instruction": "BAKING: See Note 4."
    },
    {
      "order": 5,
      "instruction": "Transfer chicken to serving plate, cover loosely with foil and rest for 5 minutes. Garnish with coriander / chilli if desired, and serve with lime wedges and Sauce."
    },
    {
      "order": 6,
      "instruction": "Place ingredients in a bowl and mix a bit. Microwave for 30 seconds, then mix until smooth. Bring to room temperature or serve warm (it thickens a bit when cooled)."
    }
  ]
}