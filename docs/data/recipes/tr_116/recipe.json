  "steps": [
    {
      "order": 1,
      "instruction": "Remove crust of each slice, then cut each into 3 equal thick batons."
    },
    {
      "order": 2,
      "instruction": "Combine the eggs, milk and a pinch of salt in a bowl large enough to roll the bread sticks in."
    },
    {
      "order": 3,
      "instruction": "Combine the cinnamon and sugar on a plate."
    },
    {
      "order": 4,
      "instruction": "Melt 2 tbsp of the butter in a large pan over medium high heat."
    },
    {
      "order": 5,
      "instruction": "Roll the sticks in the egg mixture quickly (do not soak them), shake off excess and place in pan. Cook in 2 batches."
    },
    {
      "order": 6,
      "instruction": "Turn to cook each side until golden."
    },
    {
      "order": 7,
      "instruction": "Immediately transfer to the plate with the cinnamon sugar and roll to coat. It's important to do this quickly while they are hot straight out of the pan so it sticks."
    },
    {
      "order": 8,
      "instruction": "Melt remaining butter and cook the remaining french toast sticks."
    },
    {
      "order": 9,
      "instruction": "Serve immediately with maple syrup to dunk the sticks in."
    }
  ]
}