  "steps": [
    {
      "order": 1,
      "instruction": "Toss blanched beans with oil, salt and pepper. Whisk Tahini ingredients, microwave 20 seconds, whisk again. Toast Panko mix on stove. Assemble - beans, sauce then panko. Attack!"
    },
    {
      "order": 2,
      "instruction": "Cook beans - Bring a large pot of water to the boil. Add beans, let it come back to the boil, cook for 2 minutes, then drain in a colander. Rinse under cold running water for 10 seconds to stop cooking (there is NO NEED to use ice!)."
    },
    {
      "order": 3,
      "instruction": "Season - Spread beans on a tea towel then dry with a 2nd tea towel. Transfer into bowl, toss with the oil, salt and pepper."
    },
    {
      "order": 4,
      "instruction": "Panko Mountain - Mix the ingredients in a bowl. Preheat a large non-stick pan on medium high. Add the panko mixture and stir for 4 - 5 minutes until golden brown. Transfer back into the bowl then let it cool."
    },
    {
      "order": 5,
      "instruction": "Whipped Tahini Yogurt - Whisk ingredients in a heat-proof bowl just to combine. Microwave for just 20 seconds on high, then whisk again for 10 seconds - it will resemble softly whipped cream. (Note 4) Use immediately or at room temperature."
    },
    {
      "order": 6,
      "instruction": "Assemble - Spread green beans on plate. Pour over sauce, pile on panko. Attack!"
    }
  ]
