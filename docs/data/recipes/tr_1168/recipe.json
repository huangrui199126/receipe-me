  "steps": [
    {
      "order": 1,
      "instruction": "Place Marinade ingredients in a ziplock bag (or bowl) and mix. Add chicken and massage to coat in the Marinade. Refrigerate for 1 hour (see Note 3 for skipping this)."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180C/350F (all types)."
    },
    {
      "order": 3,
      "instruction": "Line a tray with baking paper / parchment paper (or foil then spray with oil)."
    },
    {
      "order": 4,
      "instruction": "Transfer chicken to tray, shaking off excess marinade. RESERVE Marinade."
    },
    {
      "order": 5,
      "instruction": "Bake chicken for 20 minutes."
    },
    {
      "order": 6,
      "instruction": "Remove from oven. Spoon / slather / brush with reserve marinade (generously!) (Note 4). Bake for 10 minutes."
    },
    {
      "order": 7,
      "instruction": "Remove from oven and TURN chicken. Baste again using tray juices and reserved marinade. Bake for 10 minutes."
    },
    {
      "order": 8,
      "instruction": "Remove from oven and baste again (very generously!) using tray juices and reserved marinade. Bake for 10 minutes."
    },
    {
      "order": 9,
      "instruction": "Remove chicken from oven and scrape/brush tray juices onto chicken (don't waste free flavour!)."
    },
    {
      "order": 10,
      "instruction": "Sprinkle with sesame seeds and shallots/scallions if using. I served it with rice and steamed broccolini."
    }
  ]
}