  "steps": [
    {
      "order": 1,
      "instruction": "Take salmon out of fridge 20 minutes before cooking."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 220C/430F (standard) or 200C/390F (fan). Place shelf about 20cm/8\" from the broiler heat source at the top of the oven."
    },
    {
      "order": 3,
      "instruction": "Sprinkle both sides of the salmon with salt and pepper."
    },
    {
      "order": 4,
      "instruction": "Place sesame in shallow dish. Press salmon into sesame seeds to coat on all sides. Place on tray."
    },
    {
      "order": 5,
      "instruction": "Drizzle top with oil."
    },
    {
      "order": 6,
      "instruction": "Bake for 10 minutes. Flick to broiler on high - broil / grill for 3 minutes until the top is a bit golden (or bake for 5 minutes, but won't be as golden). (Note 5)"
    },
    {
      "order": 7,
      "instruction": "Remove from oven, rest 3 minutes. Serve with soba and greens, garnished with scallions (optional) and drizzled with Dressing."
    },
    {
      "order": 8,
      "instruction": "Bring a large pot of water to the boil."
    },
    {
      "order": 9,
      "instruction": "Cook soba per packet directions. Add greens for the last 1 minute of cooking."
    },
    {
      "order": 10,
      "instruction": "Drain then divide between bowls."
    },
    {
      "order": 11,
      "instruction": "Place ingredients in jar and shake. Set aside for 5 minutes."
    }
  ]
