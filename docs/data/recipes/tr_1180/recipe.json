  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F."
    },
    {
      "order": 2,
      "instruction": "Spread panko breadcrumbs on a baking tray. Spray lightly with oil. Bake for 3 to 5 minutes or until LIGHT golden."
    },
    {
      "order": 3,
      "instruction": "Scrape into a bowl. Add parmesan and mix."
    },
    {
      "order": 4,
      "instruction": "In a separate bowl, whisk together Batter ingredients with a fork. Add chicken and mix to coat."
    },
    {
      "order": 5,
      "instruction": "Optional: Place a rack on the baking tray (Note 3)"
    },
    {
      "order": 6,
      "instruction": "Pick up chicken with left hand and place in breadcrumbs. Use right hand to sprinkle with breadcrumbs, press to adhere. Use right hand to transfer to baking tray. Repeat with remaining chicken. Spray lightly with oil."
    },
    {
      "order": 7,
      "instruction": "Bake for 15 minutes for small tenders, 18 minutes for large ones. No longer than 20 minutes, otherwise they will begin to lose juiciness."
    },
    {
      "order": 8,
      "instruction": "Serve immediately with Ranch or Honey Mustard Dip if desired (Note 4)."
    }
  ]
}