      "order": 1,
      "instruction": "Chop chorizo into small pieces."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large skillet over high heat. Add garlic and chorizo and cook for 4 - 5 minutes until golden all over. Set aside to cool, but not cold (oil will harden)."
    },
    {
      "order": 3,
      "instruction": "Shake Dressing in a jar until well combined."
    },
    {
      "order": 4,
      "instruction": "Place beans, tomato, corn, onion and coriander in a bowl. Pour over Chorizo, including all the oil in the skillet, and the Dressing. Toss and serve!"
