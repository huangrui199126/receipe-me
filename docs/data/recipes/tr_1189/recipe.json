  "steps": [
    {
      "order": 1,
      "instruction": "Cut salmon into 2.5cm / 1\" cubes."
    },
    {
      "order": 2,
      "instruction": "Mix Sauce in a medium bowl. Add salmon, set aside for 3 minutes."
    },
    {
      "order": 3,
      "instruction": "Mix Dressing ingredients in a jar. Shake very well (jar is best)."
    },
    {
      "order": 4,
      "instruction": "Divide Salad ingredients between 2 bowls."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a non stick medium skillet over medium high heat. Remove salmon from Sauce, shaking off excess. Reserve Sauce."
    },
    {
      "order": 6,
      "instruction": "Place salmon in skillet. Cook for 2 minutes, turning to caramelise as many of the sides as you can (all sides is not practical, too much turning). (Note 5)"
    },
    {
      "order": 7,
      "instruction": "Pour Sauce into skillet. Cook for 30 seconds or until the Sauce reduces to a syrup (see video for how it bubbles)."
    },
    {
      "order": 8,
      "instruction": "Remove from stove. Immediately transfer salmon onto Salad. Leave to rest / cool for a few minutes. Then spoon the glaze over the salmon. Sprinkle with sesame seeds and shallots/scallions, if using."
    },
    {
      "order": 9,
      "instruction": "Drizzle salad with Dressing. Serve immediately."
    }
  ]
}