  "steps": [
    {
      "order": 1,
      "instruction": "Place Salmon Mousse ingredients in a food processor. Blitz until completely smooth, scraping down sides as needed."
    },
    {
      "order": 2,
      "instruction": "Fit piping bag with wide star tip nozzle (1.5-2cm / 0.6 - 0.75\" wide), then transfer Mousse into piping bag. Refrigerate for 5 hours until firmed."
    },
    {
      "order": 3,
      "instruction": "Cut into 1.5cm thick / 0.6\" slices."
    },
    {
      "order": 4,
      "instruction": "Use a small melon baller or teaspoon to scoop a well out."
    },
    {
      "order": 5,
      "instruction": "Pipe mousse into cucumbers. Top with dill and serve immediately."
    }
