  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F. Line a baking tray with parchment paper."
    },
    {
      "order": 2,
      "instruction": "Place the Filling ingredients in a bowl and use your hands to mix together. It should be quite soft and wet, not dry and crumbly."
    },
    {
      "order": 3,
      "instruction": "Place the filling onto the puff pastry. Shape into a loaf and roll the puff pastry up, ending with the seam side down."
    },
    {
      "order": 4,
      "instruction": "Transfer to baking tray. Cut a few diagonal slashes across the top."
    },
    {
      "order": 5,
      "instruction": "Brush with egg wash and bake for 35 to 40 minutes, or until the pastry is deep golden brown. Turn the tray at around 25 minutes for even browning."
    },
    {
      "order": 6,
      "instruction": "Remove from the oven. Rest for 5 minutes before serving."
    }
  ]
