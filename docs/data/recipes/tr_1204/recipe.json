  "steps": [
    {
      "order": 1,
      "instruction": "Mix meatball mixture until just combined."
    },
    {
      "order": 2,
      "instruction": "Roll out 2 tbsp of mixture into balls."
    },
    {
      "order": 3,
      "instruction": "Mix cornflour with splash of chicken stock, then add into skillet with all remaining Sauce ingredients."
    },
    {
      "order": 4,
      "instruction": "Bring to simmer over medium high heat, stirring regularly so the bottom doesn't catch, then gently add meatballs."
    },
    {
      "order": 5,
      "instruction": "Cook meatballs in liquid gently for 7 minutes, turning every now and then."
    },
    {
      "order": 6,
      "instruction": "If not serving immediately, remove meatballs from sauce (to stop them from cooking further)."
    },
    {
      "order": 7,
      "instruction": "Stuff into Banh Mi; OR"
    },
    {
      "order": 8,
      "instruction": "Garnish with freshly chopped red chilli, coriander and shallots and serve over rice with sauce!"
    }
  ]
