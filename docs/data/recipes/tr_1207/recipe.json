  "steps": [
    {
      "order": 1,
      "instruction": "Soak vermicelli noodles in freshly boiled water, per packet directions. Drain then set aside to cool."
    },
    {
      "order": 2,
      "instruction": "Place Dressing ingredients except coriander in a bowl. Whisk well. Stir through coriander. Adjust salt and pepper to taste."
    },
    {
      "order": 3,
      "instruction": "Place avocado and mango in a bowl. Drizzle over 3 teaspoons of Dressing, GENTLY toss."
    },
    {
      "order": 4,
      "instruction": "Place 4 to 5 lettuce leaves on each plate, overlapping slightly (see video for how I do it)."
    },
    {
      "order": 5,
      "instruction": "Divide the noodles between each plate. Then spoon over mango avocado salsa, sprinkle each plate all over with red onion and top with prawns."
    },
    {
      "order": 6,
      "instruction": "Drizzle over remaining Dressing all over everything, including the noodles. Serve immediately."
    }
  ]
}