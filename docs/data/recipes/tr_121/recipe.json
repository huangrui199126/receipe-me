  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Mix the Spice Rub ingredients together in a small bowl. Slather onto the chicken, covering both sides."
    },
    {
      "order": 3,
      "instruction": "Optional: Marinate for at least 1 hour, up to 24 hours. (Note 3)"
    },
    {
      "order": 4,
      "instruction": "Heat olive oil in a large skillet over medium high heat. Add the chicken, skin side down, and cook for 5 minutes on each side, or until light golden brown."
    },
    {
      "order": 5,
      "instruction": "Remove chicken from skillet. Scrape off excess black bits stuck to the pan and discard, along with excess oil (but leave some to cook the onion)."
    },
    {
      "order": 6,
      "instruction": "Add garlic and onion. Cook for 2 minutes until translucent."
    },
    {
      "order": 7,
      "instruction": "Add rice and stir so the grains are coated in oil and become a bit translucent."
    },
    {
      "order": 8,
      "instruction": "Add remaining ingredients. Place the chicken on top - it should be half submerged with the skin above the surface. Pour in the juices from the plate as well."
    },
    {
      "order": 9,
      "instruction": "Bring to simmer, then place a lid on (or cover with foil) and transfer to oven."
    },
    {
      "order": 10,
      "instruction": "Bake for 35 minutes, then remove the lid and bake for a further 10 minutes."
    },
    {
      "order": 11,
      "instruction": "Remove from the oven. Let it rest for 5 minutes."
    },
    {
      "order": 12,
      "instruction": "Remove chicken from the rice and mix the rice quickly (to evenly distribute flavour)."
    },
    {
      "order": 13,
      "instruction": "Serve, garnished with cilantro/coriander and parsley if desired. I also like to serve it with a bit of plain yoghurt. (Note 4)"
    }
  ]
}