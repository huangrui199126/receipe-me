  "steps": [
    {
      "order": 1,
      "instruction": "Place flour, baking powder, salt and pepper in a bowl. Mix to combine."
    },
    {
      "order": 2,
      "instruction": "Make a well in the centre. Add egg and milk. Mix until flour is incorporated - small lumps is fine (see video / photo in post)."
    },
    {
      "order": 3,
      "instruction": "Add cheese, ham and shallots. Stir through - it should have a soft dropping consistency."
    },
    {
      "order": 4,
      "instruction": "Heat a non stick pan over medium high heat (or medium if your stove is strong)."
    },
    {
      "order": 5,
      "instruction": "If using extra ham for toppings: cook it in just 1 tsp butter until golden, then remove onto paper towels to drain."
    },
    {
      "order": 6,
      "instruction": "For the pancakes: Add about 2 tsp butter, swirl to melt."
    },
    {
      "order": 7,
      "instruction": "Place 1/4 cup batter in the pan (Note 4), then roughly spread into a 7cm / 3\" circle. Repeat to fill the pan (I do 3 in a small pan, 4 in a large)."
    },
    {
      "order": 8,
      "instruction": "Cook for 2 minutes until the underside is deep golden. Don't wait for bubbles like normal pancakes, they won't appear."
    },
    {
      "order": 9,
      "instruction": "Flip and cook the other side for 1 1/2 minutes. Remove onto a rack."
    },
    {
      "order": 10,
      "instruction": "Add a bit of extra butter and repeat with remaining batter."
    },
    {
      "order": 11,
      "instruction": "Serve with dollops of sour cream (virtually mandatory!), sprinkled with extra cooked ham and shallots, if desired."
    }
  ]
}