  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (standard) or 180C/350F (fan/convection)."
    },
    {
      "order": 2,
      "instruction": "Use a baking dish about 22 x 33cm / 9 x 13\"."
    },
    {
      "order": 3,
      "instruction": "Scatter onion and garlic in baking dish, dollop butter over. Bake for 15 minutes, then remove."
    },
    {
      "order": 4,
      "instruction": "If your chicken has skin on it, remove it (just pull it off). Otherwise, the rice will be too greasy."
    },
    {
      "order": 5,
      "instruction": "Whisk together Sticky Chicken Glaze. Add chicken, turn to coat."
    },
    {
      "order": 6,
      "instruction": "Add rice, apple juice, chicken broth and Rice Herbs into the pan with the onion. Stir."
    },
    {
      "order": 7,
      "instruction": "Add cranberries and walnuts. Stir."
    },
    {
      "order": 8,
      "instruction": "Top with chicken - it will be partly submerged. Save glaze in bowl."
    },
    {
      "order": 9,
      "instruction": "Cover with foil. Bake 20 minutes. Remove foil - don't worry if there's still liquid (Note 4)."
    },
    {
      "order": 10,
      "instruction": "Spoon all remaining Glaze onto chicken. Optional: spray with oil (gives chicken a slightly nicer finish). Bake for another 30 - 35 minutes until chicken is browned."
    },
    {
      "order": 11,
      "instruction": "Remove pan from oven. Rest 5 minutes. Remove chicken, add apple, then use fork to fluff rice."
    },
    {
      "order": 12,
      "instruction": "Serve chicken with rice pilaf, garnished with fresh parsley if desired."
    }
  ]
}