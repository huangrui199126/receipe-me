    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Carefully break or cut the stems off the mushrooms."
    },
    {
      "order": 3,
      "instruction": "Chop stems (will use as filling)."
    },
    {
      "order": 4,
      "instruction": "Place mushrooms cap side up. Using a small, sharp, THIN knife, cut a small cross in the mushroom, taking great care not to split the mushroom (to drain excess water, Note 2)"
    },
    {
      "order": 5,
      "instruction": "Brush the tops with oil, then quickly sprinkle on salt and pepper (be fast so it sticks!)"
    },
    {
      "order": 6,
      "instruction": "Flip then lightly dab the inside with remaining oil, sprinkle with salt and pepper."
    },
    {
      "order": 7,
      "instruction": "Fill mushrooms with pizza sauce, sprinkle with chopped mushroom, onion, half salami and half olives."
    },
    {
      "order": 8,
      "instruction": "Bake 1 - Bake 10 minutes, remove from oven."
    },
    {
      "order": 9,
      "instruction": "Top with cheese, remaining salami and olives."
    },
    {
      "order": 10,
      "instruction": "Bake 2 - Bake further 10 minutes until cheese is melted. Serve immediately!"
    },
    {
      "order": 11,
      "instruction": "Preheat BBQ to medium high."
    },
    {
      "order": 12,
      "instruction": "Follow above steps in closed BBQ - 10 minutes for Bake 1, then 5 - 8 minutes for Bake 2."
    }
  ]
}