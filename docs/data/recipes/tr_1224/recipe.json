      "section": "",
      "order": 3
    },
    {
      "amount": "",
      "unit": "",
      "name": "100g/ 3.5 oz   salami slices (, chopped)",
      "emoji": "🥄",
      "section": "",
      "order": 4
    },
    {
      "amount": "",
      "unit": "",
      "name": "1/4  red onion (, finely chopped)",
      "emoji": "🧅",
