  "steps": [
    {
      "order": 1,
      "instruction": "Place Meatball ingredients in a bowl and use your hands to combine."
    },
    {
      "order": 2,
      "instruction": "Refrigerate for 30 minutes (firms up, easier to handle). If in a rush, add more breadcrumbs until mixture is roll-able."
    },
    {
      "order": 3,
      "instruction": "Scoop up heaped tablespoons and dollop onto work surface with the flick of the wrist. Repeat with remaining mixture. Then roll into balls."
    },
    {
      "order": 4,
      "instruction": "Cut cheese into small squares to top each meatball."
    },
    {
      "order": 5,
      "instruction": "Cut larger gherkins in half, lengthwise."
    },
    {
      "order": 6,
      "instruction": "Heat oil in a skillet over medium high heat. Add meatballs in batches and cook, shaking the pan so they roll around, until browned all over and cooked through - 5 minutes. Between batches, drain excess oil (but keep some to cook next batch)."
    },
    {
      "order": 7,
      "instruction": "Place cooked meatballs on a large plate that fits in your microwave. Top with cheese and a gherkin and secure with a toothpick."
    },
    {
      "order": 8,
      "instruction": "Microwave for 60 - 90 seconds or until cheese melts. Serve warm with ketchup!"
    }
  ]
}