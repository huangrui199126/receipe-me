      "section": "",
      "order": 1
    },
    {
      "amount": "1",
      "unit": "cup",
      "name": "roughly chopped antipasto things ((olives, sun dried tomato, chargrilled peppers, artichokes, feta etc))",
      "emoji": "🌶️",
      "section": "",
      "order": 2
    },
    {
      "amount": "",
      "unit": "",
      "name": "4 - 6 slices cheese of choice ((I used Swiss in the video))",
      "emoji": "🧀",
      "section": "",
      "order": 3
    },
    {
      "amount": "",
      "unit": "",
      "name": "3  big handfuls baby spinach ((~75g / 2.5oz))",
      "emoji": "🥬",
      "section": "",
      "order": 4
    },
    {
      "amount": "50",
      "unit": "g",
      "name": "/ 3 tbsp   salted butter (, melted)",
      "emoji": "🧈",
      "section": "",
      "order": 5
    },
    {
      "amount": "",
      "unit": "",
      "name": "1  garlic clove (, minced)",
      "emoji": "🧄",
