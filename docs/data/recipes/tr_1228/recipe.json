    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Mix butter and garlic."
    },
    {
      "order": 3,
      "instruction": "Cut the top off the bread loaf. Pick out bread from the loaf and the lid, leaving a wall and floor about 1.5cm / 3/5\" thick."
    },
    {
      "order": 4,
      "instruction": "Place bread on a large sheet of foil on a baking tray."
    },
    {
      "order": 5,
      "instruction": "Dab / brush inside with butter. Layer with: half spinach, turkey, antipasto things, remaining spinach, ham, cheese."
    },
    {
      "order": 6,
      "instruction": "Tuck flappy bits inside the loaf, top with lid."
    },
    {
      "order": 7,
      "instruction": "Brush with butter all over. Wrap with foil."
    },
    {
      "order": 8,
      "instruction": "Weigh down with something flat and heavy - cast iron skillet is ideal."
    },
    {
      "order": 9,
      "instruction": "Bake for 20 minutes. Remove skillet and foil."
    },
    {
      "order": 10,
      "instruction": "Bake for a further 10 minutes until golden."
    },
    {
      "order": 11,
      "instruction": "Cut into thick slices and serve immediately!"
    }
  ]
