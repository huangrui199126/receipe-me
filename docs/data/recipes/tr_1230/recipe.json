  "steps": [
    {
      "order": 1,
      "instruction": "Heat olive oil in a large saucepan over medium heat. Add garlic and cook for 1 minute until fragrant. Add remaining ingredients, stir, and adjust heat so it is simmering gently (about medium heat). Cook down for 40 minutes, then puree with a stick (or cool a bit then transfer to blender).&nbsp;"
    },
    {
      "order": 2,
      "instruction": "COOL before using (hot sauce = soggy base). (Note 4)"
    },
    {
      "order": 3,
      "instruction": "Top a flatbread with 2.5 tbsp of Sauce. Sprinkle a tiny amount of cheese over the base, avoiding the very edges (glue for toppings - see video)."
    },
    {
      "order": 4,
      "instruction": "Sprinkle over onion, capsicum, salami, olives, mushrooms then cheese. Repeat with remaining flatbreads."
    },
    {
      "order": 5,
      "instruction": "Stack them using paper in between each pizza. Wrap in groups of 3 or so (whatever you are comfortable handling). Transfer to a large airtight container or ziplock bag and freeze."
    },
    {
      "order": 6,
      "instruction": "Baking:"
    },
    {
      "order": 7,
      "instruction": "Remove oven shelf from oven and clean."
    },
    {
      "order": 8,
      "instruction": "Preheat oven to 240C/460F (standard) / 220C / 430F (fan/convection)."
    },
    {
      "order": 9,
      "instruction": "Place frozen (or unfrozen freshly made) pizza directly on shelf. Bake for 10 minutes or until golden on the edges and the base is crispy."
    },
    {
      "order": 10,
      "instruction": "Cut and serve immediately!"
    }
  ]
}