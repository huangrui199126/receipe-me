  "steps": [
    {
      "order": 1,
      "instruction": "Cut Chorizo into 8mm / 1/3\" thick slices on a slight angle"
    },
    {
      "order": 2,
      "instruction": "Mix together Sauce in a bowl."
    },
    {
      "order": 3,
      "instruction": "Mix together Thickener in a small bowl."
    },
    {
      "order": 4,
      "instruction": "Heat oil in a skillet over medium high heat. Add chorizo and cook until golden brown on both sides - around 3 minutes."
    },
    {
      "order": 5,
      "instruction": "Add Sauce and simmer for 3 minutes."
    },
    {
      "order": 6,
      "instruction": "Add Thickener and mix quickly, then simmer for 45 seconds to 1 minute until thickened - see video below recipe."
    },
    {
      "order": 7,
      "instruction": "Transfer to serving bowl. Garnish with parsley if desired and serve with toothpicks."
