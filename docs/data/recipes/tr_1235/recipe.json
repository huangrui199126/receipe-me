  "steps": [
    {
      "order": 1,
      "instruction": "If the chicken is much thicker than 2cm / 4/5\", pound lightly or cut in half horizontally."
    },
    {
      "order": 2,
      "instruction": "Place the Grilled Chicken ingredients in a ziplock bag and set aside for 30 minutes to overnight."
    },
    {
      "order": 3,
      "instruction": "Use the oil to brush the grill, or heat oil in a skillet over medium high heat. Cook the chicken for 4 minutes on each side, then remove onto a plate. Cover loosely with foil, rest for 5 minutes, then slice thinly."
    },
    {
      "order": 4,
      "instruction": "Cook the peas in boiling water (or steam), drain then rinse under cold tap water to cool down."
    },
    {
      "order": 5,
      "instruction": "Place cabbage, peas, mint and onion in a bowl. Add parmesan, lemon juice, olive oil, and pepper."
    },
    {
      "order": 6,
      "instruction": "Toss well. Adjust salt to taste, add more parmesan if desired."
    },
    {
      "order": 7,
      "instruction": "Transfer to serving plates, top with chicken. Garnish with more parmesan and black pepper, then serve."
    }
  ]
}