  "steps": [
    {
      "order": 1,
      "instruction": "Heat olive oil over medium high heat in large skillet."
    },
    {
      "order": 2,
      "instruction": "Add chicken and cook each side for 2 minutes or until cooked, then remove onto a plate."
    },
    {
      "order": 3,
      "instruction": "Add extra oil if the skillet is looking dry. Add onion and garlic, cook for 1 1/2 minutes until starting to soften."
    },
    {
      "order": 4,
      "instruction": "Add bell peppers and cook for a further 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add remaining ingredients except rice and cheese. Bring to simmer, then add rice."
    },
    {
      "order": 6,
      "instruction": "Stir, cover with a lid and turn down heat to medium low. Cover and cook until rice is cooked but not mushy and most of the liquid is absorbed - about 15 to 18 minutes. (Note 3). Do not stir while it cooks."
    },
    {
      "order": 7,
      "instruction": "Meanwhile, shred or roughly chop chicken."
    },
    {
      "order": 8,
      "instruction": "When rice is cooked, quickly stir chicken through, sprinkle with cheese then pop under broil / grill until golden and bubbly."
    },
    {
      "order": 9,
      "instruction": "Serve, garnished with fresh cilantro/coriander if desired."
    }
  ]
}