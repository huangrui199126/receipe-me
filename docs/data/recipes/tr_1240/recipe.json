  "steps": [
    {
      "order": 1,
      "instruction": "Place milk, broth and stock powder in a large saucepan. Bring to a very gentle simmer over medium heat, add chicken, pepper, bay leaves and thyme."
    },
    {
      "order": 2,
      "instruction": "Place lid on, simmer gently on medium low for 15 minutes (do not boil, can make milk split)."
    },
    {
      "order": 3,
      "instruction": "Remove chicken and shred. Cover pot and set poaching liquid aside."
    },
    {
      "order": 4,
      "instruction": "Heat half the oil and butter in a very large, deep skillet over high heat (or use large pot). Add half the mushrooms with half the garlic, salt and pepper."
    },
    {
      "order": 5,
      "instruction": "Cook for 5 minutes, stirring leisurely, until golden. Transfer to bowl and repeat with remaining mushrooms."
    },
    {
      "order": 6,
      "instruction": "Lower heat down to medium."
    },
    {
      "order": 7,
      "instruction": "Melt butter in skillet, then add garlic. Stir until golden."
    },
    {
      "order": 8,
      "instruction": "Add flour. Stir constantly for 1 minute."
    },
    {
      "order": 9,
      "instruction": "Gradually pour in 2 cups of reserved poaching liquid while stirring constantly, it should turn into a thick paste."
    },
    {
      "order": 10,
      "instruction": "Mix in another cup of liquid, then add remaining liquid and stir well to dissolve. Use whisk if necessary to make lump free."
    },
    {
      "order": 11,
      "instruction": "Stir constantly for 1 to 2 minutes until it thickens - you should be able to draw a path across a spoon (see video)."
    },
    {
      "order": 12,
      "instruction": "Remove from heat, stir in cheese until melted. Taste and add more salt &amp; peppers, if needed."
    },
    {
      "order": 13,
      "instruction": "REMOVE 2 1/2 cups (625ml) of sauce (save for topping). Then stir in chicken and mushrooms into remaining sauce."
    },
    {
      "order": 14,
      "instruction": "Preheat oven to 180°C/350°F."
    },
    {
      "order": 15,
      "instruction": "Smear some sauce on the base of a 23 x 33 cm / 9 x 13&quot; baking dish. Cover base with lasagna sheets."
    },
    {
      "order": 16,
      "instruction": "Top with half chicken mixture, then lasagna sheets, remaining chicken mixture then more lasagna sheets."
    },
    {
      "order": 17,
      "instruction": "Pour over reserved White Sauce, sprinkle with mozzarella. Cover loosely with foil or use upside down baking tray (ensure it&#x27;s not touching cheese)."
    },
    {
      "order": 18,
      "instruction": "Bake for 25 minutes. Remove foil, bake further 10 minutes until golden and bubbly."
    },
    {
      "order": 19,
      "instruction": "Stand 10 minutes, garnish with parsley if desired then cut to serve!"
    }
  ]
}