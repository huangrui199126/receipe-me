  "steps": [
    {
      "order": 1,
      "instruction": "Place Lentil ingredients in a large saucepan over high heat. Bring to simmer then turn down to medium low. Cook for 20 minutes for firm (I like this) or 25 minutes for soft. DO NOT overcook and make it mushy!"
    },
    {
      "order": 2,
      "instruction": "Drain in a colander, pick out celery etc. Rinse VERY quickly just to remove any grit coating the lentils (don't want to rinse away flavour!). Set aside."
    },
    {
      "order": 3,
      "instruction": "Place Dressing ingredients in a jar, shake well."
    },
    {
      "order": 4,
      "instruction": "Place lentils, tomato, cucumber, onion, coriander, parsley and some of the feta in a large bowl. Pour over most of the Dressing, then toss."
    },
    {
      "order": 5,
      "instruction": "Place rocket lettuce on a serving platter. Pile salad on top. Drizzle over remaining Dressing and crumble over feta. Serve! (I like serving with pita bread to stuff it in)"
    }
  ]
}