  "steps": [
    {
      "order": 1,
      "instruction": "Cook 1lb/500g of dried spaghetti (or any other long dried pasta) in a large pot of salted boiling water per packet MINUS 1 minute."
    },
    {
      "order": 2,
      "instruction": "Meanwhile, prepare one of the sauces below."
    },
    {
      "order": 3,
      "instruction": "When pasta is ready, scoop out 1 cup of pasta cooking water, and drain pasta."
    },
    {
      "order": 4,
      "instruction": "Add pasta into chosen sauce with 3/4 cup pasta cooking water.&nbsp;Toss pasta until sauce thickens and sticks to pasta (called \"emulsifying\" the sauce), 1 - 2 minutes.&nbsp;Use more pasta water if needed to loosen sauce."
    },
    {
      "order": 5,
      "instruction": "Season with salt and pepper to taste. Finish pasta per chosen recipe."
    },
    {
      "order": 6,
      "instruction": "Heat oil over medium high heat. Add garlic and cook until golden - be careful not to burn it. &nbsp;"
    },
    {
      "order": 7,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through parsley and chilli flakes, serve with parmesan."
    },
    {
      "order": 8,
      "instruction": "Heat oil over medium high heat. Add garlic, stir until fragrant, then add the tinned tomatoes and chilli flakes, simmer on medium for 5 minutes."
    },
    {
      "order": 9,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through parsley and serve with parmesan."
    },
    {
      "order": 10,
      "instruction": "Heat oil over medium high heat. Add garlic and anchovies, stir until the garlic is fragrant and the anchovies have melted.&nbsp;"
    },
    {
      "order": 11,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through parsley and chilli flakes, and serve with parmesan."
    },
    {
      "order": 12,
      "instruction": "Heat oil over medium high heat. Add the garlic, onion and guanciale (or pancetta or bacon) and cook until the onion has softened and the guanciale &nbsp;is golden."
    },
    {
      "order": 13,
      "instruction": "Add the tinned tomatoes and chilli flakes and bring to rapid simmer. Toss with pasta and cooking water per Base Directions. Serve with parmesan."
    },
    {
      "order": 14,
      "instruction": "Heat oil over medium high heat. Add garlic and cook&nbsp;until fragrant, add tomato and cook briefly, just to warm through.&nbsp;"
    },
    {
      "order": 15,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through basil, serve with parmesan."
    },
    {
      "order": 16,
      "instruction": "Heat oil over medium high heat. Add garlic and cook until fragrant, then add the onion and cook until softened. Then add tinned tomatoes and 1/2 cup water, simmer 5 minutes.&nbsp;"
    },
    {
      "order": 17,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through basil and serve with parmesan."
    },
    {
      "order": 18,
      "instruction": "Heat oil over medium high heat. Add garlic and cook until fragrant, then add tinned tomatoes, chilli flakes, olives, capers and 1/2 cup water. Simmer 3 minutes."
    },
    {
      "order": 19,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through parsley and serve with parmesan."
    },
    {
      "order": 20,
      "instruction": "Heat oil over medium high heat. Add garlic and cook until fragrant. Add the onion and cook until softened, then add the tinned tomatoes and 1/2 cup water. Simmer 3 minutes, then add the tuna.&nbsp;"
    },
    {
      "order": 21,
      "instruction": "Toss with pasta and cooking water per Base Directions. Toss through parsley. Seafood pasta typically not served with parmesan but you can if you want!"
    }
  ]
