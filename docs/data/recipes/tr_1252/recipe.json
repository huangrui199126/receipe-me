  "steps": [
    {
      "order": 1,
      "instruction": "Combine sugar and water in saucepan over medium heat."
    },
    {
      "order": 2,
      "instruction": "Bring to rolling boil, stirring to help dissolve the sugar."
    },
    {
      "order": 3,
      "instruction": "Boil for 5 to 8 minutes, until it turns a golden brown."
    },
    {
      "order": 4,
      "instruction": "Pour in the cream, whisking constantly. Be careful, as the caramel is hot and it will foam."
    },
    {
      "order": 5,
      "instruction": "Once the cream is combined, remove from heat and whisk in the salt and vanilla."
    },
    {
      "order": 6,
      "instruction": "The caramel will seem thin. It thickens alot as it cools."
    }
