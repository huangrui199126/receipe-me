  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large, heavy pot over medium heat, melt butter."
    },
    {
      "order": 2,
      "instruction": "Add the garlic and onion, stirring occasionally until onion is soft and fragrant - about 3 minutes."
    },
    {
      "order": 3,
      "instruction": "Turn heat up to high, add wine and bring to boil. Simmer 2 minutes until the harsh alcoholic smell is gone."
    },
    {
      "order": 4,
      "instruction": "Stir in tomatoes, add mussels stir to coat in sauce a bit."
    },
    {
      "order": 5,
      "instruction": "Cover, lower heat to medium high and cook, shaking pot once or twice."
    },
    {
      "order": 6,
      "instruction": "The mussels are cooked when they are open - around 6 to 8 minutes."
    },
    {
      "order": 7,
      "instruction": "Toss through parsley and season to taste with salt and pepper. Be careful with the salt as the mussels are already salty, so taste first."
    },
    {
      "order": 8,
      "instruction": "Drizzle with extra virgin olive oil, and serve with lemon wedgeds on the side so people can use as much as they wish. Serve immediately with crusty bread to mop up the sauce!"
    }
  ]
