  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F.&nbsp;Brush a 12 hole standard muffin tin with melted butter."
    },
    {
      "order": 2,
      "instruction": "Combine Dry ingredients in a bowl and give them a quick stir to combine."
    },
    {
      "order": 3,
      "instruction": "Whisk Wet ingredients in a bowl until combined."
    },
    {
      "order": 4,
      "instruction": "Pour Wet into Dry ingredients. Mix until combined."
    },
    {
      "order": 5,
      "instruction": "Spoon the batter into the greased muffin tray - use it all up, fill the holes right up!"
    },
    {
      "order": 6,
      "instruction": "Bake in the oven for 20 minutes or until the top is golden brown."
    },
    {
      "order": 7,
      "instruction": "Remove muffin tray from the oven. Optional: Brush tops with melted butter. Cool for 5 minutes then remove muffins onto a rack."
    }
