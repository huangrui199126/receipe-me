  "steps": [
    {
      "order": 1,
      "instruction": "Croutons: Preheat oven to 200°C/390°F (180°C fan). Toss bread with oil and salt. Spread on a tray and bake 15 minutes, stirring twice, until golden and fully crisp. Cool on tray."
    },
    {
      "order": 2,
      "instruction": "Dressing: Shake ingredients in a jar."
    },
    {
      "order": 3,
      "instruction": "Make salad: Set aside some parmesan for garnish. Place croutons and all remaining salad ingredients in a large bowl. Pour Dressing over, toss well."
    },
    {
      "order": 4,
      "instruction": "Serve: Transfer salad into a serving bowl. Sprinkle with reserved parmesan. Serve immediately!"
    }
  ]
