  "steps": [
    {
      "order": 1,
      "instruction": "Dice most of the chorizo, leaving some in slice form if you want to use them for garnish like I did."
    },
    {
      "order": 2,
      "instruction": "Heat the olive oil in a skillet over high heat."
    },
    {
      "order": 3,
      "instruction": "Add the garlic and onions and cook for 2 minutes or until starting to turn translucent."
    },
    {
      "order": 4,
      "instruction": "Add the chorizo (all of it) and saute until the chorizo is nicely browned."
    },
    {
      "order": 5,
      "instruction": "Add the remaining Baked Beans ingredients. Bring to simmer, then turn it down to medium low and leave to bubble away gently for 10 minutes or so, stirring occasionally. Add a splash of water if it gets too thick to your liking."
    },
    {
      "order": 6,
      "instruction": "Adjust salt and pepper to taste."
    },
    {
      "order": 7,
      "instruction": "Pile the Baked Beans onto toasted sourdough and top with a fried egg."
    }
  ]
