  "steps": [
    {
      "order": 1,
      "instruction": "Shred the chicken as finely as you can. The best method is using a stand-mixer. Just put the meat in the bowl with the paddle attachment and mix on medium speed until it&#39;s really finely shredded (~ 1 minute). Else use a handheld beater or your hands."
    },
    {
      "order": 2,
      "instruction": "Mix the Sauce ingredients in a bowl until smooth - use a whisk if needed."
    },
    {
      "order": 3,
      "instruction": "Pour Sauce over the chicken. Add remaining Filling ingredients. Stir until combined."
    },
    {
      "order": 4,
      "instruction": "Spread bread with butter. Spread with Filling (see below for amount)."
    },
    {
      "order": 5,
      "instruction": "Remove crusts if desired (for the authentic &quot;gourmet&quot; experience!) and cut in half. (Tip: For really neat cuts, refrigerate sandwiches before slicing so Filling firms up)."
    },
    {
      "order": 6,
      "instruction": "Serve on platters littered with green fluffage, if desired!"
    },
    {
      "order": 7,
      "instruction": "Chicken filling per sandwich:- Deli standard (recommended): 100g / 1/2 cup (makes 10 sandwiches)- Very generous: 130g / 1/2 cup (makes 8)- Everyday lunchbox: 80g (1/3 cup) (makes 15)."
    }
  ]
