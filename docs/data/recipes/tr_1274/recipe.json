  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 190°C / 375°F (170°C fan). Line a 12 hole standard muffin tin with muffin cases OR spray generously with oil."
    },
    {
      "order": 2,
      "instruction": "Whisk wet - Place coconut oil in a microwave proof bowl. Microwave for 45 seconds on high or until melted. Add remaining Wet ingredients, whisk until smooth."
    },
    {
      "order": 3,
      "instruction": "Mix in Dry - Sprinkle the Dry ingredients across the surface in the order listed. Mix just until combined."
    },
    {
      "order": 4,
      "instruction": "Raspberries - Gently stir in the whole raspberries or other add-ins of choice."
    },
    {
      "order": 5,
      "instruction": "Fill muffin tin - Divide batter between the 12 holes using an ice cream scoop. Decorate top with halved raspberries."
    },
    {
      "order": 6,
      "instruction": "Bake 25 minutes. Cool 5 minutes then transfer to a cooling rack."
    }
  ]
