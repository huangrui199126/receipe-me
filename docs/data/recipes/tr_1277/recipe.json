  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan), though you can use your slow cooker or stove instead (oven easiest! Note 4)."
    },
    {
      "order": 2,
      "instruction": "Season beef - Toss the beef with half the salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Cook onion - Heat the oil and melt the butter in a large oven-proof dutch oven over high heat. Cook onion for 6 minutes until the edges are light golden."
    },
    {
      "order": 4,
      "instruction": "Cook beef - Add the beef and stir until the outside changes from red to brown, about 2 minutes. It won&#39;t go golden brown, it&#39;s not supposed to."
    },
    {
      "order": 5,
      "instruction": "Add vegetables - Add garlic, capsicum and tomato. Stir for 3 minutes - the tomato will mostly breakdown."
    },
    {
      "order": 6,
      "instruction": "Add paprika, caraway and bay leaf. Stir for 30 seconds."
    },
    {
      "order": 7,
      "instruction": "Slow cook - Add beef stock, stir, bring to simmer. Cover with a lid and transfer to the oven for 1 1/2 hours."
    },
    {
      "order": 8,
      "instruction": "Add potato - The beef should be pretty tender but not quite &quot;fall-apart&quot;. Stir in carrot and potatoes. Return to oven, covered, for another 30 minutes. Beef should now be &quot;fall-apart&quot; - if not, return to the oven for 10 minutes at a time."
    },
    {
      "order": 9,
      "instruction": "Serve - Ladle goulash into bowls and sprinkle with parsley. Eat as is, with optional bread for dunking! (Pictured with cheese bread)"
    }
  ]
}