  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 350F/180C."
    },
    {
      "order": 2,
      "instruction": "Pasta Sauce: Pour out about 1/4 cup of the passata (to make room to add flavourings). Add the remaining Pasta Sauce ingredients into the bottle, screw the lid on and give it a shake."
    },
    {
      "order": 3,
      "instruction": "Cook pasta&nbsp;for time per packet MINUS 1 minute.&nbsp;"
    },
    {
      "order": 4,
      "instruction": "SCOOP OUT 1 mugful pasta cooking water, drain and set aside."
    },
    {
      "order": 5,
      "instruction": "Ricotta Mixture - Mix Ricotta Mixture ingredients in a very large bowl. Use a splash of pasta cooking water if needed to make it creamy."
    },
    {
      "order": 6,
      "instruction": "Add pasta and stir to combine. Transfer to a heatproof baking dish."
    },
    {
      "order": 7,
      "instruction": "Top with Pasta Sauce, top with cheese. Loosely cover with foil."
    },
    {
      "order": 8,
      "instruction": "Bake for 25 minutes, then remove the cover and bake for a further 10 minutes or until the cheese is melted and bubbly."
    },
    {
      "order": 9,
      "instruction": "Serve while hot and fresh!"
    }
  ]
