  "steps": [
    {
      "order": 1,
      "instruction": "Place tortilla on work surface. Sprinkle one side with a bit of cheese, top with Filling of Choice. Sprinkle with corn*, coriander and top with cheese. Fold in half."
    },
    {
      "order": 2,
      "instruction": "Preheat non stick skillet over medium low heat (no oil, if pan is not non-stick use 2 tsp oil)."
    },
    {
      "order": 3,
      "instruction": "Place quesadilla in skillet, press down lightly, cover with lid. Cook for 3 minutes until underside is super golden brown and crispy."
    },
    {
      "order": 4,
      "instruction": "Carefully flip over the folded edge (see video). Press down lightly. Cook for 3 minutes until crispy (no lid)."
    },
    {
      "order": 5,
      "instruction": "Transfer to cutting board, cut in half. Serve immediately!"
    },
    {
      "order": 6,
      "instruction": "Dipping Sauce options: Sour cream, salsa, Avocado Sauce (pictured)"
    },
    {
      "order": 7,
      "instruction": "Mix ingredients in a small bowl. Use for one of the Fillings Options below."
    },
    {
      "order": 8,
      "instruction": "Heat oil in a skillet over high heat. Add onion and garlic, cook for 2 minutes."
    },
    {
      "order": 9,
      "instruction": "Add beef and cook, breaking it up as you go. Once it changes from pink to brown, add capsicum. Cook for 1 minute."
    },
    {
      "order": 10,
      "instruction": "Add tomato paste, water and Spice Mix. Cook for 2 minutes. Transfer to bowl, cool."
    },
    {
      "order": 11,
      "instruction": "Drizzle chicken with 1 tbsp oil, toss to coat. Sprinkle over Spice Mix, toss well to coat."
    },
    {
      "order": 12,
      "instruction": "Heat 1 tbsp oil in a large skillet over high heat. Add onion and garlic, cook for 2 minutes. Add capsicum and cook for 1 minute. Transfer to bowl, cool."
    },
    {
      "order": 13,
      "instruction": "Return pan to stove, reduce to medium heat. Add remaining 1/2 tbsp oil. Add chicken and cook for 3 minutes until deep golden. Turn and cook for 3 minutes until cooked through."
    },
    {
      "order": 14,
      "instruction": "Transfer chicken to cutting board, rest for 2 minutes then dice and cool. Combine with capsicum mixture."
    },
    {
      "order": 15,
      "instruction": "Heat oil in a skillet over high heat. Add onion and garlic, cook for 2 minutes.&nbsp;Add capsicum, cook for 1 minute."
    },
    {
      "order": 16,
      "instruction": "Add beans, corn, tomato paste, water and Spice Mix. Cook for 2 minutes. Transfer to bowl, cool."
    }
  ]
