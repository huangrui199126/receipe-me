  "steps": [
    {
      "order": 1,
      "instruction": "Place Chicken ingredients in a bowl and mix to coat chicken."
    },
    {
      "order": 2,
      "instruction": "Heat oil in skillet over high heat. Add onion and garlic, cook for 1 minute. Then add capsicum and cook for 2 minutes until starting to soften. Transfer into bowl."
    },
    {
      "order": 3,
      "instruction": "Return skillet to the stove. Add chicken and cook until browned. Add to same bowl. Set aside until the filling cools (to speed it up, cover and refrigerate, and/or spread out on plate)."
    },
    {
      "order": 4,
      "instruction": "Preheat oven to 220C / 430F (standard) or 200C/390F (fan / convection)."
    },
    {
      "order": 5,
      "instruction": "Spray baking tray lightly with olive oil. Heat in the oven while you assemble the quesadillas."
    },
    {
      "order": 6,
      "instruction": "Divide the filling between the tortillas, covering half the surface. Top with cheese. Fold in half and press down gently but firmly."
    },
    {
      "order": 7,
      "instruction": "Remove baking tray from oven. Transfer quesadillas onto tray (you should hear a soft sizzle)."
    },
    {
      "order": 8,
      "instruction": "Bake for 8 minutes. Then turn the quesadillas (over the folded edge) then press down with the egg flip. Bake for a further 8 minutes or until the surface is crispy."
    },
    {
      "order": 9,
      "instruction": "Remove from oven and serve immediately!"
    }
  ]
}