  "steps": [
    {
      "order": 1,
      "instruction": "Place the Marinated Beef ingredients in a ziplock bag, massage to coat then refrigerate for 2 hour to overnight."
    },
    {
      "order": 2,
      "instruction": "Remove beef from marinade 30 minutes prior to cooking (to bring to room temperature) and pat dry with paper towels. Discard marinade."
    },
    {
      "order": 3,
      "instruction": "Drizzle 1/2 tbsp of oil on each side of the beef (1 tbsp in total)."
    },
    {
      "order": 4,
      "instruction": "Heat the BBQ or a skillet on high heat. Cook beef to your liking. (Note 4)"
    },
    {
      "order": 5,
      "instruction": "Remove beef onto a plate and cover loosely with foil."
    },
    {
      "order": 6,
      "instruction": "Return skillet to stove, still on high heat, and heat 1/2 tbsp oil. Add onions, sprinkle with salt and pepper, and cook until soft and charred. Remove onto serving plate."
    },
    {
      "order": 7,
      "instruction": "Heat remaining 1/2 tbsp oil in the skillet. Add bell pepper/capsicum, sprinkle with salt and pepper, and cook until charred. Remove onto plate."
    },
    {
      "order": 8,
      "instruction": "Slice beef thinly against the grain (Note 5)."
    },
    {
      "order": 9,
      "instruction": "Serve with warmed tortillas and fixings of choice. (Note 6)"
    }
  ]
}