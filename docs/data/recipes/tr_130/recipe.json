  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a skillet over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Add garlic, ginger, chilli (if using) and onion and saute until the onion is starting to soften."
    },
    {
      "order": 3,
      "instruction": "Add chicken and cook until white all over but still raw inside."
    },
    {
      "order": 4,
      "instruction": "Add curry paste and saute for 2 minutes until fragrant."
    },
    {
      "order": 5,
      "instruction": "Add coconut milk and chicken broth. Bring to simmer, stirring to dissolve the curry paste into the liquid. Then add the mango, fish sauce and kaffir lime leaves."
    },
    {
      "order": 6,
      "instruction": "Turn heat down to medium and simmer for 12 - 15 minutes, stirring occasionally, until the sauce is thickened. Adjust saltiness using fish sauce."
    },
    {
      "order": 7,
      "instruction": "Serve over jasmine rice, garnished with coriander/cilantro, wedges of lime and slices of red chilli, if desired."
    }
  ]
}