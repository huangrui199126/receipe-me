  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a 25cm/10&quot; ovenproof skillet over medium high heat. (Note 6)"
    },
    {
      "order": 2,
      "instruction": "Add garlic and sauté for 10 seconds then add onion."
    },
    {
      "order": 3,
      "instruction": "Cook onion until translucent and starting to turn golden, then passata, water, chilli flakes (if using), salt and pepper."
    },
    {
      "order": 4,
      "instruction": "Simmer for 5 minutes on medium low, then stir through basil. Should be quite thin - the lasagna sheets will absorb water while in the oven so sauce thickens alot in oven."
    },
    {
      "order": 5,
      "instruction": "Scoop out 1 cup of the Tomato Sauce which will be used to drizzle over the dish at the end. Keep sauce warm."
    },
    {
      "order": 6,
      "instruction": "Preheat oven to 180°C/350CF (all oven types)"
    },
    {
      "order": 7,
      "instruction": "Place Filling ingredients in a bowl. Mix well with wooden spoon."
    },
    {
      "order": 8,
      "instruction": "As per the photo &amp; video, lay out the lasagne sheet with the shorter end in front of you."
    },
    {
      "order": 9,
      "instruction": "Place 1/3 cup (packed) of filling onto the lasagne sheet. Dab some water on the end furthest away from you (to seal the roll), then roll up starting from the end closest to you. Finish with the seal down."
    },
    {
      "order": 10,
      "instruction": "Cut rolls into 3 (so each piece is 3.5cm/1.5&quot; wide). Place the rolls into the tomato sauce with the filling facing up."
    },
    {
      "order": 11,
      "instruction": "Repeat with remaining lasagna sheets until all the Filling is used up."
    },
    {
      "order": 12,
      "instruction": "Drizzle the reserved Tomato Sauce over (don&#039;t cover completely, leave some exposed)."
    },
    {
      "order": 13,
      "instruction": "Cover loosely with foil, bake 30 minutes."
    },
    {
      "order": 14,
      "instruction": "Remove from oven, remove foil. Drizzle with oil, top with mozzarella."
    },
    {
      "order": 15,
      "instruction": "Bake 15 minutes or until the cheese is bubbly and golden and you&#039;ve got some crunchy golden bits on the edges. Serve!"
    }
  ]
}