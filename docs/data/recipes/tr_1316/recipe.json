  "steps": [
    {
      "order": 1,
      "instruction": "Combine the fish, lime juice, oil, salt and pepper in a bowl. Cover with cling wrap and refrigerate for 20 minutes."
    },
    {
      "order": 2,
      "instruction": "Heat the 1 tbsp olive oil in a large skillet over high heat. Add the fish and cook until just cooked through and light golden brown. Remove from the skillet and set aside."
    },
    {
      "order": 3,
      "instruction": "Reduce the stove to medium high and heat 1 1/2 tbsp olive oil in the same skillet. Add the garlic and onion and cook for 1 1/2 minutes or until the onion is starting to become translucent."
    },
    {
      "order": 4,
      "instruction": "Add the bell peppers and cook for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add the remaining Broth ingredients. Bring to simmer, then turn down to medium. Cook for 15 to 20 minutes or until it thickens. Adjust salt and pepper to taste."
    },
    {
      "order": 6,
      "instruction": "Return the fish to the broth to reheat - about 2 minutes."
    },
    {
      "order": 7,
      "instruction": "Stir through lime juice."
    },
    {
      "order": 8,
      "instruction": "Garnish with cilantro/coriander and serve with rice or Lime Rice. For a low carb option, try Cauliflower Rice!"
    }
  ]
}