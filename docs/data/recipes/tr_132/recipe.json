  "steps": [
    {
      "order": 1,
      "instruction": "Combine Marinade ingredients in a bowl. Remove 1/2 cup of Marinade (for basting) and set aside in fridge. Add chicken, cover and marinate in the fridge for at least 3 hours, preferably overnight. But even 20 minutes is enough - compensate with extra basting."
    },
    {
      "order": 2,
      "instruction": "Drain and discard marinade. Thread chicken onto skewers."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large skillet or on outdoor BBQ over medium high heat. Cook skewers, turning to cook all sides, and basting generously with reserved Marinade. (Note 1)"
    },
    {
      "order": 4,
      "instruction": "Serve with Coconut Lime Rice."
    }
