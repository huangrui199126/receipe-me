  "steps": [
    {
      "order": 1,
      "instruction": "Sauté aromatics - Heat oil in a deep skillet or pot over medium high heat. Add onion, garlic and ginger, cook for 2 minutes until onion is a bit tinged with gold."
    },
    {
      "order": 2,
      "instruction": "Cook off spices - Add Spices and stir for 1 minute. Don&#39;t worry if it looks a bit dried out."
    },
    {
      "order": 3,
      "instruction": "Coconut sauce - Add coconut milk, passata and broth. Stir until incorporated. Add lentils and pumpkin. Bring to simmer then adjust heat so it&#39;s simmering energetically."
    },
    {
      "order": 4,
      "instruction": "Simmer for 10 minutes or until pumpkin is tender but not mushy, and sauce has thickened."
    },
    {
      "order": 5,
      "instruction": "Stir through baby spinach until wilted, then cashew nuts. Add salt and pepper last, adding more if needed."
    },
    {
      "order": 6,
      "instruction": "Serve over rice, sprinkled with coriander and extra cashews, if using."
    }
  ]
