  "steps": [
    {
      "order": 1,
      "instruction": "Mix together Marinade ingredients, marinate chicken for minimum 3 hours, preferably overnight."
    },
    {
      "order": 2,
      "instruction": "Shake Dressing ingredients together in a jar, set aside for at least 15 minutes."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a non stick skillet over high heat (or BBQ). Add chicken and cook each side for 3 minutes or until golden. Remove and cover loosely with foil for 5 minutes, then slice thickly."
    },
    {
      "order": 4,
      "instruction": "Sear 1/2 cup pineapple pieces and corn in the skillet until golden."
    },
    {
      "order": 5,
      "instruction": "Pile salad ingredients on a platter and top with sliced chicken. Drizzle over Dressing. Serve and pretend you're in Hawaii!"
    }
  ]
