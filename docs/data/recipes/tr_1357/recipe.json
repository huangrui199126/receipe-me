  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven 180C/350F (standard) or 160C/320F (fan). Grease and line a 22cm/9\" cake pan."
    },
    {
      "order": 2,
      "instruction": "Mix almond meal, semolina, baking powder, nutmeg and cardamon in bowl."
    },
    {
      "order": 3,
      "instruction": "Beat butter and both sugars with an electric beater until incorporated. Add eggs, beat until smooth. Then add yoghurt and orange zest, beat until smooth."
    },
    {
      "order": 4,
      "instruction": "Add dry ingredients. Stir until mixed through."
    },
    {
      "order": 5,
      "instruction": "Pour into pan, smooth surface. Scatter over pistachios."
    },
    {
      "order": 6,
      "instruction": "Bake 50 minutes to 1 hour, until skewer inserted into the centre comes out clean."
    },
    {
      "order": 7,
      "instruction": "Poke 30 - 40 holes all over the cake using a skewer (poke all the way through). Pour warm syrup over while cake still hot. Leave to soak for 1 hour+ before removing from pan. Cool then slice to serve."
    },
    {
      "order": 8,
      "instruction": "Pictured decorated with dried rose petals. Alternative: no decorations (pistachios alone look great!), dust with icing / confectionary sugar, of a Lemon Glaze (use this one)"
    },
    {
      "order": 9,
      "instruction": "Place ingredients in a saucepan over medium heat. Bring to simmer and stir to dissolve sugar. Simmer for 2 minutes. Keep warm (or reheat) for pouring."
    }
  ]
}