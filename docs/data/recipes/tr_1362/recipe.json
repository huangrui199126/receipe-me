  "steps": [
    {
      "order": 1,
      "instruction": "Make batter: Place chickpea flour in a bowl with the spices (turmeric, cumin, coriander, fenugreek, chilli). Slow whisk in the water."
    },
    {
      "order": 2,
      "instruction": "Mix in Vegetables: Add potato, cauliflower, onion, ginger, chilli and coriander. Mix well with a wooden spoon. It should be a thick batter, almost paste-like."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 80°C/175°F - to keep cooked pakoras warm. Set a rack over a tray."
    },
    {
      "order": 4,
      "instruction": "Heat oil: Heat 4cm / 1.5&quot; oil in a large heavy based pot to 180°C/350°F (Note 6)."
    },
    {
      "order": 5,
      "instruction": "Form patties: Drop 2 tbsp of batter roughly formed into a patty shape into the oil. I use my hands (as is typical in India!) but you can also use 2 tablespoons (be careful of splash-age). Don&#039;t crowd the pot, it will lower the temperature too much."
    },
    {
      "order": 6,
      "instruction": "Fry pakoras: Fry 2 - 3 minutes until golden. Drain on paper towels. Keep cooked pakoras hot in the oven on a rack set over a tray."
    },
    {
      "order": 7,
      "instruction": "Serve: Serve pakoras with Coriander Mint Sauce or Minted Yogurt Sauce!"
    },
    {
      "order": 8,
      "instruction": "Place ingredients in a small food processor or Nutribullet, or use a stick blender. Blitz until smooth."
    }
  ]
