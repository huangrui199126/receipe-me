  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 120°C / 250°F and set a wire rack on a baking tray."
    },
    {
      "order": 2,
      "instruction": "Place flour, cornflour and baking soda in a bowl, mix to combine."
    },
    {
      "order": 3,
      "instruction": "Add egg and milk, mix until incorporated (batter will be lumpy and thick)."
    },
    {
      "order": 4,
      "instruction": "Add corn, parmesan, green onions and coriander. Mix until all the corn is evenly coated in batter."
    },
    {
      "order": 5,
      "instruction": "Add enough oil into the skillet so it just covers the base. Heat over medium high heat."
    },
    {
      "order": 6,
      "instruction": "Spray the underside of a spatula with oil (so batter won’t stick when you flatten)."
    },
    {
      "order": 7,
      "instruction": "Place 1/4 cup batter into skillet (ice cream scooper with lever is handy), then flatten to 1cm thick. Repeat with 2 or 3 more, but don’t crowd the skillet."
    },
    {
      "order": 8,
      "instruction": "Cook 3 minutes until deep golden and crisp, then flip and cook the other side for 2 – 3 minutes."
    },
    {
      "order": 9,
      "instruction": "Transfer to rack and keep warm in oven. Repeat with remaining fritters, using more oil as necessary."
    },
    {
      "order": 10,
      "instruction": "Serve with sauce of choice for dunking!"
    }
  ]
}