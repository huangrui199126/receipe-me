  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/390°F (180°C fan-forced)"
    },
    {
      "order": 2,
      "instruction": "Sweat zucchini - Grate the zucchini using a standard box grater. Place into a large colander, sprinkle with the salt, toss with your fingers and leave to sweat for 30 minutes."
    },
    {
      "order": 3,
      "instruction": "Squeeze out liquid - Working a handful at a time, squeeze out the excess water (as much as you can) and place the zucchini in a bowl."
    },
    {
      "order": 4,
      "instruction": "Tots batter - Add the Batter ingredients except the feta and mix well to combine. Add the feta and gently stir through."
    },
    {
      "order": 5,
      "instruction": "Form tots - Dollop heaped tablespoons 2 trays lined with baking paper / parchment paper (I get 29 in total). Then use your fingers to shape them into cylinder &quot;tater-tot / potato gem&quot; shapes."
    },
    {
      "order": 6,
      "instruction": "Bake - Spray generously with oil. Bake for 30 minutes, swapping the trays at around 20 minutes (for extra golden, spray again with oil), or until golden brown and a crunchy crust forms on the surface. The tray on the bottom might need a few extra minutes."
    },
    {
      "order": 7,
      "instruction": "Serve with Minted Yogurt, lemon wedges and sprinkled with fresh oregano leaves if using."
    },
    {
      "order": 8,
      "instruction": "Mix together ingredients and set aside for at least 10 minutes before serving."
    }
  ]
}