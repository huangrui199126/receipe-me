  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Sauce ingredients in a small bowl and mix."
    },
    {
      "order": 2,
      "instruction": "Heat the oil in a pan over high heat. Add garlic and cook for 10 seconds until fragrant."
    },
    {
      "order": 3,
      "instruction": "Add the onion and bell pepper and cook until the onion becomes translucent - about 2 minutes."
    },
    {
      "order": 4,
      "instruction": "If you are using uncooked protein, add it and sauté until just cooked through."
    },
    {
      "order": 5,
      "instruction": "Add the black beans and corn. If you are using cooked proteins (like shredded cooked chicken) add it at the same time. Cook for 1 minute just to heat through."
    },
    {
      "order": 6,
      "instruction": "Add the rice and Sauce and stir quickly to coat the rice evenly."
    },
    {
      "order": 7,
      "instruction": "Check seasoning and add more salt if you require it. Amount of salt required depends on the saltiness of the enchilada sauce you are using."
    },
    {
      "order": 8,
      "instruction": "Season with black pepper and serve immediately."
    }
  ]
