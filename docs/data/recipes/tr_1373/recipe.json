  "steps": [
    {
      "order": 1,
      "instruction": "Marinade chicken - Combine Marinated Chicken ingredients in a bowl and set aside for marinate for 20 minutes. (Skip if in hurry, can also do overnight)"
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan)."
    },
    {
      "order": 3,
      "instruction": "Brown chicken (raw inside) - Heat 1 tablespoon olive oil in a a large oven proof skillet or pot over high heat (Note 3). Cook chicken until lightly browned but still pink inside. Remove from skillet."
    },
    {
      "order": 4,
      "instruction": "Sauté vegetables - Add 1 tbsp olive oil, garlic and onion. Saute for 1 minute, then add zucchini and bell peppers/capsicum. Cook for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add everything else - Add risoni, oregano, chicken broth, tomato, tomato paste, salt and pepper."
    },
    {
      "order": 6,
      "instruction": "Scatter chicken and cherry tomatoes across the surface (don&#39;t stir in)."
    },
    {
      "order": 7,
      "instruction": "Bake 15 minutes - Once the liquid comes to a simmer, transfer to the oven (no lid) and bake for 15 minutes (or until risoni is just cooked, tender but still firm). There may be liquid on the surface still - that&#39;s good!"
    },
    {
      "order": 8,
      "instruction": "Drizzle with lemon - Remove from oven, drizzle with lemon juice. Garnish with feta and fresh oregano leaves, if desired, then serve."
    }
  ]
