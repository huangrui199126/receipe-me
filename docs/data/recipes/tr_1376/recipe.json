  "steps": [
    {
      "order": 1,
      "instruction": "Place eggplant slightly overlapping in a large colander. Sprinkle with some salt. Repeat with remaining eggplant."
    },
    {
      "order": 2,
      "instruction": "Leave to sweat for 30 minutes.&nbsp;Meanwhile, make Meat Sauce and Béchamel Sauce."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 240C/450F.&nbsp;"
    },
    {
      "order": 4,
      "instruction": "Pat eggplant dry - make sure to do this well, otherwise it's too salty.&nbsp;Lay on parchment paper lined trays (you might need 3 trays, work in batches), brush with oil."
    },
    {
      "order": 5,
      "instruction": "Bake 15 - 20 minutes or until lightly browned and softened .&nbsp;Remove and set aside to cool slightly."
    },
    {
      "order": 6,
      "instruction": "Heat olive oil in a large skillet or pot over high heat, then cook the garlic and onion for 2 minutes.&nbsp;"
    },
    {
      "order": 7,
      "instruction": "Add the beef or lamb and cook until it changes from pink to brown, breaking it up as you go."
    },
    {
      "order": 8,
      "instruction": "Add wine, cook for 1.5 minutes or until alcohol smell is gone."
    },
    {
      "order": 9,
      "instruction": "Add remaining ingredients and stir to combine. Bring to a simmer, then lower heat to medium low and cook for 15 minutes, or until reduced to a thick sauce."
    },
    {
      "order": 10,
      "instruction": "Melt butter in a pan over medium heat. Add flour and cook for 1 minute, stirring constantly."
    },
    {
      "order": 11,
      "instruction": "Stirring constantly, slowly add the milk. Then stir regularly for 3 to 5 minutes or until it thickens so that it thickly coats the back of a wooden spoon (see video / step photos)."
    },
    {
      "order": 12,
      "instruction": "Remove from the stove and whisk in cheese, nutmeg, Vegeta/stock powder (or salt) and pepper."
    },
    {
      "order": 13,
      "instruction": "Allow to cool for 5 minutes, then whisk the eggs in. Cover with lid until required."
    },
    {
      "order": 14,
      "instruction": "Lower oven to 180C/350F (all oven types)."
    },
    {
      "order": 15,
      "instruction": "Place half the eggplant in the bottom of a baking dish (I used my 26cm/9\" Lodge skillet), then top with all the Filling."
    },
    {
      "order": 16,
      "instruction": "Top with remaining eggplant, then pour over the Béchamel Sauce, sprinkle with breadcrumbs.&nbsp;"
    },
    {
      "order": 17,
      "instruction": "Bake for 30 - 40 minutes or until golden brown. Allow to stand for 10 minutes before serving."
    }
  ]
}