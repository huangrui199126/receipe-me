  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade ingredients in a large bowl."
    },
    {
      "order": 2,
      "instruction": "Add chicken and coat well. Marinade for 24 hours (3 hours minimum)."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 180C.350F."
    },
    {
      "order": 4,
      "instruction": "Line a tray with foil (trust me), place rack on tray (optional)."
    },
    {
      "order": 5,
      "instruction": "Place chicken on rack (reserve marinade), skin side up. Bake 30 minutes,"
    },
    {
      "order": 6,
      "instruction": "Remove from oven. Brush with marinade - do not flip."
    },
    {
      "order": 7,
      "instruction": "Return to oven for 20 minutes or until golden and a bit crispy. Give it a spray of olive oil just before it's done if you want an extra crispy, shiny coat."
    },
    {
      "order": 8,
      "instruction": "Rest for a few minutes before serving. Juicy and tasty enough to serve plain but extra great with tzatziki or even some plain yogurt."
    }
  ]
