  "steps": [
    {
      "order": 1,
      "instruction": "Place chicken and Marinade into a bowl and set aside to marinate for at least 3 hours to overnight."
    },
    {
      "order": 2,
      "instruction": "Thread chicken onto 8 skewers."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large skillet over high heat (or BBQ). Cook skewers for 3 minutes on each side, or until cooked through."
    },
    {
      "order": 4,
      "instruction": "Serve Chicken Souvlaki with tzatziki, flatbreads (make your own!), lettuce and tomato slices."
    },
    {
      "order": 5,
      "instruction": "Cut the cucumber in half lengthwise. Use a teaspoon to scrape the watery seeds out. Coarsely grate the cucumber using a box grater. Then wrap in paper towels or a tea towel and squeeze to remove excess liquid."
    },
    {
      "order": 6,
      "instruction": "Place cucumber in a bowl. Add remaining ingredients then mix to combine. Set aside for at least 20 minutes for the flavours to meld."
    }
  ]
