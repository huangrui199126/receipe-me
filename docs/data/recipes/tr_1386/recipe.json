  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil over medium heat in large saucepan or small pot."
    },
    {
      "order": 2,
      "instruction": "Add garlic and onion. Cook for 5 minutes or until translucent and sweet."
    },
    {
      "order": 3,
      "instruction": "Add rice and stir until rice turns mostly translucent."
    },
    {
      "order": 4,
      "instruction": "Add broth and water. Place lid on, bring to simmer then turn heat down to low."
    },
    {
      "order": 5,
      "instruction": "Cook for 12 minutes or until water is evaporated."
    },
    {
      "order": 6,
      "instruction": "Remove from from stove and rest for 10 minutes (keep the lid on)."
    },
    {
      "order": 7,
      "instruction": "Remove lid. stir through lemon zest, lemon juice, herbs and salt and pepper to taste."
    },
    {
      "order": 8,
      "instruction": "Lovey served warm or at room temperature."
    }
  ]
