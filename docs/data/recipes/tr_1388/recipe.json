  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Dressing ingredients and mix well (or put in a jar and shake)."
    },
    {
      "order": 2,
      "instruction": "Pour 1/4 cup of the Dressing, dried oregano, and a pinch of salt and pepper onto the lamb steaks and use your hands to coat evenly."
    },
    {
      "order": 3,
      "instruction": "To freeze: Place the lamb and marinade in a ziplock bag, remove as much air as possible and freeze. To cook, defrost completely and bring back to room temperature."
    },
    {
      "order": 4,
      "instruction": "Heat BBQ (grill) or a heavy based pan on the stove over high heat."
    },
    {
      "order": 5,
      "instruction": "Remove lamb from marinade. Place lamb on BBQ (or in the pan) and grill each side for 1 to 1 1/2 minutes, or until cooked to your liking. Remove lamb steaks from the BBQ / pan onto a plate and cover loosely with foil to rest."
    },
    {
      "order": 6,
      "instruction": "Cut cucumber vertically into 8 pieces."
    },
    {
      "order": 7,
      "instruction": "Cut tomatoes into thick slices."
    },
    {
      "order": 8,
      "instruction": "Peel red onion and slice finely."
    },
    {
      "order": 9,
      "instruction": "Toast bread, either in the toaster or on the BBQ/grill. While still warm, rub lightly with the cut side of the garlic. Optional: drizzle with extra olive oil."
    },
    {
      "order": 10,
      "instruction": "Slice lamb into thin slices."
    },
    {
      "order": 11,
      "instruction": "Place 4 slices of cucumber on each plate and top with tomato slices, red onion and olives."
    },
    {
      "order": 12,
      "instruction": "Place lamb on top, sprinkle over the feta, parsley and mint leaves."
    },
    {
      "order": 13,
      "instruction": "Drizzle over Dressing and serve with toasted bread on the side."
    }
  ]
}