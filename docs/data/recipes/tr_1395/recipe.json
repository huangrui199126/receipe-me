      "emoji": "🍞",
      "section": "",
      "order": 1
    },
    {
      "amount": "",
      "unit": "",
      "name": "2  large eggs ((~55g/2oz each in-shell))",
      "emoji": "🥚",
      "section": "",
      "order": 2
    },
    {
      "amount": "3/4",
      "unit": "cup",
      "name": "shredded cheese ((Cheddar, Colby or Tasty cheese are my usual))",
      "emoji": "🧀",
      "section": "",
      "order": 3
    },
    {
      "amount": "",
      "unit": "",
      "name": "2  green onion stems (, finely sliced)",
      "emoji": "🧅",
