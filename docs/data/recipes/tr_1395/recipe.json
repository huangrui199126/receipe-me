      "amount": "2",
      "unit": "cups",
      "name": "(packed) roughly chopped soft cooked broccoli (well drained) ((~400g/14 oz raw broccoli) (Note 1))",
      "emoji": "🥦",
      "section": "",
      "order": 0
    },
    {
      "amount": "1",
      "unit": "cup",
