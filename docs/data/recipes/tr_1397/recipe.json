  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/425°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Toss cauliflower in a large bowl with oil, salt, pepper and garlic if using. (You can do this on the tray, but you'll need more oil). Add parmesan and Panko breadcrumbs at this point, if using."
    },
    {
      "order": 3,
      "instruction": "Spread on tray. Roast 20 minutes. Flip cauliflower, roast a further 5 minutes until you have golden edges and it's soft all the way through."
    },
    {
      "order": 4,
      "instruction": "Serve immediately, sprinkled with parsley if using."
    }
