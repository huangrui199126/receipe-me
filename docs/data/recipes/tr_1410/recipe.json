  "steps": [
    {
      "order": 1,
      "instruction": "Mix ingredients until sugar is dissolved."
    },
    {
      "order": 2,
      "instruction": "Mix the marinade in a bowl, then add beef.&nbsp;Marinate for 30 minutes to overnight."
    },
    {
      "order": 3,
      "instruction": "Heat 2 tsp oil in a large skillet over high heat. Let excess marinade drip off then add beef. Cook for 3 - 4 minutes until cooked and there's some caramelised bits, then remove from skillet."
    },
    {
      "order": 4,
      "instruction": "Keep warm until required or reheat to warm."
    },
    {
      "order": 5,
      "instruction": "Shiitake:&nbsp;Soak mushrooms in a large bowl of boiling water for 30 minutes, or until rehydrated.&nbsp;Drain, squeeze out excess water, then slice."
    },
    {
      "order": 6,
      "instruction": "Carrot and Zucchini salting (optional, Note 10): Place carrot and zucchini in separate bowls, sprinkle each with 1/4 tsp salt, toss, leave for 20 minutes then drain excess liquid."
    },
    {
      "order": 7,
      "instruction": "Get 2 skillets going if you can!"
    },
    {
      "order": 8,
      "instruction": "Shiitake:&nbsp;Heat 2 tsp oil oil in a skillet over medium high heat. Cook mushrooms for 2 minutes.&nbsp;Add 1.5 tsp soy, 1/4 tsp sugar, 1/2 tsp of garlic. Stir for 1 minute, then remove."
    },
    {
      "order": 9,
      "instruction": "Carrot: Add 2 tsp oil into the skillet, cook carrot until just tender (5 to 8 minutes), then remove."
    },
    {
      "order": 10,
      "instruction": "Zucchini: Cook as with carrot for 4 minutes."
    },
    {
      "order": 11,
      "instruction": "Spinach: Heat 2 tsp veg with a splash of sesame oil. Saute until starting to wilt.&nbsp;Add 1/2 tsp garlic, and salt to taste, stir, then remove.&nbsp;When cool, squeeze to drain out excess liquid."
    },
    {
      "order": 12,
      "instruction": "Beansprouts: Simmer in water for 5 min or steam in microwave for 3 min until floppy. Drain under cold water, then cool.&nbsp;Squeeze out excess liquid with hands, place in bowl. Mix with 2 tsp sesame oil, 1 tsp garlic, 1/4 tsp fish sauce.&nbsp;"
    },
    {
      "order": 13,
      "instruction": "Vegetables can cool, they are meant to be at room temp or slightly warm."
    },
    {
      "order": 14,
      "instruction": "Fry eggs in a skillet to your taste (I like mine with runny yolks)."
    },
    {
      "order": 15,
      "instruction": "Place warm rice in bowls."
    },
    {
      "order": 16,
      "instruction": "Top with vegetables and beef, as pictured in post, then lastly, the egg."
    },
    {
      "order": 17,
      "instruction": "Sprinkle with sesame seeds, drizzled with sesame oil.&nbsp;Serve with Bibimbap Sauce!"
    }
  ]
