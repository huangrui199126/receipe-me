  "steps": [
    {
      "order": 1,
      "instruction": "Place the Chipotle Adobo Mayo ingredients in a small food processor and blend until smooth. (Note 3)"
    },
    {
      "order": 2,
      "instruction": "BBQ: Heat the grill side on high. Grill corn for around 8 minutes, or until charred all over and cooked through."
    },
    {
      "order": 3,
      "instruction": "Stovetop: Boil a large pot of water. Add the corn and boil for 10 minutes. Drain and let the corn steam dry in the colander for a few minutes. Heat a skillet with 1 tbsp of olive oil over high heat. Add the corn and cook all over until nicely charred."
    },
    {
      "order": 4,
      "instruction": "Allow the corn to cool slightly."
    },
    {
      "order": 5,
      "instruction": "Place the parmesan in a shallow dish."
    },
    {
      "order": 6,
      "instruction": "Use a pastry brush to generously slather each corn with the Chipotle Adobo Mayo."
    },
    {
      "order": 7,
      "instruction": "Roll the corn in the parmesan."
    },
    {
      "order": 8,
      "instruction": "Sprinkle with a pinch of ancho chili powder, and serve with lime wedges on the side."
    }
  ]
