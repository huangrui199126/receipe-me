  "steps": [
    {
      "order": 1,
      "instruction": "Deseed, shred and squeeze - Cut the cucumber in half lengthwise. Use a teaspoon to scrape the watery seeds out. Coarsely grate the cucumber using a box grater. Then wrap in a tea towel and squeeze to remove excess liquid."
    },
    {
      "order": 2,
      "instruction": "Mix - Place cucumber in a bowl. Add remaining ingredients then mix to combine."
    },
    {
      "order": 3,
      "instruction": "Set aside for at least 20 minutes for the flavours to meld."
    },
    {
      "order": 4,
      "instruction": "Use immediately or keep in an airtight container in the fridge for 3 days."
