  "steps": [
    {
      "order": 1,
      "instruction": "Sauté garlic and onion, then toast Spices for 1 min. Stir in potatoes, then chickpeas, tomato, stock and salt. Simmer 15 min, stir in green onion and parsley, serve!"
    },
    {
      "order": 2,
      "instruction": "Sauté - Heat oil in a large pot or very deep skillet over medium high heat. Add onion and garlic, cook for 3 minutes until onion is translucent."
    },
    {
      "order": 3,
      "instruction": "Add Curry Spices and stir for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Add the potatoes and stir to coat in the Spices. If the spices start to stick to the bottom of the pot, add a tiny splash of water."
    },
    {
      "order": 5,
      "instruction": "Simmer 15 minutes - Add the chickpeas, tomatoes, veg or chicken broth and salt. Bring to simmer then turn down the heat to medium and simmer for 15 minutes, or until the potatoes are cooked and the sauce has thickened."
    },
    {
      "order": 6,
      "instruction": "Adjust salt - Taste and add more salt if needed. Stir through scallions/shallots and parsley."
    },
    {
      "order": 7,
      "instruction": "Serve with rice with a dollop of yogurt and coriander/cilantro if desired. Basmati would be ideal, or Coconut Rice if you&#39;re wanting to impress. To go all out, add some Easy Soft Flatbreads!"
    }
  ]
