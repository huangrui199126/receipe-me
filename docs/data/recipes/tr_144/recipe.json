  "steps": [
    {
      "order": 1,
      "instruction": "Place water and rice in a medium saucepan over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Bring to a simmer so the entire surface is rippling."
    },
    {
      "order": 3,
      "instruction": "Place tight fitting lid on, then reduce heat to medium low so it's simmering gently (or low for strong stoves)."
    },
    {
      "order": 4,
      "instruction": "Cook for 13 minutes - do not stir, do not remove lid."
    },
    {
      "order": 5,
      "instruction": "Water should now be absorbed - QUICKLY tilt pot, lift lid to check."
    },
    {
      "order": 6,
      "instruction": "Put lid back on, remove from stove, leave 10 minutes."
    },
    {
      "order": 7,
      "instruction": "Remove lid, fluff with fork. Serve!"
    }
