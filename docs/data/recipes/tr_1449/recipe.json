  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 200°C / 390°F (180°C fan-forced)."
    },
    {
      "order": 2,
      "instruction": "Toss the bread with the oil and salt. Spread on a tray and bake for 10 minutes, tossing once halfway."
    },
    {
      "order": 3,
      "instruction": "Cool on the tray before using. (These will keep for weeks in an airtight container in the pantry)."
    },
    {
      "order": 4,
      "instruction": "Place all the lettuce leaves in a large bowl."
    },
    {
      "order": 5,
      "instruction": "Add half of each the tomatoes, croutons, chives and eschalots. Drizzle with half the dressing then gently toss with your hands."
    },
    {
      "order": 6,
      "instruction": "Pour into a serving bowl or pile on a platter. Scatter the remaining tomatoes, croutons, chives and eschalots across the top, then drizzle with the remaining dressing. Serve!"
