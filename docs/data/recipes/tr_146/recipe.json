  "ingredients": [
    {
      "amount": "",
      "unit": "",
      "name": "4  thick slices of slightly stale white bread ((1\"/2.5cm thick) (Note 1))",
      "emoji": "🍞",
      "section": "",
      "order": 0
    },
    {
      "amount": "",
      "unit": "",
      "name": "2  large eggs ((or 3 small eggs))",
      "emoji": "🥚",
      "section": "",
      "order": 1
    },
    {
      "amount": "1/4",
      "unit": "cup",
      "name": "milk",
      "emoji": "🥛",
      "section": "",
      "order": 2
    },
    {
      "amount": "",
      "unit": "Pinch",
      "name": "of salt",
      "emoji": "🧂",
      "section": "",
      "order": 3
    },
    {
      "amount": "1/4",
      "unit": "cup",
      "name": "white sugar",
      "emoji": "🍬",
      "section": "",
      "order": 4
    },
    {
      "amount": "1/2",
      "unit": "tsp",
      "name": "cinnamon powder",
      "emoji": "🫙",
      "section": "",
      "order": 5
    },
    {
      "amount": "3",
      "unit": "tbsp",
      "name": "butter (, separated)",
      "emoji": "🧈",
      "section": "",
      "order": 6
    },
    {
      "amount": "",
      "unit": "",
      "name": "Maple syrup to serve ((not optional!))",
      "emoji": "🥄",
      "section": "",
      "order": 7
    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Cut the crust off the bread, then cut each piece into 9 equal cubes."
    },
    {
      "order": 2,
      "instruction": "Whisk the eggs, milk and salt in a medium bowl."
    },
    {
      "order": 3,
      "instruction": "Combine sugar and cinnamon in a shallow bowl."
    },
    {
      "order": 4,
      "instruction": "Melt 1 1/2 tbsp of butter in a fry pan over medium high heat. Don't let the butter brown."
    },
    {
      "order": 5,
      "instruction": "Quickly toss half the bread cubes in the egg mixture and use your hands to shake off excess egg mixture. Place the bread cubes in the fry pan and use a wooden spoon to \"sauté\" them until browned on all sides - about 2 to 3 minutes."
    },
    {
      "order": 6,
      "instruction": "Remove the bread cubes from the fry pan straight into the sugar mixture. Toss to coat, then remove onto a plate."
    },
    {
      "order": 7,
      "instruction": "Repeat with remaining bread cubes."
    },
    {
      "order": 8,
      "instruction": "Serve immediately, with maple syrup for dipping."
    }
  ]
}