  "steps": [
    {
      "order": 1,
      "instruction": "Combine Egg Mixture in a bowl with a flat base large enough to lie the roll up in. Whisk to combine."
    },
    {
      "order": 2,
      "instruction": "Spread sugar out in a small dish."
    },
    {
      "order": 3,
      "instruction": "Use a rolling pin to roll the bread flat. This makes them easier to roll up (and stay rolled up)."
    },
    {
      "order": 4,
      "instruction": "Spread each piece of bread with around 3/4 tbsp of Nutella."
    },
    {
      "order": 5,
      "instruction": "Sprinkle strawberries along the bottom of each piece of bread."
    },
    {
      "order": 6,
      "instruction": "Roll up bread. The Nutella will keep it sealed."
    },
    {
      "order": 7,
      "instruction": "Melt butter in pan over medium high heat."
    },
    {
      "order": 8,
      "instruction": "Roll each roll up in the Egg Mixture, shake off excess then place in the pan. Repeat with remaining roll ups."
    },
    {
      "order": 9,
      "instruction": "Cook for around 4 minutes until each side is golden, rotating every 1 minute or so."
    },
    {
      "order": 10,
      "instruction": "Remove from pan and immediately place in the sugar. Roll to coat in sugar, then remove. Repeat with remaining roll ups."
    },
    {
      "order": 11,
      "instruction": "Serve immediately, while warm."
    }
  ]
}