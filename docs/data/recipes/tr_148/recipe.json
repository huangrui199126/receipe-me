  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Line a baking tray with baking paper (parchment paper)."
    },
    {
      "order": 3,
      "instruction": "Cut the bacon into 1.5cm / 0.6\" pieces (remove rind if it has it)."
    },
    {
      "order": 4,
      "instruction": "Combine with remaining Candied Bacon ingredients in a bowl and use your fingers to coat the bacon."
    },
    {
      "order": 5,
      "instruction": "Combine the Candied Nuts ingredients in a bowl and toss to combine."
    },
    {
      "order": 6,
      "instruction": "Spread the Candied Bacon onto a baking tray and bake for 10 minutes, or until the sugar is bubbling and the bacon is starting to turn brown (i.e. almost cooked)."
    },
    {
      "order": 7,
      "instruction": "Remove the bacon from the tray using a slotted spatula (so you don't get too much bacon fat) and transfer it into the bowl with the nuts. Mix to combine."
    },
    {
      "order": 8,
      "instruction": "Use a spatula to scrape and pour the excess oil off the parchment paper (this is what I did)."
    },
    {
      "order": 9,
      "instruction": "Pour the nuts back onto the baking tray and bake for 15 minutes, stirring once at half time."
    },
    {
      "order": 10,
      "instruction": "Turn the oven off and open the door slightly. Leave for at least 15 minutes, then remove and allow to cool."
    },
    {
      "order": 11,
      "instruction": "Break the candy into chunks. To store, place into an airtight container and keep in the refrigerator. (Note 4)"
    }
  ]
}