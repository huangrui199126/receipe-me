  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 350F/180C."
    },
    {
      "order": 2,
      "instruction": "Spread butter onto each tortilla, like you are buttering toast. Alternatively, melt the butter and brush onto tortillas."
    },
    {
      "order": 3,
      "instruction": "Sprinkle generously with cinnamon sugar."
    },
    {
      "order": 4,
      "instruction": "Stack the tortillas, then cut into strips, or triangles."
    },
    {
      "order": 5,
      "instruction": "Spread in a single layer on a baking tray (3 tortillas should almost perfectly fit)."
    },
    {
      "order": 6,
      "instruction": "Bake for 5 to 8 minutes until golden and crisp."
    },
    {
      "order": 7,
      "instruction": "Eat warm or at room temperature."
