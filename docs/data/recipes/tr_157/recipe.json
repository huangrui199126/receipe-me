  "steps": [
    {
      "order": 1,
      "instruction": "Whizz Dressing ingredients in a food processor or blender. Strain if desired (to remove little strawberry seeds). Keep for up to 2 weeks in the fridge."
    },
    {
      "order": 2,
      "instruction": "Pecans: Line a tray with parchment / baking paper. Melt butter in a medium saucepan over medium heat. Add pecans, toss to coat. Add sugar and stir for 5 minutes. The sugar will melt and coat the pecans. Pour onto tray, spread out, allow to cool - it will harden."
    },
    {
      "order": 3,
      "instruction": "To serve, place the spinach and half the strawberries in a bowl and drizzle over a bit of Dressing. Toss gently, then transfer to a serving bowl. Top with remaining strawberries, then drizzle with more Dressing. Crumble over blue cheese and scatter with pecans. Serve immediately, with remaining Dressing on the side!"
    }
  ]
