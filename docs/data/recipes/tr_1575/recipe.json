  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 400 degrees F."
    },
    {
      "order": 2,
      "instruction": "In a baking dish, toss together the rhubarb, strawberries, honey, vanilla and butter. Roast for 25-30 minutes or until the rhubarb has softened."
    },
    {
      "order": 3,
      "instruction": "In a medium size mixing bowl, combine the flour, baking powder, sugar and salt. Add the eggs, melted butter, [Almond Breeze Almondmilk | http://www.almondbreeze.com/products/almondmilk-unsweetened-vanilla/], apple cider vinegar and vanilla. Stir until just combined, it is OK if the batter is a little lumpy. Gently stir in the blueberries."
    },
    {
      "order": 4,
      "instruction": "Heat a skillet on medium heat. Grease with butter or cooking spray. Pour 1/3 cup pancake batter on the center of the hot pan. Cook until bubbles appear on the surface. Using a spatula, gently flip the pancake over and cook the other side for a minute, or until golden. Repeat with the remaining batter."
    },
    {
      "order": 5,
      "instruction": "To serve, top each pancake with a little whipped cream and a large spoonful of the warm roasted rhubarb/straweberries. Finish with a drizzle of maple syrup. EAT!"
    }
  ]
