  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 375 degrees F."
    },
    {
      "order": 2,
      "instruction": "Add the bread cubes to a baking sheet and drizzle with olive oil. Sprinkle with salt + pepper and toss well to coat, making sure all the bread has been coated in olive oil and seasoned."
    },
    {
      "order": 3,
      "instruction": "Bake for 10 minutes, toss and bake another 5-10 minutes or until the bread is golden and crisp."
    },
    {
      "order": 4,
      "instruction": "Heat an outdoor grill, skillet or grill pan to medium high heat. Drizzle the asparagus with olive oil and sprinkle with salt and pepper. Transfer the asparagus to the grill pan and grill until charred, about 4-5 minutes. Remove from the grill and season lightly with salt and pepper or to taste."
    },
    {
      "order": 5,
      "instruction": "In a large bowl or on a platter, arrange the the tomatoes, avocados, olives and asparagus. Season the tomatoes lightly with salt and pepper. Top with basil. Scatter the mozzarella and toasty bread over top. Finish with a sprinkle of microgreens. Serve with the Vinaigrette (see below)."
    },
    {
      "order": 6,
      "instruction": "Whisk all ingredients together in a bowl. Taste and adjust as needed."
    }
  ]
}