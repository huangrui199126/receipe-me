  "steps": [
    {
      "order": 1,
      "instruction": "Fill a large pot with water and bring to boil."
    },
    {
      "order": 2,
      "instruction": "Cut the woody ends off the asparagus, then cut the asparagus into 3. Separate the asparagus heads from the stems."
    },
    {
      "order": 3,
      "instruction": "Trim the beans and place in a separate pile."
    },
    {
      "order": 4,
      "instruction": "Remove the strings along each side of the snow peas."
    },
    {
      "order": 5,
      "instruction": "Place the beans in the boiling water. When the water comes back to the simmer again, leave the beans to simmer for 30 seconds. (Note 1)"
    },
    {
      "order": 6,
      "instruction": "Add the asparagus stems in. Once it comes back up to a simmer, count 30 seconds again. Then add the snow peas and asparagus heads, bring it back up to a simmer and count to 30 seconds."
    },
    {
      "order": 7,
      "instruction": "Immediately drain the greens and run cold water over the greens for 10 seconds to stop the cooking process."
    },
    {
      "order": 8,
      "instruction": "Once cool, set aside to dry. Roughly dry with a paper towel if serving immediately."
    },
    {
      "order": 9,
      "instruction": "Combine the Dressing ingredients in a jar and shake well to mix."
    },
    {
      "order": 10,
      "instruction": "Place the greens in a bowl and toss with the Dressing."
    },
    {
      "order": 11,
      "instruction": "Transfer to a serving bowl, crumble over feta and scatter with dried cranberries. Serve immediately."
    }
  ]
}