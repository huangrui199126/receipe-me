  "steps": [
    {
      "order": 1,
      "instruction": "In a small bowl, combine the chia seeds and water (or milk); set aside until the mixture forms a gel, about 20 minutes."
    },
    {
      "order": 2,
      "instruction": "Combine the cashews, dates, cinnamon, vanilla, salt, and half of the chia gel in a high-speed blender. Puree until smooth. Transfer the pureed mixture to a medium bowl and stir in the remaining chia gel."
    },
    {
      "order": 3,
      "instruction": "Serve immediately or keep stored in the fridge until ready to eat. Top with granola (recipe below) and fresh berries."
    },
    {
      "order": 4,
      "instruction": "Preheat the oven to 325 degrees F. Line a rimmed baking sheet with parchment paper."
    },
    {
      "order": 5,
      "instruction": "In a large bowl, combine the almonds, coconut, pecans, Brazil nuts (or cashews), sunflower seeds, cinnamon, and salt."
    },
    {
      "order": 6,
      "instruction": "In a small bowl, whisk together the oil, honey, water, and almond extract. Add the wet ingredients to the nut mixture and toss to coat."
    },
    {
      "order": 7,
      "instruction": "Spread the granola on the prepared baking sheet in a single layer and bake for 25-30 minutes, or until golden brown, stirring halfway through. Remove the granola from the oven and stir in the dried apricots and cherries (or cranberries)."
    },
    {
      "order": 8,
      "instruction": "Set aside to cool for 15 minutes before serving. Store in a sealed container in the refrigerator for 3-5 days."
    }
  ]
}