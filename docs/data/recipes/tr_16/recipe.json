  "steps": [
    {
      "order": 1,
      "instruction": "Combine the sugar and strawberries in a bowl and set aside to macerate (it sweats to form a bit of syrup)."
    },
    {
      "order": 2,
      "instruction": "Lightly whisk the eggs, milk and salt in a shallow bowl."
    },
    {
      "order": 3,
      "instruction": "Melt butter in a large fry pan over medium high heat."
    },
    {
      "order": 4,
      "instruction": "Dip each side of the bread slices into the egg, 3 seconds on each side. Place in the pan and fry each side for 2 1/2 minutes, until it is nicely browned."
    },
    {
      "order": 5,
      "instruction": "Remove from the fry pan, and serve, topped with the strawberries (use the syrup created), maple syrup and confectioners sugar (icing sugar), if using."
    }
