  "steps": [
    {
      "order": 1,
      "instruction": "In a large gallon size zip-top bag, combine the tequila, olive oil, soy sauce, ketchup, lime juice, garlic, jalapeno and chipotle pepper + 1 tablespoon of the adobo sauce. Add the chicken and rub the marinade into the chicken, making sure the chicken has been well seasoned. Place in the fridge for 30 minutes or up to 12 hours."
    },
    {
      "order": 2,
      "instruction": "When ready to cook the chicken, heat a large cast iron skillet or grill pan over medium-high heat. Once hot, grill the chicken for 7-8 minutes and then flip and continue cooking for another 7-8 minutes or until the chicken is cooked through. Cooking times will vary depending on the size and thickness of your chicken. Remove from the heat and allow to rest 5 minutes, then slice."
    },
    {
      "order": 3,
      "instruction": "To the hot pan, add the pineapple and sear until both side until lightly golden and caramelized, about 4 minutes per side. Remove from the heat."
    },
    {
      "order": 4,
      "instruction": "In a large salad bowl, toss together the lettuce, watercress, cilantro, cucumber, grapefruit and tomatoes. Add the avocado, pineapple and sliced chicken. Serve with the vinaigrette. EAT!"
    },
    {
      "order": 5,
      "instruction": "Combine all the ingredients except the basil and cilantro to a blender or food processor and blend until smooth. Now add the basil and cilantro, pulse until combined. Season with salt if needed."
    }
  ]
}