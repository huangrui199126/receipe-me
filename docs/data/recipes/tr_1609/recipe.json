  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 425 degrees F."
    },
    {
      "order": 2,
      "instruction": "On a large rimmed baking sheet, combine the potatoes, 2 tablespoons olive oil and salt + pepper. Toss well to evenly coat the potatoes. Place in the oven and roast for 15 minutes."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, combine 2 tablespoons olive oil, the honey, garlic, parsley, thyme, oregano, paprika, cayenne, basil and lemon zest in a bowl."
    },
    {
      "order": 4,
      "instruction": "After 15 minutes, remove the potatoes from the oven. Add the salmon to the center of the pan (if the salmon is large, cut it into smaller portions). Rub the spice mixture onto the salmon, making sure the salmon is well coated (you may not need all of the spice mixture)."
    },
    {
      "order": 5,
      "instruction": "Add the asparagus to the pan and toss with the potatoes. Sprinkle both the asparagus and potatoes with parmesan. Scatter lemon slices all around the pan and on the salmon."
    },
    {
      "order": 6,
      "instruction": "Place in the oven and roast for 10-20 minutes or until the salmon has reached your desired doneness."
    },
    {
      "order": 7,
      "instruction": "To serve, remove the skin from the salmon and cut into 4 pieces. Serve with potatoes + asparagus and the basil chimichurri."
    },
    {
      "order": 8,
      "instruction": "Combine all ingredients in a blender or food processor and pulse until combined and pesto like. Pour into a bowl or glass jar."
    }
  ]
}