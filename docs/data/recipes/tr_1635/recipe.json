  "steps": [
    {
      "order": 1,
      "instruction": "In a bowl, mix together the greek yogurt, dill, parsley, garlic and a pinch of salt + pepper. Stir until combined. Keep stored in the fridge until ready to use."
    },
    {
      "order": 2,
      "instruction": "Heat a skillet with a little olive oil or butter over medium-high heat and fry the eggs to your liking."
    },
    {
      "order": 3,
      "instruction": "Spread the yogurt sauce over a piece of warm/toasted naan. Swirl 1-2 tablespoons of the sun-dried tomato pesto into the yogurt. Next add 1-2 eggs per piece of naan. Sprinkle each piece with lemon zest and fresh spinach. Drizzle the spicy butter sauce (recipe below) over the eggs. Garnish with fresh herbs, sesame seeds and some crumbled goat cheese. EAT!"
    },
    {
      "order": 4,
      "instruction": "In a small saucepan, melt together the butter, coconut oil, crushed red pepper flakes and paprika. Drizzle the warm sauce over the fried eggs."
    }
  ]
