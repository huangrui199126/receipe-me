  "steps": [
    {
      "order": 1,
      "instruction": "Toss broccoli with 2tbsp olive oil, salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Spread on tray and roast in 350F/180C oven for around 10 minutes until slightly softened and starting to brown."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, combine breadcrumbs, parmesan, 1 tbsp olive oil and salt in small bowl."
    },
    {
      "order": 4,
      "instruction": "When broccoli is almost done, take the tray out, move the broccoli to one side to make room to spread out the breadcrumbs on the tray."
    },
    {
      "order": 5,
      "instruction": "Roast broccoli and breadcrumbs for approximately 12 min until the breadcrumbs are golden - don't walk away, the breadcrumbs will cook quickly."
    },
    {
      "order": 6,
      "instruction": "Pile combined broccoli and breadcrumbs into serving bowl."
    }
  ]
