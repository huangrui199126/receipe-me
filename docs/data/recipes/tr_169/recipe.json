  "steps": [
    {
      "order": 1,
      "instruction": "Heat the oil in a very large skillet over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Add carrots and shake the pan so they are (almost all) cut side down. Cook for 5 to 7 minutes without stirring until golden brown."
    },
    {
      "order": 3,
      "instruction": "Add remaining ingredients except parsley. Stir once then allow to cook until the water is evaporated and carrots start to caramelise - about 3 minutes."
    },
    {
      "order": 4,
      "instruction": "Stir once or twice until caramelised, then transfer to serving dish."
    },
    {
      "order": 5,
      "instruction": "Sprinkle with parsley and serve warm"
