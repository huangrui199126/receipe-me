  "steps": [
    {
      "order": 1,
      "instruction": "Heat a fry pan over high heat. Use a fry pan with a lid or use the lid of a larger pot (it doesn't matter if it doesn't fit snugly)."
    },
    {
      "order": 2,
      "instruction": "Place tortilla in fry pan and cook for 30 seconds until charred. Flip and cook the other side for 30 seconds."
    },
    {
      "order": 3,
      "instruction": "Remove from fry pan and place into a bowl or casserole dish to form a bowl shape. As the tortilla cools, it will hold its shape in a bowl form."
    },
    {
      "order": 4,
      "instruction": "Repeat with remaining tortillas."
    },
    {
      "order": 5,
      "instruction": "Heat oil in fry pan over high heat."
    },
    {
      "order": 6,
      "instruction": "Add garlic and onion and sauté for 2 minutes until starting to become translucent."
    },
    {
      "order": 7,
      "instruction": "Add capsicum (bell pepper) and cook for 2 minutes until starting to char."
    },
    {
      "order": 8,
      "instruction": "Add remaining Tomato Filling ingredients, reserving some coriander leave for garnish. Bring to simmer and cook for 1 minute to thicken, then turn heat down to medium."
    },
    {
      "order": 9,
      "instruction": "Use a spoon to make 3 indents in the Tomato Filling."
    },
    {
      "order": 10,
      "instruction": "Crack eggs into indents."
    },
    {
      "order": 11,
      "instruction": "Cover with lid and cook for 3 minutes or to your liking. Check it at 2 minutes, then take a quick peek every 30 seconds thereafter. It can go from under to overcooked in a flash! Note that the eggs will continue to cook slightly after taking it off the heat."
    },
    {
      "order": 12,
      "instruction": "Remove fry pan from heat."
    },
    {
      "order": 13,
      "instruction": "Divide Tomato Filling between each Tortilla Bowl, topped with an egg."
    },
    {
      "order": 14,
      "instruction": "Top with remaining coriander leaves and garnish of choice. Serve immediately."
    }
  ]
}