  "steps": [
    {
      "order": 1,
      "instruction": "Add the strawberries, basil and thyme to a glass jar. In a bowl whisk together white balsamic, honey and vanilla bean seeds. Pour over the strawberries. Seal the jar and place in the fridge until cold. Should last about 3-4 days in the fridge."
    },
    {
      "order": 2,
      "instruction": "Preheat the oven to 400 degrees F."
    },
    {
      "order": 3,
      "instruction": "Add the cherry tomatoes, olive oil, 2 tablespoons fresh chopped herbs, 2 cloves minced garlic and a generous sprinkle of salt and pepper to a baking dish. Toss well, making sure the tomatoes are coated in olive oil, herbs, garlic, salt and pepper. Roast for 10-15 minutes or until the tomatoes collapse. Remove and toss with the remaining herbs,"
    },
    {
      "order": 4,
      "instruction": "Allow to cool slightly and then transfer to a serving bowl. Can be made 1 day in advance."
    },
    {
      "order": 5,
      "instruction": "Grab a really big cheeseplate/board. Assemble the cheeses on the board. Arrange all your desired serving items (fruits, spread, nuts, olives, bread + crackers) around the cheese."
    },
    {
      "order": 6,
      "instruction": "Drizzle the blue cheese with honey."
    },
    {
      "order": 7,
      "instruction": "Drizzle the burrata cheese with olive oil and garnish with a spring of rosemary."
    },
    {
      "order": 8,
      "instruction": "Top the grilled brie with pickled strawberries."
    },
    {
      "order": 9,
      "instruction": "Makes sure to serve with toasted bread and or crackers"
    }
  ]
}