  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Place bread crusts in bowl. Drizzle over olive oil, tossing the bread crusts as you go (with your other hand) so as to distribute the olive oil as evenly as possible."
    },
    {
      "order": 3,
      "instruction": "Add remaining ingredients and use hands to toss through the bread crusts."
    },
    {
      "order": 4,
      "instruction": "Spread out over 2 baking trays. Do a taste test to make sure it is seasoned to your liking - adjust if required."
    },
    {
      "order": 5,
      "instruction": "Bake for 5 to 8 minutes until golden brown and crunchy (check the ones in the middle of the tray). The tray on the top shelf will be ready first. The bottom tray will take a couple of minutes longer."
    }
  ]
