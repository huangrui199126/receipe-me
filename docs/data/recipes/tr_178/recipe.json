  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/430F with shelf placed on the highest level. Spray baking tray with oil."
    },
    {
      "order": 2,
      "instruction": "Mix sesame paste and soy sauce in a bowl (to loosen it up, easier to coat chicken). Add chicken, salt and sesame seeds."
    },
    {
      "order": 3,
      "instruction": "Place flour in a separate bowl and coat chicken in flour, shaking off excess. Place chicken on baking tray."
    },
    {
      "order": 4,
      "instruction": "Bake for 12 minutes. Remove from oven."
    },
    {
      "order": 5,
      "instruction": "Flick to broiler/grill as high as it will go with shelf about 15cm/6\" from the heat source."
    },
    {
      "order": 6,
      "instruction": "Turn chicken. Broiler/grill for 5 minutes until golden and quite crispy (Note 4), then remove."
    },
    {
      "order": 7,
      "instruction": "Meanwhile, mix together Sauce in one bowl and Cornstarch in another."
    },
    {
      "order": 8,
      "instruction": "Heat oil in a wok or skillet (I used a skillet) over medium heat. Add garlic and cook for 30 seconds until fragrant but not browned."
    },
    {
      "order": 9,
      "instruction": "Add Sauce and bring to bubble. Add Cornstarch and cook for 30 seconds until it thickens into a thick syrup."
    },
    {
      "order": 10,
      "instruction": "Remove the Sauce immediately from the stove and pour over the chicken."
    },
    {
      "order": 11,
      "instruction": "Toss chicken in Sauce then sprinkle over Sesame Seeds and Shallots/Scallions to serve. Serve with rice."
    }
  ]
}