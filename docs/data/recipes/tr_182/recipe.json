  "steps": [
    {
      "order": 1,
      "instruction": "Avocado Dressing: Place the ingredients in a small food processor and whizz until smooth. Use MILK to adjust consistency, and adjust salt to taste. (Note 1)"
    },
    {
      "order": 2,
      "instruction": "Spice Rub: Combine ingredients and scatter on a plate."
    },
    {
      "order": 3,
      "instruction": "Chicken: Slice into 4 - 5 thin steaks on the diagonal, then coat both sides with Spice Rub."
    },
    {
      "order": 4,
      "instruction": "Cook Chicken: Heat oil in a large skillet over high heat. Add chicken and cook both sides until dark brown. Remove onto a plate and cover loosely with foil. Rest for 5 minutes then slice thickly."
    },
    {
      "order": 5,
      "instruction": "Pile the Salad ingredients onto a serving platter then place the chicken on the side."
    },
    {
      "order": 6,
      "instruction": "Serve with Avocado Dressing."
    }
  ]
