  "steps": [
    {
      "order": 1,
      "instruction": "Combine Beef with Marinade and marinade at least overnight, up to 24 hours."
    },
    {
      "order": 2,
      "instruction": "Remove beef from marinade. Preheat outdoor grill or heavy based skillet on stove on very high heat. You want it to be screaming hot. Cook the beef to your liking (see notes for guide)."
    },
    {
      "order": 3,
      "instruction": "When done, remove from heat, cover loosely with foil and let them rest for 5 to 10 minutes."
    },
    {
      "order": 4,
      "instruction": "Make the Ginger Spring Onion Sauce by combining the ingredients and mixing to combine."
    },
    {
      "order": 5,
      "instruction": "Make the Ssam Sauce by combining the ingredients and mixing well until smooth."
    },
    {
      "order": 6,
      "instruction": "Slice the beef into 0.5cm / 0.2 inch thick slices, against the grain."
    },
    {
      "order": 7,
      "instruction": "Serve with lettuce, Ginger Spring Onion Sauce and Ssam Sauce on the side."
    },
    {
      "order": 8,
      "instruction": "To eat, place a piece of beef in a lettuce leaf, top with some of each sauce, then fold over lettuce, eat and be happy."
    }
  ]
