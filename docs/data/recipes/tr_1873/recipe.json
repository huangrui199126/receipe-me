  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 350 degrees F. Line two baking sheets with parchment paper."
    },
    {
      "order": 2,
      "instruction": "Combine the flour, baking soda and salt in a small bowl. Beat the butter, granulated sugar, brown sugar and vanilla extract in large mixer bowl until creamy, about 3 to 5 minutes. Add the egg + egg yolk and beat well. Beat in the peanut butter and honey."
    },
    {
      "order": 3,
      "instruction": "Gradually beat in the flour mixture. Stir in the chocolate chunks and Reese's Pieces."
    },
    {
      "order": 4,
      "instruction": "Roll the dough into scant tablespoon size balls. Stack two balls together and place them two inches apart on the prepared baking sheet."
    },
    {
      "order": 5,
      "instruction": "Bake for 10-12 minutes, but no longer. Over baking them is never good! Allow to cool three minutes then eat warm or move to a cooling rack to cool completely."
    }
  ]
