  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 375 degrees F."
    },
    {
      "order": 2,
      "instruction": "In a 12 inch cast iron skillet or 9x13 inch baking dish toss together the strawberries, blueberries and blackberries. Add the Kahlua, vanilla extract, brown sugar (1/4 cup) and lemon zest. Toss well to combine."
    },
    {
      "order": 3,
      "instruction": "In a medium size bowl add the oats, flour, brown sugar (1/2 cup), baking soda, cinnamon and salt. Add the softened butter and use your fingers to crumble it into the oats mixture until everything is moist and the butter is evenly distributed. Sprinkle the crisp over the berries. Bake for 25-30 minutes, until crisp is golden brown and the fruit is bubbling up and smells amazing."
    },
    {
      "order": 4,
      "instruction": "Serve immediately with a large scoop of ice cream and a drizzle of the sauce that settles in the skillet. DEVOUR!"
    }
  ]
