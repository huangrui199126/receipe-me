  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a medium saucepan over medium high heat. Add about 1/3 of the onions and cook for 5 minutes until golden and crispy. Drain on paper towels."
    },
    {
      "order": 2,
      "instruction": "Repeat with remaining onions, in two batches."
    },
    {
      "order": 3,
      "instruction": "Put the olive oil, cumin seeds and coriander in a saucepan over medium heat."
    },
    {
      "order": 4,
      "instruction": "Cook for a couple of minutes until the spices are fragrant."
    },
    {
      "order": 5,
      "instruction": "Add the rice and stir to coat with the oil and spices."
    },
    {
      "order": 6,
      "instruction": "Add the water and lentils."
    },
    {
      "order": 7,
      "instruction": "While it comes to boil, add all the other spices, salt and pepper."
    },
    {
      "order": 8,
      "instruction": "When it comes to a boil, turn it down to medium-low, cover with lid and let cook for 10 to 12 minutes, or until all the liquid has mostly been absorbed."
    },
    {
      "order": 9,
      "instruction": "Remove from heat and let it rest for 10 minutes - during this time, any residual liquid will absorb."
    },
    {
      "order": 10,
      "instruction": "Fluff rice with a fork and adjust the seasoning with more salt if you wish."
    },
    {
      "order": 11,
      "instruction": "Just prior to serving, stir through most of the onions and top with remainder. Sprinkle with chopped coriander if desired. Best served warm."
    }
  ]
}