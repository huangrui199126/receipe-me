  "steps": [
    {
      "order": 1,
      "instruction": "In a bowl, combine cornflour with a splash of water, mix to combine, then add remaining Sauce ingredients and mix well."
    },
    {
      "order": 2,
      "instruction": "Cut the tofu into 1/2 \"/ 1 cm cubes."
    },
    {
      "order": 3,
      "instruction": "Heat oil in wok over high heat."
    },
    {
      "order": 4,
      "instruction": "Add garlic and ginger and stir fry for 10 seconds."
    },
    {
      "order": 5,
      "instruction": "Add scallions/shallots and stir fry for 30 seconds."
    },
    {
      "order": 6,
      "instruction": "Add mince and stir fry until the outside is brown, breaking up clumps."
    },
    {
      "order": 7,
      "instruction": "Add Chili Bean Sauce and stir fry for 30 seconds."
    },
    {
      "order": 8,
      "instruction": "Add tofu and sauce, and gently stir to cook the sauce until it becomes thick and saucy (about 1 to 2 minutes)."
    },
    {
      "order": 9,
      "instruction": "Serve with rice."
    }
  ]
}