  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 375 degrees F. Lightly grease a baking sheet, set aside."
    },
    {
      "order": 2,
      "instruction": "In a medium bowl, stir together the cream cheese, shredded cheddar cheese, buffalo sauce and pepper. Stir in the chicken."
    },
    {
      "order": 3,
      "instruction": "In a separate bowl, toss together the potato chip crumbs, corn flake crumbs and half of the bacon."
    },
    {
      "order": 4,
      "instruction": "Spoon the filling into each jalapeño cavity. Then top each jalapeño with a spoonful of the potato chips and bacon topping. Place on prepared baking sheet, filling side up. Bake until the filling is melty and the potato chips are golden, about 15-20 minutes."
    },
    {
      "order": 5,
      "instruction": "Remove from oven, and sprinkle with bacon, blue cheese, green onions and drizzle with more buffalo sauce if desired. Serve immediately."
    }
  ]
