  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Garlic Shrimp ingredients in a small bowl and set aside for 10 minutes."
    },
    {
      "order": 2,
      "instruction": "Combine the Dressing ingredients in a small jar, give it a shake then set aside for 10 minutes."
    },
    {
      "order": 3,
      "instruction": "Heat a skillet / fry pan over high heat. Add the shrimp, scraping in the olive oil and garlic from the sides of the bowl. Cook for 2 minutes, or until browned and the shrimp is just cooked through. (Note 2)"
    },
    {
      "order": 4,
      "instruction": "Remove the prawns from the skillet onto a plate."
    },
    {
      "order": 5,
      "instruction": "Prepare the vermicelli noodles according to the packet directions. I like to just soak them in hot tap water for a few minutes, this ensures they don't overcook. Then drain the noodles."
    },
    {
      "order": 6,
      "instruction": "Arrange the noodles and remaining Salad ingredients on a large plate (like the photo) or toss together in a bowl. Top with prawns (warm or at room temperature). Drizzle over the Dressing (or toss through), or you can serve the Dressing on the side."
    },
    {
      "order": 7,
      "instruction": "Serve immediately."
    }
  ]
}