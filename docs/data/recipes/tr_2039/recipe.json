  "steps": [
    {
      "order": 1,
      "instruction": "Slice the Chinese roast pork (char siu) into thin slices."
    },
    {
      "order": 2,
      "instruction": "Mixed the fresh mashed garlic (you can also use a garlic press) with the olive oil and salt."
    },
    {
      "order": 3,
      "instruction": "Cut the Italian roll in half. If the roll is very thick, you may want to remove some of the soft bread inside. Spread the garlic and olive oil mixture evenly on one side of the bread and lightly toast it."
    },
    {
      "order": 4,
      "instruction": "Spread 2 teaspoons butter (if using) on the other side of the bread and repeat with the other roll. You can use the garlic and oil spread on both sides if you do not want to use butter."
    },
    {
      "order": 5,
      "instruction": "Lay the sliced pork on the sandwich, close it, cut on a diagonal, and plate with a Kosher dill pickle, Chinese hot mustard, and duck sauce on the side."
    }
  ]
