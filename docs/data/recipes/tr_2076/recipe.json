  "steps": [
    {
      "order": 1,
      "instruction": "Heat 1 tablespoon oil in a wok over high heat. Add the pork belly and sear, not stirring. Once browned and caramelized on one side, stir-fry until the pork belly is opaque. Remove from the wok and set aside."
    },
    {
      "order": 2,
      "instruction": "Lower the heat to medium, and add an additional 2 tablespoons of oil to the wok. Add the ginger. Let the ginger infuse the oil for 1 minute. Add the garlic, and cook for another 30 seconds."
    },
    {
      "order": 3,
      "instruction": "Turn the heat back up to high, and add the onions, jalapenos, red chilies, and the white parts of the scallions. Cook for another minute, and then add the rice cakes and Shaoxing wine. Mix well, scooping up from the bottom of the wok for 30 seconds. Turn the heat down to medium low, and cover for one minute."
    },
    {
      "order": 4,
      "instruction": "Remove cover, and add the pork belly back to the wok, along with the soy sauce, sugar, Sichuan peppercorn powder, and spicy bean paste. Stir-fry until the rice cakes are cooked through but still chewy. Stir in the green parts of the scallions until wilted, and serve."
    }
  ]
