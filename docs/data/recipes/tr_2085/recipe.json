  "steps": [
    {
      "order": 1,
      "instruction": "Make the wonton filling by combining the cream cheese, sugar, salt, and scallions."
    },
    {
      "order": 2,
      "instruction": "Assemble the wontons. Take each wrapper, and dampen the outer edges with a thin layer of water. Place a teaspoon of the cream cheese filling in the middle, and fold in half into a triangle. Bring the two corners on the long side of the triangle together, and seal with another dab of water. Continue until all the wontons are assembled."
    },
    {
      "order": 3,
      "instruction": "Heat a couple inches of vegetable oil in a small pot until it reaches 375 degrees F. Fry the wontons in batches––about 2 minutes per batch––until golden brown. Definitely use a small pot for this and fry in multiple batches; you’ll use much less oil!"
    },
    {
      "order": 4,
      "instruction": "Make the dipping sauce by combining all the sauce ingredients, and serve with the wontons."
    }
  ]
