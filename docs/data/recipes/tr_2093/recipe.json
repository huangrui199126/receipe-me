  "steps": [
    {
      "order": 1,
      "instruction": "Mix the soy sauces, sesame oil, sugar, wine and white pepper in a small bowl and set aside."
    },
    {
      "order": 2,
      "instruction": "Boil the noodles for about 2 minutes, or until al-dente. Drain, toss with oil to keep the noodles from clumping up, and set aside."
    },
    {
      "order": 3,
      "instruction": "Heat a wok over medium heat. Add the bacon, and fry until it’s dark and crisp. Turn up the heat to high, and add the julienned scallions. Stir-fry until they’re just beginning to wilt."
    },
    {
      "order": 4,
      "instruction": "Add the noodles back to the wok and toss them well, loosening them with tongs or a pair of chopsticks. Add the soy sauce mixture and toss continuously for a couple minutes, until the noodles are uniformly golden brown. Serve!"
    }
  ]
