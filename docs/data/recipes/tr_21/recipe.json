  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Spice Mix in a bowl."
    },
    {
      "order": 2,
      "instruction": "Place 1 tbsp of Spice Mix in a ziplock bag with the chicken and buttermilk. Set aside to marinate for at least 2 hours, preferably 3 but ideally overnight."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 400F/200C."
    },
    {
      "order": 4,
      "instruction": "Place the butter and oil on a large rimmed baking tray. Place in the oven for a few minutes until the butter is just melted. Remove and tip the tray to spread the oil and butter all over."
    },
    {
      "order": 5,
      "instruction": "Combine the remaining Spice Mix, flour, panko and cornmeal in a bowl and mix. Place half in a large ziplock bag."
    },
    {
      "order": 6,
      "instruction": "Drain the chicken of excess marinade using a colander."
    },
    {
      "order": 7,
      "instruction": "Transfer half the chicken into the ziplock bag, seal in air so it is puffed like a balloon, then shake to coat the chicken in the seasoning. Press through the bag so the coating is firmly stuck onto the chicken. Place the chicken onto the baking tray."
    },
    {
      "order": 8,
      "instruction": "Place the remaining coating into the ziplock bag and repeat with remaining chicken."
    },
    {
      "order": 9,
      "instruction": "Spray the top with oil and place in the oven. Bake for 12 minutes, then turn, spray and bake for a further 8 to 10 minutes or until golden. Don't bake more than 25 minutes, otherwise the chicken will dry out!"
    },
    {
      "order": 10,
      "instruction": "Serve with your favourite dipping sauce. I used Honey Mustard Sauce (Note 7)."
    }
  ]
}