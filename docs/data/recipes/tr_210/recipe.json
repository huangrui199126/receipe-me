  "steps": [
    {
      "order": 1,
      "instruction": "Preheat broiler/griller on high. Place the oven shelf 6\"/15cm from the heat source."
    },
    {
      "order": 2,
      "instruction": "Spray a baking tray with oil (I use olive oil, any is fine)."
    },
    {
      "order": 3,
      "instruction": "Pile asparagus, broccolini and cherry tomatoes on the baking tray. Drizzle with olive oil and sprinkle with salt and pepper. Toss with hands then spread out on the tray, mostly on one layer."
    },
    {
      "order": 4,
      "instruction": "Wedge salmon pieces on the tray between the vegetables. Sprinkle with salt and pepper."
    },
    {
      "order": 5,
      "instruction": "Mix Glaze ingredients together. Slather on the salmon - tops and sides."
    },
    {
      "order": 6,
      "instruction": "Grill/broil for 8 minutes - don't flip. The salmon should be caramelised and the inside should be blushing pink."
    },
    {
      "order": 7,
      "instruction": "Rest for 2 minutes then serve with crusty bread rolls."
    }
  ]
