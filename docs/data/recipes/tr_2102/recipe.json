  "steps": [
    {
      "order": 1,
      "instruction": "Wash the vegetables and dry off any excess water. Julienne the vegetables, and toss everything in a large mixing bowl, along with the tofu."
    },
    {
      "order": 2,
      "instruction": "In a small bowl, combine the olive oil, minced garlic, sugar, white pepper, light soy sauce, black vinegar, sesame oil, and toasted sesame seeds. Mix everything together until the sugar is completely dissolved."
    },
    {
      "order": 3,
      "instruction": "Add the sauce mixture to the vegetables and tofu, and top with chopped cilantro. Toss and serve either cold or at room temperature."
    }
  ]
