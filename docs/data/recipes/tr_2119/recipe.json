  "steps": [
    {
      "order": 1,
      "instruction": "Heat a wok or skillet over high heat just until smoking. Add the oil, followed by the pork belly, and stir-fry for 1 minute (or until slightly caramelized)."
    },
    {
      "order": 2,
      "instruction": "Add the onion, kimchi, and sugar, and cook for an additional 3 minutes. Add the gochujang and cook for another minute."
    },
    {
      "order": 3,
