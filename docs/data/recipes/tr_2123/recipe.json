  "steps": [
    {
      "order": 1,
      "instruction": "Pat the tofu dry with a paper towel, and cut into 1-inch cubes. Add the ¼ cup of cornstarch to a shallow bowl, and dredge the tofu pieces until they all have a light coating of cornstarch. You’ll see the cornstarch getting absorbed by the moisture of the tofu––this is normal."
    },
    {
      "order": 2,
      "instruction": "Heat the vegetable oil in a cast iron or nonstick pan over medium heat. Add the tofu pieces to the pan, and fry on all sides until golden. Remove the tofu from the pan and set aside."
    },
    {
      "order": 3,
      "instruction": "Add the ginger to the pan, and cook for 1 minute until fragrant. Add the onions and stir-fry for 2-3 minutes. Then add the mirin, soy sauce, dark soy sauce, brown sugar, and sesame oil."
    },
    {
      "order": 4,
      "instruction": "Bring the mixture to a simmer. Meanwhile, dissolve the remaining two teaspoons of cornstarch in 1/2 cup warm water. Add to the sauce and onions, along with the cooked tofu. Toss everything together for 1 minute, until the sauce has thickened and the tofu is coated in the sauce. Stir in the scallions."
    },
    {
      "order": 5,
      "instruction": "Serve over steamed rice with some toasted sesame seeds if desired."
    }
  ]
}