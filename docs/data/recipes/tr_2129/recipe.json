  "steps": [
    {
      "order": 1,
      "instruction": "In a small bowl, combine the pork, cornstarch, oil, wine, oyster sauce, and salt. Set aside to marinate while preparing the other ingredients."
    },
    {
      "order": 2,
      "instruction": "Bring a pot of water to a boil for the noodles, and cook according to package instructions. Drain and distribute between two bowls."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, in another pot, bring the chicken stock to a boil and keep warm on the stove. Taste for seasoning and season with salt to taste if desired."
    },
    {
      "order": 4,
      "instruction": "Heat your wok over high heat until smoking. Add a tablespoon of oil, and stir-fry the pork until browned. Add the Zha Cai and sugar, and stir-fry for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Ladle hot broth over the noodles, and top with the pork and Zha Cai mixture. Garnish with a drizzle of sesame oil and scallions. Serve."
    }
  ]
