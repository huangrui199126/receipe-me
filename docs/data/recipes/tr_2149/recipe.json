  "steps": [
    {
      "order": 1,
      "instruction": "Bring a pot of water to a boil for the noodles. Meanwhile, heat the wok over high heat, and and add a tablespoon or two of oil. Add the ground meat, and stir-fry until browned and slightly crispy."
    },
    {
      "order": 2,
      "instruction": "Add the onion and garlic, and continue to cook over high heat until the onions are slightly softened and browned at the edges. Stir in the spinach until it’s just wilted. Season with salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, cook the noodles according to the package directions. Add to a bowl, along with the soy sauce, dark soy sauce, sesame oil, honey, and chili oil (if using). Toss with the onion, meat, and spinach mixture. Serve!"
    }
