  "steps": [
    {
      "order": 1,
      "instruction": "Heat the oil a wok or skillet over medium high heat. Add the onion and garlic and cook for 5 minutes, stirring often. Add the chicken and stir-fry for 2 minutes, or until browned. Add the sui mi ya cai and chili (if using) and stir-fry for another 2 minutes."
    },
    {
      "order": 2,
      "instruction": "Stir in the soy sauces, hoisin sauce, Shaoxing wine, sesame oil, and rice wine vinegar. Add the water and cornstarch mixture, and simmer for another 2-3 minutes. Serve in the lettuce leaves garnished with scallions and cilantro."
    }
  ]
