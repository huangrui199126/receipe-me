  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Heat olive oil in a medium size, deep fry pan over medium high heat. (Note 3)"
    },
    {
      "order": 3,
      "instruction": "Add garlic and onion, sauté until onion is translucent - about 3 minutes."
    },
    {
      "order": 4,
      "instruction": "Turn up heat to high. Add beef and cook, breaking it up with the spatula, until nicely browned."
    },
    {
      "order": 5,
      "instruction": "Add HALF the bottle of tomato passata (reserve remainder for Sauce). Then add remaining Filling ingredients. Bring to rapid simmer, then turn down to medium high. Let it simmer for around 5 minutes to let the flavours come together and the liquid to reduce. Stir occasionally."
    },
    {
      "order": 6,
      "instruction": "Add Sauce Flavourings into the tomato passata bottle and shake to combine."
    },
    {
      "order": 7,
      "instruction": "Remove fry pan from the stove. Slide one lasagna sheet, starting from the side, under the Filling - this will be the base of the lasagna. Use a spoon to push it down and cover it in Filling. Break up pieces of lasagne and slide them in under the filling around the sides of the pan (to form the remainder of the bottom layer), using a spoon to push them down and cover with Filling."
    },
    {
      "order": 8,
      "instruction": "Cover the Filling with the remaining lasagna sheets."
    },
    {
      "order": 9,
      "instruction": "Pour over the Sauce and spread over the top. Sprinkle with cheese."
    },
    {
      "order": 10,
      "instruction": "Cover with a lid or foil and bake for 20 minutes. Remove cover and bake for a further 10 minutes until the cheese is melted and bubbly and golden. Remove from oven and set aside for 10 minutes to set."
    },
    {
      "order": 11,
      "instruction": "Sprinkle with parsley (if using), then serve."
    }
  ]
}