  "steps": [
    {
      "order": 1,
      "instruction": "Heat your wok over high heat until just starting to smoke, and add the green beans and salt. Immediately lower the heat to medium low, and sear the green beans for about 20 minutes, stirring occasionally. You want to see small scorch marks on the green beans. During this process, gather the rest of the ingredients and have them ready. Once the beans are somewhat tender, take them out of the wok and set aside."
    },
    {
      "order": 2,
      "instruction": "Heat the oil in your wok over medium high heat and brown the pork. Add the garlic and chili, and stir for 30 seconds. Add the sui mi ya cai, and stir everything together. Cook for another minute."
    },
    {
      "order": 3,
      "instruction": "Toss in the seared green beans, cooking wine, soy sauce, sugar, and sesame oil. Crank the heat back up to high and stir-fry for a final minute. Serve immediately."
    }
  ]
