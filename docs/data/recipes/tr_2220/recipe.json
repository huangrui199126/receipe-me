  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 375 degrees F, and spread the potatoes on a parchment-lined baking sheet. Toss with salt to taste, white pepper, and five-spice powder. Drizzle with olive oil and roast for about 30 minutes, or until fork tender."
    },
    {
      "order": 2,
      "instruction": "Once the potatoes are done roasting, heat a couple tablespoons of oil in a wok over medium low heat. Add the garlic, chili, and black beans. Cook for a couple minutes, and be careful not to burn the ingredients."
    },
    {
      "order": 3,
      "instruction": "Add the wine, soy sauces, sesame oil, and water. Stir everything together and add the roasted potatoes and leeks. Turn up the heat to high and stir-fry for another 2 minutes. Serve immediately."
    }
  ]
