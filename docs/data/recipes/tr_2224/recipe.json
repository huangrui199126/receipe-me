  "steps": [
    {
      "order": 1,
      "instruction": "Open the package of tofu and place on a plate to drain for 10 minutes. Slice it into ¾-inch thick pieces. Use a mortar and pestle to roughly crush the cumin seeds and add the Sichuan peppercorn powder if using, chili powder, garlic powder, and salt. Mix well."
    },
    {
      "order": 2,
      "instruction": "Combine 1 teaspoon oil, hoisin, and soy sauce in small bowl. Heat two tablespoons of oil in a cast iron skillet or nonstick pan over high heat and carefully place the tofu in the pan."
    },
    {
      "order": 3,
      "instruction": "Next, sprinkle about half of the dried spices evenly over the tofu and let cook for 3-5 minutes. When the bottom is golden brown, flip the tofu. Brush the tofu with about half of the sauce and sprinkle over the rest of the spices. Cook for 3 minutes and flip the tofu over again."
    },
    {
      "order": 4,
      "instruction": "Brush the other side with the remaining sauce, sprinkle with scallion and cilantro, and serve."
    }
  ]
}