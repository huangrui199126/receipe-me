  "steps": [
    {
      "order": 1,
      "instruction": "Wash and julienne the tofu and vegetables."
    },
    {
      "order": 2,
      "instruction": "Heat 2 teaspoons oil in the wok over high heat. Stir-fry the tofu for about 3 minutes until slightly crisp. Remove from pan and set aside."
    },
    {
      "order": 3,
      "instruction": "Add 2 more teaspoons oil and cook the celery and king oyster mushrooms for 2 minutes. Add the rest of the vegetables and a pinch of sugar. Cook for 2 minutes, stirring constantly."
    },
    {
      "order": 4,
      "instruction": "Add the tofu back to the pan along with the shaoxing wine, salt, five spice powder, white pepper, and soy sauce."
    },
    {
      "order": 5,
      "instruction": "Cook another 3 to 5 minutes and serve."
    }
  ]
