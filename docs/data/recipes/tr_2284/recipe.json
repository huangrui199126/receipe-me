  "steps": [
    {
      "order": 1,
      "instruction": "Put everything in a medium pot with the lid on and bring it to bring to a boil slowly, over medium heat. Once the water boils, turn off the fire and let the eggs sit for about 30 minutes, till the water cools off. Take the eggs out one at a time, and carefully crack the shells all over, but leave the shell on. This creates the marbling effect on the finished eggs."
    },
    {
      "order": 2,
      "instruction": "Put the eggs back in the pot and put the whole shebang into the refrigerator overnight. This allows the eggs to really absorb the flavor of the spices, tea, and soy."
    },
    {
      "order": 3,
      "instruction": "Tip: These are great if you cut them in half and lay them in a bowl of noodle soup."
    }
  ]
