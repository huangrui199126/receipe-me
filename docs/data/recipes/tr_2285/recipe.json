  "steps": [
    {
      "order": 1,
      "instruction": "Get a large pot of boiling water on the stove. Add the piece of pork to the water and cook for about ten minutes. This gets some of the blood and fat off the meat. Take the meat out and pat it dry with paper towel."
    },
    {
      "order": 2,
      "instruction": "Mix all your spices together and rub the pork all over with the spice mixture. Put it in the refrigerator to marinate for 1 hour."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 375 degrees, roast the pork until tender (about 45 minutes – 1 hour)."
    },
    {
      "order": 4,
      "instruction": "Allow to rest for 10 minutes before serving."
    }
  ]
