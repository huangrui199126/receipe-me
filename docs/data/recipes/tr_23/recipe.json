  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Place chicken on a plate or in a large bowl. Sprinkle with Chicken Spices and use your hands to coat the chicken."
    },
    {
      "order": 3,
      "instruction": "Heat olive oil in a large, oven proof fry pan over high heat."
    },
    {
      "order": 4,
      "instruction": "Add chicken, skin side down, and sear until the skin is nicely browned. Turn chicken over and cook the other side until browned. Remove chicken from pan. Drain pan of excess oil."
    },
    {
      "order": 5,
      "instruction": "Add onion, garlic, ginger and chili into the pan. Saute for 2 minutes until the onion is translucent and starting to brown."
    },
    {
      "order": 6,
      "instruction": "Add canned tomato, chicken stock/broth, saffron powder, cumin powder and thyme. Bring to simmer, then turn the stove off. Nestle the chicken into the tomato broth, then cover with foil (or lid) and place into the oven. Bake for 25 to 35 minutes."
    },
    {
      "order": 7,
      "instruction": "Meanwhile, cook the Giant Couscous according to packet instructions. Usually it just needs to be boiled in salted water for around 4 minutes, then drain it."
    },
    {
      "order": 8,
      "instruction": "When the chicken is dark golden brown and cooked, remove from oven. Stir through dried currents (if using), lemon juice and half the mint and coriander. Then sprinkle over remaining mint and coriander."
    },
    {
      "order": 9,
      "instruction": "Serve on Giant Couscous with a dollop of yoghurt, if using."
    }
  ]
}