  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F. Toast hazelnuts for 5 minutes or until golden brown. Cool then roughly chop. Set aside."
    },
    {
      "order": 2,
      "instruction": "Either place the bacon on the baking tray used for the hazelnuts and bake until golden, or cook in a skillet. Drain on paper towels."
    },
    {
      "order": 3,
      "instruction": "Cut apple into matchsticks, keeping the skin on. Toss in lemon juice."
    },
    {
      "order": 4,
      "instruction": "Shave brussels sprouts finely using a slicer or food processor."
    },
    {
      "order": 5,
      "instruction": "Place Dressing ingredients in a jar and shake well. Adjust salt and pepper to taste."
    },
    {
      "order": 6,
      "instruction": "Place Salad ingredients in a bowl, toss with Dressing. Set aside for 5 minutes before serving (to soften the brussels sprouts slightly)."
    }
  ]
