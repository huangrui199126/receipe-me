  "steps": [
    {
      "order": 1,
      "instruction": "Cook the noodles al dente and reserve some of the cooking liquid. Rinse the noodles with cold water and drain."
    },
    {
      "order": 2,
      "instruction": "Stir together all the sauce ingredients in a small bowl until combined. Julienne the scallion, carrot, and cucumber."
    },
    {
      "order": 3,
      "instruction": "Blanch bean sprouts in boiling water for 15 seconds and put into an ice bath and drain."
    },
    {
      "order": 4,
      "instruction": "In a bowl, pour the sauce over the noodles. Add the vegetables, chopped cilantro, crushed peanuts and toasted sesame seeds on top and serve immediately, along with extra toppings like chili sauce, rice vinegar, or soy sauce."
    }
  ]
