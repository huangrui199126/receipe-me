  "steps": [
    {
      "order": 1,
      "instruction": "Cut your Japanese or Chinese eggplants into 3-inch pieces and then cut them into quarters lengthwise. Arrange on a heatproof plate for steaming."
    },
    {
      "order": 2,
      "instruction": "Prepare your wok or large covered pot pan for steaming (or use a metal steamer or dedicated steaming kitchen gadget, if you have one)."
    },
    {
      "order": 3,
      "instruction": "Steam the eggplant for 10 minutes, or until soft. You can serve the eggplant on the same plate, or transfer it to a serving plate. If transferring your steamed eggplant to a serving plate, be sure to include any liquid from the steamed eggplant."
    },
    {
      "order": 4,
      "instruction": "Heat the canola and sesame oil in a wok or saucepan over medium high heat and add the fresh ginger and sesame seeds."
    },
    {
      "order": 5,
      "instruction": "After 15-20 seconds, stir in the hot chili oil, sesame paste, soy sauce, salt, and sugar until well combined."
    },
    {
      "order": 6,
      "instruction": "Once the sauce begins to simmer, turn off the heat and stir in the finely chopped peppers, garlic, half of the scallions, and the black beans. Add the Thai chili only if you like your food super spicy, because it will already be on the spicy side."
    },
    {
      "order": 7,
      "instruction": "Pour the sauce over the eggplant and top with the rest of the scallions."
    }
  ]
}