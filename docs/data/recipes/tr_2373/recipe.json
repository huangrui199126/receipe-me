  "steps": [
    {
      "order": 1,
      "instruction": "Clean the oxtails and pat them dry. Heat oil in a large skillet over medium high heat and brown them on all sides."
    },
    {
      "order": 2,
      "instruction": "Remove the oxtails and set aside on a plate. To the pot, add the ginger, garlic, star anise, cloves, and bay leaves. Cook for about 2 minutes."
    },
    {
      "order": 3,
      "instruction": "Now it’s time to add cooking wine, dark soy sauce, light soy sauce, rock sugar, water, and salt (careful with the salt, as the soy sauce is already quite salty)."
    },
    {
      "order": 4,
      "instruction": "Add the oxtails back to the pot, and bring to a boil. Once boiling, cover and reduce the heat to low. Simmer for 2 to 3 hours, depending on how tender you like your oxtails. Check halfway through and add more water if needed."
    },
    {
      "order": 5,
      "instruction": "Uncover, and continue simmering for another 30 minutes until the meat is tender and most of the liquid has evaporated. Stir occasionally, and add additional water if necessary to avoid sticking. Serve!"
    }
  ]
