  "steps": [
    {
      "order": 1,
      "instruction": "In a small bowl, combine the pork, salt, cornstarch, sesame oil, shaoxing wine, and white pepper. Set aside to marinate while preparing other ingredients."
    },
    {
      "order": 2,
      "instruction": "Bring a pot of water to a boil for your noodles, and cook the noodles according to package directions. Drain. In another medium pot, add your chicken stock and bring to a boil. Keep warm on the stove."
    },
    {
      "order": 3,
      "instruction": "Heat a tablespoon of oil in your wok over high heat and brown the pork. Add the chilies and the pickled vegetables. Stir-fry for a couple minutes, making sure the heat is still high. Add the sugar, give everything a final stir, and turn off the heat."
    },
    {
      "order": 4,
      "instruction": "Lay the noodles in your serving bowls and ladle in the hot broth. Top with your pork and vegetable mixture, and top each bowl with a few drops of sesame oil and chopped scallion."
    },
    {
      "order": 5,
      "instruction": "Commence slurping!"
    }
  ]
