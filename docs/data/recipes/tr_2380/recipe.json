  "steps": [
    {
      "order": 1,
      "instruction": "Combine all ingredients from the soy sauce to the wine in a shallow dish. Marinate the pork chops in this mixture for 20 minutes to an hour."
    },
    {
      "order": 2,
      "instruction": "Heat 2 tablespoons of vegetable oil in a large skillet. Sear the pork chops on both sides until cooked through (you can discard any leftover marinade). It should take 5 minutes per side for 1-inch thick pork chops, as long as they were at room temperature when you started cooking them."
    },
    {
      "order": 3,
      "instruction": "Allow to cool for 5 minutes. Enjoy!"
    }
