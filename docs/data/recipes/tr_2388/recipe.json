  "steps": [
    {
      "order": 1,
      "instruction": "Cut the daikon into half-inch thick, bite-sized pieces. In a pot, add 1 slice ginger, 1 cup water or stock (235ml), 1 tablespoon oyster sauce (16 g), ½ teaspoon salt (2 g), ¼ teaspoon sugar (1 g), ¼ teaspoon ground white pepper (a large pinch), and stir to combine. Add the daikon."
    },
    {
      "order": 2,
      "instruction": "Cover and bring everything to a boil, then reduce the heat to medium. Cook for 20 minutes until the daikon is fork tender, stirring occasionally."
    },
    {
      "order": 3,
      "instruction": "Right before serving, add in the chopped scallion, and a few drops of sesame oil (optional). Mix well and serve!"
    }
  ]
