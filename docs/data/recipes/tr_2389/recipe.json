  "steps": [
    {
      "order": 1,
      "instruction": "Heat the oil in a wok over medium heat. Add the ginger and garlic, and cook for for 20 seconds."
    },
    {
      "order": 2,
      "instruction": "Add the carrot, and stir-fry for 30 seconds––the oil should turn an orange color. Add in the daikon, turn up the heat to high, and stir-fry for another 30 seconds."
    },
    {
      "order": 3,
      "instruction": "Add the Shaoxing wine (if using), oyster sauce, white pepper, sesame oil, salt, water, and the white parts of the scallions. Stir to combine, cover, and turn down the heat to medium. Simmer for 5-8 minutes until tender."
    },
    {
      "order": 4,
      "instruction": "Uncover, add in the rest of the scallions, and mix everything well. When the daikon is translucent and tender, the dish is done."
    }
  ]
