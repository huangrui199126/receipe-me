  "steps": [
    {
      "order": 1,
      "instruction": "Beat the cream cheese, confectioners’ sugar, vanilla and lemon zest until light and fluffy."
    },
    {
      "order": 2,
      "instruction": "Fold in the whipped cream. Then cover and refrigerate for at least 2 hours, or until required (will keep for 3 days)."
    },
    {
      "order": 3,
      "instruction": "Puree half the strawberries."
    },
    {
      "order": 4,
      "instruction": "Quarter the remaining berries (if large, otherwise halve)."
    },
    {
      "order": 5,
      "instruction": "Combine the sugar and water in a pan and stir over low heat to dissolve the sugar, then turn up the heat to medium high and cook for 4 to 5 minutes without stirring until a golden caramel forms."
    },
    {
      "order": 6,
      "instruction": "Remove from heat, stir in puree carefully (it may spit) then return to low heat and stir until smooth."
    },
    {
      "order": 7,
      "instruction": "Let cool, then add reserved berries. Refrigerate until required."
    },
    {
      "order": 8,
      "instruction": "Combine the crushed crackers, brown sugar and butter in a bowl and mix well."
    },
    {
      "order": 9,
      "instruction": "In a clear glass, place some graham cracker crumble in the base."
    },
    {
      "order": 10,
      "instruction": "Spoon over cheesecake mousse and top with strawberry caramel."
    }
  ]
}