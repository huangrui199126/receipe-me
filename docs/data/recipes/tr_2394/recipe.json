  "steps": [
    {
      "order": 1,
      "instruction": "Tear the bamboo shoots into small strips with your hands."
    },
    {
      "order": 2,
      "instruction": "Add the garlic and Sichuan chili flakes to a small bowl. Heat the oil and pour over the garlic and flakes—they should sizzle and immediately smell fragrant."
    },
    {
