  "steps": [
    {
      "order": 1,
      "instruction": "Combine the chicken with 1 teaspoon cornstarch, 1 teaspoon oil, and 1 teaspoon soy sauce."
    },
    {
      "order": 2,
      "instruction": "Heat a wok over high heat until it&#39;s lightly smoking. Add 1 tablespoon of oil, and stir-fry the chicken until it just turns opaque. Remove from the wok and set aside."
    },
    {
      "order": 3,
      "instruction": "Add 2 more tablespoons of oil to the wok, and add the ginger slices. Fry for 1 minute, and add the scallions and red chili. Stir-fry until the scallions begin to wilt, about 10 seconds."
    },
    {
      "order": 4,
      "instruction": "Add the noodles, and stir-fry, adding a sprinkling of hot water if the noodles are stuck together."
    },
    {
      "order": 5,
      "instruction": "When the noodles have loosened and warmed up, add the Shaoxing wine, 1 1/2 tablespoons light soy sauce, dark soy sauce, and cooked chicken. Stir-fry until combined, about 1-2 minutes. Serve!"
    }
  ]
