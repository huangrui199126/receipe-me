  "steps": [
    {
      "order": 1,
      "instruction": "Put the garlic and Thai chili in a small heatproof bowl. Heat the oil in a medium skillet over medium-high heat until shimmering. Pour the hot oil over the garlic and chili—it will sizzle. Then add the oyster sauce, light soy sauce, dark soy sauce, and sugar."
    },
    {
      "order": 2,
      "instruction": "Put the pan back over the heat, and add half the enoki mushrooms to the pan in 1 layer, followed by the chives, and then the rest of the mushrooms. Pour the sauce mixture over the mushrooms."
    },
    {
      "order": 3,
      "instruction": "Bring to a simmer, cover, and simmer for 1-2 minutes, just until the mushrooms and chives are wilted. Serve immediately."
    }
  ]
