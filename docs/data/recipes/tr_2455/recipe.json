  "steps": [
    {
      "order": 1,
      "instruction": "Cook the noodles according to package instructions until al dente or 1 minute past al dente stage. Pull the noodles out of the pot and into a colander. Rinse the noodles under cold water, and reserve some of the cooking liquid."
    },
    {
      "order": 2,
      "instruction": "Meanwhile, in a serving bowl, add the light soy sauce, Shanghai rice vinegar, chili oil, sugar, Sichuan peppercorn powder, sesame oil, dark soy sauce, salt, MSG (if using), and garlic."
    },
    {
      "order": 3,
      "instruction": "Add the noodles, noodle cooking water, scallion, and cucumber. Toss everything together and serve. If the noodles look dry, add a bit more of the cooking water."
    }
  ]
