  "ingredients": [
    {
      "amount": "2",
      "unit": "sheets",
      "name": "puff pastry (, 25cm/10\" square)",
      "emoji": "🥄",
      "section": "",
      "order": 0
    },
    {
      "amount": "",
      "unit": "",
      "name": "4 - 5 tbsp Dijon mustard",
      "emoji": "🥄",
      "section": "",
      "order": 1
    },
    {
      "amount": "",
      "unit": "",
      "name": "8 oz/250g   shaved ham",
      "emoji": "🥓",
      "section": "",
      "order": 2
    },
    {
      "amount": "2",
      "unit": "cups",
      "name": "shredded cheddar cheese ((or any other melting cheese) (Note 1))",
      "emoji": "🧀",
      "section": "",
      "order": 3
    },
    {
      "amount": "",
      "unit": "",
      "name": "2  egg yolks ((or 1 egg - Note 2))",
      "emoji": "🥚",
      "section": "",
      "order": 4
    },
    {
      "amount": "",
      "unit": "",
      "name": "Oil spray",
      "emoji": "🫙",
      "section": "",
      "order": 5
    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/425°F (180°C fan-forced). Spray 2 baking trays lightly with oil or line with baking paper (parchment paper)."
    },
    {
      "order": 2,
      "instruction": "Puff pastry - Let the puff pastry partially defrost then cut into 9 x 8cm/3.5&quot; squares."
    },
    {
      "order": 3,
      "instruction": "Spread about 1/2 tsp of mustard diagonally across each square."
    },
    {
      "order": 4,
      "instruction": "Top with ham and sprinkle with cheese."
    },
    {
      "order": 5,
      "instruction": "Wrap - Dab one corner with egg yolk using a brush. Fold the opposite corner over the filling first, then fold the corner with the egg yolk over it and press down to bond. Place on baking tray then repeating with remaining squares."
    },
    {
      "order": 6,
      "instruction": "Bake - Brush the top with egg. Bake for 15 minutes or until deep golden brown and puffed."
    },
    {
      "order": 7,
      "instruction": "Serve warm!"
    }
  ]
}