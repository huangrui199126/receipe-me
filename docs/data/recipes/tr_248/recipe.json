  "steps": [
    {
      "order": 1,
      "instruction": "Freeze tuna for 20 minutes - just to firm. Slice into 3mm / 1/8\" strips, then cut those strips into 3mm / 1/8\" cubes. Place in a bowl."
    },
    {
      "order": 2,
      "instruction": "Peel the lychees, then finely dice the flesh and add into the bowl (Note 4). Scrape the juices that pool on the cutting board into the bowl too - don't waste a drop!"
    },
    {
      "order": 3,
      "instruction": "Add the chili, onion and coriander, olive oil and lime juice into the bowl. Season with a generous pinch of salt and a good grind of pepper."
    },
    {
      "order": 4,
      "instruction": "Use your fingers to toss together gently. Taste and adjust olive oil, lime and salt to taste."
    },
    {
      "order": 5,
      "instruction": "Pile on a platter, top with avocado and garnish with coriander/cilantro leaves. Drizzle with more olive oil. Serve immediately (Note 5), with toasted bread and extra lime wedges."
    }
  ]
