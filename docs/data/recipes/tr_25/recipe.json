  "steps": [
    {
      "order": 1,
      "instruction": "Combine all ingredients in a slow cooker. Set for 6 to 8 hours on low."
    },
    {
      "order": 2,
      "instruction": "Optional step: Remove bay leaves, then use a handheld blender to puree until smooth (or to your liking)."
    },
    {
      "order": 3,
      "instruction": "Cool before refrigerating or freezing."
    },
    {
      "order": 4,
      "instruction": "Bring a large pot of salted water to boil and add pasta."
    },
    {
      "order": 5,
      "instruction": "Heat olive oil in a pan, add garlic and diced onion, cook until translucent then add 2 cups of Marinara Sauce per 500g/1lb of dried pasta."
    },
    {
      "order": 6,
      "instruction": "Bring sauce to rapid simmer, then add pasta (cooked to just before al dente)."
    },
    {
      "order": 7,
      "instruction": "Add 1/4 cup of pasta water and cook for 1 to 2 minutes until pasta is al dente and the sauce has thickened and coats the pasta."
    },
    {
      "order": 8,
      "instruction": "Serves 4 hungry people or 6 normal servings."
    }
  ]
