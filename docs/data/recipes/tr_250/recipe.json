  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan forced)."
    },
    {
      "order": 2,
      "instruction": "Spray a 20cm/8\" square tin with oil and line with baking/parchment paper with overhang (Note 2)."
    },
    {
      "order": 3,
      "instruction": "Place butter and chocolate chips in a heatproof bowl, microwave in 30 second bursts (takes me 1m 30 sec) until melted. Stir until smooth."
    },
    {
      "order": 4,
      "instruction": "Add sugar and vanilla, mix, then add eggs and mix well until smooth and molten."
    },
    {
      "order": 5,
      "instruction": "Add flour, cocoa and salt and stir until smooth. Stir in chopped chocolate, pour into pan."
    },
    {
      "order": 6,
      "instruction": "Bake 24 minutes for really gooey in the centre, 28 minutes for fudgey but still very moist (my favourie, shown in video &amp; photos), 32 minutes for moist fudge-cake-like. (See in post for toothpick testphotos)."
    },
    {
      "order": 7,
      "instruction": "If you didn&#039;t use the extra chocolate for stirring in, reduce cook time by 2 minutes."
    },
    {
      "order": 8,
      "instruction": "Rest for 10 minutes before lifting out of the pan. Allow to cool for at least 20 minutes before cutting. Store in an airtight container for 4 days (bet they don&#x27;t last that long!) or freeze for 3 months."
    }
  ]
