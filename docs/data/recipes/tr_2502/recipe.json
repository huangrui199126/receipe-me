  "steps": [
    {
      "order": 1,
      "instruction": "In a small bowl, mix the sugar and hot water until the sugar is dissolved. Add the apricot preserves."
    },
    {
      "order": 2,
      "instruction": "Remove pit from the pickled plum and add to the bowl. The plum is very soft and should fall apart. Then add ½ teaspoon liquid from the pickled plum jar, soy sauce and rice vinegar."
    },
    {
      "order": 3,
      "instruction": "Mix everything together with a fork until the duck sauce is well-combined. Let the sauce sit for 5 minutes and mix again."
    }
