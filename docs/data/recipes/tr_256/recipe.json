  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/425°F (200°C fan-forced)."
    },
    {
      "order": 2,
      "instruction": "Separate the pita bread into 2 thin sheets. Cut into 3cm / 1.2&quot; squares."
    },
    {
      "order": 3,
      "instruction": "Pile on a tray, drizzle with olive oil, toss, then sprinkle with the salt and toss again."
    },
    {
      "order": 4,
      "instruction": "Spread on the tray. Bake for 5 minutes or until crispy, then cool on the tray before use."
    },
    {
      "order": 5,
      "instruction": "Dressing - Shake the dressing ingredients in a jar until well combined."
    },
    {
      "order": 6,
      "instruction": "Salad - Place the Salad ingredients in a large bowl. Drizzle over half the dressing, toss. Add most of the crispy pita chips, drizzle with remaining dressing and toss again."
    },
    {
      "order": 7,
      "instruction": "Serve - Transfer into a serving bowl, top with remaining crispy pita and serve immediately."
    }
  ]
