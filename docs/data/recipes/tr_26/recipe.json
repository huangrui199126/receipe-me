  "steps": [
    {
      "order": 1,
      "instruction": "Combine stock ingredients in a large pot and bring to boil."
    },
    {
      "order": 2,
      "instruction": "Meanwhile, mix the Stock Sauce ingredients together in a small bowl and cut all the vegetables into bite size pieces."
    },
    {
      "order": 3,
      "instruction": "Add the Stock Sauce and mix well to dissolve into the soup. Adjust seasoning as required."
    },
    {
      "order": 4,
      "instruction": "When the stock comes to a boil, place rice stick noodles in the stock, then 1 minute later add the carrots and broccoli, then 1 minute later remove from heat and add the bok choy stems."
    },
    {
      "order": 5,
      "instruction": "Divide the noodles and vegetables between bowls, top with the bok choy leaves and bean sprouts."
    },
    {
      "order": 6,
      "instruction": "Ladle soup into bowls over the vegetables and noodles, and garnish with spring onions."
    },
    {
      "order": 7,
      "instruction": "Optional: finish with chilli oil and more chilli paste - if you can handle the heat!"
    }
  ]
