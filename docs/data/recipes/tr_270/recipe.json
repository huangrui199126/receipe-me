  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil - Heat about 1 1/2 tbsp oil in a wok or 2 tbsp oil in a skillet over high heat until smoking."
    },
    {
      "order": 2,
      "instruction": "Add onion, garlic and bacon. Cook until bacon is light golden - about 1 1/2 minutes."
    },
    {
      "order": 3,
      "instruction": "Add vegetables (still frozen is fine). Cook for 2 minutes so they defrost and water evaporates."
    },
    {
      "order": 4,
      "instruction": "Add rice and Sauce ingredients. Cook for 1 1/2 minutes until liquid evaporates."
    },
    {
      "order": 5,
      "instruction": "Scramble egg - Shove rice to the side of the wok / skillet. Add 1/2 tbsp oil into the cleared space, shift wok so the heat is centred over the cleared space. Pour in egg then scramble - cook it through properly, don&#39;t &quot;soft scramble&quot;."
    },
    {
      "order": 6,
      "instruction": "Serve - Add green onion then stir the egg into the rice. Remove from heat and serve immediately!"
    }
  ]
