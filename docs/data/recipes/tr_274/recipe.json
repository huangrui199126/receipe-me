  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Rub ingredients and rub onto both sides of the ribs (most on meaty side). Set aside to marinate for 20 minutes (or overnight)."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 160°C/320°F (all oven types)."
    },
    {
      "order": 3,
      "instruction": "Place ribs on a tray in a single layer. Pour apple cider underneath the ribs, cover with foil then bake for 1 hour 30 minutes or until the meat is pretty tender (Note 5)."
    },
    {
      "order": 4,
      "instruction": "Remove from oven, turn up to 180°C/350°F. Remove foil, drizzle with olive oil, then return ribs to oven for 15 minutes or until rub becomes nice and crusty."
    },
    {
      "order": 5,
      "instruction": "Line a new tray with foil then baking / parchment paper (you&#x27;ll thank me later)."
    },
    {
      "order": 6,
      "instruction": "Remove ribs from oven, transfer to lined tray. Pour any juices from tray over the ribs."
    },
    {
      "order": 7,
      "instruction": "Flip ribs so the bonier side is up. Slather with Barbecue Sauce, then bake 10 minutes."
    },
    {
      "order": 8,
      "instruction": "Remove from oven, then turn ribs over so the meaty side is up. Slather with Barbecue Sauce, bake 5 minutes. Repeat 2 or 3 more times until you&#x27;ve got a thick glaze on the ribs."
    },
    {
      "order": 9,
      "instruction": "Cut ribs into individual or multiple rib portions and serve with remaining Barbcue Sauce!"
    },
    {
      "order": 10,
      "instruction": "Place all ingredients in a saucepan and simmer over medium heat, stirring occasionally, for 45 minutes or until thickened."
    },
    {
      "order": 11,
      "instruction": "Adjust to taste: sweetness with brown sugar / honey, salt and sour with vinegar. Use for glazing ribs and as a sauce for serving."
    }
  ]
}