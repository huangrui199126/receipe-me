  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F."
    },
    {
      "order": 2,
      "instruction": "Scatter onion and garlic in a baking dish (about 10 x 15\" / 25 x 35 cm), then place butter in the centre. Bake for 15 minutes (check at 12 minutes, mix if some bits are browning too much)."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, mix together Chicken Rub. Sprinkle on both sides of the chicken."
    },
    {
      "order": 4,
      "instruction": "Remove baking dish from the oven. Add rice then mix."
    },
    {
      "order": 5,
      "instruction": "Place chicken on rice. Then pour chicken broth and water around the chicken."
    },
    {
      "order": 6,
      "instruction": "Cover with foil, then bake for 30 minutes. Remove foil, spray chicken with oil (optional, gives chicken nicer finish), then bake for a further 20 minutes until liquid is absorbed."
    },
    {
      "order": 7,
      "instruction": "Stand for 5 minutes, then remove chicken and fluff up rice. Garnish with parsley or thyme if desired, serve and enjoy!"
    },
    {
      "order": 8,
      "instruction": "Dish is flavoured enough to serve without sauce, but if you want to take it over the top, make this quick Gravy in 4 minutes flat (pictured in video)."
    }
  ]
