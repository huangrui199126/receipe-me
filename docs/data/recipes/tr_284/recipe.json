  "steps": [
    {
      "order": 1,
      "instruction": "If cooking on a BBQ or over charcoal, soak skewers for 2 hours in water."
    },
    {
      "order": 2,
      "instruction": "Mix together the chicken and Marinade with 1/4 cup of coconut milk, then set aside for at least 20 minutes, or overnight."
    },
    {
      "order": 3,
      "instruction": "Thread onto skewers - I do 4 to 5 pieces each."
    },
    {
      "order": 4,
      "instruction": "Heat 1.5 tbsp oil in a large non stick pan over medium high heat."
    },
    {
      "order": 5,
      "instruction": "Cook skewers in batches for 3 minutes on each side until golden."
    },
    {
      "order": 6,
      "instruction": "Place remaining coconut milk and Peanut Sauce ingredients in a saucepan over medium low heat."
    },
    {
      "order": 7,
      "instruction": "Stir to combine then simmer, stirring every now and then, for 5 minutes."
    },
    {
      "order": 8,
      "instruction": "Adjust consistency with water - it should be a pourable but thickish sauce."
    },
    {
      "order": 9,
      "instruction": "Cover with lid and keep warm while cooking skewers."
    },
    {
      "order": 10,
      "instruction": "Pour some sauce into a bowl. Sprinkle with some peanuts - stir some through if you want."
    },
    {
      "order": 11,
      "instruction": "Pile satay skewers onto a platter, sprinkle with remaining peanuts, coriander and chilli."
    },
    {
      "order": 12,
      "instruction": "Serve with sauce on the side for dipping. Add a side of Jasmine Rice or Thai Fried Rice to complete the meal!"
    }
  ]
}