  "steps": [
    {
      "order": 1,
      "instruction": "Mix together cornflour and soy sauce, then mix in remaining ingredients.&nbsp;"
    },
    {
      "order": 2,
      "instruction": "Alternative:&nbsp;Use 1/3 cup Chinese All Purpose Stir Fry Sauce, if you have some in stock."
    },
    {
      "order": 3,
      "instruction": "Marinate Chicken: Pour 1 tbsp of Sauce over the chicken, mix to coat, set aside to marinate for 10 minutes."
    },
    {
      "order": 4,
      "instruction": "Noodles: Prepare the noodles according to the packet instructions (my pack says soak in boiled water for 1 minute), then drain."
    },
    {
      "order": 5,
      "instruction": "Heat oil in wok or large fry pan over high heat."
    },
    {
      "order": 6,
      "instruction": "Add garlic and stir fry for 10 seconds or until it starts to turn golden - don't let it burn!"
    },
    {
      "order": 7,
      "instruction": "Add chicken and stir fry until the surface gets a tinge of browning but inside is still raw - about 1 minute.&nbsp;"
    },
    {
      "order": 8,
      "instruction": "Add the cabbage, carrot, and the white pieces of shallots (i.e. from the base of the stalk). Stir fry for 1 1/2 minutes until the cabbage is mostly wilted."
    },
    {
      "order": 9,
      "instruction": "Add the noodles, Sauce and water*. Stir fry for 1 minute, tossing constantly.&nbsp;"
    },
    {
      "order": 10,
      "instruction": "Add bean sprouts and remaining shallots/scallions. Toss through for 30 seconds or until the bean sprouts just start to wilt."
    },
    {
      "order": 11,
      "instruction": "Remove from heat and serve immediately."
    }
  ]
}