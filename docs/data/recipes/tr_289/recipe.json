  "steps": [
    {
      "order": 1,
      "instruction": "Heat a heavy based skillet over high heat (no oil) until smoking."
    },
    {
      "order": 2,
      "instruction": "Place onion and ginger in pan cut side down. Cook for a few minutes until it's charred, then turn. Remove and set aside."
    },
    {
      "order": 3,
      "instruction": "Toast Spices lightly in a dry skillet over medium high heat for 3 minutes.&nbsp;"
    },
    {
      "order": 4,
      "instruction": "Rinse bones &amp; brisket then cover with water in large stock pot."
    },
    {
      "order": 5,
      "instruction": "Boil for 5 minutes, then drain."
    },
    {
      "order": 6,
      "instruction": "Rinse each bone and brisket under tap water."
    },
    {
      "order": 7,
      "instruction": "Wipe pot clean, bring 3.5 litres / 3.75 quarts water to boil."
    },
    {
      "order": 8,
      "instruction": "Add bones and brisket, onion, ginger, Spices"
    },
    {
      "order": 9,
      "instruction": "Add onion, ginger, Spices, sugar and salt - water should just barely cover everything."
    },
    {
      "order": 10,
      "instruction": "Cover with lid, simmer 3 hours."
    },
    {
      "order": 11,
      "instruction": "Remove brisket (should be fall-apart tender), cool then refrigerate for later."
    },
    {
      "order": 12,
      "instruction": "Simmer remaining soup UNCOVERED for 40 minutes."
    },
    {
      "order": 13,
      "instruction": "Strain broth into another pot, discard bones and spices. Should be about 2.5 litres / 2.65 quarts (10 cups), if loads more, reduce."
    },
    {
      "order": 14,
      "instruction": "Add fish sauce, adjust salt and sugar if needed. Broth should be beefy, fragrant with spices, savoury and barely sweet."
    },
    {
      "order": 15,
      "instruction": "Prepare rice noodles per packet, just prior to serving."
    },
    {
      "order": 16,
      "instruction": "Place noodles in bowl. Top with raw beef and brisket."
    },
    {
      "order": 17,
      "instruction": "Ladle over about 400 / 14 oz hot broth - will cook beef to medium rare."
    },
    {
      "order": 18,
      "instruction": "Serve with Toppings on the side!"
    }
  ]
}