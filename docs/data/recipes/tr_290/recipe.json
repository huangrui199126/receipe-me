  "steps": [
    {
      "order": 1,
      "instruction": "Sauté - Heat the oil on high heat in a large heavy-based pot. Cook garlic and onion for 1 1/2 minutes."
    },
    {
      "order": 2,
      "instruction": "Cook beef &amp; seasonings - Add beef and cook, breaking it up as you go, until you can no longer see red meat. Add the Italian herbs and cook for 30 seconds, then add tomato paste and cook for 1 minute to cook out the raw flavour."
    },
    {
      "order": 3,
      "instruction": "All in - Add crushed tomato, chicken stock, salt, pepper and red pepper flakes, if using. Stir, then add the pasta."
    },
    {
      "order": 4,
      "instruction": "Cook 15 min - Bring the liquid to a simmer, then cook for 15 minutes, stirring every couple of minutes then more frequently towards the end (ensure pasta doesn&#39;t stick to base) until the pasta is just about cooked."
    },
    {
      "order": 5,
      "instruction": "Creamy - Add cream, then simmer for a further 1 to 2 minutes. It will still be quite saucy - this is what you want! Pasta absorbs liquid quickly, so it will still be nice and oozy when you start eating."
    },
    {
      "order": 6,
      "instruction": "Serve - Remove from the stove. Give it a good stir then ladle into bowls. Serve with parmesan and parsley."
    }
  ]
