  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a non stick fry pan over medium high heat. Sauté garlic, onion &amp; celery for 2 minutes, then add bacon."
    },
    {
      "order": 2,
      "instruction": "Cook for a further 2 minutes (don&#x27;t make bacon golden) then transfer to bowl and allow to cool for 10 minutes."
    },
    {
      "order": 3,
      "instruction": "Add remaining Filling ingredients into the bowl. Use your hands to mix well."
    },
    {
      "order": 4,
      "instruction": "Lay out a rectangle of pastry, long edge closest to you. Brush egg along one long edge."
    },
    {
      "order": 5,
      "instruction": "Get 1/5 th of the filling and shape into a long log shape down the middle of the pastry. Ensure the meat is tight and compact, without gaps."
    },
    {
      "order": 6,
      "instruction": "Brush edge of pastry with egg. Then roll up, finishing with the seam side down.Roll up, sealing on the edge with egg wash on it ."
    },
    {
      "order": 7,
      "instruction": "If you have time/patience, refrigerate for 1 hour (makes it easier/neater to cut)"
    },
    {
      "order": 8,
      "instruction": "Preheat oven to 350F/180C."
    },
    {
      "order": 9,
      "instruction": "Cut each log into four equal lengths, or just two if you want full size sausage rolls. Brush with egg."
    },
    {
      "order": 10,
      "instruction": "Place on 2 baking trays lined with baking paper (or sprayed with oil). Bake for 30 - 35 minutes in total, swapping tray shelves at 20 minutes, or until the pastry is deep golden brown. (Note: The filling will still look pink because of the bacon, but it&#x27;s easy to tell from texture that it&#x27;s cooked)"
    },
    {
      "order": 11,
      "instruction": "Cool slightly on trays. Serve hot or warm with tomato sauce or ketchup!"
    }
  ]
}