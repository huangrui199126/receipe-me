  "steps": [
    {
      "order": 1,
      "instruction": "Heat 1 tbsp oil until very hot in a large, heavy based pot over high heat."
    },
    {
      "order": 2,
      "instruction": "Pat beef dry with paper towels, then sprinkle with salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Brown beef aggressively in 2 or 3 batches, adding more oil if needed. Remove browned beef into a bowl."
    },
    {
      "order": 4,
      "instruction": "If pot looks dry, add a touch more oil."
    },
    {
      "order": 5,
      "instruction": "Add garlic and onion, cook for 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Add carrot and celery, cook for 2 minutes or until onion is translucent."
    },
    {
      "order": 7,
      "instruction": "Stir in flour, then slowly pour in beef broth while constantly stirring."
    },
    {
      "order": 8,
      "instruction": "Add beer, water, tomato paste, bay leaves and thyme, stir well. Then add the beef back in."
    },
    {
      "order": 9,
      "instruction": "Cover, adjust heat to medium low so it's bubbling gently. Simmer 1 hr 15 min or until beef is pretty tender."
    },
    {
      "order": 10,
      "instruction": "Add potatoes and peas, simmer for a further 20 minutes without the lid. Add cooked mushrooms in the last 5 minutes."
    },
    {
      "order": 11,
      "instruction": "The soup is ready when the potatoes are cooked and beef is very tender (see video)."
    },
    {
      "order": 12,
      "instruction": "Adjust salt and pepper to taste (I like lots of pepper in this!)."
    },
    {
      "order": 13,
      "instruction": "Ladle into bowls. Sprinkle with parsley and serve with crusty bread if desired. Try quick Cheesy Garlic Bread&nbsp;or super easy Irish Soda Bread!"
    },
    {
      "order": 14,
      "instruction": "Melt butter in a large skillet over medium high heat. Add mushrooms and cook for 5 minutes until browned. Sprinkle with salt and pepper."
    }
  ]
}