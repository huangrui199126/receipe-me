  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Place 1 cup of Shredded Beef Chili Con Carne into 4 individual pie dishes, or 1 large pie dish."
    },
    {
      "order": 3,
      "instruction": "Combine Corn Bread Topping dry ingredients in a bowl and given them a quick stir to combine."
    },
    {
      "order": 4,
      "instruction": "Add Corn Bread Topping wet ingredients and mix to combine until lump free."
    },
    {
      "order": 5,
      "instruction": "Pour corn bread mixture over filling so it is about 1.5 cm / 1/2\" thick."
    },
    {
      "order": 6,
      "instruction": "Place pie in the oven and bake for 20 to 30 minutes until golden brown on top. If making one large one, it will take closer to 35 minutes. To test for doneness, insert a skewer in the middle of the corn bread and make sure it comes out clean. If there is batter on the skewer, return to oven."
    },
    {
      "order": 7,
      "instruction": "Allow to rest for 5 minutes before serving, garnished with fresh parsley."
    }
  ]
