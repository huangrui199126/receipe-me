  "steps": [
    {
      "order": 1,
      "instruction": "Yogurt Sauce: Combine the yogurt sauce ingredients and leave in fridge for at least 20 mninutes for the flavor to develop (overnight even better!)."
    },
    {
      "order": 2,
      "instruction": "Koftas: Grate the onion into the bowl using a standard box grater. Add remaining Kofta ingredients and mix well with your hands."
    },
    {
      "order": 3,
      "instruction": "With damp hands, divide the meat into 8 equal pieces and push and shape the meat onto 8 skewers. Make them smooth (looks nicer, pictured!) or a bit nubbly (more surface area to brown!)."
    },
    {
      "order": 4,
      "instruction": "Stove: Preheat 1/2 tbsp oil in a large skillet over medium high heat. Cook in batches for 5 minutes in total, turning to brown evenly all over."
    },
    {
      "order": 5,
      "instruction": "BBQ: BBQ on medium high for about 6 minutes, rotating to brown all over."
    },
    {
      "order": 6,
      "instruction": "Broiler/oven grill: preheat and cook koftas 30cm/10&quot; from heat source for 12 minutes, rotating as needed until lightly browned (you won&#x27;t get as good a browning as stove/BBQ)."
    },
    {
      "order": 7,
      "instruction": "Do a DIY spread - pile everything onto a platter a make everyone serve themselves."
    },
    {
      "order": 8,
      "instruction": "Get a flatbread, smear with Yogurt Sauce, top with Red Cabbage Mint Salad (more options Note 3) then Kofta, drizzle over more Yoghurt Sauce. Devour and be happy!"
    }
  ]
}