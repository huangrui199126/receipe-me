  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C / 430°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Toss cauliflower in oil, salt and pepper. Spread on a large tray."
    },
    {
      "order": 3,
      "instruction": "Roast 20 minutes (don&#039;t turn). Cauliflower should still be a bit firm, but with some colour on them. Remove from oven."
    },
    {
      "order": 4,
      "instruction": "Turn oven down to 180°C/350°F."
    },
    {
      "order": 5,
      "instruction": "Heat milk: Heat milk and cream until hot – either on the stove or in microwave."
    },
    {
      "order": 6,
      "instruction": "Make roux: Melt butter in a large saucepan or small pot over medium heat. Add flour and cook, stirring regularly, for 3 minutes."
    },
    {
      "order": 7,
      "instruction": "Add milk: While stirring, pour in half the milk. Once the roux is dissolved into the milk (mixture will thicken), stir in remaining milk. Stir on the heat for 1 minute – mixture should be thick enough to coat a wooden spoon."
    },
    {
      "order": 8,
      "instruction": "Add cheese: Turn the stove off, but leave the pot on the turned off stove. Stir in salt, nutmeg and both cheeses. The cheese will thicken the mixture so it&#039;s like a thick sauce."
    },
    {
      "order": 9,
      "instruction": "Mix in cauliflower: Add cauliflower and toss to coat in the sauce."
    },
    {
      "order": 10,
      "instruction": "Fill baking dish: Transfer mixture to a 2L / 2qt baking dish (30 x 20 x 5cm / 12 x 8 x 2&quot;)."
    },
    {
      "order": 11,
      "instruction": "Top with cheese: Sprinkle over gruyère followed Red Leicester cheese."
    },
    {
      "order": 12,
      "instruction": "Bake at 180°C/350°F for 30 minutes until the cheese is melted, and cauliflower is bubbly and golden."
    },
    {
      "order": 13,
      "instruction": "Serve: Sprinkle with parsley if desired. Stand 5 minutes then serve!"
    }
  ]
}