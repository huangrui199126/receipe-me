  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 160°C/325°F."
    },
    {
      "order": 2,
      "instruction": "Sprinkle beef all over with salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large ovenproof pot over high heat. Add half the ribs and brown aggressively all over (~5 - 7 min in total). Remove and repeat with remaining ribs, then remove."
    },
    {
      "order": 4,
      "instruction": "Turn heat down to medium. Add onion and garlic into the same pot and cook for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add carrot and celery, cook for 5 minutes until carrot is softened and sweet."
    },
    {
      "order": 6,
      "instruction": "Add tomato paste and cook for 1 minute."
    },
    {
      "order": 7,
      "instruction": "Add wine, broth, thyme and bay leaves. Stir until tomato paste is dissolved."
    },
    {
      "order": 8,
      "instruction": "Return beef into liquid, arranging them so they are submerged (Note 3).&nbsp;"
    },
    {
      "order": 9,
      "instruction": "Cover with lid and transfer to oven for 3 hours, or until the meat can easily be pried apart with forks. (Note 4 Other cook methods)"
    },
    {
      "order": 10,
      "instruction": "Remove beef carefully, keeping the meat on the bone. (Note 4) Cover to keep warm."
    },
    {
      "order": 11,
      "instruction": "Strain all liquid in the pot, pressing juices out of the onion, carrot etc. (Optional - can skip if you don&#039;t mind chunky sauce) Return sauce into pot, bring to simmer and stir. Adjust as necessary - simmer to reduce/thicken, add water to thin, season with salt and pepper if needed."
    },
    {
      "order": 12,
      "instruction": "Place beef on serving plate, spoon over sauce. Serve!"
    }
  ]
}