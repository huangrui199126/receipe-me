  "steps": [
    {
      "order": 1,
      "instruction": "Sprinkle both sides of chicken with garlic powder, salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large skillet over medium heat. Place chicken in skillet smooth side down."
    },
    {
      "order": 3,
      "instruction": "Press down lightly with with spatula. Cook for 5 minutes until deep golden and crispy."
    },
    {
      "order": 4,
      "instruction": "Turn and press lightly with spatula. Cook for 2 minutes. Add garlic and butter, cook for 1 minute until garlic is light golden and it smells amazing."
    },
    {
      "order": 5,
      "instruction": "Add wine, then turn up heat. Stir around the chicken to dissolve golden bits stuck on the skillet into the wine. Simmer rapidly for 1 1/2 minutes or until alcohol smell evaporates."
    },
    {
      "order": 6,
      "instruction": "Remove from heat. Serve chicken with sauce.&nbsp;"
    }
  ]
