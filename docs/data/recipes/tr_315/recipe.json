  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220C/425F (standard) or 200C/400F (fan)."
    },
    {
      "order": 2,
      "instruction": "Cut carrot on the diagonal into 4cm / 1.75” lengths. Halve thicker end so they are all roughly the same width."
    },
    {
      "order": 3,
      "instruction": "Toss in a bowl with sugar, butter, garlic, oil, salt and pepper. Pour onto tray, spread out."
    },
    {
      "order": 4,
      "instruction": "Roast 15 minutes. Toss, then roast a further 10 minutes until soft and caramelised on the edges with plenty of glaze left on the tray."
    },
    {
      "order": 5,
      "instruction": "Toss carrots in the glaze, sprinkle with parsley if using. Serve warm."
    }
  ]
