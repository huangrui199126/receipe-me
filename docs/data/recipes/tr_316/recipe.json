  "steps": [
    {
      "order": 1,
      "instruction": "Sauce: Mix cornflour and dark soy until lump free, then add remaining Sauce ingredients."
    },
    {
      "order": 2,
      "instruction": "Season Chicken: Transfer 2 tsp Sauce into bowl with chicken. Toss to coat."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a wok or large heavy based skillet over high heat until smoking."
    },
    {
      "order": 4,
      "instruction": "Add onion and garlic, stir 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Add chicken, stir until white on the outside, still raw inside - 1 minute."
    },
    {
      "order": 6,
      "instruction": "Add carrot and capsicum/bell peppers, cook 2 minutes or until chicken is cooked."
    },
    {
      "order": 7,
      "instruction": "Add noodles, Sauce and water. Use 2 wooden spoons and toss for 30 seconds."
    },
    {
      "order": 8,
      "instruction": "Add green onions, toss for another 1 minute until all the noodles are slick with sauce."
    },
    {
      "order": 9,
      "instruction": "Serve immediately, garnished with extra green onions if using."
    }
  ]
}