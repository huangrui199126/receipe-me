  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Mix Sauce ingredients together."
    },
    {
      "order": 3,
      "instruction": "Mix Rub ingredients then sprinkle over the pork."
    },
    {
      "order": 4,
      "instruction": "Heat oil in a large oven proof skillet (Note 3) over high heat. Add pork and sear until golden all over."
    },
    {
      "order": 5,
      "instruction": "When pork is almost seared, push to the side, add garlic and cook until golden."
    },
    {
      "order": 6,
      "instruction": "Pour sauce in. Turn pork once, then immediately transfer to the oven."
    },
    {
      "order": 7,
      "instruction": "Roast 15 - 18 minutes or until the internal temperature is 68C / 155F (Note 4)."
    },
    {
      "order": 8,
      "instruction": "Remove pork onto plate, cover loosely with foil and rest 5 minutes."
    },
    {
      "order": 9,
      "instruction": "Place skillet with sauce on stove over medium high heat, simmer rapidly for 3 minutes until liquid reduces down to thin syrup."
    },
    {
      "order": 10,
      "instruction": "Remove from stove, put pork in and turn to coat in sauce."
    },
    {
      "order": 11,
      "instruction": "Cut pork into thick slices and serve with sauce!"
    }
  ]
