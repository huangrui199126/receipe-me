  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large skillet over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Cook sausages, turning to brown all over then remove. Optional: slice sausages into pieces on the diagonal."
    },
    {
      "order": 3,
      "instruction": "In the same skillet, add garlic and onion. Cook for 2 minutes until translucent."
    },
    {
      "order": 4,
      "instruction": "Add curry powder and stir for 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Add flour and mix for 30 seconds."
    },
    {
      "order": 6,
      "instruction": "Gradually pour in chicken stock, mixing constantly."
    },
    {
      "order": 7,
      "instruction": "Add carrots, sugar, salt and pepper, stir well."
    },
    {
      "order": 8,
      "instruction": "Add sausages and peas, bring to simmer and cook for 3 minutes or until sauce thickens."
    },
    {
      "order": 9,
      "instruction": "Serve over mashed potato, rice, pasta or noodles. For low carb, try mashed cauliflower!"
    }
  ]
