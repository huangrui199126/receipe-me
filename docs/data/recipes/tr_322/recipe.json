  "steps": [
    {
      "order": 1,
      "instruction": "Bring a large pot of water to the boil with the salt."
    },
    {
      "order": 2,
      "instruction": "Add pasta and cook for the length of time per the packet."
    },
    {
      "order": 3,
      "instruction": "Just before draining, scoop out 1 cup of of the pasta cooking water."
    },
    {
      "order": 4,
      "instruction": "Drain pasta in a colander, leave it for a minute."
    },
    {
      "order": 5,
      "instruction": "Transfer pasta to a bowl (do not use pasta cooking pot, too hot)."
    },
    {
      "order": 6,
      "instruction": "Add pesto and 1/4 cup of pasta water. Toss to coat pasta in pesto, adding more water if required to make pasta silky and saucy, rather than dry and sticky."
    },
    {
      "order": 7,
      "instruction": "Taste, add more salt and pepper if desired."
    },
    {
