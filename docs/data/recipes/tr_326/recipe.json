  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (standard) or 180C/350F (fan)."
    },
    {
      "order": 2,
      "instruction": "Spread panko breadcrumbs on a baking tray and spray with oil. Bake for 3 minutes or until light golden. Remove and scrape into bowl straight away."
    },
    {
      "order": 3,
      "instruction": "Cut a pocket into each chicken breast, as per the photo below."
    },
    {
      "order": 4,
      "instruction": "Fold the cheese in half and place 2 pieces inside each pocket. Do the same with the ham. Close the pocket, seal with 2 toothpicks.&nbsp;Sprinkle with salt and pepper."
    },
    {
      "order": 5,
      "instruction": "Mix the mayonnaise, mustard, salt and pepper in a bowl. Spread onto the top and sides of the chicken (not underside)."
    },
    {
      "order": 6,
      "instruction": "Sprinkle panko over the chicken, using your other hand to press the breadcrumbs onto the side of the chicken. Spray with oil."
    },
    {
      "order": 7,
      "instruction": "Whisk egg and flour. Dip chicken into egg mixture, then into the panko breadcrumbs. Transfer to tray, spray with oil."
    },
    {
      "order": 8,
      "instruction": "Bake for 25 to 30 minutes, or until golden brown and just cooked through. Remove toothpicks, serve with the Dijon Cream Sauce."
    },
    {
      "order": 9,
      "instruction": "Melt butter over medium heat in a small saucepan. Add flour and cook for 1 minute."
    },
    {
      "order": 10,
      "instruction": "Add half the milk and whisk until the flour mixture is blended in."
    },
    {
      "order": 11,
      "instruction": "Add remaining milk, mustard and cheese. Cook for 3 minutes, whisking constantly, until thickened. It will thicken as it cools."
    },
    {
      "order": 12,
      "instruction": "Remove from heat, &nbsp;add salt and pepper to taste. Serve with chicken."
    }
  ]
}