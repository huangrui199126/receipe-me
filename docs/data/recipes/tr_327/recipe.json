  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta in salted water for 1 minute less than time per packet (start this mid mushroom cook). Just before draining, scoop out 1 cup cooking water, then drain."
    },
    {
      "order": 2,
      "instruction": "Melt butter and heat oil in a large skillet over high heat."
    },
    {
      "order": 3,
      "instruction": "Add mushrooms and cook, stirring regularly. When they start to sweat, add a pinch of salt and pepper."
    },
    {
      "order": 4,
      "instruction": "When pretty golden (about 4 - 5 minutes), add garlic and cook until garlic is golden and mushroom is golden."
    },
    {
      "order": 5,
      "instruction": "Stand back and add wine (it will be steamy!!), stir, scraping the bottom of the skillet. Simmer rapidly until wine is mostly evaporated and winey smell is gone."
    },
    {
      "order": 6,
      "instruction": "Add broth, cream, parmesan, salt and pepper. Stir to dissolve parmesan and simmer for 2 minutes, stirring regularly."
    },
    {
      "order": 7,
      "instruction": "Transfer pasta into sauce, toss for 1 - 2 minutes until sauce thickens and coats pasta. If sauce gets too thick (rather than slick, see video), add a splash of reserved pasta cooking water."
    },
    {
      "order": 8,
      "instruction": "Garnish with parsley and serve immediately with extra parmesan!"
    }
  ]
}