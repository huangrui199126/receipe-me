  "steps": [
    {
      "order": 1,
      "instruction": "Pat beef dry with paper towels. Sprinkle generously with salt and pepper all over."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a skillet over high heat. Brown aggressively all over - a deep dark brown crust is essential for flavour base! Should take about 7 minutes."
    },
    {
      "order": 3,
      "instruction": "Transfer beef to slow cooker."
    },
    {
      "order": 4,
      "instruction": "In the same skillet, add onion and garlic. Cook for 2 minutes until onion is browned."
    },
    {
      "order": 5,
      "instruction": "Add wine, reduce by half. Transfer to slow cooker."
    },
    {
      "order": 6,
      "instruction": "Mix together flour and about 1 cup of the broth. Lumps is fine. Pour into slow cooker."
    },
    {
      "order": 7,
      "instruction": "Add remaining broth, carrots, celery, rosemary and thyme into slow cooker."
    },
    {
      "order": 8,
      "instruction": "Cover and slow cook on LOW for 5 hours. (45 min pressure cook on HIGH, Note 3a for Oven and Stove)"
    },
    {
      "order": 9,
      "instruction": "Add potato, slow cook on LOW for 3 hours. (10 min pressure cooker on HIGH, Note 3b)"
    },
    {
      "order": 10,
      "instruction": "Remove beef. Rest for 5 minutes, then slice thickly."
    },
    {
      "order": 11,
      "instruction": "Adjust salt and pepper of Sauce to taste."
    },
    {
      "order": 12,
      "instruction": "Serve beef with vegetables and plenty of sauce! Bread also terrific for mopping up sauce - try these No Knead Dinner Rolls, No Yeast Irish Soda Bread or these fabulous Cheese Muffins."
    }
  ]
}