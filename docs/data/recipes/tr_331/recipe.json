  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a skillet over medium high heat. Cook garlic, ginger and onion for 3 minutes until onion is translucent."
    },
    {
      "order": 2,
      "instruction": "Add chicken and cook until it it changes from pink to white."
    },
    {
      "order": 3,
      "instruction": "Add curry powder and cook for 2 minutes."
    },
    {
      "order": 4,
      "instruction": "Add coconut milk and chicken stock. Stir, lower heat to medium and cook, simmering rapidly, for 10 minutes until sauce reduces and thickens."
    },
    {
      "order": 5,
      "instruction": "Add peas and salt. Cook for a further 2 minutes, then taste to see if it needs more salt. Garnish with coriander."
    },
    {
      "order": 6,
      "instruction": "Serve over rice, noodles or mashed potato!"
    }
  ]
