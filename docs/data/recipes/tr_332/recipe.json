  "steps": [
    {
      "order": 1,
      "instruction": "Combine Chicken and Marinade ingredients and set aside for at least 1 hour, up to 24 hours. (Note 4)"
    },
    {
      "order": 2,
      "instruction": "Heat 1/2 tbsp oil in a fry pan over medium heat (or heat the BBQ). Remove chicken from marinade, shaking off large bits of lemongrass (small bits should fall off during cooking)."
    },
    {
      "order": 3,
      "instruction": "Place chicken in the pan and cook each side until dark golden brown and chicken is just cooked through - about 6 to 8 minutes in total."
    },
    {
      "order": 4,
      "instruction": "Remove from pan, shaking off any remaining bits of visible lemongrass and set aside to rest for 5 minutes. Then slice into thin pieces."
    },
    {
      "order": 5,
      "instruction": "Combine the Nuoc Cham ingredients and mix well to dissolve the sugar. Adjust to your taste (spiciness, lime, sweetness) and set aside for at least 20 minutes."
    },
    {
      "order": 6,
      "instruction": "Soak the vermicelli noodles in hot water for 3 minutes (or according to packet instructions), then drain and rinse under cold water to stop the noodles from sticking together."
    },
    {
      "order": 7,
      "instruction": "Individual servings: Place noodles in bowl. Top with vegetables and herbs, and sliced chicken pieces. Drizzle with a few tablespoons of Nuoc Cham Sauce (be generous, ~ 4 tbsp per serving) and serve with lime wedges."
    },
    {
      "order": 8,
      "instruction": "DIY (my preferred way): Place chicken, vegetables, herbs, noodles and sauce in separate bowls / piled on platters. Then let everyone make their own bowls!"
    }
  ]
}