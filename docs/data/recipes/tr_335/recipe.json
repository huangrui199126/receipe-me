  "steps": [
    {
      "order": 1,
      "instruction": "Combine all ingredients except chicken in a bowl and mix. Add chicken and turn well to coat."
    },
    {
      "order": 2,
      "instruction": "Cover with cling wrap and leave in fridge to marinate overnight (3 hours minimum)."
    },
    {
      "order": 3,
      "instruction": "Heat 1 tbsp oil in a non stick pan over high heat until smoking. Add half the chicken and spread out. Leave for 2 minutes or until charred. Turn each piece and cook the other side until charred - don't worry if not cooked inside. (Note 4, also Video helpful here) Remove into bowl."
    },
    {
      "order": 4,
      "instruction": "Scrape out charred bits left in pan and discard. Add more oil if required and cook remaining chicken."
    },
    {
      "order": 5,
      "instruction": "Wipe skillet with paper towels (or do this part in a pot as you need a lid). Turn heat down to medium high."
    },
    {
      "order": 6,
      "instruction": "Add oil and butter. When butter is melted, add onions, ginger and salt."
    },
    {
      "order": 7,
      "instruction": "Cook, stirring constantly to ensure it doesn't burn, until the ginger is starting to turn golden and the onions smell sweet, about 5 - 7 minutes."
    },
    {
      "order": 8,
      "instruction": "Reduce the heat to medium. Add the garlic and paprika, and cook for 2 minutes."
    },
    {
      "order": 9,
      "instruction": "Add the Curry Sauce Spices, and cook a further 2 minutes, stirring."
    },
    {
      "order": 10,
      "instruction": "Add tomato passata and water, and mix. Bring to a simmer, then cover and reduce heat to low."
    },
    {
      "order": 11,
      "instruction": "Simmer for 15 minutes, stirring occasionally."
    },
    {
      "order": 12,
      "instruction": "Pour curry into a bowl, then use a stick blender to puree until smooth (Note 5)."
    },
    {
      "order": 13,
      "instruction": "Return sauce to skillet. Add cream, sugar and butter. Stir to melt the butter."
    },
    {
      "order": 14,
      "instruction": "Add chicken, stir. Simmer for a few minutes until the chicken is cooked through."
    },
    {
      "order": 15,
      "instruction": "Optional: Sprinkle with a pinch of extra garam masala at the end."
    },
    {
      "order": 16,
      "instruction": "Serve over basmati rice, sprinkled with coriander/cilantro if desired. Try this No Yeast Flatbread as a quick naan!"
    }
  ]
