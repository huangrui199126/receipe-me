  "steps": [
    {
      "order": 1,
      "instruction": "Mix together the Potato Cake ingredients in a bowl until just combined."
    },
    {
      "order": 2,
      "instruction": "Spread the panko or flour out on a large plate or baking tray (to fit 6 patties)."
    },
    {
      "order": 3,
      "instruction": "Measure out 1/4 cup level amount of potato mixture OR a slightly heaped ice cream scooper (this is what I use because using the lever, it pops out easily) and drop onto panko/flour. Repeat to fill plate / baking tray (don't crowd, difficult to handle)."
    },
    {
      "order": 4,
      "instruction": "Use an egg flip (or base of cup) to pat it down to 1.5cm/2/3\" thick patties, then flip and pat to coat the other side with panko/flour. Set aside and repeat with remaining potato mixture."
    },
    {
      "order": 5,
      "instruction": "Heat 1/2 the oil in a large skillet over medium high heat. Cook 6 patties at a time until golden brown on each side - around 2 minutes, then flip and cook the other side."
    },
    {
      "order": 6,
      "instruction": "Remove onto a paper towel lined baking tray. Cook remaining patties."
    },
    {
      "order": 7,
      "instruction": "Serve hot!"
    }
  ]
