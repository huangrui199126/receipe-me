  "steps": [
    {
      "order": 1,
      "instruction": "Peel the prawns. Place heads and shell in pot, reserve meat."
    },
    {
      "order": 2,
      "instruction": "Use a meat mallet or similar to bash the garlic, chilli and lemongrass so they burst open to release flavour. Add into pot."
    },
    {
      "order": 3,
      "instruction": "Crush kaffir lime leaves with your hands. Add into pot."
    },
    {
      "order": 4,
      "instruction": "Add galangal, stock and water. Bring to simmer on high heat, cover, then reduce to medium and simmer for 10 minutes."
    },
    {
      "order": 5,
      "instruction": "Strain the broth, discard the prawn shells etc, then return broth into same pot over low heat."
    },
    {
      "order": 6,
      "instruction": "Add onions and mushrooms, simmer 3 minutes. Add tomatoes, simmer for 1 minute."
    },
    {
      "order": 7,
      "instruction": "Add prawns, simmer 2 minutes or until just cooked."
    },
    {
      "order": 8,
      "instruction": "Stir in sugar and fish sauce, simmer for 1 minute."
    },
    {
      "order": 9,
      "instruction": "Add lime juice, then taste. Adjust sweet (sugar), salt (fish sauce) and sour (lime) to your taste (trust me, you&#x27;ll know when you like it!)."
    },
    {
      "order": 10,
      "instruction": "Ladle into bowls and serve with fresh coriander and fresh chilli! This is the CLEAR version of Tom Yum."
    },
    {
      "order": 11,
      "instruction": "When you add sugar, also add Thai Chilli Paste and evaporated milk."
    },
    {
      "order": 12,
      "instruction": "Then continue with recipe!"
    },
    {
      "order": 13,
      "instruction": "Following Creamy Tom Yum steps but use coconut milk instead of evaporated milk."
    }
  ]
}