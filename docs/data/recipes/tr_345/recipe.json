  "steps": [
    {
      "order": 1,
      "instruction": "Prepare noodles per packet directions."
    },
    {
      "order": 2,
      "instruction": "Mix Sauce in a small bowl."
    },
    {
      "order": 3,
      "instruction": "Heat oil in wok or large heavy based skillet over high heat."
    },
    {
      "order": 4,
      "instruction": "Add garlic and chilli and cook for 10 seconds. Don't inhale - the chilli will make you cough!"
    },
    {
      "order": 5,
      "instruction": "Add onion, cook for 1 minute.&nbsp;"
    },
    {
      "order": 6,
      "instruction": "Add chicken and fish sauce, and fry until cooked, around 2 minutes."
    },
    {
      "order": 7,
      "instruction": "Add green onion, noodles and sauce and cook for 1 minute until the sauce reduces and coats the noodles."
    },
    {
      "order": 8,
      "instruction": "Remove from heat and immediately add basil, toss until just wilted, then serve immediately."
    }
  ]
