  "steps": [
    {
      "order": 1,
      "instruction": "Sauté - Heat oil in a small pot over medium high heat. Add garlic, onion, bay leaf, thyme and oregano. Cook for 3 - 4 minutes until the onion is translucent. Add tomato paste and cook for 1 minute."
    },
    {
      "order": 2,
      "instruction": "Reduce wine - Add wine, increase heat to high and let it simmer rapidly until mostly evaporated (about 2 minutes)."
    },
    {
      "order": 3,
      "instruction": "Simmer - Add tomatoes, stock, sugar, salt and pepper. Stir then simmer on medium low for 20 minutes."
    },
    {
      "order": 4,
      "instruction": "Blitz - Remove bay leaf then blitz with a stick blender until smooth. Simmer for 1 more minute then remove from the stove"
    },
    {
      "order": 5,
      "instruction": "Basil - Stir in basil then cover to keep warm until required."
    },
    {
      "order": 6,
      "instruction": "Squeeze spinach - Place spinach in a colander and press out most of the liquid (don&#39;t need to thoroughly squeeze dry)."
    },
    {
      "order": 7,
      "instruction": "Mix filling - Place Spinach in bowl with remaining Filling ingredients. Mix, taste, adjust salt and pepper to taste (different cheeses have different saltiness)."
    },
    {
      "order": 8,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan)."
    },
    {
      "order": 9,
      "instruction": "Pan - Choose a baking pan which will comfortably fit about 20 cannelloni - mine is 21 x 26 cm / 8.5 x 10.5&quot;."
    },
    {
      "order": 10,
      "instruction": "Smear - Spread 1 cup of Sauce on the base (stops cannelloni from sliding around)."
    },
    {
      "order": 11,
      "instruction": "Fill tubes - Transfer Filling to a piping bag with a large nozzle (that fits in the tubes), or use a strong ziplock bag. Or do this step using a knife (it&#39;s a bit tedious though!). Pipe the filling into the tubes."
    },
    {
      "order": 12,
      "instruction": "Assemble - Place cannelloni in baking dish. Pour over remaining Sauce, covering all the tubes."
    },
    {
      "order": 13,
      "instruction": "Bake covered (but naked) - Cover with foil, then bake for 30 minutes."
    },
    {
      "order": 14,
      "instruction": "Cheese it! Remove foil, scatter over parmesan then mozzarella. Return to oven for 15 minutes until cheese is melted."
    },
    {
      "order": 15,
      "instruction": "Serve, garnished with extra parmesan and basil if desired."
    }
  ]
}