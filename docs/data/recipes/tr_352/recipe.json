  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade ingredients in a bowl, then add chicken and toss to coat. If time permits, marinate for 24 hours, otherwise proceed to next step."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 3,
      "instruction": "Place potatoes and onion in baking pan, top with chicken. Pour over the chicken stock then marinade from the bowl."
    },
    {
      "order": 4,
      "instruction": "Bake for 20 minutes, then remove from oven."
    },
    {
      "order": 5,
      "instruction": "Scatter over cherry tomatoes, drizzle everything with 1 tbsp olive oil, sprinkle with salt and pepper. Bake for a further 30 - 35 minutes until chicken is golden and potatoes are cooked."
    },
    {
      "order": 6,
      "instruction": "Remove from oven, garnish with fresh oregano if using and serve!"
    }
  ]
