  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large skillet or wok over high heat."
    },
    {
      "order": 2,
      "instruction": "Add chilli and garlic, stir for 10 seconds."
    },
    {
      "order": 3,
      "instruction": "Add onion, cook for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Add chicken, cook until it mostly turns white, then add 1 tbsp kecap manis and cook for a further 1 minute or until chicken is mostly cooked through and a bit caramelised."
    },
    {
      "order": 5,
      "instruction": "Add rice, 2 tbsp kecap manis and shrimp paste, if using. Cook, stirring constantly, for 2 minutes until sauce reduces down and rice grains start to caramelise (key for flavour!)."
    },
    {
      "order": 6,
      "instruction": "Serve, garnished with garnishes of choice (green onions, red chilli, fried shallots)."
    },
    {
      "order": 7,
      "instruction": "Serve as a side for Asian main dishes or as part of a &nbsp;large spread, Asian or not! :) See in post for suggestions."
    },
    {
      "order": 8,
      "instruction": "Make it a meal - traditional Indonesian style!: Serve with a fried egg sunny side up (runny yolk!), tomato wedges and slices of cucumber on the side."
    }
  ]
