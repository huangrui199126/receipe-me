  "steps": [
    {
      "order": 1,
      "instruction": "Mix together Spice Mix ingredients. Set aside."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large saucepan over medium heat. Add flour and mix to combine into a paste. Cook for 1 minute, stirring constantly."
    },
    {
      "order": 3,
      "instruction": "Add 1/2 cup chicken broth, whisk straight away then it will turn into a thick smooth paste quite quickly."
    },
    {
      "order": 4,
      "instruction": "Add remaining chicken broth, passata, salt, pepper and 2 tablespoons of SPICE MIX. Whisk"
    },
    {
      "order": 5,
      "instruction": "Increase heat slightly to medium high. Cook for 3 to 5 minutes, whisking regularly, until the sauce thickens to the consistency of thick syrup (see video). Remove from stove."
    },
    {
      "order": 6,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 7,
      "instruction": "Heat oil in a skillet over high heat. Add garlic and onion, cook for 2 minutes."
    },
    {
      "order": 8,
      "instruction": "Add beef and cook for 2 minutes, breaking it up as you go. Add remaining Spice Mix. Cook for a further 2 minutes or until completely brown."
    },
    {
      "order": 9,
      "instruction": "Add refried beans, black beans, about 1/4 cup of Enchilada Sauce + salt &amp; pepper. Mix (Note 4) and cook for 2 minutes then remove from stove (see video)."
    },
    {
      "order": 10,
      "instruction": "Smear a bit of Sauce on the bottom of a baking dish (stops sliding)."
    },
    {
      "order": 11,
      "instruction": "Place filling on the lower third of a tortilla. Roll up then place in the baking dish, seam side down. Repeat with remaining Filling &amp; Tortillas."
    },
    {
      "order": 12,
      "instruction": "Pour Sauce over the Enchiladas, top with cheese, bake for 10 minutes covered (Note 5) then 10 minutes uncovered. Serve hot!"
    }
  ]
}