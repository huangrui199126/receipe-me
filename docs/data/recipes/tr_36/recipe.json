  "steps": [
    {
      "order": 1,
      "instruction": "Cream Cheese Filling - place ingredients in a bowl and mix well until combined. Adjust salt to taste."
    },
    {
      "order": 2,
      "instruction": "Feta Cheese Filling - place ingredients in a bowl and mix well until combined."
    },
    {
      "order": 3,
      "instruction": "Make the balls - measure out 1 tbsp of filling and use a teaspoon to scoop the filling out of the tablespoon and place onto a tray or cutting board. Once you have scooped out all the filling, use your hands to roll into balls. Refrigerate for 3 to 4 hours."
    },
    {
      "order": 4,
      "instruction": "Place the Coatings into small bowls."
    },
    {
      "order": 5,
      "instruction": "Roll the cheese balls in the Coatings."
    },
    {
      "order": 6,
      "instruction": "Refrigerate the cheese balls until ready to serve."
    },
    {
      "order": 7,
      "instruction": "Take them out of the fridge around 15 minutes before serving (so they are spreadable)."
    },
    {
      "order": 8,
      "instruction": "Serve with crackers or pieces of toasted bread."
    }
  ]
