  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/420°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Pan - Use a pan large enough to fit the thighs lying flat (not bunched up/folded). Line pan with foil (you&#39;ll thank me later), place thighs in pan."
    },
    {
      "order": 3,
      "instruction": "Glaze 1 - Mix Glaze ingredients together. Spoon over about 2/3 of the Glaze on the surface of each (not underside), reserve rest."
    },
    {
      "order": 4,
      "instruction": "Bake 15 minutes, remove pan."
    },
    {
      "order": 5,
      "instruction": "Flick to grill/broiler on high, adjust shelf to be 20cm/8&quot; from heat source."
    },
    {
      "order": 6,
      "instruction": "Glaze 2 - Spoon pan juices over chicken. Then spoon/dab remaining Glaze onto chicken."
    },
    {
      "order": 7,
      "instruction": "Broil chicken for 8 to 10 minutes until surface is nicely caramelised."
    },
    {
      "order": 8,
      "instruction": "Rest - Remove and stand for a few minutes (uncovered) before serving with pan juices."
    }
  ]
