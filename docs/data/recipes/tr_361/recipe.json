  "steps": [
    {
      "order": 1,
      "instruction": "Place milk, broth and stock powder in a large saucepan. Bring to a very gentle simmer over medium heat, add chicken and thyme."
    },
    {
      "order": 2,
      "instruction": "Place lid on, simmer gently on medium low for 15 minutes (do not boil, can make milk split)."
    },
    {
      "order": 3,
      "instruction": "Remove chicken, shred or dice (don't worry if inside a bit uncooked). Cover pot and set poaching liquid aside."
    },
    {
      "order": 4,
      "instruction": "Melt butter in a large pot over medium high heat. Add garlic and onion, cook for 2 minutes. Add thyme, carrot and celery, cook for 3 minutes or until carrot is softened."
    },
    {
      "order": 5,
      "instruction": "Add wine. Stir, scraping the bottom of the pot, and cook for 1 1/2 minutes or until wine is mostly evaporated."
    },
    {
      "order": 6,
      "instruction": "Add flour and stir for 1 minute."
    },
    {
      "order": 7,
      "instruction": "Add about half the reserved poaching liquid and stir until all flour is incorporated - it will be a thick sludge."
    },
    {
      "order": 8,
      "instruction": "Add remaining milk broth, parmesan, pepper. Stir."
    },
    {
      "order": 9,
      "instruction": "Add chicken and peas, stir."
    },
    {
      "order": 10,
      "instruction": "Once mixture is heated (you'll see steam), cook for 3 minutes to thicken the sauce, stirring regularly. (Note 3)"
    },
    {
      "order": 11,
      "instruction": "Remove from heat. Spoon into oven proof pots - 4 large or 6 small (Note 4). Cool in fridge at least 30 minutes. (Note 5)"
    },
    {
      "order": 12,
      "instruction": "Meanwhile, remove puff pastry from freezer to partially thaw. Then use a bowl as a guide to cut rounds from the pastry about 2.5cm / 1\" wider (all the way around) than the pots - be generous!"
    },
    {
      "order": 13,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 14,
      "instruction": "Brush edge of pots with egg. Top with puff pastry, folding down the edges."
    },
    {
      "order": 15,
      "instruction": "Brush pastry with egg. Cut a 2cm / 2/3\" slide in the middle with a small knife."
    },
    {
      "order": 16,
      "instruction": "Bake 35 - 40 minutes until deep golden."
    },
    {
      "order": 17,
      "instruction": "Serve immediately!"
    }
  ]
}