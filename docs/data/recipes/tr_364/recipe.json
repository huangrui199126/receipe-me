  "steps": [
    {
      "order": 1,
      "instruction": "Place Taco Seasoning ingredients in a bowl. Add 2 tbsp of the chicken broth and mix to form a loose paste."
    },
    {
      "order": 2,
      "instruction": "Add chicken, turn to coat."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large skillet over medium high heat. Cook chicken for 3 minutes on each side until lightly seared. (Reserve marinade dregs in bowl)"
    },
    {
      "order": 4,
      "instruction": "Remove chicken into a shallow dish."
    },
    {
      "order": 5,
      "instruction": "Return skillet to stove, reduce to medium. Add remaining chicken broth, tomato paste, sugar and scrape in any marinade left in the bowl. Mix to dissolve, scraping base of pan, and bring to simmer"
    },
    {
      "order": 6,
      "instruction": "Meanwhile, shred chicken with forks, or chop (don't worry if raw inside)."
    },
    {
      "order": 7,
      "instruction": "Return chicken into sauce, toss and simmer for 2 to 3 minutes until sauce reduces to a thin syrup consistency (add water if reduces too fast). Adjust salt to taste."
    },
    {
      "order": 8,
      "instruction": "Transfer chicken and all sauce to serving bowl."
    },
    {
      "order": 9,
      "instruction": "Warm taco shells or tortillas."
    },
    {
      "order": 10,
      "instruction": "Stuff with chicken, making sure it's soaked with the sauce."
    },
    {
      "order": 11,
      "instruction": "Top with tomato, avocado, onion, coriander, lettuce and sour cream. Devour!"
    }
  ]
}