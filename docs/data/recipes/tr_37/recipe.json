  "steps": [
    {
      "order": 1,
      "instruction": "Place a pan over medium high heat. Add pine nuts and toast until golden. Remove pine nuts from pan and set aside."
    },
    {
      "order": 2,
      "instruction": "Return pan to stove (still on medium high heat) and add olive oil."
    },
    {
      "order": 3,
      "instruction": "Add onion and cook until translucent (2 minutes). Then turn up the heat to high, add mince, spices and salt. Cook, breaking up the mince into small pieces, until browned and cooked through (3 minutes)."
    },
    {
      "order": 4,
      "instruction": "Set aside and cover so it doesn't dry out. Bring it to room temperature."
    },
    {
      "order": 5,
      "instruction": "Place all ingredients except salt in a food processor or blender and process until smooth."
    },
    {
      "order": 6,
      "instruction": "Taste before adding salt and pepper. Different brands of chick peas have different levels of saltiness. Also adjust acidity with lemon juice, if required."
    },
    {
      "order": 7,
      "instruction": "Use water to adjust the consistency to a tomato sauce (ketchup) like consistency. This consistency is \"proper\" hummus. In the Middle East, hummus is not the thick consistency that is typical of store bought hummus in Western countries, it is thinner."
    },
    {
      "order": 8,
      "instruction": "Spread hummus on a plate, using the back of a spoon to create \"swirls\"."
    },
    {
      "order": 9,
      "instruction": "Top with lamb mince, scatter over the pine nuts and sprinkle with parsley. Finish with a drizzle of olive oil."
    },
    {
      "order": 10,
      "instruction": "Serve with pita bread."
    }
  ]
}