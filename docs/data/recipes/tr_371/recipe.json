  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/430°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Cut the carrots on the diagonal into 5cm / 2&quot; lengths. Cut the thicker ones in half lengthwise so they are all roughly the same width."
    },
    {
      "order": 3,
      "instruction": "Place on a tray, drizzle with oil, sprinkle with salt and pepper, toss."
    },
    {
      "order": 4,
      "instruction": "Roast 20 minutes: Spread out on tray, roast 20 minutes."
    },
    {
      "order": 5,
      "instruction": "Flip &amp; garlic: Remove from oven. Push carrots to one end, add garlic and toss. (Add other Flavour Options at this point too)"
    },
    {
      "order": 6,
      "instruction": "Roast 10 minutes: Roast for a further 10 minutes. Remove from oven, toss carrots to coat in the garlicky oil and juices on the tray."
    },
    {
      "order": 7,
      "instruction": "Sprinkle with parsley and serve!"
    }
  ]
