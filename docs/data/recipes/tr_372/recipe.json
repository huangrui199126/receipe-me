  "steps": [
    {
      "order": 1,
      "instruction": "Place peas in slow cooker, push ham in. Scatter all ingredients around the ham bone, then pour over water."
    },
    {
      "order": 2,
      "instruction": "Slow cook 8 to 10 hours on LOW or 6 hours on HIGH. (Or 2.5 hours on low on stove, 1 h - 1 hr 20 min pressure cooker/Instant Pot on HIGH)"
    },
    {
      "order": 3,
      "instruction": "Remove ham bone, shred ham meat. Discard bone and fatty skin."
    },
    {
      "order": 4,
      "instruction": "Remove bay leaves. Use a stick blender to blitz 2 or 3 times - thickens soup but doesn't make it completely smooth (my preference, you can blend completely if you want)."
    },
    {
      "order": 5,
      "instruction": "Return ham into slow cooker, stir. Taste and add more salt if needed (soup gets lots of salt from ham)."
    },
    {
      "order": 6,
      "instruction": "Serve garnished with parsley. Serve with crusty bread for dunking - make a quick Irish Soda Bread, Garlic Bread or upgrade to Cheesy Garlic Bread!"
    }
  ]
