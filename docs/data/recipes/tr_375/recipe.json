  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large pot over high heat. Brown chicken on both sides until light golden, sprinkling with salt and pepper. Remove from pot. (Do in 2 batches if pot not big enough)."
    },
    {
      "order": 3,
      "instruction": "If there's too much oil in the pot, discard some. Add onion and garlic. Cook for 2 minutes until onion is translucent."
    },
    {
      "order": 4,
      "instruction": "Add carrots and celery, cook for 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add wine. Stir, scraping the bottom of the pan to dissolve the brown bits into the liquid. Cook for 1 minute until liquid is mostly gone."
    },
    {
      "order": 6,
      "instruction": "Sprinkle flour across surface, stir."
    },
    {
      "order": 7,
      "instruction": "Add broth, tomato paste, Worcestershire sauce, thyme and bay leaves. Stir to dissolve tomato paste."
    },
    {
      "order": 8,
      "instruction": "Place chicken on top, keeping the skin above the liquid level as much as you can."
    },
    {
      "order": 9,
      "instruction": "Bring to simmer then cover. Bake for 45 minutes."
    },
    {
      "order": 10,
      "instruction": "Remove from oven, remove lid. Add potatoes, pushing them into the liquid and rearranging chicken so they sit on top (for lovely crispy skin)."
    },
    {
      "order": 11,
      "instruction": "Return to oven without the lid for a further 40 minutes until the chicken skin is deep golden and super crispy, the potatoes are soft and the sauce is thickened."
    },
    {
      "order": 12,
      "instruction": "Taste sauce and adjust salt and pepper to taste."
    },
    {
      "order": 13,
      "instruction": "Serve with warm crusty bread on the side to dunk in the sauce - or go all the way with Garlic Bread! Optional: garnish with extra fresh thyme leaves or parsley."
    }
  ]
}