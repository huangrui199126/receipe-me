  "steps": [
    {
      "order": 1,
      "instruction": "Add 1 tbsp oil and half the butter in a large heavy based pot over high heat (Note 5). Once melted, add half the mushrooms and cook until pretty golden brown (~4 min)."
    },
    {
      "order": 2,
      "instruction": "Add 1/2 the garlic, 1/4 tsp each salt and pepper, then continue to cook until golden brown (~1.5 min). Then remove into bowl."
    },
    {
      "order": 3,
      "instruction": "Repeat with remaining mushrooms, then remove."
    },
    {
      "order": 4,
      "instruction": "Turn heat down to medium. In the same pot, melt butter then add garlic and onion."
    },
    {
      "order": 5,
      "instruction": "Cook 2 minutes until onion is translucent but not golden."
    },
    {
      "order": 6,
      "instruction": "Add wine and allow to simmer rapidly for 2 minutes, scraping the base of the pot, until mostly evaporated."
    },
    {
      "order": 7,
      "instruction": "Add rice and stir for 1 minute until semi translucent."
    },
    {
      "order": 8,
      "instruction": "Add about 1.5 cups of stock. Stir, then leave for 3 minutes, stirring just a few times, until mostly absorbed (~3 min)."
    },
    {
      "order": 9,
      "instruction": "Add about 1.5 cups stock, stir every now and then until mostly absorbed (~3 min) - no need to stir constantly. Repeat twice more until all stock used up, rice is just cooked but risotto still creamy and sloppy (~10 min, Note 6)."
    },
    {
      "order": 10,
      "instruction": "Add cream and butter, stir vigorously to make creamy."
    },
    {
      "order": 11,
      "instruction": "Stir in parmesan, salt and pepper."
    },
    {
      "order": 12,
      "instruction": "Stir through half the mushrooms, then taste and add more salt and pepper if needed. Consistency should be creamy, not stodgy (Note 7)."
    },
    {
      "order": 13,
      "instruction": "Reheat remaining mushrooms (I microwave)."
    },
    {
      "order": 14,
      "instruction": "Spoon risotto into bowls, then top with reserved mushrooms (including a drizzle of buttery juices pooled in bowl!)"
    },
    {
      "order": 15,
      "instruction": "Garnish with parsley if using, and extra parmesan. Serve immediately!"
    }
  ]
}