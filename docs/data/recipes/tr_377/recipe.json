  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C / 400°F (180°C fan-forced)."
    },
    {
      "order": 2,
      "instruction": "Coat chicken - Mix the marinade ingredients in a bowl, then add the chicken and toss to coat."
    },
    {
      "order": 3,
      "instruction": "Optional marinade - overnight. (Note 5)"
    },
    {
      "order": 4,
      "instruction": "Assemble - Mix Sauce ingredients in a 23 x 33cm / 9 x 13&quot; baking dish. Place chicken in, smooth side up. Scrape residual marinade out of bowl and dab onto chicken surface."
    },
    {
      "order": 5,
      "instruction": "Bake 45 minutes, basting with sauce at the 30 minute and 40 minute mark. The sauce will change from pink to orangey-red (Note 6 for sauce thickening)."
    },
    {
      "order": 6,
      "instruction": "Serve - Rest for 5 minutes. Then serve over basmati rice, garnished with coriander if desired! Naan for mopping would make everyone extra happy. :)"
    }
  ]
