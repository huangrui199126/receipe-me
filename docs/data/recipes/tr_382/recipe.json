  "steps": [
    {
      "order": 1,
      "instruction": "Remove reedy outer layers and trim lemongrass per Note 1.&nbsp;"
    },
    {
      "order": 2,
      "instruction": "Reserve all the trimmings (for beef). Finely chop the white part (for paste."
    },
    {
      "order": 3,
      "instruction": "Place Beef ingredients in a medium saucepan. Liquid should almost cover beef but not completely - if not, add water."
    },
    {
      "order": 4,
      "instruction": "Add lemongrass trimmings."
    },
    {
      "order": 5,
      "instruction": "Bring to boil over high heat, then reduce heat and simmer gently for 1.5 - 2 hours until beef is fork tender."
    },
    {
      "order": 6,
      "instruction": "Remove beef. If there's much more than 1.5 cups liquid, simmer to reduce. Set liquid aside."
    },
    {
      "order": 7,
      "instruction": "Place heavy based skillet over high heat until smoking (no oil)."
    },
    {
      "order": 8,
      "instruction": "Add eschalot, garlic and galangal in skillet. Get a nice char on them, then remove (~1.5 minutes)."
    },
    {
      "order": 9,
      "instruction": "Add dried chillies into skillet, char 10 seconds or so on each side until charred, then remove."
    },
    {
      "order": 10,
      "instruction": "Once cool enough to handle: Grate galangal. Peel garlic.&nbsp;Break chillies in half, shake out seeds and discard."
    },
    {
      "order": 11,
      "instruction": "Wipe the skillet used above or use a clean one. Heat on medium heat, add&nbsp;Spice Paste Dried Spices. Toast for 30 seconds or until they start to smell fragrant - do not let them burn. Immediately transfer into bowl."
    },
    {
      "order": 12,
      "instruction": "Place chillies in food processor. (Note 8) Blitz until finely chopped."
    },
    {
      "order": 13,
      "instruction": "Add galangal, finely chopped lemongrass, the toasted Spice Paste Dried Spices, and remaining Spice Paste ingredients, starting with 4 tbsp water.&nbsp;Blitz until smooth - add more water if required."
    },
    {
      "order": 14,
      "instruction": "Place oil in a pot or large skillet over medium high heat. Add curry paste and cook for 3 minutes until the liquid has cooked out and it's thick and fragrant."
    },
    {
      "order": 15,
      "instruction": "Add coconut milk, stir to incorporate."
    },
    {
      "order": 16,
      "instruction": "Add cinnamon, star anise and reserved beef braising liquid. Reduce heat to medium and simmer for 3 minutes."
    },
    {
      "order": 17,
      "instruction": "Stir in fish sauce, tamarind and sugar, stir."
    },
    {
      "order": 18,
      "instruction": "Add potatoes and cook for 7 minutes or until potatoes are tender, turning as required."
    },
    {
      "order": 19,
      "instruction": "Add beef and simmer for 2 minutes or until sauce has reduced and thickened."
    },
    {
      "order": 20,
      "instruction": "Adjust: saltiness with fish sauce, sour with tamarind and sweet with sugar.&nbsp;The taste should be sweet, salty and sour, with more emphasis on the sweet and sour notes. Top up with a little water if the curry seems too thick"
    },
    {
      "order": 21,
      "instruction": "Serve over jasmine rice, garnished with peanuts (essential!) plus optional crispy Asian shallots and fresh chillies."
    }
  ]
}