  "steps": [
    {
      "order": 1,
      "instruction": "Place Dressing ingredients and Optional Flavourings in a jar and shake well until mustard dissolves."
    },
    {
      "order": 2,
      "instruction": "Makes enough for a big leafy salad for 4 people (4 big handfuls of lettuce), or garden salad."
    },
    {
      "order": 3,
      "instruction": "Storage: Excluding garlic and fresh herbs, Dressing will keep for weeks in the fridge - just give it a good shake before using. Big batch - click servings and slide."
    },
    {
      "order": 4,
      "instruction": "Use to dress any fresh salad (make sure leaves are dry otherwise it won&#x27;t stick) or steamed, boiled or roasted vegetables (douse while hot so it absorbs!). Drizzle and toss well just before serving."
    }
