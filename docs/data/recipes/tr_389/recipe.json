  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large skillet over high heat. Add garlic and onion - cook 2 minutes until golden."
    },
    {
      "order": 3,
      "instruction": "Add beef and cook for 2 minutes, breaking it up as you go, until it changes from red to light brown."
    },
    {
      "order": 4,
      "instruction": "Add Taco Seasonings and cook for 2 minutes until beef is cooked through."
    },
    {
      "order": 5,
      "instruction": "Add tomato paste and water. Cook for 1 minute or until water is evaporated and you're left with a juicy not not watery beef filling."
    },
    {
      "order": 6,
      "instruction": "Place taco shells in a baking pan (I can fit 10 in). Fill with taco meat, top with cheese."
    },
    {
      "order": 7,
      "instruction": "Bake 5 to 7 minutes until cheese is melted by which time the shells with be crispy."
    },
    {
      "order": 8,
      "instruction": "Serve tacos hot, straight out of the oven. Lay out toppings and sauces of choice on the table and let everyone assemble their own!"
    }
  ]
