  "steps": [
    {
      "order": 1,
      "instruction": "Place broth, creamed corn, soy sauce, Chinese cooking wine, ginger, garlic and cornflour / water mixture in a saucepan over high heat."
    },
    {
      "order": 2,
      "instruction": "Bring to boil, then turn down the heat to medium and stir occasionally. Cook for 5 minutes or until slightly thickened."
    },
    {
      "order": 3,
      "instruction": "Adjust seasoning with salt, turn off heat, and slowly whisk in the egg so it cooks in \"ribbons\" throughout the soup. This also thickens the soup."
    },
    {
      "order": 4,
      "instruction": "Add the chicken, season with white pepper, and serve, garnished with scallions."
    }
  ]
