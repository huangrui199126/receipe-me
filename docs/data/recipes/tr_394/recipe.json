  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F (all types)."
    },
    {
      "order": 2,
      "instruction": "Peel and cut the potatoes into 1 3/4 cm / 2/3\" cubes. Place in a large bowl."
    },
    {
      "order": 3,
      "instruction": "Add all remaining ingredients except mozzarella. Mix."
    },
    {
      "order": 4,
      "instruction": "Pour into a 3 litre / quart baking dish (mine is 22cm / 9\" square x 6 cm / 2.3\" high)."
    },
    {
      "order": 5,
      "instruction": "Cover with foil. Bake 60 minutes, or until potatoes are tender."
    },
    {
      "order": 6,
      "instruction": "Remove foil, sprinkle over mozzarella cheese. Bake for 25 minutes or until cheese is golden."
    },
    {
      "order": 7,
      "instruction": "Rest for 5 - 10 minutes before serving, garnished with extra theme leaves if desired."
    }
  ]
