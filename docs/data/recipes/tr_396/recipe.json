  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F."
    },
    {
      "order": 2,
      "instruction": "Crunchy Topping - Mix together."
    },
    {
      "order": 3,
      "instruction": "Cook pasta per packet directions MINUS 1 minute. Drain then allow to cool slightly, then return into pot."
    },
    {
      "order": 4,
      "instruction": "White Sauce - Melt butter in a large pot over medium heat. Add garlic and cook for 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Add flour and stir into melted butter. While whisking, gradually pour in about 1/3 of the milk. Once the flour-butter mixture is incorporated into the milk, pour in remaining milk and whisk."
    },
    {
      "order": 6,
      "instruction": "Add Vegeta, mustard, onion and garlic powder, whisk."
    },
    {
      "order": 7,
      "instruction": "When the milk starts to heat up, whisk constantly to make sure the white sauce doesn’t catch on the base."
    },
    {
      "order": 8,
      "instruction": "After 4 - 5 minutes, the sauce should be thick enough that you can draw a path across the back of a spoon (see video). Remove from stove and stir in parmesan."
    },
    {
      "order": 9,
      "instruction": "Assemble &amp; Bake - Add tuna into pasta and flake into large chunks with fork (not too much, don&#x27;t want it to turn to mush when stirred). Add corn, pour over sauce, then gently stir."
    },
    {
      "order": 10,
      "instruction": "Scrape into baking dish, top with Crunchy Topping."
    },
    {
      "order": 11,
      "instruction": "Bake 25 minutes until top is golden and edges are bubbling. Sprinkle with chives if desired then serve!"
    }
  ]
}