      "section": "",
      "order": 1
    },
    {
      "amount": "1/2",
      "unit": "cup",
      "name": "cocoa powder (, unsweetened, preferably Dutch Processed, sifted(Note 3))",
      "emoji": "🥄",
      "section": "",
      "order": 2
    },
    {
      "amount": "1/4",
      "unit": "cup",
      "name": "milk  ((any))",
      "emoji": "🥛",
      "section": "",
      "order": 3
    },
    {
      "amount": "1",
      "unit": "tsp",
      "name": "vanilla extract ( (optional))",
      "emoji": "🫙",
      "section": "",
      "order": 4
    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Place butter in the bowl of a stand mixer with paddle attached. Beat for 3 minutes on speed 7 until it becomes pale."
    },
    {
      "order": 2,
      "instruction": "Add half the icing sugar and cocoa powder. Beat for 3 minutes - start slow, increase to speed 7."
    },
    {
      "order": 3,
      "instruction": "Add remaining icing sugar and cocoa powder. Beat again for 3 minutes."
    },
    {
      "order": 4,
      "instruction": "Add milk and vanilla if using. Beat again for 1 minute on speed 7."
    },
    {
      "order": 5,
      "instruction": "Spread onto cakes / cupcakes, or spoon into frosting bag and pipe."
    }
  ]
