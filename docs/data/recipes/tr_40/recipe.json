    },
    {
      "order": 4,
      "instruction": "Gently add tofu. Simmer 5 minutes without breaking it up.",
      "imageUri": "https://images.unsplash.com/photo-1466637574441-749b8f19452f?w=600&q=80"
    },
    {
      "order": 5,
      "instruction": "Thicken with cornstarch slurry. Add sesame oil and peppercorn powder.",
      "imageUri": "https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=600&q=80"
    },
    {
      "order": 6,
      "instruction": "Serve over rice, topped with green onion.",
