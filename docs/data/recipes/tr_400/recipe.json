  "steps": [
    {
      "order": 1,
      "instruction": "Char onion &amp; ginger - Heat oil in a 6 litre / 6 quart pot (Note 5) over high heat. Place ginger and onion facedown, leave undisturbed for 2 minutes until they blacken. Turn and leave for another 2 minutes."
    },
    {
      "order": 2,
      "instruction": "Put everything in pot - Add water and remaining Broth ingredients EXCEPT salt. Bring it a simmer, then lower heat so it&#039;s simmering VERY gently with the lid on, but open a crack (Note 6)."
    },
    {
      "order": 3,
      "instruction": "Simmer gently 1.5 hours. Scoop off scum (dirty foam) that rises to surface once or twice during the simmering."
    },
    {
      "order": 4,
      "instruction": "Strain &amp; measure - Remove chicken, then strain broth into a clean pot - you should have 1.5 litres / 1.5 quarts. If you have more, simmer to reduce. If less, top it up with water."
    },
    {
      "order": 5,
      "instruction": "Salt broth - Add salt, bring broth to a gentle simmer. Broth should be slightly on the salty side - it dilutes when you add the noodles."
    },
    {
      "order": 6,
      "instruction": "Keep broth warm until ready to serve"
    },
    {
      "order": 7,
      "instruction": "Shred chicken meat, discard bones and skin. (Note 6 Leftover Chicken ideas)"
    },
    {
      "order": 8,
      "instruction": "Place Toppings out on the table."
    },
    {
      "order": 9,
      "instruction": "Reheat chicken (can briefly dunk in broth!)."
    },
    {
      "order": 10,
      "instruction": "Prepare noodles per packet directions, just prior to serving. Drain very well (excess water dilutes broth)."
    },
    {
      "order": 11,
      "instruction": "Place noodle in bowls. Top with chicken, ladle over 375ml / 1.5 cups broth. Sprinkle with green onion."
    },
    {
      "order": 12,
      "instruction": "Pile on Toppings of choice, add a squeeze of lime into the broth. Consume immediately!"
    }
  ]
}