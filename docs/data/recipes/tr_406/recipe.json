  "steps": [
    {
      "order": 1,
      "instruction": "Place Chicken Stock ingredients in a medium saucepan over high heat. Bring to simmer, then reduce to medium high.&nbsp;"
    },
    {
      "order": 2,
      "instruction": "Cook for 25 minutes or until chicken flesh is falling off the bone and liquid reduces by about 1/3.&nbsp;"
    },
    {
      "order": 3,
      "instruction": "Discard skin, pull flesh off the bone and place in bowl, discard bone. Set broth aside."
    },
    {
      "order": 4,
      "instruction": "Mix ingredients together in a small bowl. Set aside for 20 minutes."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a large saucepan or small pot over medium low heat. Add garlic and ginger, sauté for 20 seconds, then add lemongrass and chillis. Cook for 1 minute."
    },
    {
      "order": 6,
      "instruction": "Add laksa paste. Turn heat up to medium and cook for 2 minutes, stirring constantly, or until fragrant."
    },
    {
      "order": 7,
      "instruction": "Add chicken stock, coconut milk, fish sauce and 2 tsp of Laksa Chilli Sauce.&nbsp;Place lid on and simmer on for 10 minutes."
    },
    {
      "order": 8,
      "instruction": "Adjust to taste using lime juice (for sour) and fish sauce (for saltiness).&nbsp;Add tofu puffs. Leave on turned off stove with lid on for 5 minutes."
    },
    {
      "order": 9,
      "instruction": "Prepare noodles per packet directions."
    },
    {
      "order": 10,
      "instruction": "Divide noodles between 2 bowls. Top with shredded chicken."
    },
    {
      "order": 11,
      "instruction": "Pour broth over chicken. Top with beansprouts. Sprinkle with Garnishes you choose to use. Serve with Laksa Chilli Sauce on the side."
    }
  ]
