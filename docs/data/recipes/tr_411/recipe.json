  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta: Boil a large pot of water with 2 tsp salt, add pasta."
    },
    {
      "order": 2,
      "instruction": "Chop broccoli: Chop broccoli into small florets."
    },
    {
      "order": 3,
      "instruction": "Cook broccoli: Add broccoli into water 1 - 2 minutes before pasta is cooked."
    },
    {
      "order": 4,
      "instruction": "Sauce ingredients in jar: Place Sauce ingredients in a jar with lid."
    },
    {
      "order": 5,
      "instruction": "Reserve pasta water: SCOOP OUT 1 cup pasta cooking water just before draining. Then drain and return pasta back into same pot on turned off stove."
    },
    {
      "order": 6,
      "instruction": "Add pasta water into Sauce: Add 1/2 cup pasta water to Pasta Sauce jar, shake well."
    },
    {
      "order": 7,
      "instruction": "Add Sauce &amp; Cheese to pasta: Pour Sauce and add cheese into pot with pasta."
    },
    {
      "order": 8,
      "instruction": "Stir then serve! Stir vigorously, adding more pasta water if required. Add more salt and pepper if required. Serve immediately, garnished with parmesan."
    }
  ]
