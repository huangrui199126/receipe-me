  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 275°C/530°F, or as high as it will go. Place oven shelf in top third of oven."
    },
    {
      "order": 2,
      "instruction": "Stretch dough to form pizza base and slide onto baking pan."
    },
    {
      "order": 3,
      "instruction": "Follow topping directions below, then place in oven."
    },
    {
      "order": 4,
      "instruction": "Turn pizza at 4 minutes so it cooks evenly, and check at 8 minutes (even if recipe says 10 minutes). Take out early if cheese gets too brown."
    },
    {
      "order": 5,
      "instruction": "Spread pizza sauce over base, followed by cheese."
    },
    {
      "order": 6,
      "instruction": "Distribute pepperoni over pizza, and bake."
    },
    {
      "order": 7,
      "instruction": "Spread pizza sauce over base, followed by cheese."
    },
    {
      "order": 8,
      "instruction": "Scatter remaining ingredients over pizza, and bake."
    },
    {
      "order": 9,
      "instruction": "Spread pizza sauce over base, followed by cheese."
    },
    {
      "order": 10,
      "instruction": "Scatter remaining ingredients over pizza, and bake."
    },
    {
      "order": 11,
      "instruction": "Spread barbecue sauce over base, followed by cheese."
    },
    {
      "order": 12,
      "instruction": "Scatter remaining ingredients over pizza, and bake."
    },
    {
      "order": 13,
      "instruction": "Toss prawns/shrimp with salt."
    },
    {
      "order": 14,
      "instruction": "Heat butter over medium heat in a skillet or heavy frying pan until frothing. Add garlic and cook for another 30 seconds."
    },
    {
      "order": 15,
      "instruction": "Cook prawns for 1 minute on one side until just starting to brown. Flip prawns, cook 1 minute more and remove. Reserve garlic butter."
    },
    {
      "order": 16,
      "instruction": "Spread pizza sauce over base, followed by cheese."
    },
    {
      "order": 17,
      "instruction": "Scatter remaining ingredients except rocket over pizza, top with prawns. Bake until done."
    },
    {
      "order": 18,
      "instruction": "Drizzle reserved garlic butter over prawns and scatter with rocket."
    },
    {
      "order": 19,
      "instruction": "Spread pizza sauce over base, followed by cheese."
    },
    {
      "order": 20,
      "instruction": "Scatter remaining ingredients over pizza, and bake. (Note 2)"
    },
    {
      "order": 21,
      "instruction": "Spread pizza sauce over base. Drizzle 1 tbsp of oil over base, and bake."
    },
    {
      "order": 22,
      "instruction": "After 5 minutes, remove pizza from oven. Tear buffalo mozzarella into 10 pieces and distribute over pizza. Continue baking until pizza is done."
    },
    {
      "order": 23,
      "instruction": "Drizzle with remaining olive oil, and scatter with basil leaves."
    },
    {
      "order": 24,
      "instruction": "See recipe directions in the separate recipe here."
    },
    {
      "order": 25,
      "instruction": "Spread mozzarella cheese over base. Scatter provolone, parmesan and finally blue cheese over pizza. Bake."
    },
    {
      "order": 26,
      "instruction": "Spread pizza sauce over base, followed by cheese. Drizzle 1 tbsp oil over pizza and bake."
    },
    {
      "order": 27,
      "instruction": "2 minutes before the pizza is done, remove from oven. Drape prosciutto casually around the pizza."
    },
    {
      "order": 28,
      "instruction": "Continue baking until done. Scatter rocket over pizza and drizzle with a little more olive oil."
    },
    {
      "order": 29,
      "instruction": "See recipe directions in the separate recipe here."
    },
    {
      "order": 30,
      "instruction": "Spread mozzarella cheese over base."
    },
    {
      "order": 31,
      "instruction": "Arrange potato slices over pizza, each slice overlapping no more than 1/3 so it will cook through properly."
    },
    {
      "order": 32,
      "instruction": "Sprinkle over the rosemary and salt, and drizzle with the olive oil. Bake for the standard cooking time given. Check with a fork or skewer that the potato is tender. If not fully cooked, cook another 2 minutes."
    }
  ]
}