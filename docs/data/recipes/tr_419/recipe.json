  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan-forced). Grease a 22.5cm / 9&quot; pie dish with butter or spray lightly with oil. (Note 4)"
    },
    {
      "order": 2,
      "instruction": "Whisk eggs, cream, salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Scatter most of the ham, cheese and green onion in the pie pan."
    },
    {
      "order": 4,
      "instruction": "Pour in egg mixture. Top with remaining ham, cheese and green onion."
    },
    {
      "order": 5,
      "instruction": "Bake 35 minutes until golden on top and centre barely wiggles. Don&#39;t overcook, it will lose custardy-ness."
    },
    {
      "order": 6,
      "instruction": "Remove from oven, rest 5 minutes and watch it deflate!"
    },
    {
      "order": 7,
      "instruction": "Cut then serve with a simple side salad, or stuff into soft rolls, or wrap into burritos (then pan fry to crisp!)"
    }
