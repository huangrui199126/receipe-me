  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce."
    },
    {
      "order": 2,
      "instruction": "Sauté onion and garlic - Heat oils in a medium skillet over high heat. Add onion and garlic, cook for 1 1/2 minutes until starting to go golden."
    },
    {
      "order": 3,
      "instruction": "Cook beef - Add beef and cook, breaking it up as you go, until it changes from pink to light brown."
    },
    {
      "order": 4,
      "instruction": "Caramelise beef - Add Sauce and cook for 2 to 3 minutes until well caramelised (see video)."
    },
    {
      "order": 5,
      "instruction": "Add water and noodles - Push beef to the side to make enough space for the noodles. Add water, place noodles in water."
    },
    {
      "order": 6,
      "instruction": "Cook ramen - Leave for 45 seconds then turn. Leave for 30 seconds, then untangle the noodles, then toss through the beef."
    },
    {
      "order": 7,
      "instruction": "Add beansprouts, toss for 1 minute or until sauce reduces to coat the noodles and the noodles are cooked. (Note 7)"
    },
    {
      "order": 8,
      "instruction": "Serve immediately, garnished with green onions and sesame seeds."
    }
  ]
