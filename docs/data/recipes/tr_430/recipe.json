  "steps": [
    {
      "order": 1,
      "instruction": "Preheat BBQ (grill side) until very hot."
    },
    {
      "order": 2,
      "instruction": "Peel husk off the corn."
    },
    {
      "order": 3,
      "instruction": "Place corn on the BBQ (no oil required)."
    },
    {
      "order": 4,
      "instruction": "Cook for 10 minutes, turning every couple of minutes, until there's little charred bits and the kernels are tender when pierced with a knife, but still JUICY! Overcooked corn is shrivelled, dry and sad."
    },
    {
      "order": 5,
      "instruction": "In the last minute, brush with melted butter and roll around."
    },
    {
      "order": 6,
      "instruction": "Serve corn with softened butter, sprinkled with parsley if desired!"
