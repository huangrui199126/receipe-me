  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Sprinkle chicken with garlic powder, salt and pepper on both sides."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large skillet over medium heat. Place chicken in skillet smooth side down."
    },
    {
      "order": 3,
      "instruction": "Press down lightly with with spatula. Cook for 4 minutes until golden."
    },
    {
      "order": 4,
      "instruction": "Turn and press lightly with spatula. Cook for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Remove chicken onto a plate."
    },
    {
      "order": 6,
      "instruction": "Turn heat up to medium high. Add butter, melt. Then add onions, cook for 1 minute, then add mushrooms."
    },
    {
      "order": 7,
      "instruction": "Cook mushrooms until golden. Scrape bottom of fry pan to get all the golden bits off (this is flavour!)."
    },
    {
      "order": 8,
      "instruction": "Add flour, cook, stirring, for 1 minute."
    },
    {
      "order": 9,
      "instruction": "Add half the broth while stirring. Once incorporated, add remaining broth."
    },
    {
      "order": 10,
      "instruction": "Stir, then add sour cream and mustard. Stir until incorporated (don't worry if it looks split, sour cream will \"melt\" as it heats)."
    },
    {
      "order": 11,
      "instruction": "Bring to simmer ,then reduce heat to medium low. Once it thickens to the consistency of pouring cream (3 minutes), adjust salt and pepper to taste."
    },
    {
      "order": 12,
      "instruction": "Add chicken back in (including plate juices). Simmer for 1 minute, then remove from stove."
    },
    {
      "order": 13,
      "instruction": "Serve over pasta or egg noodles, sprinkled with parsley or chives if desired."
    }
  ]
}