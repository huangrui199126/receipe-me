    },
    {
      "amount": "",
      "unit": "",
      "name": "1  large onion (, chopped)",
      "emoji": "🧅",
      "section": "",
      "order": 4
    },
    {
      "amount": "300",
      "unit": "g",
      "name": "/ 10oz   mushrooms (, sliced (not too thin))",
