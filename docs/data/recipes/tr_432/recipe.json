  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 170C/335F (standard) / 150C/305F (fan forced / convection)."
    },
    {
      "order": 2,
      "instruction": "Grease a 5 - 6 cup baking dish with butter. (Note 3)"
    },
    {
      "order": 3,
      "instruction": "Topping: Whisk brown sugar and cocoa in a bowl, set aside."
    },
    {
      "order": 4,
      "instruction": "Whisk flour, baking powder, caster sugar, cocoa powder and salt in a bowl."
    },
    {
      "order": 5,
      "instruction": "In a separate bowl or jug, whisk together the butter and milk, then whisk in the egg and vanilla."
    },
    {
      "order": 6,
      "instruction": "Pour the egg mixture into the flour mixture. Mix until combined - it will be a thick batter."
    },
    {
      "order": 7,
      "instruction": "Spread into baking dish. Sprinkle with sugar / cocoa mixture. Shake gently to spread out thinly."
    },
    {
      "order": 8,
      "instruction": "Carefully pour the hot water over the back of a dessert spoon all over the top of the pudding - see photo in post or video below recipe. (Note 4)"
    },
    {
      "order": 9,
      "instruction": "Transfer to oven and bake for 30 minutes, or until the top of the cake springs back when poked lightly. The top will be a bit crusty, like the top of brownies."
    },
    {
      "order": 10,
      "instruction": "Remove from oven, stand for just a few minutes (no more!), then serve immediately. (Note 5)"
    }
  ]
}