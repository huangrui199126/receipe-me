  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade in a large pot (about 26cm / 11\" diameter). Add chicken and coat well. Marinade 20 minutes to overnight."
    },
    {
      "order": 2,
      "instruction": "Bring 3 litres / 3 quarts water to the boil, add salt and spices."
    },
    {
      "order": 3,
      "instruction": "Add rice, bring back up to the boil then cook for 4 minutes, or until rice is just cooked still a bit firm in the middle. Rice will taste salty at this stage, disappears in next stage of cooking."
    },
    {
      "order": 4,
      "instruction": "Drain immediately. Set aside. (Note 10 re: leaving whole spices in)"
    },
    {
      "order": 5,
      "instruction": "Heat oil in a large saucepan over medium high heat. Cook onion, in batches, for 3 to 4 minutes, until golden brown. Don't burn - they become bitter."
    },
    {
      "order": 6,
      "instruction": "Remove onto paper towel lined plate. Repeat with remaining onion."
    },
    {
      "order": 7,
      "instruction": "Place in a bowl, leave for 10 minutes+."
    },
    {
      "order": 8,
      "instruction": "Place pot with chicken in it onto a stove over medium heat. Cover and cook for 5 minutes."
    },
    {
      "order": 9,
      "instruction": "Remove lid. Cook for 5 minutes, turning chicken twice."
    },
    {
      "order": 10,
      "instruction": "Remove from heat."
    },
    {
      "order": 11,
      "instruction": "Turn chicken so skin side is down - it should cover most of the base of the pot."
    },
    {
      "order": 12,
      "instruction": "Scatter over half the onion then half the coriander."
    },
    {
      "order": 13,
      "instruction": "Top with all the rice. Gently pat down and flatten surface."
    },
    {
      "order": 14,
      "instruction": "Drizzle saffron across rice surface in random pattern, then drizzle over ghee."
    },
    {
      "order": 15,
      "instruction": "Place lid on. Return to stove over medium heat."
    },
    {
      "order": 16,
      "instruction": "As soon as you see steam, turn down to low then cook for 25 minutes."
    },
    {
      "order": 17,
      "instruction": "Remove from stove, rest with lid on for 10 minutes."
    },
    {
      "order": 18,
      "instruction": "Aim to serve it so you get nice patches of yellow rice, white rice, the curry stained rice + chicken (rather than all mixed up). To do this, use a large spoon and dig deep into the pot, and try to scoop up as much as you can in one scoop."
    },
    {
      "order": 19,
      "instruction": "Turn out into bowl - or onto platter. Garnish with remaining onion and coriander with yoghurt on the side (see Note 7 for Minted Yoghurt)"
    }
  ]
