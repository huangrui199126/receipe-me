  "steps": [
    {
      "order": 1,
      "instruction": "Cook lobster tails. Remove meat, reserve shells.",
      "imageUri": "https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=600&q=80"
    },
    {
      "order": 2,
      "instruction": "Simmer shells in broth 20 minutes. Strain and reserve stock.",
      "imageUri": "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80"
    },
    {
      "order": 3,
      "instruction": "Sauté shallots and garlic in butter. Add tomato paste.",
      "imageUri": "https://images.unsplash.com/photo-1507048331197-7d4ac70811cf?w=600&q=80"
    },
    {
      "order": 4,
      "instruction": "Flambé with brandy, then add white wine and lobster stock.",
      "imageUri": "https://images.unsplash.com/photo-1466637574441-749b8f19452f?w=600&q=80"
    },
    {
      "order": 5,
      "instruction": "Add cream and simmer until slightly thickened. Blend until smooth.",
      "imageUri": "https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=600&q=80"
    },
    {
      "order": 6,
      "instruction": "Add lobster meat. Season with cayenne and serve garnished with cream.",
      "imageUri": "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=600&q=80"
    }
