  "steps": [
    {
      "order": 1,
      "instruction": "Marinade fish: Combine Fish Marinade ingredients in a ziplock bag. Set aside for 20 minutes to marinate - no longer than 1 hour."
    },
    {
      "order": 2,
      "instruction": "Pickled Cabbage: Place Pickled Cabbage ingredients in a bowl. Toss to combine and set aside for 30 minutes. Drain excess liquid, scrunch cabbage with your hands (to help soften). Set aside."
    },
    {
      "order": 3,
      "instruction": "Pink Sauce: Mix to combine."
    },
    {
      "order": 4,
      "instruction": "Cook fish: Heat oil in a skillet over high heat. Cook fish for 2 minutes on each side, or until golden and cooked."
    },
    {
      "order": 5,
      "instruction": "Remove fish onto plate then flake into large pieces."
    },
    {
      "order": 6,
      "instruction": "To assemble tacos, top with cabbage then fish, a dollop of sour cream and a squeeze of lime juice. Fold tortilla over and enjoy!"
    }
  ]
