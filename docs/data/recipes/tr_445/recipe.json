  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta - Bring 3 litres of water to the boil with the salt. Cook for the pasta packet time + 1 minute. Drain in a colander, rinse under cold water. Shake off excess water well, then allow to fully cool and dry."
    },
    {
      "order": 2,
      "instruction": "Pesto - Place all ingredients in a tall jug just large enough to fit the head of a stick blender. Blitz under pretty smooth. Not a green smoothie, we still want some visible green bits! but not chunks."
    },
    {
      "order": 3,
      "instruction": "Toss - Place pasta in a bowl, scrape in the pesto. Add mayonnaise then toss well. Add bocconcini and tomato, toss gently just to disperse. Add rocket/arugula and toss just to disperse."
    },
    {
      "order": 4,
      "instruction": "Serve - Transfer into a serving bowl. Scatter with basil leaves, if using. Serve!"
    }
  ]
