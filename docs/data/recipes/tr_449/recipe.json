  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan). Grease a 20cm/8” round cake pan (or springform pan) with butter then line with paper."
    },
    {
      "order": 2,
      "instruction": "Melt butter - Place the butter in a large microwavable bowl and melt in the microwave. Let cool for a couple of minutes."
    },
    {
      "order": 3,
      "instruction": "Wet ingredients - Add egg, vanilla and sugar and whisk until combined."
    },
    {
      "order": 4,
      "instruction": "Dry ingredients - Add almond meal, salt, baking powder, coconut and lemon zest. Whisk until combined."
    },
    {
      "order": 5,
      "instruction": "Bake 40 minutes - Pour into pan. Sprinkle over almonds. Bake 40 minutes. Cool 15 minutes in pan then carefully turn out onto cooling rack."
    },
    {
      "order": 6,
      "instruction": "Cool at least 1 hour before cutting slices to serve. Moist enough to serve plain - doesn&#39;t need cream or anything!"
    }
  ]
