  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F. Lightly spray baking tray with oil."
    },
    {
      "order": 2,
      "instruction": "Cut puff pastry into 4 pieces and place on baking tray. Bake for 15 minutes until puffed and golden. Remove from oven and set aside."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, melt butter in large pan over high heat."
    },
    {
      "order": 4,
      "instruction": "Add onion and garlic cloves and sauté for 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add bacon and chicken and cook for 2 to 3 minutes until chicken is lightly browned but still not cooked through inside."
    },
    {
      "order": 6,
      "instruction": "Add marsala and cook for 30 seconds to allow the alcohol to cook out. Most of the marsala should evaporate."
    },
    {
      "order": 7,
      "instruction": "Add the broccoli, peas, corn and carrots and stir to combine."
    },
    {
      "order": 8,
      "instruction": "Sprinkle the flour over and add milk, stirring to dissolve the flour into the milk."
    },
    {
      "order": 9,
      "instruction": "Bring to simmer then stir through cheese, salt and pepper. Adjust salt to your taste."
    },
    {
      "order": 10,
      "instruction": "Simmer, stirring for 30 seconds to 1 minute until the sauce is thickened, then remove from heat."
    },
    {
      "order": 11,
      "instruction": "To serve, divide the chicken filling between 4 plates and top with a piece of puff pastry."
    }
  ]
}