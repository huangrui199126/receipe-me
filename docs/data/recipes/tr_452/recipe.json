  "steps": [
    {
      "order": 1,
      "instruction": "Frozen shortcrust pastry or homemade quiche crust - prepare and bake the crust per Quiche Crust recipe (23cm / 9\" quiche tin)."
    },
    {
      "order": 2,
      "instruction": "Prepared pie shell - bake per packet directions."
    },
    {
      "order": 3,
      "instruction": "Preheat oven to 200C/390F (standard) or 180C/350F (fan / convection)."
    },
    {
      "order": 4,
      "instruction": "Melt butter in a skillet over medium high heat. Add onion, garlic and bacon. Cook until bacon is light golden."
    },
    {
      "order": 5,
      "instruction": "Transfer to a paper towel lined bowl and leave to cool."
    },
    {
      "order": 6,
      "instruction": "Place ingredients in a bowl and whisk to combine."
    },
    {
      "order": 7,
      "instruction": "Place quiche tin with cooked quiche crust on tray. Scatter cooled Bacon Filling evenly across base of cooked quiche crust."
    },
    {
      "order": 8,
      "instruction": "Scatter cheese evenly across top."
    },
    {
      "order": 9,
      "instruction": "Carefully pour Egg mixture over the top. Push some of the cheese/bacon below the surface."
    },
    {
      "order": 10,
      "instruction": "Bake for 35 - 40 minutes until the top is golden. The centre should still jiggly."
    },
    {
      "order": 11,
      "instruction": "Garnish with Extra Bacon, if using. Rest for 10 minutes before removing from the pan to cut and serve.&nbsp;"
    }
  ]
