  "steps": [
    {
      "order": 1,
      "instruction": "Sauté - Heat oil in a large heavy based pot over medium high heat. Add onion and garlic, cook for 2 minutes until soft."
    },
    {
      "order": 2,
      "instruction": "Add curry paste and cook for 2 minutes."
    },
    {
      "order": 3,
      "instruction": "Add pumpkin and stir to coat in the flavours for around 2 minutes."
    },
    {
      "order": 4,
      "instruction": "Simmer 8 minutes - Set aside 1/4 cup coconut milk for garnish. Add stock, remaining coconut milk and fish sauce. Bring to simmer then reduce heat to medium and simmer for 8 minutes until the pumpkin is soft."
    },
    {
      "order": 5,
      "instruction": "Blitz using stick blender until smooth."
    },
    {
      "order": 6,
      "instruction": "Serve topped with garnishes. Dunk in roti. Enjoy!"
    }
  ]
}