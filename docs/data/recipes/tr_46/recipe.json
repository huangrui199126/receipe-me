  "steps": [
    {
      "order": 1,
      "instruction": "Defrost the spinach in the microwave (4 minutes on high), then squeeze out excess water."
    },
    {
      "order": 2,
      "instruction": "Make Egg mixture: Place ingredients into a bowl and whisk until combined."
    },
    {
      "order": 3,
      "instruction": "Spread half the bread into the base of a baking dish 25cm x 25cm (10\" x 10\")."
    },
    {
      "order": 4,
      "instruction": "Layer with the spinach, then chicken then top with half the cheese."
    },
    {
      "order": 5,
      "instruction": "Top with remaining bread. Squish the bread down to compress (this helps the egg mixture to be soaked up evenly)."
    },
    {
      "order": 6,
      "instruction": "Pour over egg mixture - try to cover all the bread evenly."
    },
    {
      "order": 7,
      "instruction": "Top with remaining cheese, then squish down to help the bread soak up the egg mixture."
    },
    {
      "order": 8,
      "instruction": "Set aside for at least 15 minutes, preferably 30 minutes."
    },
    {
      "order": 9,
      "instruction": "To freeze: Cover tightly and place in freezer. Defrost completely before cooking."
    },
    {
      "order": 10,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 11,
      "instruction": "Cover baking dish with foil and bake for 20 minutes. Remove foil, then bake for a further 10 minutes until golden on top."
    },
    {
      "order": 12,
      "instruction": "Serve immediately, sprinkled with parsley if desired."
    }
  ]
}