  "steps": [
    {
      "order": 1,
      "instruction": "Carrot: cut in half lengthwise then diagonally sliced 2mm / 1/10&quot; thick"
    },
    {
      "order": 2,
      "instruction": "Buk Choy (Note 1): Trim base off, then cut leaves off the stem. Cut the stem lengthwise into 1cm / 2/5&quot; wide pieces. Keep leaves separate from stems, they will be cooked at different times."
    },
    {
      "order": 3,
      "instruction": "Place cornflour and soy sauce in a bowl and mix until cornflour is dissolved, then mix in remaining Sauce ingredients."
    },
    {
      "order": 4,
      "instruction": "Heat oil in a wok or large heavy based skillet over high heat."
    },
    {
      "order": 5,
      "instruction": "Add garlic and ginger, stir for 10 seconds. Add onion, stir for 30 seconds."
    },
    {
      "order": 6,
      "instruction": "Add carrot, capsicum and stems of buk choy - stir for 1 minute."
    },
    {
      "order": 7,
      "instruction": "Add mushrooms, then stir for 2 to 3 minutes until the vegetables are almost cooked."
    },
    {
      "order": 8,
      "instruction": "Add Sauce and toss for 1 minute until Sauce thickens and becomes glossy, coating all the vegetables. Don&#x27;t overcook so they become floppy and limp - they should be just cooked, &quot;crisp tender&quot;."
    },
    {
      "order": 9,
      "instruction": "Remove from stove and serve over rice (low carb option: cauliflower rice). Garnish with green onions and sesame seeds if using. A big dollop of chilli sauce wouldn&#x27;t go astray either!"
    }
  ]
