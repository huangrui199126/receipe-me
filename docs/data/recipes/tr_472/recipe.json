  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/390°F (all oven types) (Note 4). Line a 12 hole muffin tin with paper patties."
    },
    {
      "order": 2,
      "instruction": "Whisk Dry: Whisk flour, baking powder, baking soda, sugar and salt in a bowl."
    },
    {
      "order": 3,
      "instruction": "Whisk Wet: In a separate bowl, whisk buttermilk, melted butter, oil, eggs and vanilla."
    },
    {
      "order": 4,
      "instruction": "Combine Wet &amp; Dry: Make a well in the flour bowl, pour in egg mixture. Mix until just combine - try not to stir more than 8 times. Some flour lumps in the batter is fine."
    },
    {
      "order": 5,
      "instruction": "Add blueberries: Stir through most of the blueberries - reserve some for topping."
    },
    {
      "order": 6,
      "instruction": "Fill muffin tin: Divide batter between paper cases. Top with remaining blueberries."
    },
    {
      "order": 7,
      "instruction": "Bake 1: Bake for 5 minutes, then turn oven down to 180°C/350°F."
    },
    {
      "order": 8,
      "instruction": "Bake 2: Bake for a further 13 minutes (fan) or 15 minutes (standard ovens), or until a skewer inserted into the muffin comes out clean."
    },
    {
      "order": 9,
      "instruction": "Cool: Remove muffins from the muffin tin immediately onto a cooling rack. Serve warm or at room temperature (warm is extra yum!)"
    }
  ]
}