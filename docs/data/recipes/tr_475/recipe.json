  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large saucepan over medium heat. Add garlic, stir briefly, then add onion. Cook for 4 - 5 minutes until translucent (not browned / golden)."
    },
    {
      "order": 2,
      "instruction": "Add rice, broth, salt and tomato paste. Stir until tomato paste is dissolved."
    },
    {
      "order": 3,
      "instruction": "Plonk in jalapeno and coriander. Cover, bring to simmer, then lower heat to low so the water is simmering gently."
    },
    {
      "order": 4,
      "instruction": "Cook for 15 minutes or until the liquid is absorbed (tilt pot to check)."
    },
    {
      "order": 5,
      "instruction": "Remove from heat, leave lid on and rest for 10 minutes (KEY STEP). The residual liquid on the surface of the rice will get absorbed and rice will go from sticky to fluffy."
    },
    {
      "order": 6,
      "instruction": "Fluff with fork then serve! (Optional: garnish with extra coriander)"
    }
  ]
