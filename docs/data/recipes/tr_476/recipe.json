  "steps": [
    {
      "order": 1,
      "instruction": "Place oil and bacon in a large heavy based casserole pot over high heat."
    },
    {
      "order": 2,
      "instruction": "When the oil is heated and bacon releases some fat, add chicken."
    },
    {
      "order": 3,
      "instruction": "Sprinkle with salt and pepper and cook, until chicken and bacon is browned."
    },
    {
      "order": 4,
      "instruction": "Add garlic and onion, cook 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add celery and carrot, cook 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Add red wine, allow to simmer rapidly 2 minutes until the winey alcohol smell is gone."
    },
    {
      "order": 7,
      "instruction": "Add flour, mix until incorporated."
    },
    {
      "order": 8,
      "instruction": "Slowly pour in half the beef broth while stirring, then pour the rest in."
    },
    {
      "order": 9,
      "instruction": "Add tomato, Worcestershire, thyme, bay leaves, salt, pepper."
    },
    {
      "order": 10,
      "instruction": "Stir, add potato."
    },
    {
      "order": 11,
      "instruction": "Cover, simmer 30 minutes."
    },
    {
      "order": 12,
      "instruction": "Remove lid, add mushrooms and green beans. Simmer without lid* for a further 10 minutes."
    },
    {
      "order": 13,
      "instruction": "Serve with crusty bread, sprinkled with parsley if desired!"
    }
  ]
}