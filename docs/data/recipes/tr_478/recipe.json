  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta in a large pot of salted boiling water for time per packet minus 1 1/2 minutes."
    },
    {
      "order": 2,
      "instruction": "Just before draining, scoop out a mugful of pasta cooking water. Then drain pasta."
    },
    {
      "order": 3,
      "instruction": "Sprinkle both sides of chicken with salt and pepper."
    },
    {
      "order": 4,
      "instruction": "Melt half the butter in a large skillet over hig heat."
    },
    {
      "order": 5,
      "instruction": "Add chicken and cook for 2 minutes on each side until deep golden."
    },
    {
      "order": 6,
      "instruction": "Remove chicken onto plate, rest for a few minutes then shred with 2 forks."
    },
    {
      "order": 7,
      "instruction": "Turn down heat to medium high. In the same skillet, add remaining butter and garlic."
    },
    {
      "order": 8,
      "instruction": "Cook garlic for 30 seconds until golden, then add wine."
    },
    {
      "order": 9,
      "instruction": "Simmer rapidly, stirring to scrape the brown bits off the bottom of the pan. Once mostly evaporated, add chicken broth, cream, parmesan and sun dried tomato."
    },
    {
      "order": 10,
      "instruction": "Simmer on medium for 3 - 5 minutes, stirring leisurely, until it reduces and thickens."
    },
    {
      "order": 11,
      "instruction": "Add spinach, chicken and cooked pasta."
    },
    {
      "order": 12,
      "instruction": "Toss for 1 1/2 - 2 minutes on the stove, until sauce thickens and coats the pasta strands (see VIDEO). Use pasta cooking water if needed if it gets too thick."
    },
    {
      "order": 13,
      "instruction": "Serve immediately with parmesan, crumbled bacon and parsley (if desired)."
    }
  ]
}