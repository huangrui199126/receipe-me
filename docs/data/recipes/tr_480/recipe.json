  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (standard) or 180C/350F (fan / convection)."
    },
    {
      "order": 2,
      "instruction": "Place Vegetable ingredients in a large bowl. Toss well to coat."
    },
    {
      "order": 3,
      "instruction": "Add sausages and toss briefly.&nbsp;"
    },
    {
      "order": 4,
      "instruction": "Transfer into roasting pan. Pan should be of a size so the vegetables are stacked about 2 deep - see photos and video. Rearrange sausages so they are on top."
    },
    {
      "order": 5,
      "instruction": "In the same bowl used for the vegetables, add butter and flour. Whisk."
    },
    {
      "order": 6,
      "instruction": "Add a bit of beef broth and whisk, then whisk in remaining broth. (Don't worry if you end up with some floating butter bits)"
    },
    {
      "order": 7,
      "instruction": "Pour down the side of the pan (don't pour over the sausages or veggies)."
    },
    {
      "order": 8,
      "instruction": "Optional: Spray sausages with oil - browns slightly better (especially lean sausages)."
    },
    {
      "order": 9,
      "instruction": "Bake 25 minutes. Turn sausages. Spray again with oil (optional) then bake for a further 25 minutes or until sausages are browned and potatoes are soft."
    },
    {
      "order": 10,
      "instruction": "Serve Sausages and Vegetables with Gravy on top, garnished with fresh thyme leaves if desired. (See notes for Gravy thickness adjustment)"
    }
  ]
}