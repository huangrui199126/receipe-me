  "steps": [
    {
      "order": 1,
      "instruction": "Place the onion, jalapeño, salt and half the coriander on a cutting board and use a fork to mash until juicy. OR do this in a mortar and pestle - grind into a paste."
    },
    {
      "order": 2,
      "instruction": "Scrape into a bowl, add avocado and remaining coriander, and mash to desired consistency."
    },
    {
      "order": 3,
      "instruction": "Do a taste test then adjust to your taste: salt, lime juice for sour, more chilli for spiciness."
    },
    {
      "order": 4,
      "instruction": "If using tomatoes, stir through."
    },
    {
      "order": 5,
      "instruction": "Serve with corn chips!"
