  "steps": [
    {
      "order": 1,
      "instruction": "Preheat the oven to 220°C/425°F (200°C fan-forced)."
    },
    {
      "order": 2,
      "instruction": "Toss &amp; squidge - Place the tomatoes and unpeeled garlic cloves on a tray. Drizzle/sprinkle with the oil, paprika, salt and pepper. Toss to coat, squidging the cut face of the tomato in the oil on the tray to thoroughly coat. Arrange tomatoes cut face up."
    },
    {
      "order": 3,
      "instruction": "Roast for 40 to 45 minutes or until there is some charring on the tomatoes (see photos)."
    },
    {
      "order": 4,
      "instruction": "Sauté - Heat the oil in a large pot over medium high heat. Sauté the garlic and onion for 3 minutes or until the onion is translucent."
    },
    {
      "order": 5,
      "instruction": "Tomatoes - Remove the garlic cloves from the baking tray. Scrape all the tomatoes and juices into the pot. Squeeze garlic flesh into the pot. Add vegetable stock."
    },
    {
      "order": 6,
      "instruction": "Blitz with a stick blender until smooth (or do this in a food processor or blender)."
    },
    {
      "order": 7,
      "instruction": "Simmer - Bring to a simmer then lower heat to medium and simmer for 10 minutes. Stir in the cream."
    },
    {
      "order": 8,
      "instruction": "Ladle into bowls, drizzle with cream and garnish with basil. Dunk in grilled cheese and enjoy!"
    }
  ]
}