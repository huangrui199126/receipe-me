  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F."
    },
    {
      "order": 2,
      "instruction": "Place vegetables on the tray, drizzle with oil, sprinkle with garlic, salt and pepper. Toss."
    },
    {
      "order": 3,
      "instruction": "Roast for 25 minutes, turning at 15 minutes, until tender and browned."
    },
    {
      "order": 4,
      "instruction": "Remove from oven, loosen from tray with spatula while warm (can stick when cools)."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a skillet over medium high heat. Add garlic and onion, cook for 3 minutes until golden."
    },
    {
      "order": 6,
      "instruction": "Add passata, crushed tomato, water, dried herbs, chilli, salt and pepper. Stir. Simmer on medium low heat for 20 minutes. Adjust salt at the end. *Add a teeny touch of sugar if it's a bit sour, depends on quality of tomatoes used.*"
    },
    {
      "order": 7,
      "instruction": "Remove from stove and let cool for 5 minutes before using."
    },
    {
      "order": 8,
      "instruction": "Place ingredients in a bowl and mix until combined."
    },
    {
      "order": 9,
      "instruction": "Preheat oven to 160C/320F."
    },
    {
      "order": 10,
      "instruction": "Spread a ladle of tomato sauce on the base of a large baking dish (Note 5)."
    },
    {
      "order": 11,
      "instruction": "Cover with lasagna sheets, tearing as required to fit."
    },
    {
      "order": 12,
      "instruction": "Top with roasted vegetables, scatter over red peppers. Spoon over 2 1/2 cups of Sauce, then sprinkle with half the cheese."
    },
    {
      "order": 13,
      "instruction": "Cover with lasagna sheets. Spread over Ricotta mixture."
    },
    {
      "order": 14,
      "instruction": "Cover with lasagna sheets. Pour over remaining sauce and sprinkle with remaining cheese."
    },
    {
      "order": 15,
      "instruction": "Bake for 25 - 30 minutes or until the cheese is golden. If using dried lasagna sheets, stick a knife in the middle to ensure it's cooked - if it needs longer, cover and stick it back in the oven."
    },
    {
      "order": 16,
      "instruction": "Rest for 5 minutes before cutting and serving. Store leftovers per notes - brilliant reheated!"
    }
  ]
}