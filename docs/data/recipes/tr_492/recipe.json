  "steps": [
    {
      "order": 1,
      "instruction": "Sauce: Mix ingredients. Set aside 10 minutes+."
    },
    {
      "order": 2,
      "instruction": "Noodles: Pour over boiling water and soak per packet directions. Drain, set aside."
    },
    {
      "order": 3,
      "instruction": "Mix all ingredients except oil until combined."
    },
    {
      "order": 4,
      "instruction": "Shape into 6 mini hamburger patties with your hands."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a skillet over medium high heat. Add patties and cook for 2 1/2 minutes or until golden. Flip, cook 2 minutes then remove."
    },
    {
      "order": 6,
      "instruction": "Place noodles in bowl. Top with a handful of beansprouts, wedge in lettuce, carrots and radish in."
    },
    {
      "order": 7,
      "instruction": "Place meatballs on top, top with coriander and mint."
    },
    {
      "order": 8,
      "instruction": "Spoon over a generous amount of Sauce (it's supposed to be like a soup broth), eat and be happy!"
    }
  ]
