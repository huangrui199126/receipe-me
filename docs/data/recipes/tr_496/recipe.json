  "steps": [
    {
      "order": 1,
      "instruction": "Place marinade in a ziplock bag and mix to combine."
    },
    {
      "order": 2,
      "instruction": "Add salmon and massage to coat. Marinate for 3 - 24 hours (1 hr minimum)."
    },
    {
      "order": 3,
      "instruction": "Take out of fridge 30 minutes prior to cooking."
    },
    {
      "order": 4,
      "instruction": "Remove salmon onto plate, allowing excess marinade to drain off."
    },
    {
      "order": 5,
      "instruction": "Pour remaining marinade into a small saucepan and simmer over medium high for 3 to 5 minutes until syrupy."
    },
    {
      "order": 6,
      "instruction": "Pour into bowl/jug (some used for basting, some for serving)."
    },
    {
      "order": 7,
      "instruction": "Brush BBQ grills with oil. Then preheat to medium (or medium low for strong BBQ's)."
    },
    {
      "order": 8,
      "instruction": "Drizzle salmon with oil, the place onto the BBQ flesh side down (skin side up)."
    },
    {
      "order": 9,
      "instruction": "Cook for 3 minutes or until golden, then use tongs to carefully turn."
    },
    {
      "order": 10,
      "instruction": "Brush the flesh with Sauce, then close BBQ lid.&nbsp;"
    },
    {
      "order": 11,
      "instruction": "Cook for 3 - 4 minutes, basting one more time halfway through, or until the internal temperature is 50C/120F(medium rare) or 55C/130F&nbsp;(medium)."
    },
    {
      "order": 12,
      "instruction": "Transfer salmon to plate and serve with remaining Sauce."
    }
  ]
}