  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large pot over high heat. Add garlic and onion, cook 1 1/2 minutes until onion is translucent."
    },
    {
      "order": 2,
      "instruction": "Add beef and cook, breaking it up as you go, until you no longer see raw meat (about 2 minutes)."
    },
    {
      "order": 3,
      "instruction": "Add Mexican Spices and cook for 30 seconds."
    },
    {
      "order": 4,
      "instruction": "Add capsicum and cook for 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add tomato paste and broth, stir to mix in."
    },
    {
      "order": 6,
      "instruction": "Add rice, corn and black beans."
    },
    {
      "order": 7,
      "instruction": "Stir, bring to simmer then cover and lower heat to medium low (simmering gently). Cook 15 minutes."
    },
    {
      "order": 8,
      "instruction": "Remove lid, quickly stir through green onion and HALF the cheese."
    },
    {
      "order": 9,
      "instruction": "Smooth top then sprinkle on remaining cheese. Cover and leave for 1 minute just to melt cheese."
    },
    {
      "order": 10,
      "instruction": "Remove from stove and serve immediately, garnished with more green onion if desired."
    }
  ]
}