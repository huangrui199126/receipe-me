  "steps": [
    {
      "order": 1,
      "instruction": "Place chickpeas, couscous, vegetable stock powder, coriander and garlic in a large bowl. Pour over hot water, shake to level out couscous (chickpeas should mostly settle on top). Cover with plate or cling wrap, set aside for 5 minutes."
    },
    {
      "order": 2,
      "instruction": "Fluff couscous with fork. Cool a bit."
    },
    {
      "order": 3,
      "instruction": "Add coriander, parsley, onion, sun dried tomatoes (including all oil), rocket, lemon juice and black pepper. Sprinkle zest across surface. Toss well to combine."
    },
    {
      "order": 4,
      "instruction": "Adjust salt and pepper to taste."
    },
    {
      "order": 5,
      "instruction": "Transfer to serving bowl, sprinkle with feta. Serve."
    }
  ]
