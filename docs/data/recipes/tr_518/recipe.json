    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Mix cornflour and soy sauce in a small bowl until cornflour is dissolved. Then mix in remaining Sauce ingredients EXCEPT water."
    },
    {
      "order": 2,
      "instruction": "Pour 1.5 tbsp Sauce over chicken. Toss to coat, set aside for 10 - 20 minutes."
    },
    {
      "order": 3,
      "instruction": "Add water into remaining Sauce."
    },
    {
      "order": 4,
      "instruction": "Heat oil in wok over high heat. Add garlic, ginger and chillies. Cook for 30 seconds or until fragrant."
    },
    {
      "order": 5,
      "instruction": "Add chicken, cook until it turns white, then add the white part of the green onions. Cook until chicken is cooked through - about 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Add Sauce and Sichuan pepper. Bring to simmer, mixing constantly, until almost all the sauce reduces to a thick syrup."
    },
    {
      "order": 7,
      "instruction": "Just before the end, mix through peanuts and green part of the green onions. Also check spiciness - add more Sichuan pepper if you can handle the heat!"
    },
    {
      "order": 8,
      "instruction": "Serve immediately with rice - or for a low carb, low cal option, try Cauliflower Rice!"
    }
  ]
}