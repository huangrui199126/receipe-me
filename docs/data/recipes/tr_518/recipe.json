    },
    {
      "amount": "1.5",
      "unit": "tsp",
      "name": "ground sichuan peppercorns (, adjust to taste (Note 6))",
      "emoji": "🌶️",
      "section": "",
      "order": 14
    },
    {
      "amount": "3/4",
      "unit": "cup",
      "name": "whole peanuts (or 1/2 cup halved) (, roasted unsalted)",
      "emoji": "🧂",
      "section": "",
