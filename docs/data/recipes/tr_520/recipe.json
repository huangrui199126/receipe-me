  "steps": [
    {
      "order": 1,
      "instruction": "Tenderise chicken: Consider tenderising chicken breast using this method. (Not needed for thigh)"
    },
    {
      "order": 2,
      "instruction": "Broccoli: steam or boil using preferred method until cooked to your taste (it won&#39;t cook any further in the stir fry). I usually microwave steam 3 minutes on high. Drain well (waterlogged florets = diluted sauce)."
    },
    {
      "order": 3,
      "instruction": "Sauce: Mix cornflour and soy sauce until lump free, then mix in remaining ingredients."
    },
    {
      "order": 4,
      "instruction": "Cook aromatics: Heat oil in a large skillet over high heat. Add garlic and onion, stir for 10 seconds until garlic starts to go golden."
    },
    {
      "order": 5,
      "instruction": "Cook chicken: Add chicken and cook for 2 minutes or until the chicken is just cooked through."
    },
    {
      "order": 6,
      "instruction": "Thicken sauce: Add broccoli, Sauce and water. Stir well and cook for 1 to 2 minutes until the Sauce thickens and becomes glossy, and coats the ingredients."
    },
    {
      "order": 7,
      "instruction": "Serve over rice!"
    }
  ]
