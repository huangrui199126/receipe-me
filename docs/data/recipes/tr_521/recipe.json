  "steps": [
    {
      "order": 1,
      "instruction": "Split rolls down the centre of the top (see video)."
    },
    {
      "order": 2,
      "instruction": "Spread 1.5 tbsp pate on one side, then 1.5 tbsp mayonnaise on top."
    },
    {
      "order": 3,
      "instruction": "Layer in the hams, cucumber slices and green onion."
    },
    {
      "order": 4,
      "instruction": "Stuff in plenty of carrots and coriander sprigs."
    },
    {
      "order": 5,
      "instruction": "Sprinkle with fresh chilli - as much as you dare!"
    },
    {
      "order": 6,
      "instruction": "Drizzle with Maggi Seasoning (about 1/2 tsp per roll)."
    },
    {
      "order": 7,
      "instruction": "Close sandwich together and devour!"
    },
    {
      "order": 8,
      "instruction": "Banh Mi pork meatballs - for each Banh Mi, use 3 meatballs. Shake off excess sauce, split warm meatballs in half then stuff into Banh Mi in place of the ham."
    },
    {
      "order": 9,
      "instruction": "Shredded cooked chicken - use in place of ham. I often use store bought rotisserie chicken for convenience!"
    },
    {
      "order": 10,
      "instruction": "Dissolve salt and sugar in the hot water, then add rice vinegar."
    },
    {
      "order": 11,
      "instruction": "Add carrot, then let stand for at least 1 hour - carrot should be a bit tangy, a bit floppy but still with a soft crunch.&nbsp;"
    },
    {
      "order": 12,
      "instruction": "Drain and use per recipe."
    }
  ]
}