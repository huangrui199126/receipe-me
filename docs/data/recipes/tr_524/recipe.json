  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in large pot over high heat. Add onion, capsicum and garlic. Cook for 1 minute."
    },
    {
      "order": 2,
      "instruction": "Add beef, cook until brown, breaking it up as you go."
    },
    {
      "order": 3,
      "instruction": "Add tomato paste, salt, pepper, onion powder, oregano, cumin and cayenne pepper. Cook for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Turn heat down to medium. Add rice and beef broth, mix well. Add frozen veggies and bay leaf, then stir."
    },
    {
      "order": 5,
      "instruction": "Place lid on, lower heat to medium low so it's simmering gently. Cook for 12 - 15 minutes (might even take longer) until all liquid is absorbed (tilt pot to check). The rice should be just cooked, but will be wet."
    },
    {
      "order": 6,
      "instruction": "Remove from heat. Quickly toss spinach on top of the rice and put the lid back on. Leave to rest for 10 minutes."
    },
    {
      "order": 7,
      "instruction": "Fluff rice and mix through wilted spinach with a fork. Adjust salt if desired. Serve!"
    }
  ]
}