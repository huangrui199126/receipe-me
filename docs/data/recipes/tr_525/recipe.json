  "steps": [
    {
      "order": 1,
      "instruction": "Combine the Dressing ingredients in a jar and shake. Set aside for 10 minutes or so for the flavours to meld."
    },
    {
      "order": 2,
      "instruction": "Place the Salad ingredients together in a large bowl along with half the crunchy noodles. Drizzle over dressing then toss. (Note 4)"
