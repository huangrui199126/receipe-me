  "steps": [
    {
      "order": 1,
      "instruction": "Place the Marinade ingredients in a ziplock bag and massage the bag to mix the ingredients."
    },
    {
      "order": 2,
      "instruction": "Add pork to the Marinade and massage the bag to coat all the cutlets with the Marinade."
    },
    {
      "order": 3,
      "instruction": "Marinate for at least 4 hours, up to 24 hours."
    },
    {
      "order": 4,
      "instruction": "Brush the outdoor grill with oil and heat to medium high (or pan on a stove)."
    },
    {
      "order": 5,
      "instruction": "Remove pork from the marinade."
    },
    {
      "order": 6,
      "instruction": "Place pork on the grill and cook each side for 2 minutes, or until cooked (depends on thickness of the cutlets). Remember that it will continue to cook while resting."
    },
    {
      "order": 7,
      "instruction": "Remove pork from the grill onto a plate and cover loosely with foil. Rest for 5 minutes before serving."
    }
  ]
