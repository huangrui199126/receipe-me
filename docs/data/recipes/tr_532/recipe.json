  "steps": [
    {
      "order": 1,
      "instruction": "Cut the larger florets in half or quarter so they're all about the same size."
    },
    {
      "order": 2,
      "instruction": "Add cauliflower and garlic into a large pot of boiling water and cook for 10 minutes until very soft."
    },
    {
      "order": 3,
      "instruction": "Scoop out a mug of cooking water."
    },
    {
      "order": 4,
      "instruction": "Drain well, then transfer to food processor."
    },
    {
      "order": 5,
      "instruction": "Add remaining ingredients, starting with no water, blitz until smooth. (Use handheld blender stick if you don&#x27;t have food processor)"
    },
    {
      "order": 6,
      "instruction": "Use reserved cooking water to adjust consistency to taste and help puree smooth."
    },
    {
      "order": 7,
      "instruction": "Adjust salt and pepper to taste"
    },
    {
      "order": 8,
      "instruction": "Transfer to serving bowl, drizzle with melted butter and garnish with parsley if desired."
    },
    {
      "order": 9,
      "instruction": "Serve as a side with anything that you'd usually serve with mashed potato!"
    }
  ]
