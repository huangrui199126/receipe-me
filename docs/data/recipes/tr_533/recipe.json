  "steps": [
    {
      "order": 1,
      "instruction": "Combine dressing ingredients in a jar and shake well to combine. Set aside for 5 minutes for the flavours to infuse."
    },
    {
      "order": 2,
      "instruction": "Prepare vermicelli noodles per packet directions (usually soak in warm or boiling water 2 minutes). Drain well then set aside for 10 minutes to drain off exces water. Turn out onto tea towel if necessary to dry more (watery noodles = watery flavour)."
    },
    {
      "order": 3,
      "instruction": "Combine vermicelli noodles with remaining salad ingredients."
    },
    {
      "order": 4,
      "instruction": "Just prior to serving, toss through dressing. Garnish with Fried Asian Shallots if you wish."
