  "steps": [
    {
      "order": 1,
      "instruction": "Cook ziti&nbsp;for the recommended cooking time on the packet MINUS 2 minutes. (Note 5) Drain, then return to pot.&nbsp;"
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 3,
      "instruction": "Make Sauce: Heat oil in a large skillet over high heat. Add onion and garlic and cook for 2 minutes or until onion is translucent."
    },
    {
      "order": 4,
      "instruction": "Add meat and cook, breaking it up as you go. When it is just cooked, add Seasonings and cook for 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add passata, water, basil, oregano and sugar. Bring to simmer, reduce heat to low and cook for 10 minutes. Adjust salt and pepper to taste (remember it gets spread across lots of pasta)."
    },
    {
      "order": 6,
      "instruction": "Toss Ziti with Sauce:&nbsp;Pour about 2 cups of sauce into the pot with the ziti. Toss."
    },
    {
      "order": 7,
      "instruction": "Assemble: Spread ziti into baking dish (23x33cm / 9x13&quot;). Dollop with ricotta. Pour over remaining sauce. Top with cheese and parmesan."
    },
    {
      "order": 8,
      "instruction": "Bake:&nbsp;Cover loosely with foil. Bake 20 minutes. Remove foil, bake further 10 to 15 minutes until cheese is golden."
    },
    {
      "order": 9,
      "instruction": "Serve:&nbsp;Sprinkle with parsley or basil if desired, then serve!"
    }
  ]
}