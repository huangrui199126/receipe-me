  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade ingredients."
    },
    {
      "order": 2,
      "instruction": "Place wings in large bowl, pour over Marinade and toss well. Set aside for 10 minutes - do not marinate for longer than 1 hour. (Note 3)"
    },
    {
      "order": 3,
      "instruction": "Preheat the oven to 180C/350F."
    },
    {
      "order": 4,
      "instruction": "Line baking tray with foil then greaseproof paper (you&#x27;ll thank me later)."
    },
    {
      "order": 5,
      "instruction": "Shake excess marinade off wings (but reserve the marinade) and spread on baking tray - can be fairly snug but not super squished (use 2 trays if needed)."
    },
    {
      "order": 6,
      "instruction": "Bake 45 - 50 minutes, basting with a brush at 25 minutes and 35 minutes, using the reserved marinade and juieces on the tray."
    },
    {
      "order": 7,
      "instruction": "The meat should be able to be pulled off the bones quite easily, they should be just starting to char on the edges and a sticky, dark red/golden colour all over."
    },
    {
      "order": 8,
      "instruction": "Sprinkle with garnishes - coriander/cilantro leaves, sesame seeds, chilli, sliced shallots/scallions - then serve!"
    }
  ]
