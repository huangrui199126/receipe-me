  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/400°F (180°C fan)."
    },
    {
      "order": 2,
      "instruction": "Sauté aromatics - Melt butter over medium-high heat in a medium or large ovenproof pot (Note 5). Cook garlic, onion, thyme, all spice, bay leaves, scotch bonnet until onion is translucent (~ 3 minutes)."
    },
    {
      "order": 3,
      "instruction": "Add coconut milk, water, beans and salt. Once it comes to a simmer, add rice then give it a quick stir. Once you see bubbles breaking the surface, immediately cover then transfer to oven."
    },
    {
      "order": 4,
      "instruction": "Bake for 40 minutes. All liquid should be absorbed (tilt to check) though you will have some coconut cream on the surface."
    },
    {
      "order": 5,
      "instruction": "Rest - Leave the pot on the counter with the lid on for 15 minutes. Then fluff and serve!"
    }
  ]
