  "steps": [
    {
      "order": 1,
      "instruction": "Place ingredients in a jar and shake well. Set aside 10 minutes+."
    },
    {
      "order": 2,
      "instruction": "Keep pieces large for easy handling on the BBQ (so you don't have to turn hundreds of pieces!) and so they don't fall through the grills."
    },
    {
      "order": 3,
      "instruction": "Capsicum/bell peppers - cut the \"walls\" off, then cut each each on the diagonal into fairly large pieces."
    },
    {
      "order": 4,
      "instruction": "Onion (Note 4) - keep the root end (hairy end!) in tact. Peel, cut in half, then cut into wedges through the root end."
    },
    {
      "order": 5,
      "instruction": "Brush BBQ grills lightly with oil, then preheat to high. Or oven 250°C/480°F."
    },
    {
      "order": 6,
      "instruction": "Place vegetables in a very large bowl or use a big tray. Drizzle with oil, sprinkle with salt, pepper and garlic. Toss with hands (there is no better way!)."
    },
    {
      "order": 7,
      "instruction": "Place on BBQ and cook until tender crisp with charred edges - cook times below. Then remove into large bowl.&nbsp;"
    },
    {
      "order": 8,
      "instruction": "Asparagus, zucchini - grill 2 min each side. (Oven - 10 min, no flipping)"
    },
    {
      "order": 9,
      "instruction": "Capsicum, mushroom, onion - grill 3 min each side (oven 15 min, flip at 10 min)"
    },
    {
      "order": 10,
      "instruction": "Eggplant - grill 4 min each side. Jab in middle to ensure soft but not soggy! (oven 18 min)"
    },
    {
      "order": 11,
      "instruction": "While vegetables are still hot, drizzle over Dressing and toss."
    },
    {
      "order": 12,
      "instruction": "Set aside 10 minutes+ before serving, sprinkled with parsley. See in post for serving ideas."
    }
  ]
}