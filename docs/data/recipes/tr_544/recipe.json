  "steps": [
    {
      "order": 1,
      "instruction": "Mix the Sauce in a bowl."
    },
    {
      "order": 2,
      "instruction": "Prepare noodles per packet directions just before cooking."
    },
    {
      "order": 3,
      "instruction": "Heat 1 tbsp oil in a large skillet over medium heat. Pour in egg, swirl to coat base. Cook 1 minute until mostly set, then flip (do your best!)."
    },
    {
      "order": 4,
      "instruction": "Slide onto cutting board, roll up into loose \"wrap\". Slice into 1cm/ 1/3\" thick pieces - you now have egg ribbons!"
    },
    {
      "order": 5,
      "instruction": "Heat remaining 1 tbsp oil in same skillet over HIGH heat."
    },
    {
      "order": 6,
      "instruction": "Add garlic and chicken, cook until half surface turns white."
    },
    {
      "order": 7,
      "instruction": "Add prawns and cook for 1 minute until chicken is mostly cooked."
    },
    {
      "order": 8,
      "instruction": "Add cabbage and bean sprouts, toss for 1 minute until a bit wilted."
    },
    {
      "order": 9,
      "instruction": "Add noodles, green onions and Sauce, toss for 1 - 2 minutes until Sauce reduces and noodles caramelise a bit."
    },
    {
      "order": 10,
      "instruction": "Toss through egg ribbons and serve immediately!"
    }
  ]
