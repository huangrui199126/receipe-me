  "steps": [
    {
      "order": 1,
      "instruction": "Mix the Dill Sauce ingredients together (Mix well to loosen the sour cream). Adjust consistency with milk and tartness with lemon juice. Set aside for 10 minutes if you can - if using fresh garlic, set aside for 20 min."
    },
    {
      "order": 2,
      "instruction": "Pat fish dry with paper towel. Sprinkle with salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Heat oil in skillet over medium high heat. Place fish in skillet skin side down. Cook for 2 minutes, then flip and cook the other side for 1 1/2 minutes."
    },
    {
      "order": 4,
      "instruction": "Remove from skillet onto serving plates. Serve with Dill Sauce on the side, garnished with fresh dill and lemon wedges if desired."
    }
  ]
