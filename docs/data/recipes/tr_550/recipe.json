  "steps": [
    {
      "order": 1,
      "instruction": "Bring a large pot of salted water to the boil. Add the pasta into the pot when you start cooking the mushrooms."
    },
    {
      "order": 2,
      "instruction": "Cook pasta per packet instructions minus 1 minute. RESERVE 1 mugful of pasta cooking liquid, then drain pasta."
    },
    {
      "order": 3,
      "instruction": "Melt half butter and all oil in a large skillet over heat."
    },
    {
      "order": 4,
      "instruction": "Add mushrooms and cook until water has leeched then evaporated, and the mushrooms start to turn golden around edges - around 5 minutes."
    },
    {
      "order": 5,
      "instruction": "Halfway through cooking, add salt &amp; pepper."
    },
    {
      "order": 6,
      "instruction": "Add garlic and remaining butter, cook for 2 minutes until mushrooms and garlic are golden."
    },
    {
      "order": 7,
      "instruction": "Add pasta, about 3/4 cup of reserved pasta water and parmesan. Toss gently or until water reduces and thickens into a saucy glaze that coats the pasta. If the pasta dries out, add more pasta water."
    },
    {
      "order": 8,
      "instruction": "Taste and add more salt and pepper if needed."
    },
    {
      "order": 9,
      "instruction": "Remove from stove and serve immediately, garnished with fresh parsley and parmesan cheese."
    }
  ]
