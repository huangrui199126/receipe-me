  "steps": [
    {
      "order": 1,
      "instruction": "Place chicken in a bowl, sprinkle over baking soda. Use your fingers to mix then set aside for 20 minutes, no longer than 30 minutes (can get too tender). Rinse well, pat excess water with paper towels, set aside (see video)."
    },
    {
      "order": 2,
      "instruction": "Sauce: Place cornflour and soy sauce in a bowl. Mix until lump free. Then add remaining Sauce ingredients and stir."
    },
    {
      "order": 3,
      "instruction": "Chop choy sum: Trim end off choy sum. Then cut into 7cm (3&quot;) pieces. Separate stems from leaves."
    },
    {
      "order": 4,
      "instruction": "Chop carrot - Peel then cut into 3cm (1.3&quot;) pieces. Then slice the pieces thinly."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a wok or skillet over high heat. Add garlic, stir quickly, then add onion, Cook for 1 minute, moving constantly, until onion is starting to wilt."
    },
    {
      "order": 6,
      "instruction": "Add chicken, cook for 1 minute until the surface changes from pink to white."
    },
    {
      "order": 7,
      "instruction": "Add choy sum stems, carrot and mushrooms. Stir fry for 1 minute."
    },
    {
      "order": 8,
      "instruction": "Add choy sum leaves, bean sprouts and Sauce. Stir fry for 1 to 2 minutes until the Sauce thickens to a thick syrup consistency. Vegetables should still be tender/crisp, not soggy and soft."
    },
    {
      "order": 9,
      "instruction": "Serve immediately with rice (for low carb, low cal option, try Cauliflower Rice!)"
    }
  ]
}