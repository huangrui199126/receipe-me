  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Heat a non stick fry pan over high heat."
    },
    {
      "order": 3,
      "instruction": "Add the diced pepperoni and fry for 1 minute until it starts to brown."
    },
    {
      "order": 4,
      "instruction": "Then add the onions and sauté for 1 minute. Then add the mushrooms and cook for 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Remove onion mixture from the fry pan and place onto a plate with a paper towel (to drain the excess fat)."
    },
    {
      "order": 6,
      "instruction": "Combine the Base ingredients in a bowl and mix until smooth and combined."
    },
    {
      "order": 7,
      "instruction": "Spread the Base in a 20 cm / 8 inch base with a 24 cm / 9 inch rim pie dish."
    },
    {
      "order": 8,
      "instruction": "Spread the pizza sauce over the Base, then sprinkle with the onion mixture."
    },
    {
      "order": 9,
      "instruction": "Sprinkle over the tasty cheese, then the mozzarella cheese."
    },
    {
      "order": 10,
      "instruction": "Place sliced pepperoni over the cheese."
    },
    {
      "order": 11,
      "instruction": "Bake in the oven for 15 to 20 minutes, until golden brown and bubbling. Check it at 15 minutes."
    },
    {
      "order": 12,
      "instruction": "Serve immediately with Garlic Toast."
    },
    {
      "order": 13,
      "instruction": "Spread french stick slices on 2 baking trays (or one very large one)."
    },
    {
      "order": 14,
      "instruction": "Bake for 5 to 8 minutes until crispy and lightly browned."
    },
    {
      "order": 15,
      "instruction": "Remove from oven and rub each piece lightly with the cut side of the garlic."
    }
  ]
}