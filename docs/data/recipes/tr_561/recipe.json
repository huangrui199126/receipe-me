  "steps": [
    {
      "order": 1,
      "instruction": "Spice mix - Mix the spices in a small bowl."
    },
    {
      "order": 2,
      "instruction": "Toast - Heat the oil in a large heavy based pot over medium high heat. Toast the star anise and cinnamon for 2 minutes."
    },
    {
      "order": 3,
      "instruction": "Add onion, cook for 2 minutes."
    },
    {
      "order": 4,
      "instruction": "Add chicken, cook for 3 minutes or it&#39;s no longer pink on the outside (still raw inside)."
    },
    {
      "order": 5,
      "instruction": "Add aromatics - Add garlic, ginger and turmeric. Cook for 1 minute."
    },
    {
      "order": 6,
      "instruction": "Add spice mix and stir for 30 seconds."
    },
    {
      "order": 7,
      "instruction": "Simmer 12 minutes - Add stock and coconut cream. Stir and bring to an energetic simmer. Cook for 12 minutes (no need to stir) so the sauce thickens slightly."
    },
    {
      "order": 8,
      "instruction": "Add broccoli florets. Bring back to a simmer and cook for 3 minutes or until softened."
    },
    {
      "order": 9,
      "instruction": "Serve - Cool for 5 minutes, this will allow the sauce to thicken slightly. Then stir in coriander and serve with rice (basmati or jasmine especially nice). Garnish with extra coriander and crispy fried shallots."
    }
  ]
}