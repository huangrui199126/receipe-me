  "steps": [
    {
      "order": 1,
      "instruction": "Preheat grill / broiler on high."
    },
    {
      "order": 2,
      "instruction": "Combine the Crumb ingredients and mix well to combine."
    },
    {
      "order": 3,
      "instruction": "Sprinkle both sides of fish with salt and pepper, then spread the mustard on the top of each fillet (top only)."
    },
    {
      "order": 4,
      "instruction": "Press the mustard smeared side of the fish into the crumb mixture. Press down firmly to make it stick. Then spray with oil (for extra golden crumb!)."
    },
    {
      "order": 5,
      "instruction": "Drizzle 1/2 tbsp oil in a skillet and preheat on the stove over high heat."
    },
    {
      "order": 6,
      "instruction": "Once skillet is hot, place the fillets in the hot pan then place under the grill / broiler (about 5&quot;/15cm from the heat source) for 5 - 6 minutes until the crumb is golden and the fish is cooked, rotating as required. Fish should flake in centre once cooked."
    },
    {
      "order": 7,
      "instruction": "Oven option: bake at 220C/390F for 10 - 12 minutes, then finish under the grill/broiler on high to make the crumb golden."
    },
    {
      "order": 8,
      "instruction": "Serve immediately with lemon wedges!"
    }
  ]
