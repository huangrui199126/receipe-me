  "steps": [
    {
      "order": 1,
      "instruction": "Place Marinade ingredients in a large bowl and mix. Add chicken, toss well to coat. Marinade for 1 hour to 24 hours (or freeze immediately then defrost overnight)."
    },
    {
      "order": 2,
      "instruction": "Use 2 skillets to cook the chicken and vegetables at the same time, if you can."
    },
    {
      "order": 3,
      "instruction": "Heat 1 tbsp oil in a heavy based skillet over high heat until smoking. Add vegetables to cover the base of the pan in a single layer without too much overlapping (I cook in 3 batches). Spread out, leave for 45 seconds (to char it)."
    },
    {
      "order": 4,
      "instruction": "Toss quickly then spread out. Sprinkle with salt and pepper. Leave 45 seconds, toss then spread out, then leave 45 seconds. Remove onto platter and repeat with remaining Vegetables."
    },
    {
      "order": 5,
      "instruction": "Heat 1 tbsp oil in a large skillet over medium high heat. Add chicken and cook for 3 to 4 minutes until caramelised. Turn and cook the other side for 3 – 4 minutes."
    },
    {
      "order": 6,
      "instruction": "Remove onto a plate, cover loosely with foil. Rest for 3 minutes then slice."
    },
    {
      "order": 7,
      "instruction": "Warm tortillas using chosen method."
    },
    {
      "order": 8,
      "instruction": "Pile peppers and onion onto tortilla. Top with chicken, drizzle with sour cream, squeeze over lime juice. Fold, devour and be happy."
    }
  ]
}