  "steps": [
    {
      "order": 1,
      "instruction": "Fit stand mixer with dough hook. Combine flour, oil, salt and water in the stand mixer bowl. Mix for 2.5 minutes on medium high speed 7 until smooth (see video for before &amp; after). (Note 4) Dough should be a pliable, smooth ball, not sticky."
    },
    {
      "order": 2,
      "instruction": "Cover and rest for 20 minutes."
    },
    {
      "order": 3,
      "instruction": "Sprinkle work surface with flour. Cut dough into 4 pieces."
    },
    {
      "order": 4,
      "instruction": "Roll out into 35cm/14\" x 20cm/8\" rectangle."
    },
    {
      "order": 5,
      "instruction": "Make EITHER the lamb / beef Filling, or Spinach &amp; Feta (or make 1/2 batch of both!)."
    },
    {
      "order": 6,
      "instruction": "Heat oil in large skillet over high heat."
    },
    {
      "order": 7,
      "instruction": "Cook garlic and onion for 1 minute. Add capsicum, cook for 2 minutes."
    },
    {
      "order": 8,
      "instruction": "Add beef and cook until it changes from pink to brown, breaking it up as you go."
    },
    {
      "order": 9,
      "instruction": "Add cumin, paprika, cayenne (if using), salt, pepper and water. Cook for 2 minutes."
    },
    {
      "order": 10,
      "instruction": "Add spinach, stir until wilted."
    },
    {
      "order": 11,
      "instruction": "Cool before using."
    },
    {
      "order": 12,
      "instruction": "Place spinach, garlic, egg and pepper in a bowl. Scrunch with hands to reduce volume and make spinach \"floppy\"."
    },
    {
      "order": 13,
      "instruction": "Add feta and stir through."
    },
    {
      "order": 14,
      "instruction": "Spread Filling on half the pastry, pushing to the edge. Sprinkle Lamb/Beef Filling with crumbled feta. Sprinkle Spinach Feta with mozzarella cheese, if using."
    },
    {
      "order": 15,
      "instruction": "Fold other side of pastry over to cover Filling. Press down edges, pressing out excess air pockets trapped inside as you go. Use water if needed to seal well."
    },
    {
      "order": 16,
      "instruction": "Sprinkle flour on a round pizza paddle (or similar). Slide gozleme onto paddle."
    },
    {
      "order": 17,
      "instruction": "Heat 1.5 tbsp oil in a large skillet over medium high heat. (I usually get 2 pans going)"
    },
    {
      "order": 18,
      "instruction": "Slide gozleme into skillet. Cook, lightly pressing down (including edges), until deep golden and crispy - about 3 minutes. Flip and cook, pressing down lightly, until crispy."
    },
    {
      "order": 19,
      "instruction": "Transfer to cutting board. Cut into 6 or 8 pieces."
    },
    {
      "order": 20,
      "instruction": "Serve immediately with lemon wedges, if desired."
    }
  ]
}