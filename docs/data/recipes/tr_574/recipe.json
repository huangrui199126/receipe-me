  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/390°F (180°C fan)."
    },
    {
      "order": 2,
      "instruction": "Grease and line a 23 cm / 9&quot; cake pan with baking paper/parchment paper. (Any type of cake pan is fine)"
    },
    {
      "order": 3,
      "instruction": "For inside of cake: Dice some strawberries into ~1.5cm / 1&quot; pieces to make 1 cup (about 1/3 of the strawberries)"
    },
    {
      "order": 4,
      "instruction": "Topping: Cut the remaining strawberries in half."
    },
    {
      "order": 5,
      "instruction": "Place Wet ingredients in a bowl and whisk well for 1 minute."
    },
    {
      "order": 6,
      "instruction": "Add Dry ingredients then whisk well until lump free."
    },
    {
      "order": 7,
      "instruction": "Pour half into cake pan, smooth surface. Scatter over diced strawberries."
    },
    {
      "order": 8,
      "instruction": "Top with remaining batter. Smooth surface, then top with halved strawberries, cut face down."
    },
    {
      "order": 9,
      "instruction": "Bake 50 minutes or until skewer inserted into centre comes out clean. (Note 1) If you need to cook longer, cover with foil if it starts getting too golden."
    },
    {
      "order": 10,
      "instruction": "Stand 15 minutes in the cake pan before turning out onto cooling rack."
    },
    {
      "order": 11,
      "instruction": "Cool 15 minutes+ before serving warm or at room temp. Dust with icing sugar, and serve with cream or if serving warm, ice cream!"
    }
  ]
}