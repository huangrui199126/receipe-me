  "steps": [
    {
      "order": 1,
      "instruction": "Heat cream with vanilla bean until just simmering. Remove from heat.",
      "imageUri": "https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=600&q=80"
    },
    {
      "order": 2,
      "instruction": "Whisk yolks and sugar until pale. Gradually add warm cream.",
      "imageUri": "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80"
    },
    {
      "order": 3,
      "instruction": "Strain custard into ramekins.",
      "imageUri": "https://images.unsplash.com/photo-1507048331197-7d4ac70811cf?w=600&q=80"
    },
    {
      "order": 4,
      "instruction": "Bake in a water bath at 160°C for 35-40 minutes until just set.",
      "imageUri": "https://images.unsplash.com/photo-1466637574441-749b8f19452f?w=600&q=80"
    },
    {
      "order": 5,
      "instruction": "Chill 4 hours or overnight.",
      "imageUri": "https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=600&q=80"
    },
    {
      "order": 6,
      "instruction": "Sprinkle sugar on top and torch until caramelized. Serve immediately.",
