  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F (or fan forced 160C/320F)."
    },
    {
      "order": 2,
      "instruction": "Sift flour and baking powder together."
    },
    {
      "order": 3,
      "instruction": "Grease a 20 cm x 30 cm / 8\" x 12\" cake pan. Line with baking paper (parchment paper), leaving an overhang on all sides (to make it easy to remove)."
    },
    {
      "order": 4,
      "instruction": "Beat butter, sugar and vanilla with an electric mixer on medium high speed until light and fluffy - about 1 1/2 to 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add eggs 1 at a time, beating well after each addition so the batter is smooth, not curdled."
    },
    {
      "order": 6,
      "instruction": "Add half the flour and gently fold to combine, then stir in half the milk. Repeat with remaining flour and milk."
    },
    {
      "order": 7,
      "instruction": "Pour the batter into the prepared pan and bake for 25 minutes until a skewer inserted into the centre comes out clean."
    },
    {
      "order": 8,
      "instruction": "Stand for 5 minutes then use the overhang baking paper to lift the cake out onto a wire rack and cool completely.&nbsp;"
    },
    {
      "order": 9,
      "instruction": "Cut cake into 15 squares (5 x 3), or 18 rectangles. Freeze for 1 to 1.5 hours. (Note 2)"
    },
    {
      "order": 10,
      "instruction": "Combine the Icing ingredients in a heat proof bowl and mix until smooth. Should be a syrup consistency, but not watery. (Note 2)"
    },
    {
      "order": 11,
      "instruction": "Place coconut in a shallow bowl or pan with a largish surface area (Note 3)."
    },
    {
      "order": 12,
      "instruction": "Place a piece of cake in the icing and roll to coat using 2 forks. Transfer it into the coconut and quickly roll to coat all over in coconut. Transfer to tray."
    },
    {
      "order": 13,
      "instruction": "Repeat with remaining sponges.&nbsp;"
    },
    {
      "order": 14,
      "instruction": "Stand for 1 to 2 hours, or until set. Then serve with tea and coffee!"
    },
    {
      "order": 15,
      "instruction": "Beat cream and sugar until firm peaks form."
    },
    {
      "order": 16,
      "instruction": "Cut coated Lamington in half horizontally. Spread with jam then pipe or dollop on cream. Top with lid, keep refrigerated."
    }
  ]
}