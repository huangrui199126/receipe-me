  "steps": [
    {
      "order": 1,
      "instruction": "Mix chicken, cornstarch and oil in a bowl."
    },
    {
      "order": 2,
      "instruction": "Mix Sauce ingredients in a bowl. OR use 3 tbsp Homemade Stir Fry Sauce + 6 tbsp water."
    },
    {
      "order": 3,
      "instruction": "Just before cooking, soak noodles in hot water per packet directions, then drain. (Note 7)"
    },
    {
      "order": 4,
      "instruction": "Heat oil in a wok or large skillet over high heat."
    },
    {
      "order": 5,
      "instruction": "Add garlic and onion, cook for 30 seconds."
    },
    {
      "order": 6,
      "instruction": "Add chicken, cook for 1 minute until it changes colour from pink to white."
    },
    {
      "order": 7,
      "instruction": "Add carrot, Choy Sum stems and capsicum. Cook for 1 minute."
    },
    {
      "order": 8,
      "instruction": "Add mushrooms, cook for 30 seconds."
    },
    {
      "order": 9,
      "instruction": "Add noodles, Choy Sum leaves and Sauce. Toss for 1 minute until leaves have wilted and Sauce has evaporated. Don't toss for more then 1 1/2 minutes - noodles may break."
    },
    {
      "order": 10,
      "instruction": "Garnish with sesame seeds and green onions then serve immediately."
    }
  ]
}