  "steps": [
    {
      "order": 1,
      "instruction": "Place Curry Paste ingredients in a tall jug or milkshake container (something that fits the head of a blender stick) then blitz on high for 5 to 10 seconds until the onion is pureed. Add more water if needed to make it puree."
    },
    {
      "order": 2,
      "instruction": "Sizzle black mustard seeds: Heat oil over medium heat in a large pot. Add black mustard seeds and let them sizzle for 30 seconds - careful, they might pop!"
    },
    {
      "order": 3,
      "instruction": "Saute onion: Add red onion and cook for 3 minutes until edges start to tinge with gold."
    },
    {
      "order": 4,
      "instruction": "Cook off curry paste: Add curry paste and cook for 3 minutes - to evaporate water, make spices bloom and cook garlic &amp; ginger."
    },
    {
      "order": 5,
      "instruction": "Cook off tomato: Turn heat up to medium high. Add tomato paste and tomato pulp, cook for 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Coconut milk: Add water, coconut milk, sugar, salt and chilli powder if using. Stir, then bring to simmer, low heat so it&#039;s bubbling gently."
    },
    {
      "order": 7,
      "instruction": "Simmer 2 minutes, add tomato &amp; green chilli: Simmer for 2 minutes, add tomato and green chilli."
    },
    {
      "order": 8,
      "instruction": "Simmer 3 minutes: Simmer for another 3 minutes, stirring every now and then - sauce should be thickened (not watery), it gets looser again when fish is added (because fish will drop some juices = even more flavour!)."
    },
    {
      "order": 9,
      "instruction": "Add fish: Add fish, stir, cook for 3 to 4 minutes until fish easily flakes."
    },
    {
      "order": 10,
      "instruction": "Garnish &amp; serve: Remove from stove and transfer to serving bowl. Garnish with coriander/cilantro and fresh green chillies if desired. Serve with basmati rice!"
    }
  ]
