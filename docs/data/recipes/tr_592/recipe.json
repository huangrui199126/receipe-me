  "steps": [
    {
      "order": 1,
      "instruction": "Combine all ingredients except water in a powerful blender or food processor. I use my Vitamix because it makes the paste smoother."
    },
    {
      "order": 2,
      "instruction": "Blend to a fine paste, scraping down the sides as you go. Add the water as required to help it blend (you may not need any as the herbs and chilis have moisture)."
    },
    {
      "order": 3,
      "instruction": "Use to make Thai Green Curry!"
    },
    {
      "order": 4,
      "instruction": "Best to use immediately. Otherwise, refrigerate for up to 2 days, or freeze for 1 month."
    }
