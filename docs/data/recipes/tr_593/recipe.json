  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/430°F (200°C/390°F fan/convection)"
    },
    {
      "order": 2,
      "instruction": "Mix the Seasoning ingredients."
    },
    {
      "order": 3,
      "instruction": "Cut the potatoes in half lengthwise, then cut each half into 4 &quot;wedges&quot; (so you get 8 pieces from each potato). If your potato is small/medium, just cut into 6 wedges."
    },
    {
      "order": 4,
      "instruction": "Place potatoes in a large bowl, drizzle over oil and seasoning. Toss with hands."
    },
    {
      "order": 5,
      "instruction": "Spread out on tray, ensuring cut side lies flat on the tray."
    },
    {
      "order": 6,
      "instruction": "Bake for 35 to 45 minutes, turning once, or until dark golden brown and crispy."
    },
    {
      "order": 7,
      "instruction": "Serve immediately!"
    },
    {
      "order": 8,
      "instruction": "Dipping sauces: Classic Aussie way is with sour cream and sweet chilli sauce. Otherwise, try tomato sauce/ketchup, BBQ sauce, yogurt, ranch, aoli."
    }
  ]
