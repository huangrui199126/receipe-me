  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 350F/180C."
    },
    {
      "order": 2,
      "instruction": "Combine Roasted Vegetable ingredients, spread on baking tray and bake for 30 to 40 minutes."
    },
    {
      "order": 3,
      "instruction": "Combine Tahini Sauce ingredients. Mix until smooth, and use water to adjust to the consistency of honey."
    },
    {
      "order": 4,
      "instruction": "Pile roasted vegetables onto a plate. Sprinkle with za'atar, drizzle with Tahini Sauce, scatter over roasted pine nuts and coriander."
    },
    {
      "order": 5,
      "instruction": "Serve with lebanese bread wedges or pita bread."
