  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (all oven types)."
    },
    {
      "order": 2,
      "instruction": "Grease and line a 21 cm / 9&quot; springform cake pan. (Note 4)"
    },
    {
      "order": 3,
      "instruction": "Place flour, baking soda, salt and spices in a large bowl and whisk to combine."
    },
    {
      "order": 4,
      "instruction": "Whisk oil and sugar in a bowl, then whisk in eggs and vanilla."
    },
    {
      "order": 5,
      "instruction": "Pour the wet ingredients into the dry and mix with a wooden spoon until JUST combined. Stir through apple (optional: add 3/4 cup chopped walnuts or other nuts)."
    },
    {
      "order": 6,
      "instruction": "Pour into cake pan. Sprinkle over almonds."
    },
    {
      "order": 7,
      "instruction": "Bake for 50 minutes - 1 hr. Check at 50 minutes - it is cooked when a skewer inserted into the centre comes out clean."
    },
    {
      "order": 8,
      "instruction": "Cool for 10 minutes before turning out onto a rack to cool. Dust with icing sugar if using, then serve. This cake doesn't need cream or ice cream because it is so moist, but I wouldn't turn it down!"
    }
  ]
