  "steps": [
    {
      "order": 1,
      "instruction": "Sauté - Heat oil in a small pot over medium high heat. Add garlic, onion, bay leaf, thyme and oregano. Cook for 3 - 4 minutes until the onion is translucent. Add tomato paste and cook for 1 minute."
    },
    {
      "order": 2,
      "instruction": "Reduce wine - Add wine, increase heat to high and let it simmer rapidly until mostly evaporated (about 2 minutes)."
    },
    {
      "order": 3,
      "instruction": "Simmer - Add passata, stock, sugar, salt and pepper. Stir then simmer on low *(uncovered) for 20 minutes. Use while hot."
    },
    {
      "order": 4,
      "instruction": "Squeeze spinach - Grab handfuls of spinach and squeeze out excess water."
    },
    {
      "order": 5,
      "instruction": "Mix filling - Place spinach in a bowl with remaining Filling ingredients. Mix well."
    },
    {
      "order": 6,
      "instruction": "Preheat oven to 200°C/400°F (180°C fan)."
    },
    {
      "order": 7,
      "instruction": "Stuff - Stuff UNCOOKED shells with spinach ricotta filling. Stuff them full!"
    },
    {
      "order": 8,
      "instruction": "Assemble - Pour the hot tomato sauce in a 23 x 33 cm / 9 x 13&quot; baking dish. Gently place the stuffed shells in - most will be submerged, some may poke above surface."
    },
    {
      "order": 9,
      "instruction": "Bake - Cover with a baking tray (or foil) then bake for 70 minutes."
    },
    {
      "order": 10,
      "instruction": "Cheese it! Check the shells - they should be al dente! (If not, return to oven, covered). Sprinkle with mozzarella then parmesan. Bake 15 minutes until melted."
    },
    {
      "order": 11,
      "instruction": "Serve, garnished with extra parmesan and basil if desired!"
    }
  ]
}