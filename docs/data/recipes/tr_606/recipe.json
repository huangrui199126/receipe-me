  "steps": [
    {
      "order": 1,
      "instruction": "Bash the cucumbers until they split open on the sides (see video) using something heavy like the smooth side of a meat mallet, rolling pin, pestle or even a can."
    },
    {
      "order": 2,
      "instruction": "Cut into 2.5cm/1\" chunks then place in a bowl."
    },
    {
      "order": 3,
      "instruction": "Sprinkle with salt, toss, leave for 20 minutes."
    },
    {
      "order": 4,
      "instruction": "Drain excess liquid in the bowl."
    },
    {
      "order": 5,
      "instruction": "Shake or mix Dressing well."
    },
    {
      "order": 6,
      "instruction": "Drizzle over cucumbers, sprinkle with coriander and green onions. Toss and serve immediately."
    }
