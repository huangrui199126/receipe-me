  "steps": [
    {
      "order": 1,
      "instruction": "Start the rice the day before or first thing in the morning - it needs minimum 4 hours to chill."
    },
    {
      "order": 2,
      "instruction": "Make the toppings first, then refrigerate while you cook the crispy rice cakes."
    },
    {
      "order": 3,
      "instruction": "Cook the crispy rice cakes and sprinkle with salt per the recipe."
    },
    {
      "order": 4,
      "instruction": "Assemble - Place rice cakes on a serving platter. Pile on toppings - I use teaspoons to make football shapes then slide on. Sprinkle with black sesame seeds, top with jalapeño. Eat!"
    },
    {
      "order": 5,
      "instruction": "Freeze to firm - Place tuna in the freezer for 30 minutes to partially freeze - it&#39;s much easier to finely chop when slightly firm."
    },
    {
      "order": 6,
      "instruction": "Cut into 0.5cm / 1/2&quot; cubes - the smaller the better! Place into a bowl and let it de-chill for 20 minutes (not as nice ice-cold)."
    },
    {
      "order": 7,
      "instruction": "Mix - Add everything into the tuna and mix until combined."
    },
    {
      "order": 8,
      "instruction": "Place tuna in a bowl and use a fork to mash it up really finely. Add everything else and mix well."
    }
  ]
