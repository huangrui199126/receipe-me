    },
    {
      "order": 4,
      "instruction": "Fold in flour, baking soda, and salt until just combined.",
      "imageUri": "https://images.unsplash.com/photo-1466637574441-749b8f19452f?w=600&q=80"
    },
    {
      "order": 5,
      "instruction": "Fold in walnuts. Pour into greased loaf pan.",
