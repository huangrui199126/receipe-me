  "steps": [
    {
      "order": 1,
      "instruction": "Place water and rice in a large saucepan over medium high heat, no lid."
    },
    {
      "order": 2,
      "instruction": "As soon as it comes to a boil (see video), lower heat to medium low, place lid on and leave for 18 - 20 minutes or until water is completely absorbed). DO NOT stir, DO NOT remove lid!"
    },
    {
      "order": 3,
      "instruction": "Remove from stove with lid still on and leave undisturbed for 15 minutes."
    },
    {
      "order": 4,
      "instruction": "Mix Sushi Seasoning ingredients until sugar dissolves."
    },
    {
      "order": 5,
      "instruction": "Spread rice out into large pan (23 x 33cm / 9 x 13&quot;), drizzle half Seasoning all over."
    },
    {
      "order": 6,
      "instruction": "Using a rice paddle OR rubber spatula, cut through the rice and gently fold the rice over (see video!) to mix the Seasoning through."
    },
    {
      "order": 7,
      "instruction": "After 1 minute of mixing, drizzle remaining Seasoning then cut/fold for 1 minute. Will look wet but will absorb in next step."
    },
    {
      "order": 8,
      "instruction": "Leave rice to cool to warm or room temp (if you can stick it in front of a fan, that&#x27;s even better!) - about 20 minutes."
    },
    {
      "order": 9,
      "instruction": "Dressing: Mix ingredients in a bowl."
    },
    {
      "order": 10,
      "instruction": "Divide rice between bowls. Top with radish, carrot, edamame and avocado."
    },
    {
      "order": 11,
      "instruction": "Place tuna in Dressing and toss (no need to marinate), then immediately transfer onto rice."
    },
    {
      "order": 12,
      "instruction": "Sprinkle cucumber over the top (mainly on tuna), then green onion and sesame seeds."
    },
    {
      "order": 13,
      "instruction": "Drizzle over remaining Dressing then serve!"
    }
  ]
