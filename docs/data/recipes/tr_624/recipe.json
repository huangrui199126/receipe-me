  "steps": [
    {
      "order": 1,
      "instruction": "Place Nachos Seasoning ingredients in a bowl. Add 2 tbsp of the chicken broth and mix to form a loose paste."
    },
    {
      "order": 2,
      "instruction": "Add chicken, turn to coat in paste.&nbsp;"
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large skillet over medium high heat. Cook chicken for 3 minutes on each side (reserve paste left in bowl).&nbsp;Remove chicken into a shallow dish."
    },
    {
      "order": 4,
      "instruction": "Return skillet to stove. Add remaining chicken broth, tomato paste, sugar and scrape in any paste left in the bowl. Mix to dissolve, scraping base of pan, and bring to simmer."
    },
    {
      "order": 5,
      "instruction": "Meanwhile, shred chicken with forks, or chop (don't worry if raw inside)."
    },
    {
      "order": 6,
      "instruction": "Return chicken into sauce, toss and simmer for 3 minutes until sauce reduces down to a thick sauce. Adjust salt to taste. Keep warm."
    },
    {
      "order": 7,
      "instruction": "Place ingredients in a bowl. Use potato masher to mash to desired consistency. Adjust salt and pepper to taste."
    },
    {
      "order": 8,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 9,
      "instruction": "Place half the corn chips slightly overlapping on a tray. Top with half the (warm) chicken and cheese."
    },
    {
      "order": 10,
      "instruction": "Top with remaining chips and cheese. Bake 7 minutes or until cheese is melted and bubbly."
    },
    {
      "order": 11,
      "instruction": "Garnish with coriander/cilantro and jalapeño. Serve immaterial with quick Guacamole and sour cream."
    }
  ]
}