  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large wok or a large skillet over medium high heat. (Add 1 tbsp extra oil if using a skillet)"
    },
    {
      "order": 2,
      "instruction": "Add garlic and onion, stir fry for 30 seconds."
    },
    {
      "order": 3,
      "instruction": "Add prawns/shrimp and white part of green onion, stir fry for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Push everything to the side and pour the egg onto the other side. Scramble it quickly - about 20 seconds."
    },
    {
      "order": 5,
      "instruction": "Add the rice and Sauce of choice. Stir fry for 2 minutes, adding green part of green onions halfway through, until all the rice is coated with the Sauce."
    },
    {
      "order": 6,
      "instruction": "Serve immediately, garnished with fresh cilantro/coriander with tomato and cucumbers on the side. (See in post for more serving ideas)"
    }
