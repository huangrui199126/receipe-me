  "steps": [
    {
      "order": 1,
      "instruction": "Melt butter in a large pot over medium heat."
    },
    {
      "order": 2,
      "instruction": "Add garlic and onion, cook for 5 minutes until translucent but not golden."
    },
    {
      "order": 3,
      "instruction": "Add carrots and stir through."
    },
    {
      "order": 4,
      "instruction": "Turn heat up to high and add wine. Stir then let it simmer rapidly until it's mostly evaporated."
    },
    {
      "order": 5,
      "instruction": "Add flour and stir for 30 seconds - it will become sludgy!"
    },
    {
      "order": 6,
      "instruction": "Slow pour in broth while stirring to dissolve paste, then stir in milk."
    },
    {
      "order": 7,
      "instruction": "Add potato, corn, salt and pepper. Bring to simmer then turn heat down so it's simmering gently."
    },
    {
      "order": 8,
      "instruction": "Cook, stirring every now and then, for 8 minutes or until potato is almost cooked."
    },
    {
      "order": 9,
      "instruction": "Add fish and peas, simmer for 3 minutes or until fish is just cooked (should flake easily)."
    },
    {
      "order": 10,
      "instruction": "Adjust salt and pepper to taste. If soup is too thick, add a touch of water or milk."
    },
    {
      "order": 11,
      "instruction": "Serve, garnished with green onions and crusty bread on the side for dunking!"
    }
  ]
}