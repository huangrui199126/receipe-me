  "steps": [
    {
      "order": 1,
      "instruction": "Place oil and butter in a large pot over medium high heat. Add onion and garlic, cook for 5 minutes until onion is translucent."
    },
    {
      "order": 2,
      "instruction": "Add carrots and celery, stir for 1 minute."
    },
    {
      "order": 3,
      "instruction": "Add stock powder, dried parsley, thyme (if using), pepper, chicken broth, water. Stir, then add chicken."
    },
    {
      "order": 4,
      "instruction": "Cover with lid, simmer on medium low for 30 minutes. Adjust heat so it's bubbling a nice amount, but not crazy energetically or super slowly. Skim off excess foam build up once or twice (not critical, just makes broth clearer)."
    },
    {
      "order": 5,
      "instruction": "Remove lid, add rice. Stir, cover, simmer 15 minutes."
    },
    {
      "order": 6,
      "instruction": "Remove soup from stove."
    },
    {
      "order": 7,
      "instruction": "Remove chicken into large bowl. Shred with 2 forks, discard bones then stir into soup."
    },
    {
      "order": 8,
      "instruction": "Stir in half the parsley, taste for salt and add if required.&nbsp;Serve, then garnish with extra parsley."
    }
  ]
}