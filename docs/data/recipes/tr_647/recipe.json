  "steps": [
    {
      "order": 1,
      "instruction": "Slice chicken breast horizontally to create two thin steaks (so you end up with 4 thin steaks in total)."
    },
    {
      "order": 2,
      "instruction": "Sprinkle each side with salt and pepper, then coat with flour, shaking off excess."
    },
    {
      "order": 3,
      "instruction": "Melt butter in a large skillet over medium high heat. Cook chicken 2 minutes on each side until golden and crispy, then remove onto plate."
    },
    {
      "order": 4,
      "instruction": "Add a touch of butter if your pan is dry - but you shouldn&#x27;t need it. Add garlic, stir 10 seconds."
    },
    {
      "order": 5,
      "instruction": "Then add chicken broth, cream, lemon and Dijon mustard. Bring to simmer and scrape the bottom of the pan to dissolve brown bits into the liquid. Use a whisk if needed to dissolve mustard."
    },
    {
      "order": 6,
      "instruction": "Add parmesan then simmer rapidly for 3 minutes or until sauce thickens slightly. Add salt, pepper and adjust lemon to taste."
    },
    {
      "order": 7,
      "instruction": "Return the chicken to the pan (pour in any juices on the plate too), turn to coat."
    },
    {
      "order": 8,
      "instruction": "Place chicken on serving plates with pasta or mashed potatoes. Sprinkle with fresh parsley if using. Spoon over Lemon Sauce and serve! (Bread for mopping wouldn&#x27;t go astray either)"
    }
  ]
}