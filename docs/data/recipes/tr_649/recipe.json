  "steps": [
    {
      "order": 1,
      "instruction": "Whisk together Egg Mixture in a bowl. Vigorous whisk = avoid cinnamon floating on top."
    },
    {
      "order": 2,
      "instruction": "Melt 15g / 1 tbsp butter in a non stick skillet over medium heat."
    },
    {
      "order": 3,
      "instruction": "Dunk a piece of bread quickly into the egg mixture, coating both sides. Place in pan. Repeat with more slices to fill the pan, but don’t crowd it (do 2 or 3 at a time)."
    },
    {
      "order": 4,
      "instruction": "Cook for 2 ½ - 3 minutes on each side until the surface is golden, then transfer to serving plates."
    },
    {
      "order": 5,
      "instruction": "Add more butter into the pan and cook remaining bread."
    },
    {
      "order": 6,
      "instruction": "Serve with butter and plenty of maple syrup, and Macerated Strawberries if using!"
    },
    {
      "order": 7,
      "instruction": "Toss strawberries with sugar, set aside for 20 minutes+. The strawberries will soften and sweat, and create a bit of syrup."
    }
  ]
