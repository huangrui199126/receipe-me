  "steps": [
    {
      "order": 1,
      "instruction": "Heat the olive oil in a large non stick pan over high heat (if you aren't using non stick, use more oil)."
    },
    {
      "order": 2,
      "instruction": "Add the mushrooms and cook until softened (around 3 minutes). Remove from the pan and set aside."
    },
    {
      "order": 3,
      "instruction": "Lower the heat to medium and melt the butter in the pan. Add garlic and onion, and sauté until the onion becomes translucent - around 3 minutes."
    },
    {
      "order": 4,
      "instruction": "Add the flour, stir it in and cook for 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add the milk and chicken broth and use a whisk to mix the butter flour mixture into the liquid."
    },
    {
      "order": 6,
      "instruction": "Increase heat to medium high. Add the orzo/risoni, salt and pepper, stir once, then put a lid on (Note 2). Bring it to a simmer, then leave it to cook for around 8 to 10 minutes or until the orzo/risoni is cooked but still slightly firm, and it is still quite saucy. Note: If you have a strong stove, turn it down slightly so it just simmers)."
    },
    {
      "order": 7,
      "instruction": "While the orzo is cooking, break up the spinach into little pieces with your fingers."
    },
    {
      "order": 8,
      "instruction": "Remove the pan from the stove. Stir through the parmesan, spinach and cooked mushrooms. Check if more salt or pepper is required."
    },
    {
      "order": 9,
      "instruction": "Serve immediately, garnished with more parmesan and fresh finely chopped parsley, if desired."
    }
  ]
}