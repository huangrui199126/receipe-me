  "steps": [
    {
      "order": 1,
      "instruction": "Place Broth ingredients in a saucepan over high heat. Place lid on, bring to simmer then reduce to medium and simmer for 8 - 10 minutes to allow the flavours to infuse."
    },
    {
      "order": 2,
      "instruction": "Meanwhile, cook noodles according to packet directions."
    },
    {
      "order": 3,
      "instruction": "Cut bok choys in half (for small / medium) or quarter (for large). Wash thoroughly."
    },
    {
      "order": 4,
      "instruction": "Either cook the bok choi in the broth in the soup broth OR noodle cooking water for 1 min (if noodles required boiling)."
    },
    {
      "order": 5,
      "instruction": "Pick garlic and ginger out of soup."
    },
    {
      "order": 6,
      "instruction": "Place noodles in bowls. Top with chicken and bok choy. Ladle over soup, garnish with green onions. Great served with chilli paste or fresh chillis."
    }
  ]
