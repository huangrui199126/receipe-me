  "steps": [
    {
      "order": 1,
      "instruction": "Put Sauce ingredients in a small bowl and mix to combine."
    },
    {
      "order": 2,
      "instruction": "Heat oil in wok or pan over high heat."
    },
    {
      "order": 3,
      "instruction": "Add garlic and chilli and cook for 10 seconds. Don't inhale - the chilli will make you cough!"
    },
    {
      "order": 4,
      "instruction": "Add the white part of the green onions and chicken and fry until cooked, around 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add Sauce and cook for 1 minute until the water reduces to make a thick glossy sauce."
    },
    {
      "order": 6,
      "instruction": "Toss through green part of green onions and basil leaves. Stir until just wilted, then serve immediately with steamed jasmine rice."
    }
