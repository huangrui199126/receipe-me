  "steps": [
    {
      "order": 1,
      "instruction": "Place all Rice ingredients in a large saucepan and give it a stir."
    },
    {
      "order": 2,
      "instruction": "Bring to simmer over medium high heat (edges bubbling, entire surface rippling), put the lid on and turn stove down to medium low (LOW for strong stoves). It should be simmering gently."
    },
    {
      "order": 3,
      "instruction": "Cook for 13 minutes - do not lift lid!"
    },
    {
      "order": 4,
      "instruction": "Tilt pot then QUICKLY peek to ensure all water is absorbed."
    },
    {
      "order": 5,
      "instruction": "Remove from stove, stand 10 minutes with lid on."
    },
    {
      "order": 6,
      "instruction": "Add butter and fluff rice with a rubber spatula. Serve!"
    },
    {
      "order": 7,
      "instruction": "Storage - please read Note 4."
    },
    {
      "order": 8,
      "instruction": "Rice cooker - Same ingredients, water and rice ratio. Pop it all in your rice cooker and cook per manufacturer directions, stir through butter at end."
