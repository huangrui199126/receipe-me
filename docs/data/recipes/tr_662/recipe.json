  "steps": [
    {
      "order": 1,
      "instruction": "Sauce &amp; chicken: Mix Sauce in a bowl. Pour 2 tsp over chicken, toss to coat, then set aside for 10 minutes."
    },
    {
      "order": 2,
      "instruction": "Egg: Heat 1 tbsp oil in a wok or skillet over medium heat. Add egg and scramble until just cooked (still a touch wet) then remove."
    },
    {
      "order": 3,
      "instruction": "Fried Rice: Turn heat up to high, add remaining 1/2 tbsp oil and bacon into same skillet. Cook for 1 minute or so until fat starts to melt, then add onion and garlic."
    },
    {
      "order": 4,
      "instruction": "Cook until bacon is light golden - about 1 1/2 minutes."
    },
    {
      "order": 5,
      "instruction": "Add vegetables (still frozen is fine). Cook for 1 minute."
    },
    {
      "order": 6,
      "instruction": "Add chicken and cook until it changes from pink to white - about 1 1/2 minutes."
    },
    {
      "order": 7,
      "instruction": "Add rice and Sauce ingredients. Cook for 1 1/2 minutes, stirring consantly."
    },
    {
      "order": 8,
      "instruction": "Add egg and green onion, toss through to disperse then remove from heat."
    },
    {
      "order": 9,
      "instruction": "Serve immediately!"
    }
  ]
}