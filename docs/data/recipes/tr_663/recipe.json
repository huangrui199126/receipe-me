  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil over high heat in a very large pot."
    },
    {
      "order": 2,
      "instruction": "Add bacon, cook until starting to turn golden (~2 min) then add garlic and onion."
    },
    {
      "order": 3,
      "instruction": "Cook until onion is translucent and bacon is light golden ~ 2minutes."
    },
    {
      "order": 4,
      "instruction": "Add carrot, celery and zucchini. Stir for 1 minute to coat in flavour."
    },
    {
      "order": 5,
      "instruction": "Add crushed tomato, chicken stock, water, tomato paste, Worcestershire sauce, kidney beans, salt and pepper."
    },
    {
      "order": 6,
      "instruction": "Stir, bring to simmer, then place lid on and adjust heat so it's simmering gently."
    },
    {
      "order": 7,
      "instruction": "Simmer 20 minutes, then add potato and beans."
    },
    {
      "order": 8,
      "instruction": "Simmer 5 minutes, then add pasta. Cook for time per pasta packet MINUS 1 1/2 minutes."
    },
    {
      "order": 9,
      "instruction": "Remove from stove, stir through parmesan and baby spinach. Taste and adjust for salt and pepper."
    },
    {
      "order": 10,
      "instruction": "Serve, garnished with extra parmesan and a sprinkle of parsley if desired. Warm crusty bread on the side would certainly be the cherry on top!"
    }
  ]
}