  "steps": [
    {
      "order": 1,
      "instruction": "Season chicken with the salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Sear chicken thighs - Heat oil in a large pan that is not non-stick over medium-high heat. (Note 3) Place chicken in pan smooth side-down and cook for 4 minutes or until deep golden. Turn and cook the other side for 3 minutes until cooked through (internal temperature 72°C/162°F, Note 4). Remove to a plate."
    },
    {
      "order": 3,
      "instruction": "Breast - If using breast (prepared per Note 1), sear on high for 2 minutes on each side, target temp 67°C/153°F.)"
    },
    {
      "order": 4,
      "instruction": "Clean pan - Scrape any loose black bits out of the pan and discard."
    },
    {
      "order": 5,
      "instruction": "Make sauce - Return the pan to medium heat. Add cream and both mustards. Mix with a wooden spoon until mustard dissolves, scraping up any brown bits stuck to the pan. Once sauce is hot but not simmering, stir in salt, pepper and herbs (if using). If getting too thick loosen with a touch of water."
    },
    {
      "order": 6,
      "instruction": "Serve - Place chicken on serving plates. Spoon over sauce. Enjoy!"
    }
  ]
