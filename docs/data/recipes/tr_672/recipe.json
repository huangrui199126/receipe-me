  "steps": [
    {
      "order": 1,
      "instruction": "Sprinkle chicken with salt and pepper, then toss with Seasoning if using."
    },
    {
      "order": 2,
      "instruction": "Thickener: In a small bowl, mix together the mayonnaise and flour."
    },
    {
      "order": 3,
      "instruction": "Heat 1 1/2 tbsp oil in a skillet over medium high heat. Add chicken and cook for 2 minutes on each side or until golden. Remove onto a plate."
    },
    {
      "order": 4,
      "instruction": "Reduce heat to medium. Add remaining oil in the middle of the skillet and put garlic straight onto the puddle of oil. Sauté for 20 seconds or until golden (don't let it burn)."
    },
    {
      "order": 5,
      "instruction": "Add chicken broth, bring to simmer, scraping the bottom of the fry pan."
    },
    {
      "order": 6,
      "instruction": "Whisk in Dijon Mustard and honey, then whisk in Thickener (make sure you scrape it all in)."
    },
    {
      "order": 7,
      "instruction": "Add thyme and wholegrain mustard, if using."
    },
    {
      "order": 8,
      "instruction": "Cook for 1 - 2 minutes or until starting to thicken. Adjust salt and pepper to taste."
    },
    {
      "order": 9,
      "instruction": "Return chicken and any juices pooled on the plate into the sauce. Turn to coat and reheat through - about 1 1/2 minutes - or until sauce is thickened to your taste."
    },
    {
      "order": 10,
      "instruction": "Serve on mashed potato, garnished with parsley, with a simple side salad."
    }
  ]
}