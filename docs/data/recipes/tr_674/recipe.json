  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/430°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Toss vegetables on tray with oil, garlic, herbs, salt and pepper. Spread out."
    },
    {
      "order": 3,
      "instruction": "Roast 25 minutes, undisturbed (no flipping). Remove and cool for at least 5 minutes before using."
    },
    {
      "order": 4,
      "instruction": "Lower oven to 180°C/350°F (160°C fan)."
    },
    {
      "order": 5,
      "instruction": "Grease &amp; line pan: Spray a 19 x 30cm / 8 x 10&quot; rectangle or 22 cm / 9&quot; square pan lightly with oil, then line with parchment paper with overhang. (Note 3)"
    },
    {
      "order": 6,
      "instruction": "Egg mixture: Whisk eggs, cream, salt and pepper in a bowl."
    },
    {
      "order": 7,
      "instruction": "Assemble: Spread 2/3 of the vegetables in the prepared pan. Pour over egg mixture, sprinkle with cheese, then top with remaining vegetables."
    },
    {
      "order": 8,
      "instruction": "Topping: Top with crumbled feta, then mushrooms. Drizzle mushrooms with a touch of olive oil (makes it brown)."
    },
    {
      "order": 9,
      "instruction": "Bake: Bake 40 minutes until centre is just set."
    },
    {
      "order": 10,
      "instruction": "Rest &amp; serve: Rest frittata 5 minutes in the pan. Use paper overhang to lift out of pan, then slice into squares and serve."
    },
    {
      "order": 11,
      "instruction": "Serving later: Cool on rack and remove paper from underneath (otherwise base gets soggy). Cut then refrigerate up to 5 days, or freeze. Reheat in microwave."
    }
  ]
}