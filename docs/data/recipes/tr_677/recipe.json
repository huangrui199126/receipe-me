  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan)."
    },
    {
      "order": 2,
      "instruction": "Grease a 6 cup baking dish (1.6L/1.6Q) with butter."
    },
    {
      "order": 3,
      "instruction": "Butterscotch Sauce: Whisk sugar and cornflour in bowl. Set aside."
    },
    {
      "order": 4,
      "instruction": "Pudding batter: Place sugar, flour and baking powder in a separate bowl. Whisk to combine."
    },
    {
      "order": 5,
      "instruction": "Add butter, egg, milk and golden syrup. Whisk until mostly lump free."
    },
    {
      "order": 6,
      "instruction": "Scrape into baking dish and smooth surface."
    },
    {
      "order": 7,
      "instruction": "Sprinkle Butterscotch Sauce sugar mixture all over surface."
    },
    {
      "order": 8,
      "instruction": "Pour boiling water over the surface over the back of a dessert spoon held as close to the batter as you can (to soften the pour so it doesn't break the surface of the batter)."
    },
    {
      "order": 9,
      "instruction": "Transfer to oven, bake 40 minutes or until skewer inserted into the cake part comes out clean."
    },
    {
      "order": 10,
      "instruction": "Cut through pudding to reveal butterscotch sauce underneath."
    },
    {
      "order": 11,
      "instruction": "To serve, scoop pudding into a bowl then douse with butterscotch sauce. Top with ice cream!"
    }
  ]
}