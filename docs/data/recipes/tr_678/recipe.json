  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C / 390°F (180°C fan)."
    },
    {
      "order": 2,
      "instruction": "Mix ingredients in baking dish: Place all Baked Fried Rice ingredients except bacon in a baking dish (~22 x 32cm / 9 x 13&quot;). Stir, then spread rice evenly across pan."
    },
    {
      "order": 3,
      "instruction": "Top with bacon: Scatter bacon across surface."
    },
    {
      "order": 4,
      "instruction": "Bake covered 40 min: Cover with foil. Bake 40 minutes."
    },
    {
      "order": 5,
      "instruction": "Bake uncovered 15 min: Remove foil. Bake uncovered 15 minutes - this will colour the bacon. Liquid should be absorbed, rice should be cooked (but will seem wet, will absorb and soften while resting)."
    },
    {
      "order": 6,
      "instruction": "Rest 10 min: Cover loosely with foil, stand for 10 minutes."
    },
    {
      "order": 7,
      "instruction": "Fluff: Add green onion and sesame oil. Fluff rice with fork, marvel at how perfectly cooked the rice grains are. Serve!"
    }
  ]
