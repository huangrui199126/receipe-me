  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Using a small knife, cut around the top of the capsicum at downwards 45 degree angle. Remove top, empty seeds. If capsicum bottoms aren't quite level, cut so they'll sit flat. (Be careful to cut off as little as possible so you don'' accidentally cut a hole in the bottom.)"
    },
    {
      "order": 3,
      "instruction": "Place capsicums in a baking dish that will fit them snugly (Note 4)"
    },
    {
      "order": 4,
      "instruction": "Heat oil in a large skillet over high heat,"
    },
    {
      "order": 5,
      "instruction": "Add onion and garlic, cook for 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Add beef and cook, breaking it up as you go, until it's all changed from pink to brown."
    },
    {
      "order": 7,
      "instruction": "Add Spices, stir through. Then add Tomato paste and cook for 1 minute."
    },
    {
      "order": 8,
      "instruction": "Add rice, corn and chicken broth. Stir, bring to simmer, place lid on and lower heat to medium low."
    },
    {
      "order": 9,
      "instruction": "Cook for 13 - 15 minutes until rice is JUST cooked - mixture should be fairly loose still at this stage, not thick and stodgy (see video)."
    },
    {
      "order": 10,
      "instruction": "Stir in green onion."
    },
    {
      "order": 11,
      "instruction": "Spoon half the filling into the prepared capsicums."
    },
    {
      "order": 12,
      "instruction": "Top with half the cheese, then fill to top with remaining beef rice."
    },
    {
      "order": 13,
      "instruction": "Place capsicum lids back on, pour 1/2 cup water into the pan."
    },
    {
      "order": 14,
      "instruction": "Cover tightly with foil, bake 45 minutes."
    },
    {
      "order": 15,
      "instruction": "Remove foil and capsicum lids. Top with remaining cheese. Bake further 5 to 10 minutes, just until cheese is melted."
    },
    {
      "order": 16,
      "instruction": "Serve with sour cream and Guacamole! Quick Guac - Note 5."
    }
  ]
}