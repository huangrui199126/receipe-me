  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Spray 8 holes of a muffin tin."
    },
    {
      "order": 3,
      "instruction": "Grate the onion and carrot straight into a large bowl."
    },
    {
      "order": 4,
      "instruction": "Add remaining meatloaf ingredients and use your hands to mix and combine well."
    },
    {
      "order": 5,
      "instruction": "Scoop up 1/2 cup of mince and use your hands to form a rough ball shape. Press into the muffin tin. The surface should be a slight dome shape."
    },
    {
      "order": 6,
      "instruction": "Repeat with remaining mince. It should make about 8."
    },
    {
      "order": 7,
      "instruction": "Bake for 20 - 25 minutes until browned on top. Remove from oven."
    },
    {
      "order": 8,
      "instruction": "Peel and dice the potato. Steam or boil until soft but not waterlogged."
    },
    {
      "order": 9,
      "instruction": "Drain, then add butter and 1/2 cup of milk. Mash using a potato masher until smooth or to your liking. Add extra milk if you need it. The mash needs to be creamy but stiff enough to hold its shape when piped or piled onto the Meatloaf Cupcakes."
    },
    {
      "order": 10,
      "instruction": "Smear a dollop of tomato ketchup on the Meatloaf Cupcakes."
    },
    {
      "order": 11,
      "instruction": "Top with mashed potato, either by piping it or just dolloping it on with a spoon."
    },
    {
      "order": 12,
      "instruction": "Serve with a sprinkle of parsley, if using."
    }
  ]
}