  "steps": [
    {
      "order": 1,
      "instruction": "Cut the beef into four equal sizes. Season with salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Heat 1/2 the oil in a heavy based skillet over high heat. Brown beef well all over - about 1 1/2 minute on each side, then remove onto a plate."
    },
    {
      "order": 3,
      "instruction": "Add a touch more oil if needed."
    },
    {
      "order": 4,
      "instruction": "Add the garlic, onion and capsicum (bell peppers) and saute until caramelised, around 2 to 3 minutes."
    },
    {
      "order": 5,
      "instruction": "Add 1/2 cup beef broth, bring to simmer, scraping the bottom of the skillet to dissolve brown bits into the liquid. Simmer for 30 seconds then scrape it all into the slow cooker."
    },
    {
      "order": 6,
      "instruction": "In the slow cooker, add the beans, tomato, tomato paste, beef broth and Chili Spices. Stir, then add beef - it won&#x27;t be fully submerged, beef juices will raise liquid level (see video)."
    },
    {
      "order": 7,
      "instruction": "Cook on low for 8 hours."
    },
    {
      "order": 8,
      "instruction": "Remove beef from slow cooker and shred with two forks."
    },
    {
      "order": 9,
      "instruction": "Mix cornflour and 1/4 cup beef stock, then pour into slow cooker. Add beef, then slow cook for a further 20 minutes to allow sauce to thicken."
    },
    {
      "order": 10,
      "instruction": "Adjust seasoning to taste with salt and pepper."
    },
    {
      "order": 11,
      "instruction": "Serve with garnishes of choice, such as sour cream, guacamole or diced avocado, grated cheese, coriander/cilantro. Serve either with corn chips or cornbread for dunking, or serve over rice!"
    }
  ]
}