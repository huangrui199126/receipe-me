  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade ingredients in a large bowl. Add chicken, cover and marinate 12 to 24 hours (Note 5)"
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180C/350F. Line a tray with foil and place a rack on the tray."
    },
    {
      "order": 3,
      "instruction": "Remove chicken from the Marinade, shaking off excess (reserve Marinade), and place on the rack. Bake for 20 minutes, then slather Marinade generously on both sides."
    },
    {
      "order": 4,
      "instruction": "Bake for a further 10 minutes, brush/dab top with Marinade."
    },
    {
      "order": 5,
      "instruction": "Bake further 10 minutes, do a final baste with Marinade then spray with oil."
    },
    {
      "order": 6,
      "instruction": "Increase heat to 220C/450F. Bake for a further 10 to 15 minutes until you get some nice charred spots. Serve with Minted Yogurt and Saffron Rice (below) or plain Basmati Rice."
    },
    {
      "order": 7,
      "instruction": "Combine ingredients in a food processor and blitz until mint is very finely chopped.&nbsp;"
    },
    {
      "order": 8,
      "instruction": "Preheat BBQ with closed lid to medium, brush grills lightly with oil. Place bone-in skin-on chicken skin side down on grills, cook 5 min until surface is just caramelised - no more."
    },
    {
      "order": 9,
      "instruction": "Baste, then flip. Baste, then close lid. Cook for 20 minutes or until internal temperature is&nbsp;175F/80C (bone in thighs and drumsticks), basting once or twice more."
    }
  ]
}