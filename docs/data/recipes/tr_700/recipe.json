  "steps": [
    {
      "order": 1,
      "instruction": "Cut the tomatoes into 8 or 10 wedges, cutting out the core. Place in a large bowl."
    },
    {
      "order": 2,
      "instruction": "Sprinkle over eschallots, garlic, salt and pepper. Drizzle with olive oil and vinegar."
    },
    {
      "order": 3,
      "instruction": "Gently toss to coat tomatoes. Add basil, toss again to disperse."
    },
    {
      "order": 4,
      "instruction": "Pour into bowl and serve immediately! (Tip: Bread for mopping up the tomato juices is on point)."
