  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce ingredients in a small bowl, then set aside."
    },
    {
      "order": 2,
      "instruction": "Scramble eggs - Heat sesame oil in a large wok or non-stick pan over medium high heat. Add egg and cook, stirring gently, so it is softly scrambled. Remove onto a plate."
    },
    {
      "order": 3,
      "instruction": "Cook beef - Heat vegetable oil in the same pan over high heat. Add onion and garlic, cook for 30 seconds. Add beef and cook, breaking it up as you go, for 2 minutes or until you no longer see raw beef. Add 2 tablespoons of sauce and cook for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Veg / caramelise beef - Add frozen vegetables and cook for 2 minutes or until the beef gets nicely caramelised - this is the trick to great flavour so do not shortcut this!"
    },
    {
      "order": 5,
      "instruction": "Rice &amp; sauce - Add rice and remaining sauce. Toss for 2 minutes until the sauce is well dispersed throughout the rice and the rice grains start to caramelise a bit."
    },
    {
      "order": 6,
      "instruction": "Egg &amp; green onion - Then add scrambled eggs and green onion, give it a quick toss to disperse then divide between bowls. EAT!"
    }
  ]
}