  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce in a large bowl. Add chicken and set aside to marinate for 10 minutes to overnight."
    },
    {
      "order": 2,
      "instruction": "Cut Chinese broccoli stems cut into 2.5 cm/1\" pieces, leafy part 5cm/2.5cm pieces."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large pot over medium high heat. Remove chicken from marinade, shaking off excess marinade - RESERVE marinade!"
    },
    {
      "order": 4,
      "instruction": "Cook both sides until golden - about 90 seconds on each side, don't let them burn! Remove chicken onto plate."
    },
    {
      "order": 5,
      "instruction": "Add a touch of oil if pot is dry. Add onion, garlic and ginger, cook for 2 minutes until tinged with gold."
    },
    {
      "order": 6,
      "instruction": "Add rice, stir to coat grains in oil. Add broth, reserved Marinade and Chinese broccoli stems. Stir."
    },
    {
      "order": 7,
      "instruction": "Place chicken across the top, pour in juices pooled on plate. Cover, bring to simmer then lower heat to medium."
    },
    {
      "order": 8,
      "instruction": "Cook for 12 -15 minutes or until liquid is absorbed (tilt pot to check)."
    },
    {
      "order": 9,
      "instruction": "Remove from heat. Working quickly, scatter Chinese broccoli leaves across surface, clamp lid back on."
    },
    {
      "order": 10,
      "instruction": "Rest for 10 minutes. Remove lid, toss rice and serve, garnished with sesame seeds and green onions. A dollop of your favourite chilli paste wouldn't go astray either!"
    }
  ]
}