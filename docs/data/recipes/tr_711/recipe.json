  "steps": [
    {
      "order": 1,
      "instruction": "Mix Garlic Mayo ingredients in a small bowl, set aside for 20+ minutes."
    },
    {
      "order": 2,
      "instruction": "Mix Seasoning in a flat bowl / dish."
    },
    {
      "order": 3,
      "instruction": "If required, pound chicken to about 1 cm / 2/5” thick. If wanting to be exact, trim to shape of rolls BUT ensure it is about 15% larger (it shrinks) (Note 2)."
    },
    {
      "order": 4,
      "instruction": "Heat 1 tbsp oil in a skillet over high heat (if doing on BBQ, drizzle flat plate)."
    },
    {
      "order": 5,
      "instruction": "Add onion and cook, turning regularly, for 5 minutes until golden. Season with salt and pepper, toss, then remove."
    },
    {
      "order": 6,
      "instruction": "While cooking the onions, preheat oven to 160C/320F. Split rolls, then lightly toast / warm the rolls (if using BBQ, just toast the cut side until crispy). Leave in turned off oven with door ajar while you cook chicken."
    },
    {
      "order": 7,
      "instruction": "Heat 1 tbsp oil into the same skillet, still on high heat."
    },
    {
      "order": 8,
      "instruction": "Dredge chicken in Seasoning, shake off excess, then place in skillet. Repeat."
    },
    {
      "order": 9,
      "instruction": "Cook for 2 ½ minutes until golden, then flip."
    },
    {
      "order": 10,
      "instruction": "Top with cheese then leave for 1 1/2 minutes. When the underside is golden, if the cheese is not yet melted, place lid on for 15 seconds (or tray or foil)."
    },
    {
      "order": 11,
      "instruction": "Remove chicken from skillet onto plate. Cover loosely with foil while you start assembling the burgers."
    },
    {
      "order": 12,
      "instruction": "Smear base of roll with avocado, sprinkle with salt and pepper. Top with chicken, onion, lettuce then tomato."
    },
    {
      "order": 13,
      "instruction": "Smear lid of roll with Garlic Mayo, place on burger. Enjoy!"
    }
  ]
}