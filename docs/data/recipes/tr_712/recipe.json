  "steps": [
    {
      "order": 1,
      "instruction": "Homemade quiche crust or frozen shortcrust pastry - prepare and bake the crust per Quiche Crust recipe."
    },
    {
      "order": 2,
      "instruction": "Refrigerated pie crust - unroll, fit into a 9\" pie dish or tart tin. Bake per packet directions."
    },
    {
      "order": 3,
      "instruction": "Prepared pie shell (ie comes in foil dish) - bake per packet directions, scale Filling down to 4 eggs (Note 1)."
    },
    {
      "order": 4,
      "instruction": "Preheat oven to 180C/350F (160C/320F fan forced)."
    },
    {
      "order": 5,
      "instruction": "Place cooked quiche crust on a tray."
    },
    {
      "order": 6,
      "instruction": "Asparagus - break woody ends off (Note 7). Cut into 3.5cm / 1.5\" pieces, separate tips from stems (tips for decorating)."
    },
    {
      "order": 7,
      "instruction": "Melt butter in a skillet over medium heat. Add leeks and garlic, saute for 2&nbsp;minutes or until leeks are translucent, don't let them go golden."
    },
    {
      "order": 8,
      "instruction": "Stir in asparagus stems (don't cook), then remove from stove."
    },
    {
      "order": 9,
      "instruction": "Cool slightly then scatter across base of quiche crust."
    },
    {
      "order": 10,
      "instruction": "Whisk together eggs, cream, dill, salt, pepper in a bowl."
    },
    {
      "order": 11,
      "instruction": "Scatter 2/3 of the salmon across quiche, folding/twisting pieces rather than laying flat."
    },
    {
      "order": 12,
      "instruction": "Top with cheese, pour over egg mixture."
    },
    {
      "order": 13,
      "instruction": "Top with remaining salmon and asparagus tips."
    },
    {
      "order": 14,
      "instruction": "Bake for 40 minutes or until top is light golden and centre is set but still slightly jiggly when you poke it."
    },
    {
      "order": 15,
      "instruction": "Rest for 10 minutes before carefully removing from tin and slicing."
    }
  ]
}