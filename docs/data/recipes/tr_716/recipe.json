  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C/320°F fan)."
    },
    {
      "order": 2,
      "instruction": "Brush a 12 hole standard muffin tin generously with butter"
    },
    {
      "order": 3,
      "instruction": "Whisk Dry ingredients in a bowl."
    },
    {
      "order": 4,
      "instruction": "Whisk Wet ingredients in a separate bowl."
    },
    {
      "order": 5,
      "instruction": "Pour Wet into the Dry ingredients bowl. Mix 8 times."
    },
    {
      "order": 6,
      "instruction": "Add cheese, feta, sun dried tomato, capsicum, olives and green onion. Mix as few times as possible just to incorporate remaining bits of flour - no more than 7 big stirs (secret to soft muffs)."
    },
    {
      "order": 7,
      "instruction": "Divide between 12 holes in muffin in (I use an ice cream scooper). Batter should be thick and fill muffin tin slightly mounded (see video)"
    },
    {
      "order": 8,
      "instruction": "Bake for 25 minutes or until the muffins are golden and crusty and spring back when touched in the centre."
    },
    {
      "order": 9,
      "instruction": "Cool for 10 minutes, then transfer to cooling rack. Serve warm for optimum experience!"
    }
  ]
}