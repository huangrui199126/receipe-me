  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (all ovens) (Note 6). Line a 12 hole muffin tin with paper patties."
    },
    {
      "order": 2,
      "instruction": "Whisk flour, baking powder, baking soda, sugar and salt in a bowl. Stir through chocolate chips."
    },
    {
      "order": 3,
      "instruction": "In a separate bowl, whisk buttermilk, melted butter, oil, eggs and vanilla."
    },
    {
      "order": 4,
      "instruction": "Make a well in the flour bowl, pour in egg mixture. Mix until just combine - try not to stir more than 8 times. Some flour lumps in the batter is fine."
    },
    {
      "order": 5,
      "instruction": "Divide batter between paper cases. Top with remaining 1/4 cup chocolate chips."
    },
    {
      "order": 6,
      "instruction": "Bake for 5 minutes, then turn down to 180C/350F (fan forced/convection) and bake for a further 15 minutes, or until a skewer inserted into the muffin comes out clean."
    },
    {
      "order": 7,
      "instruction": "Remove muffins from the muffin tin immediately onto a cooling rack."
    },
    {
      "order": 8,
      "instruction": "Serve warm or at room temperature (warm is extra yum!)"
    }
  ]
}