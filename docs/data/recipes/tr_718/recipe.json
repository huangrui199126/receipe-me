  "steps": [
    {
      "order": 1,
      "instruction": "Mix spices - Put the garlic, sugar, chilli flakes, sichuan pepper, five spices and stock powder in a medium mixing bowl."
    },
    {
      "order": 2,
      "instruction": "Heat oil - Heat the chilli oil and vegetable oil in a small frying pan over medium heat until hot. Pour over garlic mixture. Enjoy the sizzle! (Don&#39;t worry, it doesn&#39;t spit)"
    },
    {
      "order": 3,
      "instruction": "Add sauces: - Whisk in soy sauce, rice vinegar and hot water. The oil will remain a little separated on top. Set aside while you make wontons."
    },
    {
      "order": 4,
      "instruction": "Cook wontons - Bring a large saucepan of water to the boil. Add wontons and cook until they float: 4 minutes for freshly made, 6 to 8 minutes from frozen."
    },
    {
      "order": 5,
      "instruction": "Assemble - Transfer to serving dish using a slotted spoon. Pour over sauce, add an extra drizzle of chilli oil (if you dare!), sprinkle with green onion. Serve immediately!"
    }
  ]
