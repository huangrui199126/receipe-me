  "steps": [
    {
      "order": 1,
      "instruction": "Microwave potatoes for 10 minutes on high or until cooked. (Note 5)"
    },
    {
      "order": 2,
      "instruction": "Place on one side of tray. Squish using potato masher (Note 6) to about 1.7cm / 2/3\" thickness. Drizzle with oil, sprinkle with salt and pepper."
    },
    {
      "order": 3,
      "instruction": "If making smashed potatoes, fold up the edges of the foil the drumsticks are on&nbsp;"
    },
    {
      "order": 4,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 5,
      "instruction": "Mix Sauce ingredients together with a good pinch of salt and pepper."
    },
    {
      "order": 6,
      "instruction": "Line tray with foil, then top with parchment paper."
    },
    {
      "order": 7,
      "instruction": "Place drumsticks on paper. If making smashed potatoes, fold up the edges of the foil so the sauce won't leak into the potatoes (doesn't need to be high - even 1cm / 2/5\" is enough, video useful)."
    },
    {
      "order": 8,
      "instruction": "Spoon Sauce over drumsticks.&nbsp;Drizzle chicken with olive oil."
    },
    {
      "order": 9,
      "instruction": "Bake for 30 minutes. Turn drumsticks (not potatoes), spoon juices over drumsticks.&nbsp;"
    },
    {
      "order": 10,
      "instruction": "Bake for a further 20 minutes, turn, spoon over juices. Bake for 10 - 15 minutes until sauce reduces and the drumsticks are golden and sticky."
    },
    {
      "order": 11,
      "instruction": "Remove from oven. Squidge the drumsticks around in what should now be a syrupy sauce. (Note 7) Serve drumsticks with sauce, with crispy smashed potatoes and steamed broccolini on the side. Sprinkle with fresh thyme leaves if using."
    }
  ]
