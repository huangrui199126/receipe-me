  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/390°F (180°C fan)."
    },
    {
      "order": 2,
      "instruction": "Seasoning - mix in a small bowl."
    },
    {
      "order": 3,
      "instruction": "Season chicken - Place chicken in a 23 x 33cm / 9 x 13&quot; baking pan. Drizzle with oil then rub all over Sprinkle &amp; rub in the Seasoning, using most on the skin side."
    },
    {
      "order": 4,
      "instruction": "Arrange chicken skin side up in the pan."
    },
    {
      "order": 5,
      "instruction": "Gravy mixture - Whisk flour with about 1/2 cup of stock until lump free, then whisk in remaining stock and pepper (forgot in video!). Pour into the pan around the chicken."
    },
    {
      "order": 6,
      "instruction": "Bake uncovered for 50 minutes, or until chicken is crispy and golden."
    },
    {
      "order": 7,
      "instruction": "Whisk gravy - Remove chicken onto a plate, then give the gravy a good whisk to make it smooth. Adjust Gravy thickness if required - Note 4. Taste and add salt and pepper, if needed."
    },
    {
      "order": 8,
      "instruction": "Serve - Pour gravy into a jug. Serve alongside chicken!"
    }
  ]
