  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 240°C / 450°F (220°C fan). Line tray with parchment/baking paper."
    },
    {
      "order": 2,
      "instruction": "Cut eggplant into 2cm / 4/5&quot; slices, then cut into 2cm / 4/5&quot; batons."
    },
    {
      "order": 3,
      "instruction": "Place in large bowl, toss with oil, salt and pepper."
    },
    {
      "order": 4,
      "instruction": "Spread on tray, roast 20 minutes. Turn, roast for a further 10 minutes - edges should be caramelised, soft inside, but they&#039;re not shrivelled up and dismal. Use per recipe."
    },
    {
      "order": 5,
      "instruction": "Heat oil in a large pot over medium heat. Add mustard seeds, let them sizzle for 15 seconds."
    },
    {
      "order": 6,
      "instruction": "Add curry leaves, stir, leave to sizzle for 15 seconds - seeds might pop, Indian cooking is very dramatic!"
    },
    {
      "order": 7,
      "instruction": "Add onions, cook 5 minutes until golden brown."
    },
    {
      "order": 8,
      "instruction": "Add tomato, cook for 1 minute, stirring."
    },
    {
      "order": 9,
      "instruction": "Add garlic and ginger, cook 2 minutes."
    },
    {
      "order": 10,
      "instruction": "Add Curry Spices and salt, and cook for another 3 minutes - it will be a thick paste and might stick to the bottom of the pot, don&#039;t let it burn (if it starts to, remove from stove and quickly add splash of water to loosen)."
    },
    {
      "order": 11,
      "instruction": "Stir in water, and then add the eggplant."
    },
    {
      "order": 12,
      "instruction": "Gently stir, partially cover, reduce heat to low and simmer 30 minutes. Stir carefully once or twice (so the eggplants don&#039;t break up completely), add more water if it dries out."
    },
    {
      "order": 13,
      "instruction": "Stir in coconut milk, taste then add more salt if needed."
    },
    {
      "order": 14,
      "instruction": "Your result should be a very thick, juicy, strongly flavoured curry with eggplant partially intact but half collapsed."
    },
    {
      "order": 15,
      "instruction": "Serve with basmati rice and a dollop of yogurt and fresh coriander leaves, if you want."
    }
  ]
}