  "ingredients": [
    {
      "amount": "2",
      "unit": "cups",
      "name": "white flour ((plain / all purpose))",
      "emoji": "🌾",
      "section": "",
      "order": 0
    },
    {
      "amount": "1 3/4",
      "unit": "cups",
      "name": "wholemeal flour ((wholewheat, Note 1))",
      "emoji": "🌾",
      "section": "",
      "order": 1
    },
    {
      "amount": "",
      "unit": "",
      "name": "2 - 3 tbsp Extra Flour ((either flour, for dusting))",
      "emoji": "🌾",
      "section": "",
      "order": 2
    },
    {
      "amount": "1 1/2",
      "unit": "tsp",
      "name": "baking soda ((bi-carb, Note 2))",
      "emoji": "🥄",
      "section": "",
      "order": 3
    },
    {
      "amount": "1 1/2",
      "unit": "tsp",
      "name": "salt",
      "emoji": "🧂",
      "section": "",
      "order": 4
    },
    {
      "amount": "2",
      "unit": "cups",
      "name": "buttermilk (, fridge cold (Note 3))",
      "emoji": "🧈",
      "section": "",
      "order": 5
    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/430°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Line tray with baking paper."
    },
    {
      "order": 3,
      "instruction": "Whisk both flours (not Extra Flour), baking soda and salt in a bowl."
    },
    {
      "order": 4,
      "instruction": "Add buttermilk, stir until it's too hard to stir anymore."
    },
    {
      "order": 5,
      "instruction": "Sprinkle 2 tbsp Extra Flour onto work surface, scrape out dough, sprinkle with more flour."
    },
    {
      "order": 6,
      "instruction": "Gently knead no more than 8 times, bring together into a ball. (Note 4)"
    },
    {
      "order": 7,
      "instruction": "Transfer to tray, pat into 2.5cm/1\" thick disc."
    },
    {
      "order": 8,
      "instruction": "Cut cross on surface 1cm / 0.3\" deep using serrated knife."
    },
    {
      "order": 9,
      "instruction": "Bake 20 minutes. Turn oven down to 200°C/390°F (180°C fan)."
    },
    {
      "order": 10,
      "instruction": "Bake further 20 minutes, or until the base sounds hollow when tapped in the middle."
    },
    {
      "order": 11,
      "instruction": "Transfer to rack and cool for at least 30 minutes before slicing.&nbsp;"
    }
  ]
}