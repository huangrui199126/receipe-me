  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large pan over high heat. Make sure the pan is reasonably deep - around 5cm / 2.5&quot; or more. Otherwise, use a large pot."
    },
    {
      "order": 2,
      "instruction": "Sear chicken - Add garlic and onion, cook for 1 minute. Add chicken, then cook for 2 minutes until seared on the outside but still raw inside."
    },
    {
      "order": 3,
      "instruction": "Vegetables and flour - Add frozen vegetables (still frozen ok) and flour, stir until flour is incorporated."
    },
    {
      "order": 4,
      "instruction": "Add uncooked risoni - Add risoni/orzo, stock and milk, then stir well."
    },
    {
      "order": 5,
      "instruction": "Cook 7 minutes - Bring to simmer then adjust heat so it&#39;s bubbling gently (see video). Cook for 7 minutes (no lid), stirring every now and then, until risoni is almost tender (still quite soupy at this stage)."
    },
    {
      "order": 6,
      "instruction": "Add parmesan, spinach, salt and pepper. Stir through until the spinach is wilted."
    },
    {
      "order": 7,
      "instruction": "Serve - The consistency should be like a loose risotto (it absorbs liquid and thickens quite quickly when serving), nice and creamy. Serve, garnished with parsley and more parmesan if desired!"
    }
  ]
