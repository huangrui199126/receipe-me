  "steps": [
    {
      "order": 1,
      "instruction": "Marinade chicken - Mix Marinade ingredients in a large bowl. Add chicken and toss to coat. Marinade for at least 3 hours, preferably overnight."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan-forced)."
    },
    {
      "order": 3,
      "instruction": "Prepare - Line a tray with baking paper/parchment paper. Place chicken on the tray, skin side up. Scrape all Marinade out of th bowl and dab onto chicken."
    },
    {
      "order": 4,
      "instruction": "Bake for 40 minutes, basting at the 30 minute and 40 minute mark using the tray juices to make it golden brown and sticky, and rotate the tray as needed for even colour."
    },
    {
      "order": 5,
      "instruction": "Increase the oven temperature to 200°C/390°F (180°C fan-forced). Pop the chicken back in for a final 10 minutes to caramelise the skin."
    },
    {
      "order": 6,
      "instruction": "Rest for 3 minutes before serving with jasmine or coconut rice, and plain chunks of tomato and cucumber the Thai way!"
    }
  ]
