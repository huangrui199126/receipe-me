  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220°C/425°F (200°C fan)."
    },
    {
      "order": 2,
      "instruction": "Toss cauliflower with oil, salt and pepper. Spread on tray, roast 20 minutes, turn, then roast for a further 5 to 10 minutes until the edges are golden brown and the cauliflower is cooked through. Don&#039;t let it get overcooked, sad and soggy!"
    },
    {
      "order": 3,
      "instruction": "Transfer to bowl and let cool for 20 minutes."
    },
    {
      "order": 4,
      "instruction": "Turn oven down to 160°C/320°F (140°C fan). Spread hazelnuts on tray then roast for 5 minutes until they smell amazing."
    },
    {
      "order": 5,
      "instruction": "Cool slightly, then roughly chop (most skin will naturally fall off)."
    },
    {
      "order": 6,
      "instruction": "Place hazelnuts, parsley and celery into the bowl. Sprinkle over cinnamon, allspice, salt and pepper. Drizzle with olive oil, maply syrup and vinegar. Toss gently with hands or rubber spatula."
    },
    {
      "order": 7,
      "instruction": "Plate up: Taste, add more salt or pepper if needed. Transfer to serving bowl. Scatter over pomegranates. Serve at room temperature."
    }
  ]
