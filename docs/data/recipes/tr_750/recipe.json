  "steps": [
    {
      "order": 1,
      "instruction": "Take pastry out of freezer."
    },
    {
      "order": 2,
      "instruction": "Place spinach in a colander and use a wooden spoon or your hands to press out excess water. You could also do this using a tea towel or paper towels. Transfer spinach to a bowl (drink the liquid, it’s good for you!)."
    },
    {
      "order": 3,
      "instruction": "Add remaining Filling ingredients. Mix to combine."
    },
    {
      "order": 4,
      "instruction": "Place pastry on work surface and cut in half to create 2 rectangles – you should have 6 in total."
    },
    {
      "order": 5,
      "instruction": "Divide filling between pastries, brush edge with egg then roll up, finishing with the seam side down."
    },
    {
      "order": 6,
      "instruction": "Refrigerate for 15 minutes. Meanwhile, preheat oven to 180C/350F."
    },
    {
      "order": 7,
      "instruction": "Spray 2 x baking trays with oil (any)."
    },
    {
      "order": 8,
      "instruction": "Cut rolls into 4, or whatever size you want. Brush tops with egg (makes it golden) then sprinkle with sesame seeds."
    },
    {
      "order": 9,
      "instruction": "Bake for 25 minutes, then take out the top tray and move the bottom tray to the top and give it an additional 5 - 10 minutes to make it golden."
    },
    {
      "order": 10,
      "instruction": "Best served warm – the pastry is crispier and the filling is juicier. See notes for make ahead instructions."
    }
  ]
