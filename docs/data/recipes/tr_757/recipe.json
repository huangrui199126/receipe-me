  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F (standard) or 160C/320F (fan/convection). Line a tray with parchment/baking paper."
    },
    {
      "order": 2,
      "instruction": "Roughly chop dates. Place in bowl, pour over water. Cover and leave to soak for 10 minutes+."
    },
    {
      "order": 3,
      "instruction": "Mash with potato masher or fork until it becomes a paste."
    },
    {
      "order": 4,
      "instruction": "Add remaining Wet ingredients. Mix well with wooden spoon."
    },
    {
      "order": 5,
      "instruction": "Add Dry ingredients. Mix until all flour is incorporated - should be a thick batter (see video)."
    },
    {
      "order": 6,
      "instruction": "Measure out just shy of 1/2 cup (6 cookies) or 1/3 cup flat (8 cookies). &nbsp;Flatten to 1.7cm / 2/3\" thick rounds. (Note 9) Bake 20 minutes until golden."
    },
    {
      "order": 7,
      "instruction": "Remove from oven, leave to cool on the tray."
    }
  ]
