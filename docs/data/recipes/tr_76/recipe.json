  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a pan over high heat. Add bacon and cook until lightly browned. Remove onto a plate lined with a paper towel to drain excess fat. Set aside to cool."
    },
    {
      "order": 3,
      "instruction": "Cut the ends off the baguette and cut the baguette in half (or quarters - makes it easier to stuff)."
    },
    {
      "order": 4,
      "instruction": "Use a long knife (preferably bread knife) to cut the bread out, leaving about a 1/2\" / 1.5cm wall of bread and crust. (Note 2)"
    },
    {
      "order": 5,
      "instruction": "Place the bacon, cream cheese, cheddar and mozzarella cheese, jalapeños, scallions/shallots and pepper in a bowl and mix until combined."
    },
    {
      "order": 6,
      "instruction": "Use a knife or piping bag to stuff the mixture inside the baguettes."
    },
    {
      "order": 7,
      "instruction": "Garlic Butter: melt butter with the garlic and salt in the microwave or on the stove."
    },
    {
      "order": 8,
      "instruction": "Brush the baguette with garlic butter (or you can do this after you slice it)."
    },
    {
      "order": 9,
      "instruction": "Slice the baguette into 1 1/4cm / 1/2\" slices."
    },
    {
      "order": 10,
      "instruction": "Keep the slices pressed up against each other, and transfer to a large piece of foil."
    },
    {
      "order": 11,
      "instruction": "Wrap the baguette, then bake for 15 to 20 minutes, or until the bread is crusty and the cheese inside is melted."
    },
    {
      "order": 12,
      "instruction": "For optimal experience, serve warm!"
    }
  ]
}