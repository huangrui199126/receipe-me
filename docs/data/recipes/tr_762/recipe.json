  "steps": [
    {
      "order": 1,
      "instruction": "Tenderise Chicken (optional, Note 4): Place chicken and bicarb in a bowl and mix with your fingers. Set aside for 20 minutes. Rinse well in a colander then shake off excess water. Roughly pat dry with a paper towel."
    },
    {
      "order": 2,
      "instruction": "Sauce: Place all ingredients except water in a bowl and mix (microwave if needed to melt the peanut butter). Add water and mix."
    },
    {
      "order": 3,
      "instruction": "Prepare noodles per packet directions (usually soak in boiled water). Drain, set aside."
    },
    {
      "order": 4,
      "instruction": "Heat oil in a large skillet or wok over high heat. Add garlic and onion, stir for 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Add chicken and cook until the outside changes from pink to white. Add carrot and cabbage, cook until it starts to wilt."
    },
    {
      "order": 6,
      "instruction": "Add noodles, bean sprouts and Sauce. Toss for 1 1/2 - 2 minutes or until the Sauce thickens and coats the noodles."
    },
    {
      "order": 7,
      "instruction": "Serve immediately, garnished with coriander and peanuts."
    }
  ]
}