  "steps": [
    {
      "order": 1,
      "instruction": "Sauté aromatics: Heat oil in a very large pot (6L/qt) over medium high heat. Cook onion, leek, celery, garlic and fennel for 5 minutes until softened."
    },
    {
      "order": 2,
      "instruction": "Cook spices: Add all spice and cumin, and cook for 1 minute."
    },
    {
      "order": 3,
      "instruction": "Add water, potatoes, broccoli, salt and pepper. Stir, bring to simmer, and simmer for 7 minutes (no lid) until the broccoli is tender."
    },
    {
      "order": 4,
      "instruction": "Add peas: Add peas, simmer for 1 minute."
    },
    {
      "order": 5,
      "instruction": "Blitz in kale: Remove pot off the stove. Add kale, push it under the liquid, then blitz with a stick blender until mostly smooth. Add spinach, push under the liquid then blitz again until smooth as possible (approx 3 to 5 mins). This will result in a smooth soup but with little green bits in it - I like this for a little texture."
    },
    {
      "order": 6,
      "instruction": "Serve: Stir in cream. Ladle into bowls, drizzle with extra cream and/or olive oil and finish with a sprinkle of sunflower seeds. Eat and feel great!"
    }
  ]
}