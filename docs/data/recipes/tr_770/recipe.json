  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220C / 430F."
    },
    {
      "order": 2,
      "instruction": "Cut sweet potato into 1.5cm / 3/5\" thick slices. Cut the larger rounds in half (into semi circles)."
    },
    {
      "order": 3,
      "instruction": "Place in a bowl, drizzle over oil, sprinkle with salt and pepper. Toss well to coat. Pour onto baking tray."
    },
    {
      "order": 4,
      "instruction": "Roast for 20 minutes, then use an egg flip to turn and roast for a further 10 minutes or until golden."
    },
    {
      "order": 5,
      "instruction": "Meanwhile, place Dressing ingredients in a jar, mix with a teaspoon (to get honey off the base) then shake well until combined."
    },
    {
      "order": 6,
      "instruction": "Toast pecans in a dry skillet over medium high heat for 3 minutes, or until they smell nutty."
    },
    {
      "order": 7,
      "instruction": "Remove pecans, then heat 1 tsp oil. Add bacon and cook until golden."
    },
    {
      "order": 8,
      "instruction": "To assemble, place everything in a bowl, reserving some bacon, pecans and goats cheese for garnish. Drizzle with most of the dressing, then toss gently."
    },
    {
      "order": 9,
      "instruction": "Transfer into a serving bowl, garnish with remaining bacon, pecans and goats cheese. Drizzle with remaining dressing. Serve!"
    }
  ]
}