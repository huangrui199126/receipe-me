  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a wok or large non stick skillet over high heat."
    },
    {
      "order": 2,
      "instruction": "Add garlic and onion, cook for 1 minute."
    },
    {
      "order": 3,
      "instruction": "Add capsicum, cook for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Add peas, stir for 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Add rice and Sauce ingredients of choice. Cook, stirring constantly, for 2 minutes or until rice grains goes from being wet with sauce to sort of caramelised."
    },
    {
      "order": 6,
      "instruction": "Add pineapple, stir for just 30 seconds to warm through."
    },
    {
      "order": 7,
      "instruction": "Stir through green onions then serve!"
