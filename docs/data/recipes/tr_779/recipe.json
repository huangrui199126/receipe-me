  "steps": [
    {
      "order": 1,
      "instruction": "Bring large pot of water to the boil - 4 to 5 litres / quarts. Add salt then add pasta. Cook per packet directions."
    },
    {
      "order": 2,
      "instruction": "Drain pasta then cool."
    },
    {
      "order": 3,
      "instruction": "Meanwhile, mix Dressing ingredients in a bowl."
    },
    {
      "order": 4,
      "instruction": "Place pasta in a bowl. Add remaining Macaroni Salad ingredients. Pour over Dressing."
    },
    {
      "order": 5,
      "instruction": "Toss. Adjust salt / sugar / sour (vinegar) / mayo to taste."
    },
    {
      "order": 6,
      "instruction": "Set aside for at least 20 minutes. Then serve at room temperature (not cold). It's great the next day too!"
    }
  ]
