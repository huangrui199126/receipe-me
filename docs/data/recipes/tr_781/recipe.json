  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large, heavy based pot over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Add garlic and onion, cook 2 minutes."
    },
    {
      "order": 3,
      "instruction": "Add celery and carrot, cook 3 minutes."
    },
    {
      "order": 4,
      "instruction": "Turn heat up to high, add beef and cook, breaking it up as you go."
    },
    {
      "order": 5,
      "instruction": "Once beef is brown, add wine. Simmer rapidly for 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Add remaining Sauce ingredients, stir."
    },
    {
      "order": 7,
      "instruction": "Bring to simmer, lower heat, cover with lid. Simmer for 45 minutes (minimum) or 1.5 - 2 hours (best!).&nbsp;"
    },
    {
      "order": 8,
      "instruction": "If liquid evaporates too much, add water - should be saucy (see video/pics). Adjust salt and pepper to taste."
    },
    {
      "order": 9,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 10,
      "instruction": "Cook pasta per packet directions, minus 1 minute."
    },
    {
      "order": 11,
      "instruction": "Drain, then return into pot."
    },
    {
      "order": 12,
      "instruction": "Add just over half the Sauce, toss."
    },
    {
      "order": 13,
      "instruction": "Spread half the pasta in a casserole pan, spread with half remaining Sauce."
    },
    {
      "order": 14,
      "instruction": "Top with cheese slices, then remaining pasta, remaining Sauce, finish with mozzarella."
    },
    {
      "order": 15,
      "instruction": "Cover loosely with foil (so cheese doesn't stick), bake 25 minutes."
    },
    {
      "order": 16,
      "instruction": "Remove foil (reserve), bake further 10 minutes than remove."
    },
    {
      "order": 17,
      "instruction": "Cover loosely with foil, stand 10 - 15 minutes. Then cut slices with a knife and use a spatula to serve pieces like lasagna!"
    }
  ]
}