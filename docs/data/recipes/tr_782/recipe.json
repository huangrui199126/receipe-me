    }
  ],
  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F (160°C fan)."
    },
    {
      "order": 2,
      "instruction": "Butter and line a 20cm / 8&quot; spring form pan."
    },
    {
      "order": 3,
      "instruction": "Melt chocolate and butter in microwave in 30 second bursts, stirring in between until smooth."
    },
    {
      "order": 4,
      "instruction": "Whisk in sugar. Add eggs and vanilla, whisking well until combined,"
    },
    {
      "order": 5,
      "instruction": "Switch to wooden spoon. Add cocoa powder, baking powder and almond meal, fold through until just combined."
    },
    {
      "order": 6,
      "instruction": "Pour batter into pan, bake 45 min until top has thin crust and skewer comes out clean, not smeared with batter."
    },
    {
      "order": 7,
      "instruction": "Cool cake in the pan for 10 minutes, then remove sides. Cool completely on rack before carefully removing base."
    },
    {
      "order": 8,
      "instruction": "Dust with cocoa powder then serve. I served mine with strawberries and dollop cream, but it doesn't need it!"
    }
  ]
}