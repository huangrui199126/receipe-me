  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta: Bring a large pot of water to the boil. Add salt, then cook pasta per packet directions. Drain well, let cool."
    },
    {
      "order": 2,
      "instruction": "Dressing: Mix Dressing ingredients in a bowl. Set aside 10 minutes+."
    },
    {
      "order": 3,
      "instruction": "Cook bacon: Place bacon in a cold non-stick skillet (Note X). Turn stove on to medium high, then cook bacon until golden. Drain on paper towels."
    },
    {
      "order": 4,
      "instruction": "Toss! Place cooked pasta in a large bowl along with all the Pasta Salad ingredients, reserving some bacon for garnish. Pour over Dressing, then toss well."
    },
    {
      "order": 5,
      "instruction": "Set aside for 20 minutes. Transfer to serving bowl, sprinkle with remaining bacon. Serve!"
    },
    {
      "order": 6,
      "instruction": "Storage: Keeps for 3 - 4 days in the fridge. Best to bring to room temp before serving!"
    }
  ]
