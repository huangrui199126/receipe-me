  "steps": [
    {
      "order": 1,
      "instruction": "Cook pasta in a big pot of boiling water for time per packet MINUS 2 minutes. Just before draining, scoop out a mugful of pasta cooking water."
    },
    {
      "order": 2,
      "instruction": "Melt butter in large skillet over medium heat. Add garlic and onion, cook until translucent - about 2 minutes."
    },
    {
      "order": 3,
      "instruction": "Add remaining ingredients. Stir until parmesan is melted. Turn heat up slightly and simmer for 2 minutes. Adjust salt to taste."
    },
    {
      "order": 4,
      "instruction": "Add pasta. Toss for 1 to 2 minutes or until sauce thickens and is clinging to pasta instead of swimming on the base of the skillet (video shows this well). Use reserved pasta cooking water if required to thin the sauce out if it gets too thick."
    },
    {
      "order": 5,
      "instruction": "Serve immediately, garnished with more parmesan and parsley if desired."
    }
