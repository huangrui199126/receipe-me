  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 220C/430F (standard) or 200C/390F (fan / convection)."
    },
    {
      "order": 2,
      "instruction": "Place a rack on a tray (optional, rack keeps balls slightly rounder)."
    },
    {
      "order": 3,
      "instruction": "Place Meatball ingredients in a bowl (except oil spray), mix well with your hands. Only use extra breadcrumbs if necessary - sometimes, chicken mince can be quite wet. Scoop up 1 slightly heaped tablespoon and roll into a ball (about 3cm / 1.25\" diameter). (Note 6 for my way)"
    },
    {
      "order": 4,
      "instruction": "Spray rack well with oil and place the meatballs on the rack."
    },
    {
      "order": 5,
      "instruction": "Spray meatballs generously with oil, then bake for 20 - 25 minutes or until a bit browned. They should be beautifully soft - see video!"
    },
    {
      "order": 6,
      "instruction": "Serve warm with Sauce, garnished with coriander and chillies if desired."
    },
    {
      "order": 7,
      "instruction": "Place ingredients in a bowl and mix. Set aside for at least 10 minutes before using."
    }
  ]
