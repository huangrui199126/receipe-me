  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C / 400°F (180°C fan)."
    },
    {
      "order": 2,
      "instruction": "Sauté - Heat the olive oil in a cast-iron skillet over medium high heat (or other oven-proof pan). Cook onion, garlic and capsicum for 3 minutes."
    },
    {
      "order": 3,
      "instruction": "Cook beef &amp; spices - Add beef and cook, breaking it up as you go, until you no longer see raw meat. Add spices, then cook for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Beans &amp; tomato - Add kidney beans and passata. Stir, then bring to a simmer."
    },
    {
      "order": 5,
      "instruction": "Cheese it! Scatter the jalapeño across the surface, top with cheese."
    },
    {
      "order": 6,
      "instruction": "Bake 15 minutes (no lid) then remove from the oven."
    },
    {
      "order": 7,
      "instruction": "Serve! Scoop into bowls and serve with corn chips or tortillas with your favourite Mexican fixings (guacamole or avocado sauce pico de gallo or restaurant style salsa, fresh coriander/coriander, sour cream). Dunk like nachos, make DIY burritos or tacos!"
    }
  ]
