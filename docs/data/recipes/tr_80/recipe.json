  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F. Generously butter a 10cm x 21cm / 4\" x 8\" loaf tin"
    },
    {
      "order": 2,
      "instruction": "Make Cream Cheese Filling - beat (or mix) the cream cheese, sugar and vanilla until combined. Then add the egg and lemon juice, then beat/mix until smooth, light and fluffy."
    },
    {
      "order": 3,
      "instruction": "Whisk the Egg Mixture ingredients together in a large bowl."
    },
    {
      "order": 4,
      "instruction": "Dip 2 slices of bread into the Egg Mixture. Because you're using fresh bread, it should soak through with egg mixture pretty quickly."
    },
    {
      "order": 5,
      "instruction": "Line the base of the loaf tin with the egg dipped bread. Cut bread if necessary to fill in gaps. Repeat twice more so you have 3 layers of egg dipped bread."
    },
    {
      "order": 6,
      "instruction": "Spread all the Cream Cheese filling over the bread. Then top with two more layers of egg-dipped bread."
    },
    {
      "order": 7,
      "instruction": "Dot surface with butter and scatter over the sugar."
    },
    {
      "order": 8,
      "instruction": "Bake for 40 minutes until golden and puffed. Check at 30 minutes - if the top is already dark golden, then cover loosely with foil and return to the oven to finish baking (this is what I did)."
    },
    {
      "order": 9,
      "instruction": "Allow to rest for 15 minutes in the tin before turning out onto a cooling rack to rest for a further 5 minutes."
    },
    {
      "order": 10,
      "instruction": "To serve, topped with Macerated Strawberries."
    },
    {
      "order": 11,
      "instruction": "Combine strawberries and sugar in a bowl and set aside to \"sweat\" for at least 20 minutes."
    }
  ]
}