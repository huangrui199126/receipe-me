  "steps": [
    {
      "order": 1,
      "instruction": "Whisk Dry ingredients."
    },
    {
      "order": 2,
      "instruction": "Add Wet ingredients, whisk until just incorporated. Stir through blueberries."
    },
    {
      "order": 3,
      "instruction": "Melt about 1 tsp butter in a non stick skillet over medium high heat (medium if strong stove)."
    },
    {
      "order": 4,
      "instruction": "Dollop a heaped 1/4 cup into the skillet, quickly nudge into a circle about 10 - 12 cm / 4-5\" wide (smaller = thicker). (Note 4)"
    },
    {
      "order": 5,
      "instruction": "Cook for 1 1/2 minutes until a few bubbles appear and underside is mostly golden."
    },
    {
      "order": 6,
      "instruction": "Flip with confidence. Cook a further 1 minute - poke centre, should spring back, underside should be golden."
    },
    {
      "order": 7,
      "instruction": "Transfer to rack and keep warm in 100C/200F oven in single layer (do not stack). Or get 2 pans going (won't need to keep warm)"
    },
    {
      "order": 8,
      "instruction": "Repeat with remaining batter, using extra butter as required."
    },
    {
      "order": 9,
      "instruction": "Serve with copious amounts of maple syrup and softened butter."
    }
  ]
