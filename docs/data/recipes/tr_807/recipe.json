  "steps": [
    {
      "order": 1,
      "instruction": "Toast for extra flavour: Preheat oven to 200°C/390°F (180° fan) Spread quinoa on a tray. Bake 15 minutes, stirring halfway, until it&#039;s lightly browned and smells nutty."
    },
    {
      "order": 2,
      "instruction": "Rinse: Transfer to fine mesh sieve or strainer. Rinse under running water for 10 seconds, shake off excess water well."
    },
    {
      "order": 3,
      "instruction": "Cook: Scrape into a medium saucepan. Add water, place lid on. Bring to simmer on medium heat, then lower stove to low and simmer for 15 minutes (or until all water is absorbed, tilt pot to check)."
    },
    {
      "order": 4,
      "instruction": "Rest: Remove from stove (lid still on) and rest for 10 minutes."
    },
    {
      "order": 5,
      "instruction": "Fluff &amp; cool: Remove lid, fluff quinoa with a fork and allow to fully cool before using. (Spread on a tray if you want to speed things up)."
    },
    {
      "order": 6,
      "instruction": "Dressing: Place ingredients in a jar and shake well."
    },
    {
      "order": 7,
      "instruction": "Toss salad! Place quinoa in a large bowl. Add all salad ingredients. Pour over dressing, toss very well."
    },
    {
      "order": 8,
      "instruction": "Garnish: Either transfer to a large serving platter or individual bowls. Sprinkle generously with crushed Wasabi Peas and sesame seeds. Devour!"
    }
  ]
