  "steps": [
    {
      "order": 1,
      "instruction": "Rinse rice until water runs pretty clear, then drain well. (Note 4)"
    },
    {
      "order": 2,
      "instruction": "Melt butter in a small to medium pot (or large saucepan) over medium high heat."
    },
    {
      "order": 3,
      "instruction": "Add garlic and ginger, cook 30 seconds. Add onion and cook for 2 minutes until partly translucent."
    },
    {
      "order": 4,
      "instruction": "Add carrot and cook for 2 - 3 minutes until softened and sweet."
    },
    {
      "order": 5,
      "instruction": "Add rice and stir to coat all the grains in the oil."
    },
    {
      "order": 6,
      "instruction": "Add Spices and mix to coat the rice."
    },
    {
      "order": 7,
      "instruction": "Add broth, peas, salt and pepper, stir. If any rice is protruding above the surface, poke it under the liquid."
    },
    {
      "order": 8,
      "instruction": "When the entire surface of the liquid is simmering, stir once, place lid on and immediately turn heat down to LOW."
    },
    {
      "order": 9,
      "instruction": "Cook for 14 minutes, do not peek while cooking!"
    },
    {
      "order": 10,
      "instruction": "Lift lid slightly and quickly tilt pot to check to ensure liquid has been absorbed. Clamp lid back on and remove from heat."
    },
    {
      "order": 11,
      "instruction": "Stand for 10 minutes, undisturbed."
    },
    {
      "order": 12,
      "instruction": "Use a rubber spatula to gently fluff the rice. (Note 6)"
    },
    {
      "order": 13,
      "instruction": "Add most of the cashews and coriander, stir through."
    },
    {
      "order": 14,
      "instruction": "Transfer to serving bowl, sprinkle with remaining cashews and coriander. See in post for serving ideas."
    }
  ]
}