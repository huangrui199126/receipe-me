  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/390°F (180°C fan forced)."
    },
    {
      "order": 2,
      "instruction": "Line loaf pan: Butter and line a loaf pan with parchment / baking paper. I used a 21 x 11 x 7 cm pan (8.3 x 4.5 x 2.75&quot;) which makes a nice tall loaf."
    },
    {
      "order": 3,
      "instruction": "Coat blueberries: Toss blueberries in flour (less flour sticks if dry, more if frozen). This helps keep them suspended in the batter."
    },
    {
      "order": 4,
      "instruction": "Whisk Dry ingredients in a bowl."
    },
    {
      "order": 5,
      "instruction": "Add Wet ingredinets: Make a well in the Dry ingredients. Add Wet ingredients. Whisk until incorporated."
    },
    {
      "order": 6,
      "instruction": "Fold in blueberries: Fold in blueberries, including any flour remaining in the blueberry bowl."
    },
    {
      "order": 7,
      "instruction": "Bake: Pour into the prepared tin. Bake for 50 minutes, then cover with foil. Bake for a further 15 - 25 minutes, or until a skewer comes out clean. Check after 15 minutes, then if the skewer comes out with batter on it, bake a further 10 minutes."
    },
    {
      "order": 8,
      "instruction": "Cool: Rest for 5 minutes then turn onto a cooling rack and completely cool. Drizzle with Glaze. Wait until the glaze sets (about 20 minutes) before slicing to serve."
    },
    {
      "order": 9,
      "instruction": "Whisk icing sugar and lemon until smooth, using milk only if needed to achieve the right thickness (Note 3). Pour or spread over cake set on a rack over a baking tray. Scrape glaze drippings on the tray back onto the cake."
    }
  ]
}