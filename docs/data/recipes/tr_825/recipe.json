  "steps": [
    {
      "order": 1,
      "instruction": "Pickle – In a large bowl, dissolve the salt and sugar in the hot water. Stir in vinegar. Add carrots and daikon – they should just about be covered."
    },
    {
      "order": 2,
      "instruction": "2 hours – Leave for 2 hours until slightly floppy. Drain well then use per recipe."
    },
    {
      "order": 3,
      "instruction": "Nuoc cham sauce - Mix ingredients together. Until sugar is dissolved."
    },
    {
      "order": 4,
      "instruction": "Vermicelli noodles - Soak in boiling water for 5 minutes (or per packet directions). Drain, rinse under tap water, then cool and drain thoroughly (nobody likes watery noodles!)."
    },
    {
      "order": 5,
      "instruction": "Toppings - Prepare all the other toppings, ready to use."
    },
    {
      "order": 6,
      "instruction": "Cook pork per the recipe."
    },
    {
      "order": 7,
      "instruction": "Assemble bowls - Place noodles in a bowl. Top with lettuce, pickled vegetables, cucumber and bean sprouts. Slice pork, place 2 steaks on each bowl. Top with herbs, sprinkle with peanuts and sliced chilli. Add a lime wedge."
    },
    {
      "order": 8,
      "instruction": "Serve with nuoc cham on the side so everybody can help themselves. Douse generously! Dive in and eat!"
    }
  ]
}