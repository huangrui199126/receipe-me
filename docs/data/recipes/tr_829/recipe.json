  "steps": [
    {
      "order": 1,
      "instruction": "Sprinkle both sides of salmon with salt and pepper."
    },
    {
      "order": 2,
      "instruction": "Heat 1 tbsp oil in a non stick pan or well seasoned skillet over medium high heat. Add salmon, skin side up, and sear for just 1 1/2 minutes until golden. Turn salmon and cook the other side just for 1 minute, then remove onto a plate (should still be raw inside)."
    },
    {
      "order": 3,
      "instruction": "Turn heat down to medium low and allow skillet to cool."
    },
    {
      "order": 4,
      "instruction": "Heat remaining 1 tbsp oil. Add garlic, ginger and lemongrass. Cook until garlic is light golden ~ 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add sugar and cook for 20 seconds until it becomes a caramel (see video). Then stir in chilli paste."
    },
    {
      "order": 6,
      "instruction": "Add coconut milk and stir, scraping the bottom of the skillet to dissolve any bits stuck on the base into the sauce."
    },
    {
      "order": 7,
      "instruction": "Stir in fish sauce, increase heat to medium. Simmer for 2 minutes."
    },
    {
      "order": 8,
      "instruction": "Place salmon into the sauce, lower heat and simmer gently for 4 minutes, or until just cooked."
    },
    {
      "order": 9,
      "instruction": "Remove salmon, stir in lime zest and juice to taste. Adjust salt to taste with fish sauce."
    },
    {
      "order": 10,
      "instruction": "Serve salmon over noodles or rice. Spoon over sauce, garnish with coriander and chili if using."
    }
  ]
}