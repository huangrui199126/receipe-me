  "steps": [
    {
      "order": 1,
      "instruction": "Cut chicken in half length wise then slice thinly. Place in a bowl with baking soda, use fingers to coat. Set aside for 20 minutes."
    },
    {
      "order": 2,
      "instruction": "Rinse well, pat dry with paper towel then place in a bowl."
    },
    {
      "order": 3,
      "instruction": "Mix together Seasoning."
    },
    {
      "order": 4,
      "instruction": "Sprinkle 1 tsp of Seasoning over chicken. Mix to coat then set aside for 10 minutes (not critical, can skip this)."
    },
    {
      "order": 5,
      "instruction": "Place all ingredients except water in a bowl. Add remaining Seasoning. Mix, then add water and mix."
    },
    {
      "order": 6,
      "instruction": "Heat oil in wok or skillet over high heat. Add onion and garlic, stir fry for 1 minute."
    },
    {
      "order": 7,
      "instruction": "Add chicken and stir fry for 2 minutes until just cooked through and a bit browned."
    },
    {
      "order": 8,
      "instruction": "Lower heat slightly, then add Sauce. Stir fry until it reduce down and becomes thicker - 1 to 1 1/2 minutes."
    },
    {
      "order": 9,
      "instruction": "Serve immediately with rice - or for a low carb, low cal option, try Cauliflower Rice! Garnish with sliced shallots/scallions if desired."
    }
  ]
}