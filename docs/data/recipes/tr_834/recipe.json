  "steps": [
    {
      "order": 1,
      "instruction": "Trim ends off Chinese Broccoli. If any stems are super thick, cut them in half (you want all stems approximately the same width)."
    },
    {
      "order": 2,
      "instruction": "Steam Chinese Broccoli using whatever method you want - I microwave in a steamer on high for 4 minutes. The stem should be just cooked - not super soft and floppy."
    },
    {
      "order": 3,
      "instruction": "Stack the Chinese broccoli together and cut into 4&quot;/10cm lengths, then stack neatly on top of each other."
    },
    {
      "order": 4,
      "instruction": "Combine water and corn flour in small saucepan, mix to dissolve."
    },
    {
      "order": 5,
      "instruction": "Then add remaining ingredients, turn stove onto medium and bring to boil. Boil for 30 seconds to allow to thicken, then remove from stove."
    },
    {
      "order": 6,
      "instruction": "Drizzle over Chinese broccoli and serve. Best served warm."
    }
  ]
