    },
    {
      "amount": "2",
      "unit": "tbsp",
      "name": "(30g) unsalted butter",
      "emoji": "🧈",
      "section": "",
      "order": 3
    },
    {
      "amount": "",
      "unit": "",
      "name": "3 - 4  large garlic cloves (, minced)",
      "emoji": "🧄",
      "section": "",
      "order": 4
    },
    {
      "amount": "1 1/2",
      "unit": "cups",
      "name": "uncooked white rice ((Note 2))",
      "emoji": "🍚",
      "section": "",
