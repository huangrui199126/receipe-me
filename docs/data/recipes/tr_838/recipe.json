  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan). Spray 2 standard muffin tins with oil."
    },
    {
      "order": 2,
      "instruction": "Cut 24 rounds out of pastry using a 7.5 - 8cm / 3- 3.25&quot; cutter. (Note 3)"
    },
    {
      "order": 3,
      "instruction": "Press into muffin tin, making sure there's no air underneath the pastry."
    },
    {
      "order": 4,
      "instruction": "Prick the base 4 times with a fork, then bake for 5 minutes JUST until a skin partially forms on surface of pastry. CHECK at 4 minutes - if pastry is bubbling, press back down."
    },
    {
      "order": 5,
      "instruction": "Remove from oven and let cool - pastry should be partially cooked on surface only."
    },
    {
      "order": 6,
      "instruction": "Melt butter over medium high. Cook bacon for 2 minutes, then add eschallots and cook until bacon is light golden. Transfer to bowl."
    },
    {
      "order": 7,
      "instruction": "Place pinch of cheese in quiche crust, top with 1 teaspoon bacon mixture then 1 tbsp egg mixture - fill to top."
    },
    {
      "order": 8,
      "instruction": "Melt butter over medium high. Add garlic, sauté 20 seconds. Add spinach and cook for 1 minute until just wilted, then transfer to bowl."
    },
    {
      "order": 9,
      "instruction": "Place pinch of cheese in quiche crust, top with 1 teaspoon of spinach then 1 tbsp egg mixture - fill to top."
    },
    {
      "order": 10,
      "instruction": "Melt butter over medium high. Add garlic, sauté 20 seconds. Add chopped mushrooms and cook for 2 minutes until mushroom is starting to go golden on edges, then transfer to bowl."
    },
    {
      "order": 11,
      "instruction": "Place pinch of cheese in quiche crust, top with 1 teaspoon cooked mushrooms then 1 tbsp egg mixture - fill to top. Top with 1 or 2 slices mushrooms."
    },
    {
      "order": 12,
      "instruction": "Antipasto Mix: Toss the olives, sun dried tomatoes and feta together."
    },
    {
      "order": 13,
      "instruction": "Place pinch of cheese in quiche crust, top with 1 heaped teaspoon Antipasto Mix, then 1 tbsp egg mixture - fill to top."
    },
    {
      "order": 14,
      "instruction": "Bake 20 minutes at 180C/350F until surface is light golden. They will puff, then sink."
    },
    {
      "order": 15,
      "instruction": "Sprinkle Mushroom quiche with fresh chives. Serve warm!"
    }
  ]
}