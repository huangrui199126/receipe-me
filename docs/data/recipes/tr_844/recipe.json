  "steps": [
    {
      "order": 1,
      "instruction": "Rinse barley in a colander with cold tap water. Leave to drain for several minutes."
    },
    {
      "order": 2,
      "instruction": "Sauté veg 5 minutes: Heat olive oil in a pot over medium-high heat. Add onion, carrot, celery, swede, mushrooms and garlic (yes, all at once!). Cook for 5 minutes, stirring regularly."
    },
    {
      "order": 3,
      "instruction": "Sauté herbs/spices: Add thyme, coriander, fennel, bay leaves, salt and pepper. Cook for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Simmer 35 minutes: Add pearl barley and vegetable stock. Stir, bring to a boil and simmer for 35 minutes until barley is cooked. It will have a nice chew to it but should not have a hard centre like uncooked rice."
    },
    {
      "order": 5,
      "instruction": "Stir in parsley: Stir in parsley leaves. Ladle into bowls and serve!"
    },
    {
      "order": 6,
      "instruction": "Strain soup (or use slotted spoon), store vegetables/barley separate from soup broth. Otherwise the barley will soak up all the liquid!"
    }
  ]
}