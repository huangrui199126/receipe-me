  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce ingredients in a small bowl."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a wok or heavy based skillet over high heat. Add garlic and chilli - cook for 15 seconds."
    },
    {
      "order": 3,
      "instruction": "Add onion and cook for 45 seconds."
    },
    {
      "order": 4,
      "instruction": "Add chicken and cook, breaking it up as you go. When it changes from pink to white, add Sauce. Cook until the liquid mostly disappears - about 2 minutes."
    },
    {
      "order": 5,
      "instruction": "Stir through shallots. Then stir through coriander and immediately take off the heat."
    },
    {
      "order": 6,
      "instruction": "Serve immediately with jasmine rice or other rice - or for a low carb, low cal option, try Cauliflower Rice! Add slices of cucumber and tomato wedges (very authentic Thai!). Garnish with extra chilli and coriander if desired."
    }
  ]
}