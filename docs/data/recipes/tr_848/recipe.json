  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade ingredients in a bowl, then toss the prawns in the marinade."
    },
    {
      "order": 2,
      "instruction": "Set aside for just 20 minutes - no longer. Even 5 minutes is enough."
    },
    {
      "order": 3,
      "instruction": "Warm a serving bowl using any method (microwave 1 minute, hot water then dry)."
    },
    {
      "order": 4,
      "instruction": "Heat 1 tablespoon oil in a large skillet over high heat. Add half the prawns and cook each side for 60 seconds (or on a BBQ on high heat, suggest double skewer for easy rotation)."
    },
    {
      "order": 5,
      "instruction": "Transfer to warmed bowl, loosely cover with foil. Cook the remaining prawns."
    },
    {
      "order": 6,
      "instruction": "Serve with Slaw, Pink Taco Sauce, warmed tortillas and lime wedges."
    },
    {
      "order": 7,
      "instruction": "Place all ingredients in a very large bowl then toss well (I use my hands!)."
    },
    {
      "order": 8,
      "instruction": "Set aside for at least 1 hour until the cabbage becomes wilted and floppy. Keeps for 3 days!"
    },
    {
      "order": 9,
      "instruction": "Mix ingredients and adjust Sriracha to your taste. Mix well - sour cream becomes looser the more you mix it."
    }
  ]
