  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a pot or large deep skillet over high heat. Add garlic and onion, cook for 1 minute."
    },
    {
      "order": 2,
      "instruction": "Add capsicum, cook for 2 minutes until onion is translucent and slightly golden on edges."
    },
    {
      "order": 3,
      "instruction": "Add remaining Curry ingredients except baby spinach. Stir, bring to simmer then lower to medium low so it's simmering gently."
    },
    {
      "order": 4,
      "instruction": "Simmer 12 - 15 minutes until it changes from pale pink to an orangey red colour."
    },
    {
      "order": 5,
      "instruction": "Stir in spinach until just wilted, then stir in coriander and lime juice. Add more salt it needed."
    },
    {
      "order": 6,
      "instruction": "Serve over rice with a dollop of yogurt, extra sprinkle of coriander and squeeze of lime (don't go overboard, I often do and it's too sour!)"
    }
  ]
