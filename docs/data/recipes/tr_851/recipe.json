  "steps": [
    {
      "order": 1,
      "instruction": "Place butter in a small non stick skillet over medium heat. When melted, add sugar. Stir briefly, then leave until the sugar mostly melts."
    },
    {
      "order": 2,
      "instruction": "When it starts bubbling a bit, add nuts."
    },
    {
      "order": 3,
      "instruction": "Stir 2 minutes. Pour out on parchment paper lined tray."
    },
    {
      "order": 4,
      "instruction": "Spread nuts out, allow to cool. Roughly chop half, leave some whole."
    },
    {
      "order": 5,
      "instruction": "Place in a bowl, pour over freshly boiled water. Leave to soak 10 minutes then drain."
    },
    {
      "order": 6,
      "instruction": "Drizzle with lemon juice and toss (stops apple from browning)."
    },
    {
      "order": 7,
      "instruction": "Place Dressing ingredients in a jar and shake well. Adjust to taste - more oil to make it creamier, sugar for sweet, vinegar for tart."
    },
    {
      "order": 8,
      "instruction": "Place salad in a large bowl with half the apple slices and all the onion. Drizzle with half the dressing then toss."
    },
    {
      "order": 9,
      "instruction": "Scatter over the cranberries, desired amount of walnuts, remaining apple slices and feta. Drizzle with remaining dressing. Serve immediately!"
    }
  ]
