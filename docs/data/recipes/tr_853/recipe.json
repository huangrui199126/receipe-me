  "steps": [
    {
      "order": 1,
      "instruction": "Dressing: Shake in a jar."
    },
    {
      "order": 2,
      "instruction": "Halve so they are about 2.5cm / 1\" pieces (cut large ones into 3)."
    },
    {
      "order": 3,
      "instruction": "Bring 4 litres / 4 quarts water to the boil, add salt. Add potatoes, bring back up to the boil then reduce to simmer. Cook for 5 minutes or until just cooked - don't let them overcook or become too soft, they will keep cooking from residual heat."
    },
    {
      "order": 4,
      "instruction": "Drain and immediately transfer to a bowl."
    },
    {
      "order": 5,
      "instruction": "While potatoes are hot, pour over half the Dressing. Use rubber spatular to gently stir."
    },
    {
      "order": 6,
      "instruction": "Set aside to marinate for at least 30 minutes, even overnight."
    },
    {
      "order": 7,
      "instruction": "Add green onions and parsley, pour over remaining Dressing. Carefully toss with rubber spatular, then serve. Great warm or at room temperature, and it's also great the next day."
    }
  ]
