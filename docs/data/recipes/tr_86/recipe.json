  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Line two cookie sheets with baking (parchment) paper. I streak the tray with a bit of butter to make the paper stay in place."
    },
    {
      "order": 3,
      "instruction": "Use a mixer or handheld beater to cream the butter, vanilla extract and sugar until light and fluffy - around 3 minutes on high."
    },
    {
      "order": 4,
      "instruction": "Add the eggs, sour cream, cocoa powder and red food colour and mix until combined."
    },
    {
      "order": 5,
      "instruction": "Add the flour and baking powder and mix until just combined."
    },
    {
      "order": 6,
      "instruction": "Drop heaped tablespoons of batter onto the baking tray, spacing them out around 1 inch / 2.5cm from each other and the edge of the tray."
    },
    {
      "order": 7,
      "instruction": "Bake for 8 to 10 minutes until the top springs back when touched."
    },
    {
      "order": 8,
      "instruction": "Allow to cool for 5 minutes on the tray before transferring to a wire rack."
    },
    {
      "order": 9,
      "instruction": "Top with cream cheese frosting and red sprinkles, if using."
    },
    {
      "order": 10,
      "instruction": "Beat the ingredients together until fluffy and smooth - around 5 minutes on high."
    }
  ]
}