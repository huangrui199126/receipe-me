  "steps": [
    {
      "order": 1,
      "instruction": "Sauce - Mix cornflour/cornstarch with water until lump free. Add everything else, then mix."
    },
    {
      "order": 2,
      "instruction": "Crumble tofu - Drain tofu, then cut into 5mm/0.2&quot; slices. Use your fingers to crumble into a mince. Not too fine crumbs, can always break up more when cooking (just like cooking mince/ground meat!)."
    },
    {
      "order": 3,
      "instruction": "Filling - Heat oil over high heat in a large non stick pan. Cook onion, garlic and carrot for 1 minute. Add green beans and mushrooms. Cook 2 minutes - green beans should still be firm."
    },
    {
      "order": 4,
      "instruction": "Sauce it - Add tofu and toss through. Pour in the sauce. Stir for 1 minute or until the sauce thickens and is coating the mixture nicely. (If it evaporates too quickly, add a splash of water)"
    },
    {
      "order": 5,
      "instruction": "Serving - Transfer filling into a bowl. Lay out on the table with lettuce leaves, green onion, peanuts and bottle of sriracha."
    },
    {
      "order": 6,
      "instruction": "DIY lettuce wraps - Spoon filling into lettuce leaf. Drizzle with sriracha, sprinkle with peanuts and green onion. Bundle / fold, eat!"
    }
  ]
}