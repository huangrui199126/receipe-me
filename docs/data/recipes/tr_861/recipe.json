  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (160°C fan)."
    },
    {
      "order": 2,
      "instruction": "SPICINESS - Read note above about spiciness!"
    },
    {
      "order": 3,
      "instruction": "Puree chipotle in adobo until smooth using a stick blender or similar."
    },
    {
      "order": 4,
      "instruction": "Sprinkle pork all over with salt, pepper and cumin."
    },
    {
      "order": 5,
      "instruction": "Brown pork - Heat all the oil in a large oven-proof pot over high heat. Brown the pork all over in 2 batches, the remove onto a plate (~ 1 minute each side)."
    },
    {
      "order": 6,
      "instruction": "Sauté - Cool the pot slightly then return to medium heat. If the pot looks dry, add 1 tbsp oil. Sauté onion, garlic, the herbs &amp; spices for 3 minutes."
    },
    {
      "order": 7,
      "instruction": "Cook off tomato &amp; chipotle - Add tomato paste and cook it off for 2 minutes. Add chipotle puree and cook for 2 minutes."
    },
    {
      "order": 8,
      "instruction": "Slow cook 2 hours - Add remaining ingredients EXCEPT beans. Stir, then bring to simmer. Place pork in - arrange so its submerged as best as possible. Cover with lid. Place in oven for 2 hours. (Note 6 other cook methods)"
    },
    {
      "order": 9,
      "instruction": "Add beans, cook 30 min - Remove lid, add beans. Return to oven for 30 minutes without lid to caramelise the surface. The pork will be fork-tender!"
    },
    {
      "order": 10,
      "instruction": "Serve like stew over Mexican red rice or with tortillas for dunking. Or make wickedly food tacos with finely chopped white onion, fresh coriander/cilantro, avocado slices and a squeeze of lime. More serving options above the recipe video."
    }
  ]
