  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large pot over medium high heat. Add onion and garlic and cook for 2 minutes until partly translucent but not browned."
    },
    {
      "order": 2,
      "instruction": "Add carrots, celery and capsicum, cook for 1 minute to soften."
    },
    {
      "order": 3,
      "instruction": "Add butter and melt. Then add flour and mix until incorporated, and stir constantly for 1 minute."
    },
    {
      "order": 4,
      "instruction": "Add broth, mix until flour is incorporated, then add milk. Mix to combine, then add salt, Spices, chicken and peas."
    },
    {
      "order": 5,
      "instruction": "Bring to simmer, mixing occasionally to stop bottom of sticking. As it heats, it will thicken – about 4 to 5 minutes. Don’t let it bubble."
    },
    {
      "order": 6,
      "instruction": "Once thickened to your taste, adjust salt and pepper. Ladle into bowls and serve garnished with croutons and fresh thyme if desired."
    },
    {
      "order": 7,
      "instruction": "Croutons: Spray croutons generously with oil, sprinkle with salt, then bake for 5 minutes at 180C/350F or until golden and crunchy."
    }
  ]
