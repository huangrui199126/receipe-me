  "steps": [
    {
      "order": 1,
      "instruction": "Mix ingredients, refrigerate 20 minutes+ (keeps 2 weeks)."
    },
    {
      "order": 2,
      "instruction": "Dissolve sugar and salt in vinegar."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a large pot over medium heat. Add onion and cook for 2 minutes to soften, don't let it brown."
    },
    {
      "order": 4,
      "instruction": "Add cabbage, vinegar, water and caraway seeds, give it a toss."
    },
    {
      "order": 5,
      "instruction": "Cover, cook on low for 15 minutes, mixing once at 10 minutes."
    },
    {
      "order": 6,
      "instruction": "Transfer to container (including liquid), cool until just warm. Keeps 2 weeks in the fridge."
    },
    {
      "order": 7,
      "instruction": "Thinly slice still cold pastrami (Note 1). Place in a container with a couple of tablespoons of pastrami liquid (reserved from cooking, see pastrami recipe)."
    },
    {
      "order": 8,
      "instruction": "Microwave to warm through (or use other method of choice etc cover with foil and place in oven)."
    },
    {
      "order": 9,
      "instruction": "Preheat grill/broiler to medium high with shelf about 25cm/10\" from heat source."
    },
    {
      "order": 10,
      "instruction": "Toast bread. Spread with butter, then 1 tbsp Russian Dressing on each piece."
    },
    {
      "order": 11,
      "instruction": "Pick up pastrami and let excess juices drip away, then place on bread."
    },
    {
      "order": 12,
      "instruction": "Do same for sauerkraut, pile onto pastrami, then top with cheese."
    },
    {
      "order": 13,
      "instruction": "Also place cheese on other slice of bread (ie with just Russian Dressing)."
    },
    {
      "order": 14,
      "instruction": "Place under grill until cheese is just melted. Sandwich together and devour while hot!"
    }
  ]
}