  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C/350°F (all types)."
    },
    {
      "order": 2,
      "instruction": "Grease a 10 cup+ casserole dish with butter."
    },
    {
      "order": 3,
      "instruction": "Place milk, sugar and vanilla in a saucepan over medium high heat. Bring to a simmer, stirring to dissolve the sugar, until the surface is foamy - do not boil, it will split."
    },
    {
      "order": 4,
      "instruction": "Place rice, sultanas and cinnamon in baking dish. Pour over milk, give it a brief stir then cover with lid or foil."
    },
    {
      "order": 5,
      "instruction": "Bake for 1 hour, stirring every 20 minutes to break up the rice that starts to set on the base."
    },
    {
      "order": 6,
      "instruction": "After 1 hour, remove from oven and add cream. Give it a good stir - it will look a bit watery straight out of the oven but it evaporates quickly. I like mine creamy so it oozes when you serve it."
    },
    {
      "order": 7,
      "instruction": "Serve immediately, just as is or with a scoop of vanilla ice cream if you want to take it over the top!"
    }
  ]
}