  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F. Line a baking tray with baking paper (or spray with oil)."
    },
    {
      "order": 2,
      "instruction": "Place Fritter ingredients in a bowl, mix to combine."
    },
    {
      "order": 3,
      "instruction": "Measure out about ¼ cup of mixture and pat into fritter shapes about 6 cm / 2.25\" wide, 1cm / 2/5\" thick (they shrink a bit and become thicker)."
    },
    {
      "order": 4,
      "instruction": "Place on tray. Spray the top (generously) with oil."
    },
    {
      "order": 5,
      "instruction": "Bake for 15 minutes, flip, spray with oil again then bake for a further 8 - 10 minutes until golden on top. Serve immediately with Sauce."
    },
    {
      "order": 6,
      "instruction": "Sauce: Mix ingredients together. Add salt and pepper to taste. Set aside for 20+ minutes."
    }
  ]
