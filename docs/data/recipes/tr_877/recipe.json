  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C/400°F (180°C fan). Place a rack on a foil lined tray. Spray rack with oil."
    },
    {
      "order": 2,
      "instruction": "Crumbing bowls - Place the flour, whisked eggs and panko in 3 separate medium bowls (bear in mind shape to fit the drumsticks!)."
    },
    {
      "order": 3,
      "instruction": "Mix Seasoning in a small bowl. Put 1 tablespoon into the flour and the rest in the panko, then mix."
    },
    {
      "order": 4,
      "instruction": "Crumb - Pat drumsticks dry with paper towels. Coat in flour (shake off excess), then egg (let excess drip off). Place in panko and rotate, pressing to adhere all over, including the handle. (Note 3 for mess-free hands technique!)"
    },
    {
      "order": 5,
      "instruction": "Spray - Place drumstick on the rack. Repeat with remaining chicken. Spray very generously with oil."
    },
    {
      "order": 6,
      "instruction": "Bake 25 minutes. Turn drumsticks, spray again with oil. Bake a further 20 minutes until golden brown and super crunchy!"
    },
    {
      "order": 7,
      "instruction": "Serve Eat and enjoy the CRUNCH!"
    }
  ]
}