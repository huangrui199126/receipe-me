  "steps": [
    {
      "order": 1,
      "instruction": "Cut the florets into slices no thicker than 0.7 cm / 1/4\" thick."
    },
    {
      "order": 2,
      "instruction": "Place in a bowl with remaining Salad ingredients."
    },
    {
      "order": 3,
      "instruction": "Mix Dressing well in a large bowl - use a whisk to ensure it's all well incorporated. It will be thin and pourable - see video for consistency."
