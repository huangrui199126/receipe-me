  "steps": [
    {
      "order": 1,
      "instruction": "Place Dressing ingredients in a jar and shake well."
    },
    {
      "order": 2,
      "instruction": "Sprinkle both sides of salmon with salt and pepper."
    },
    {
      "order": 3,
      "instruction": "Heat oil in a non stick skillet over medium high heat."
    },
    {
      "order": 4,
      "instruction": "Place salmon in upside down (ie skin side up), cook for 3 minutes or until deep golden."
    },
    {
      "order": 5,
      "instruction": "Turn and cook for another 2 - 3 minutes, or until cooked to your taste."
    },
    {
      "order": 6,
      "instruction": "Remove onto plate and cool for 5 minutes."
    },
    {
      "order": 7,
      "instruction": "Place lettuce in a large bowl. Drizzle with a bit of dressing and toss."
    },
    {
      "order": 8,
      "instruction": "Place lettuce in a large serving bowl (or individual plates). Top with salmon, then place tomato, cucumber, avocado, edamame and radish in piles around it."
    },
    {
      "order": 9,
      "instruction": "Sprinkle with green onion and crispy shallots."
    },
    {
      "order": 10,
      "instruction": "Just prior to serving, drizzle all over with remaining Dressing."
    }
  ]
