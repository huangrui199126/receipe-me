  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200°C / 390°F."
    },
    {
      "order": 2,
      "instruction": "Shake Dressing ingredients in a jar."
    },
    {
      "order": 3,
      "instruction": "Toss sweet potato with olive oil, salt and pepper, spread onto tray."
    },
    {
      "order": 4,
      "instruction": "Roast for 20 minutes, flip, then roast for a further 5 minutes until golden on edges."
    },
    {
      "order": 5,
      "instruction": "Place baby spinach, onion and half almonds in a bowl. Drizzle with 2 tbsp Dressing, toss."
    },
    {
      "order": 6,
      "instruction": "Drizzle warm rice with 1 tbsp Dressing, toss."
    },
    {
      "order": 7,
      "instruction": "Spread spinach on serving platter. Top with rice, then sweet potato and cranberries."
    },
    {
      "order": 8,
      "instruction": "Drizzle with remaining Dressing, then top with feta and remaining almonds. Serve!"
    }
