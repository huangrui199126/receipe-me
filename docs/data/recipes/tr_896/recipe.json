  "steps": [
    {
      "order": 1,
      "instruction": "Heat the oil over medium heat in a large skillet and sauté the onion, capsicum/bell pepper and garlic for 5 minutes until translucent."
    },
    {
      "order": 2,
      "instruction": "Add a splash of chicken broth, bring to simmer then tip it all into the slow cooker. (Instant Pot: Do Step 1 &amp; 2 on saute function)."
    },
    {
      "order": 3,
      "instruction": "Add remaining chicken broth, Spices, corn, bean and tomato. Give it a good stir, then add chicken and push down to submerge."
    },
    {
      "order": 4,
      "instruction": "Slow cook for 6 to 8 hours on LOW. (Or pressure cooker 25 minutes on high, see Note for stove)."
    },
    {
      "order": 5,
      "instruction": "Remove chicken onto plate, shred with 2 forks. Return into slow cooker, give it a good stir. Check if it needs more salt or pepper."
    },
    {
      "order": 6,
      "instruction": "Ladle into bowls and serve with Toppings of choice!"
    }
  ]
}