  "steps": [
    {
      "order": 1,
      "instruction": "Shake Dressing in a jar."
    },
    {
      "order": 2,
      "instruction": "Place chickpeas in a microwaveable bowl. Toss with half the Dressing."
    },
    {
      "order": 3,
      "instruction": "Microwave 1 1/2 minutes, stirring every 30 seconds, until warmed through."
    },
    {
      "order": 4,
      "instruction": "Set aside 20 minutes to marinate (warm chickpeas = absorbs flavour)."
    },
    {
      "order": 5,
      "instruction": "Mix ingredients in a bowl, set aside 30 minutes until onion is wilted. Drain."
    },
    {
      "order": 6,
      "instruction": "Speedy option: microwave for 2 minutes until hot, cool 10 minutes then use."
    },
    {
      "order": 7,
      "instruction": "Place spinach in a big bowl, add marinated chickpeas (including all residual Dressing in the bowl). Add tomatoes, pickled onion and peppers, if using."
    },
    {
      "order": 8,
      "instruction": "Pour over remaining Dressing, toss well. Transfer to serving plate, crumble over feta, serve!"
    }
  ]
