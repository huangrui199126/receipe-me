  "steps": [
    {
      "order": 1,
      "instruction": "If cooking on a BBQ or over charcoal, soak skewers for 2 hours in water so they don&#039;t burn."
    },
    {
      "order": 2,
      "instruction": "Mix together the beef and Marinade in a bowl. Cover with cling wrap and marinate overnight (do not reduce marinating time else the beef may not tenderise enough)."
    },
    {
      "order": 3,
      "instruction": "Thread onto skewers - I do 4 pieces each."
    },
    {
      "order": 4,
      "instruction": "Heat 1.5 tbsp oil in a large non stick pan over medium high heat."
    },
    {
      "order": 5,
      "instruction": "Cook 10 minutes (yes, well done!): Cook skewers in batches for 2 to 2 1/2 minutes on all 4 sides until deep golden (total of 8 to 10 minutes) and fully cooked through. (Note: baking soda tenderised beef needs to be thoroughly cooked to be tender. The beef is still a bit chewy if it&#039;s medium or less.)"
    },
    {
      "order": 6,
      "instruction": "Rest: Transfer skewers to plate and rest for 3 minutes before serving with Peanut Sauce."
    },
    {
      "order": 7,
      "instruction": "Place all Peanut Sauce ingredients in a small saucepan over medium low heat."
    },
    {
      "order": 8,
      "instruction": "Stir to combine then simmer, stirring every now and then, for 5 minutes. Adjust consistency with water - it should be a pourable but thickish sauce."
    },
    {
      "order": 9,
      "instruction": "Remove from stove, cover with lid and keep warm while cooking skewers."
    },
    {
      "order": 10,
      "instruction": "Pour sauce into a bowl. Sprinkle with some peanuts - stir some through if you want."
    },
    {
      "order": 11,
      "instruction": "Pile satay skewers onto a platter, sprinkle with remaining peanuts, coriander and chilli."
    },
    {
      "order": 12,
      "instruction": "Serve with sauce on the side for dipping. Add a side of Jasmine Rice or Thai Fried Rice or Pineapple Fried Rice to complete the meal!"
    }
  ]
}