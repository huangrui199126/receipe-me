  "steps": [
    {
      "order": 1,
      "instruction": "Spray a loaf pan with oil then line with cling wrap with overhang."
    },
    {
      "order": 2,
      "instruction": "Mix Cheese Log ingredients together. Taste and adjust salt if needed (bear in mind saltiness of crackers you are serving with)."
    },
    {
      "order": 3,
      "instruction": "Scrape into loaf pan and level surface, pressing to remove air pockets. Smaller pan = taller loaf."
    },
    {
      "order": 4,
      "instruction": "Cover with cling wrap overhang and refrigerate for 4 hours+ (up to 1 week)."
    },
    {
      "order": 5,
      "instruction": "Turn out onto platter, peel off cling wrap."
    },
    {
      "order": 6,
      "instruction": "Top with sun dried tomato and pour over oil. Garnish with parsley and rosemary sprigs to give it a festive look."
    },
    {
      "order": 7,
      "instruction": "Best to serve closer to room temp than fridge cold. Serve with crackers! Knives for smearing optional - it's soft enough to scoop with crackers."
    }
  ]
