  "steps": [
    {
      "order": 1,
      "instruction": "Take the chicken out of the fridge 30 minutes before cooking."
    },
    {
      "order": 2,
      "instruction": "Boil water in a saucepan. Add chicken, put the lid on, let the water come back up to a simmer, then remove from stove. Set aside for 20 minutes (even up to 45 min is fine). (Note 4)"
    },
    {
      "order": 3,
      "instruction": "Remove chicken from water and shred, then cool."
    },
    {
      "order": 4,
      "instruction": "Place ingredients in a jar. Shake well. Taste and adjust as required. It should be a balance of tangy / sweet / salty / hint of spice. (Note 5)"
    },
    {
      "order": 5,
      "instruction": "Place Salad ingredients in a large bowl. Drizzle over most of the Dressing, toss. Serve immediately, drizzled with remaining Dressing."
    }
  ]
