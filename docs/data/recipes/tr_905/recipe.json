  "steps": [
    {
      "order": 1,
      "instruction": "Mix ingredients in a bowl. Set aside for 10 minutes+."
    },
    {
      "order": 2,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 3,
      "instruction": "Spread breadcrumbs on a tray. Spray with oil directly down, not from side."
    },
    {
      "order": 4,
      "instruction": "Bake for 3 - 5 minutes until golden. Immediately transfer to bowl."
    },
    {
      "order": 5,
      "instruction": "Brush tray clean, spray with oil."
    },
    {
      "order": 6,
      "instruction": "Cut fish fillets into square-ish shapes slightly larger than the buns (they shrink when cooked).&nbsp;"
    },
    {
      "order": 7,
      "instruction": "Mix Batter ingredients in a bowl."
    },
    {
      "order": 8,
      "instruction": "Carefully coat fish in batter (handle with care, fish fillets can be delicate)."
    },
    {
      "order": 9,
      "instruction": "Place in breadcrumbs. Use other hand to cover top and sides with breadcrumbs, pressing to adhere. Transfer to tray. Repeat with remaining fish."
    },
    {
      "order": 10,
      "instruction": "Bake 12 - 15 minutes until fish is cooked through. Immediately top with cheese - allow residual heat to make it semi melt (do not oven melt processed cheese, you get a plasticy film!)."
    },
    {
      "order": 11,
      "instruction": "Cut buns in half, microwave for 20 seconds to warm through (microwave = stays soft)."
    },
    {
      "order": 12,
      "instruction": "Top with fish and cheese, dollop with tartare sauce. Devour!"
    }
  ]
