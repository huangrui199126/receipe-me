  "steps": [
    {
      "order": 1,
      "instruction": "Brush BBQ grills with oil, then preheat on high until very hot."
    },
    {
      "order": 2,
      "instruction": "If shrimp are small and might fall through grills, skewer them (use 2 skewers, Note 3)"
    },
    {
      "order": 3,
      "instruction": "Melt butter in a small saucepan over medium high heat."
    },
    {
      "order": 4,
      "instruction": "Add garlic and salt. Stir until garlic is LIGHT golden brown, then immediately remove from stove (residual heat will make garlic golden &amp; crispy)."
    },
    {
      "order": 5,
      "instruction": "Stir through lemon."
    },
    {
      "order": 6,
      "instruction": "Pat shrimp dry with paper towels (to ensure crispiness!)"
    },
    {
      "order": 7,
      "instruction": "Just prior to cooking, place in bowl, sprinkle/drizzle over remaining ingredients. Toss gently to coat."
    },
    {
      "order": 8,
      "instruction": "Working quickly, place shrimp on BBQ and cook each side for 2 minutes until golden and crusty."
    },
    {
      "order": 9,
      "instruction": "Immediately remove shrimp onto serving plate."
    },
    {
      "order": 10,
      "instruction": "Drizzle over all the Lemon Garlic Butter, sprinkle with parsley and serve immediately with fresh lemon."
    },
    {
      "order": 11,
      "instruction": "Crusty bread to mop up the crazy delish butter on the plate is essential!"
    }
  ]
}