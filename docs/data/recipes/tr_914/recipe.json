  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 250°C / 480°F (both fan and standard). Allow time to get it nice and hot!!"
    },
    {
      "order": 2,
      "instruction": "Pizza sauce - Mix the ingredients in a small bowl then set aside."
    },
    {
      "order": 3,
      "instruction": "Pizza base - Make and stretch out your chosen pizza base (no rolling pin!), stretch onto a pizza pan or baking tray per the directions in your chosen pizza base. (Note 4 for pizza stone)"
    },
    {
      "order": 4,
      "instruction": "Top - Spread the pizza sauce on the pizza, leaving a 1 cm/1/2&quot; border along the edge. Sprinkle with cheese first, then drape the ham randomly across the surface, sprinkle with olives, artichoke slices and mushrooms. (If using the no-yeast pizza base, spray/brush exposed crust with olive oil.)"
    },
    {
      "order": 5,
      "instruction": "Bake for 10 - 12 minutes, turning after 4 minutes, or until the the cheese has golden spots and the crust is crispy. Cut and eat, stat!"
    }
  ]
