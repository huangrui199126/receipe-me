  "steps": [
    {
      "order": 1,
      "instruction": "Glass noodles: Place dry noodles in a bowl and cover with freshly boiled water. Leave for 3 to 4 minutes or until transparent and softened. Drain using a colander, rinse under tap water (for rapid cool and reduce stickiness) then detangle using your fingers. Drain thoroughly before use. Set aside to fully cool."
    },
    {
      "order": 2,
      "instruction": "Lime cashew crumble: Place ingredients in a bowl and toss. (No marinating time needed)"
    },
    {
      "order": 3,
      "instruction": "Dressing: Place ingredients in a jar and shake until well combined."
    },
    {
      "order": 4,
      "instruction": "Salad: Place glass noodle salad ingredients in a large bowl. Pour over dressing, toss well. Add half the cashews, toss again."
    },
    {
      "order": 5,
      "instruction": "Serve: Transfer to a large salad bowl or individual bowls. Sprinkle with remaining lime cashew crumble and serve!"
    }
  ]
}