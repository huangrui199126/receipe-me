  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180°C / 350°F."
    },
    {
      "order": 2,
      "instruction": "Toast breadcrumbs: Spread breadcrumbs on tray. Spray with oil, bake 4 minutes until golden. Transfer toasted breadcrumbs into bowl, add remaining Crumb ingredients and mix."
    },
    {
      "order": 3,
      "instruction": "Increase oven to 220°C / 425°F (fan 200°C). Spray used tray with oil."
    },
    {
      "order": 4,
      "instruction": "Batter: Mix Batter ingredients in a separate bowl."
    },
    {
      "order": 5,
      "instruction": "Cut the fish into strips 1.5 x 11 cm / 3/5 x 4.5&quot; (they shink 30% in length)."
    },
    {
      "order": 6,
      "instruction": "Place fish in Batter, gently mix with rubber spatula to coat. Do not leave sitting around (will become watery), coat immediately."
    },
    {
      "order": 7,
      "instruction": "Breading: Pick up fish with tongs, place in breadcrumbs. Spoon over crumb, use fingers to press to adhere."
    },
    {
      "order": 8,
      "instruction": "Baking: Transfer to baking tray. Spray with oil, bake 13 minutes or until crispy on the outside."
    },
    {
      "order": 9,
      "instruction": "Serve immediately with lemon wedges, Tartare Sauce or other Sauce of choice - see here for recipes, any of these great for fish fingers! Also Note 3 for few quick sauce options."
    }
  ]
