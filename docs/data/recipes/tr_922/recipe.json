  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a large skillet over high heat. Add onion and garlic, cook for 1 1/2 minutes until starting to go golden."
    },
    {
      "order": 3,
      "instruction": "Add chicken and cook just until the outside mostly changes from pink to white."
    },
    {
      "order": 4,
      "instruction": "Add Sauce and cook for 1 minute until chicken is quite caramelised."
    },
    {
      "order": 5,
      "instruction": "Add carrot and capsicum, cook for 1 minute (chicken should now be nicely caramelised, see video)."
    },
    {
      "order": 6,
      "instruction": "Push chicken and veg to the side to make enough space for the noodles.&nbsp;Add water, place noodles in water."
    },
    {
      "order": 7,
      "instruction": "When the water starts simmering on the edges, leave noodles for 45 seconds then turn."
    },
    {
      "order": 8,
      "instruction": "Leave for 30 seconds, then untangle the noodles, then toss through the chicken and veg."
    },
    {
      "order": 9,
      "instruction": "Add cabbage, toss for 1 minute until sauce reduces to coat the noodles and the noodles are cooked. (Note 6)"
    },
    {
      "order": 10,
      "instruction": "Serve immediately, garnished with green onions."
    }
  ]
}