  "steps": [
    {
      "order": 1,
      "instruction": "Drain oil from the jar of sun dried tomatoes."
    },
    {
      "order": 2,
      "instruction": "Measure out 1/3 cup of the oil, top with extra virgin olive oil if short. Reserve excess oil for another purpose."
    },
    {
      "order": 3,
      "instruction": "Add remaining Dressing ingredients. Mix well."
    },
    {
      "order": 4,
      "instruction": "Cook pasta in a large pot of salted boiling water per packet directions."
    },
    {
      "order": 5,
      "instruction": "Drain, then rinse briefly under cold water. Leave to cool."
    },
    {
      "order": 6,
      "instruction": "Transfer into large bowl. Add spinach, chicken, tomato, onion, pour over Dressing."
    },
    {
      "order": 7,
      "instruction": "Toss well, sprinkle with dried herbs, toss again."
    },
    {
      "order": 8,
      "instruction": "Just before serving, sprinkle with crumbled feta. Best served at room temperature."
    },
    {
      "order": 9,
      "instruction": "SCOOP OUT a mug of pasta cooking water just before draining. Add 3 tbsp water to Dressing, shake well. Use this Dressing per above, but reserve 3 tbsp to freshen up pasta salad on Day 2 onwards."
    },
    {
      "order": 10,
      "instruction": "Freshen up pasta salad: Bring to room temp or briefly microwave (cold pasta = dry) to warm gently. Toss with Reserved Dressing then serve."
    }
  ]
}