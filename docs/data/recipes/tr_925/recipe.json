  "steps": [
    {
      "order": 1,
      "instruction": "Scrunch up the kale leaves then slice to about 1cm / 2/5\" thickness."
    },
    {
      "order": 2,
      "instruction": "Transfer to large bowl."
    },
    {
      "order": 3,
      "instruction": "Drizzle over oil, scatter with salt and pepper. Use your hands to scrunch the kale leaves for 1 minute (see video). It should shrink to about half the size."
    },
    {
      "order": 4,
      "instruction": "Set aside for 30 minutes. The leaves will soften, making them suitable for eating raw."
    },
    {
      "order": 5,
      "instruction": "Place quinoa in a fine mesh colander, then rinse under running water for 30 seconds. Drain excess water well. (Or do this in a big bowl)"
    },
    {
      "order": 6,
      "instruction": "Place in a saucepan with water. Cover with lid, bring to simmer over medium heat then leave for 12 - 15 minutes until all water is absorbed."
    },
    {
      "order": 7,
      "instruction": "Remove from heat, leave lid on, and rest for 5 - 10 minutes. Fluff with fork then cool (spread on tray and refrigerate to speed up)."
    },
    {
      "order": 8,
      "instruction": "Place ingredients in a jar, screw lid on and shake well. Set aside for 10 minutes."
    },
    {
      "order": 9,
      "instruction": "Add the quinoa into the bowl with the kale. Add all the dill and coriander/cilantro, half the nuts, feta, and 2/3 of dressing."
    },
    {
      "order": 10,
      "instruction": "Toss well."
    },
    {
      "order": 11,
      "instruction": "Transfer into serving platter or bowls. Drizzle with remaining dressing, garnish with remaining feta and nuts.&nbsp;"
    },
    {
      "order": 12,
      "instruction": "See Note 3 for serving suggestions - I've been having this as a meal, just plain."
    }
  ]
}