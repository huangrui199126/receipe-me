  "steps": [
    {
      "order": 1,
      "instruction": "Sauce: Place water and cornflour in a bowl, mix. Then add remaining ingredients and mix."
    },
    {
      "order": 2,
      "instruction": "Beef: Place in a bowl and add 1 1/2 tbsp Sauce. Mix."
    },
    {
      "order": 3,
      "instruction": "Broccoli &amp; Noodles: Bring a large pot of water to the boil. Add broccoli, cook for 1 minute. Add noodles then after 15 seconds, use a wooden spoon to separate the noodles then immediately drain (don't have the noodles in the water for more than 1 minute)."
    },
    {
      "order": 4,
      "instruction": "Heat oil in a large skillet over high heat."
    },
    {
      "order": 5,
      "instruction": "Add garlic, quickly stir. Add onion and cook for 1 minute until it's tinged with brown."
    },
    {
      "order": 6,
      "instruction": "Add beef and cook until it changes from red to brown."
    },
    {
      "order": 7,
      "instruction": "Add noodles, broccoli and sauce. Toss together for 1 1/2 - 2 minutes or until Sauce thickens and coats the noodles. Sprinkle with sesame seeds and shallots, if using, and serve!"
    }
  ]
