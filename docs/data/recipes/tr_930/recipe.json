  "steps": [
    {
      "order": 1,
      "instruction": "Marinade - Combine lamb, soy sauce, Chinese cooking wine, salt, baking soda and cornflour in a mixing bowl. Mix well then set aside for marinade for 30 minutes (counter fine)."
    },
    {
      "order": 2,
      "instruction": "Spice mix - Mix the ingredients in a small bowl."
    },
    {
      "order": 3,
      "instruction": "Cook lamb - Heat 3 tablespoons of the oil in a large non-stick skillet (30cm/1&quot;) over medium-high heat until hot. Add half the lamb and spread out in a single layer. Leave for 30 seconds then, using 2 wooden spoons, toss for a further 1 minute until the lamb is slightly golden. Remove onto a plate then repeat with remaining lamb (you shouldn&#39;t need more oil)."
    },
    {
      "order": 4,
      "instruction": "Sauté aromatics - Heat the remaining 1 tablespoon of oil. Add the dried chilli, ginger and garlic. Stir for 10 seconds to release flavour, then add the onion. Cook for 2 minutes until the onion just starts to soften."
    },
    {
      "order": 5,
      "instruction": "Spiced lamb - Add the cooked lamb then sprinkle the spice mix over. Toss well to evenly coat."
    },
    {
      "order": 6,
      "instruction": "Finish dish - Add the cilantro, sesame seeds and toss. Serve over rice! (Note: the dried chillies are not meant to be eaten.)"
    }
  ]
