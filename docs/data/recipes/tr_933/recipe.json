  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil over high heat (can skip oil if bacon is super fatty). Add bacon and cook for 2 minutes."
    },
    {
      "order": 2,
      "instruction": "Add onion and garlic. Cook for 3 minutes until onion and bacon are golden."
    },
    {
      "order": 3,
      "instruction": "Add remaining ingredients. Stir, bring to simmer, then place lid on."
    },
    {
      "order": 4,
      "instruction": "Then either turn down heat to medium low (simmering gently) and cook on the stove for 1 hour, stirring every now and then so the bottom doesn&#039;t catch. OR bake at 160°C/325°F for 60 minutes."
    },
    {
      "order": 5,
      "instruction": "SLOW COOKER option: Reduce water to 1/4 cup, transfer to slow cooker and cook for 6 hours on low."
    },
    {
      "order": 6,
      "instruction": "The sauce should be thickened (cook with lid off for a bit if not thick enough) and glossy. Adjust salt and pepper to taste at the end. See notes for serving suggestions!"
    }
  ]
