  "steps": [
    {
      "order": 1,
      "instruction": "Melt butter in a large pot over high heat."
    },
    {
      "order": 2,
      "instruction": "Ad garlic and onion, cook for 2 minutes until onion is almost translucent."
    },
    {
      "order": 3,
      "instruction": "Add capsicum and cook for 2 minutes until softened."
    },
    {
      "order": 4,
      "instruction": "Add beef and cook, breaking it up as you go, until it changes from red to brown."
    },
    {
      "order": 5,
      "instruction": "Add remaining ingredients. Mix well, then turn heat down to medium low (or low for strong stoves)."
    },
    {
      "order": 6,
      "instruction": "Cover and cook for 30 minutes, stirring once or twice to make sure it doesn't catch on the base. (If in rush, cook 15 minutes without lid)"
    },
    {
      "order": 7,
      "instruction": "Remove lid and give it a good stir for a minute. Mixture should be thick, not runny and saucy (see video). Adjust salt to taste."
    },
    {
      "order": 8,
      "instruction": "Toast rolls. Butter if desired (I don't)."
    },
    {
      "order": 9,
      "instruction": "Pile on lots of filling, immediately top with cheese (heat should semi melt, otherwise pop under broiler/grill). Top with lid and serve immediately!"
    }
  ]
}