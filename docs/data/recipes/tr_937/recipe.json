  "steps": [
    {
      "order": 1,
      "instruction": "Place all ingredients other than water in a bowl. Mix to combine. Then add water and mix again."
    },
    {
      "order": 2,
      "instruction": "Heat oil in a skillet or wok over high heat. Add garlic and 1/2 sliced onion. Cook 1 minute."
    },
    {
      "order": 3,
      "instruction": "Add protein of choice or sliced tofu. Cook 2 minutes until just cooked."
    },
    {
      "order": 4,
      "instruction": "Add vegetables in order of time to cook, starting with the veggies that take the longer. Cook briefly until just cooked but still crisp."
    },
    {
      "order": 5,
      "instruction": "Add delicate veggies (eg bean sprouts, spinach and other leafy greens) and Sauce. Toss until Sauce thickens (add extra water if needed)."
    },
    {
      "order": 6,
      "instruction": "Garnish with peanuts and coriander / cilantro, if using. Serve over rice - or for a low carb, low cal option, try Cauliflower Rice!"
    },
    {
      "order": 7,
      "instruction": "Follow Stir Fry directions. Add NOODLES with the Sauce in step 4."
    },
    {
      "order": 8,
      "instruction": "Toss for 1 - 2 minutes until Sauce thickens and coats noodles.&nbsp;Remove from heat, garnish and serve immediately!"
    }
  ]
