  "steps": [
    {
      "order": 1,
      "instruction": "Place dry, oil free large saucepan or small skillet over medium high heat."
    },
    {
      "order": 2,
      "instruction": "Add almonds and pistachios. Toast lightly, shaking the pan, until the nuts smell amazing. Remove immediately."
    },
    {
      "order": 3,
      "instruction": "Melt butter in a large saucepan over medium high heat. Add garlic and onion, saute until translucent."
    },
    {
      "order": 4,
      "instruction": "Add rice and stir for 30 seconds or until mostly translucent."
    },
    {
      "order": 5,
      "instruction": "Add Spices, stir. Add broth, sultanas and apricots, stir."
    },
    {
      "order": 6,
      "instruction": "Cover with lid, bring to simmer then immediately turn heat down to medium low (low for strong ovens)."
    },
    {
      "order": 7,
      "instruction": "Cook for 15 minutes or until liquid is absorbed (tilt pot to check). Then remove pot from the stove (still covered) and leave, undisturbed, for 10 minutes."
    },
    {
      "order": 8,
      "instruction": "Remove lid, use fork to fluff rice. Add most of the nuts, toss."
    },
    {
      "order": 9,
      "instruction": "Transfer to serving bowl. Garnish with remaining nuts and a little sprinkle of parsley if using. Serve!"
    }
  ]
}