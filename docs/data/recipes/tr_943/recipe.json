  "steps": [
    {
      "order": 1,
      "instruction": "Dressing - shake in a jar."
    },
    {
      "order": 2,
      "instruction": "Place Lentil ingredients in a saucepan, bring to simmer over medium heat. Place lid on then lower heat to medium low so it&#039;s simmering gently."
    },
    {
      "order": 3,
      "instruction": "Cook for 20 minutes (for al dente, my preference), or 25 minutes (for soft), stirring occasionally."
    },
    {
      "order": 4,
      "instruction": "Drain, then pick out all the flavouring bits (garlic etc). BRIEFLY rinse to get grit off - don&#039;t wash off all the flavour! Shake off excess water well."
    },
    {
      "order": 5,
      "instruction": "Preheat oven to 240°C / 450°F (220°C fan). Line a tray with parchment/baking paper."
    },
    {
      "order": 6,
      "instruction": "Cut eggplant into large cubes - 3 cm / 1.2&quot;. Place in large bowl, drizzle with oil, salt and pepper."
    },
    {
      "order": 7,
      "instruction": "Toss well, then immediately spread on tray and roast 20 minutes. Flip, then roast for a further 10 minutes - edges should be caramelised, soft inside, but they&#039;re not shrivelled up and dismal."
    },
    {
      "order": 8,
      "instruction": "Add tomato and rocket into lentils, drizzle over most of the Dressing then toss."
    },
    {
      "order": 9,
      "instruction": "Pour onto serving platter. Pile over eggplant."
    },
    {
      "order": 10,
      "instruction": "Drizzle eggplant with remaining Dressing, sprinkle with feta . Serve warm or at room temp! Great with a side of flatbread or this easy crusty bread."
    }
  ]
