  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 160C/320F."
    },
    {
      "order": 2,
      "instruction": "Mix butter with garlic and salt."
    },
    {
      "order": 3,
      "instruction": "Cut bread in half horizontally."
    },
    {
      "order": 4,
      "instruction": "Drizzle with garlic butter all over - don't miss any patches!"
    },
    {
      "order": 5,
      "instruction": "Bake 20 minutes until bread is crispy on the edges."
    },
    {
      "order": 6,
      "instruction": "Crank oven up to 200C/390F. Top with cheese, bake 7 - 10 min until cheese is melted and bubbly."
    },
    {
      "order": 7,
      "instruction": "Sprinkle with parsley if using, cut bread into pieces. Serve immediately as a side for meals, dunking in soups and stews!"
    }
