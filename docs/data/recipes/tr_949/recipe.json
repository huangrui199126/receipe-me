  "steps": [
    {
      "order": 1,
      "instruction": "Mix Marinade in a large bowl."
    },
    {
      "order": 2,
      "instruction": "Scoop out 1/2 cup and reserve for basting (&quot;Glaze&quot;)."
    },
    {
      "order": 3,
      "instruction": "Add chicken, turn to coat. Marinade overnight (minimum 3 hours, up to 48 hours, or freeze)."
    },
    {
      "order": 4,
      "instruction": "Brush BBQ with vegetable or canola oil, then preheat to medium."
    },
    {
      "order": 5,
      "instruction": "Pick up chicken, allowing excess Marinade to drip off."
    },
    {
      "order": 6,
      "instruction": "Place on BBQ, cook 4 minutes until nicely caramelised."
    },
    {
      "order": 7,
      "instruction": "Turn chicken, then brush generously with Glaze. Cook 4 minutes."
    },
    {
      "order": 8,
      "instruction": "Flip, brush with more Glaze, flip again and brush with Glaze."
    },
    {
      "order": 9,
      "instruction": "Remove chicken onto plate, cover loosely with foil."
    },
    {
      "order": 10,
      "instruction": "Rest 3 minutes before serving, sprinkled with parsley if using. Pictured in post with Macaroni Salad!"
    },
    {
      "order": 11,
      "instruction": "Stove - follow up steps in a non stick pan, heated to medium high with 1 tbsp oil (cook in batches if needed)."
    },
    {
      "order": 12,
      "instruction": "Oven - use this recipe: Sticky Baked Chicken"
    }
  ]
}