  "steps": [
    {
      "order": 1,
      "instruction": "Place the Seasoning ingredients in a small dish and mix."
    },
    {
      "order": 2,
      "instruction": "Coat salmon in the Seasoning, shaking off excess well."
    },
    {
      "order": 3,
      "instruction": "Place oil and about 1 tsp of the butter in a large non stick skillet over medium high heat. Once the butter is melted, add the salmon."
    },
    {
      "order": 4,
      "instruction": "Cook salmon for 3 minutes, or until it’s a beautiful bronzed golden brown. Turn and cook for 1 minute."
    },
    {
      "order": 5,
      "instruction": "Add remaining butter, garlic and honey. Swirl the mixture around the pan as the butter melts."
    },
    {
      "order": 6,
      "instruction": "Simmer for 1 minute - the honey butter mixture will start to bubble like caramel and turn golden. Add lemon juice, shake pan to disperse. Taste sauce – adjust salt, pepper and lemon to taste."
    },
    {
      "order": 7,
      "instruction": "Turn salmon over to coat in the sauce, then remove from heat immediately. Place salmon on plates and drizzle over sauce. Garnish with parsley and fresh lemon, if desired"
    }
  ]
