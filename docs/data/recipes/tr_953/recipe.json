  "steps": [
    {
      "order": 1,
      "instruction": "Heat oil in a large saucepan over high heat. Add prawns and sear both sides until light golden (doesn't need to cook inside). Remove onto plate."
    },
    {
      "order": 2,
      "instruction": "Turn heat down to medium. If pot is looking dry, add a touch of extra oil."
    },
    {
      "order": 3,
      "instruction": "Add garlic, ginger and lemongrass. Saute for 20 seconds until garlic is golden."
    },
    {
      "order": 4,
      "instruction": "Add sugar and fish sauce. Stir and cook for 30 seconds - it should look like caramel."
    },
    {
      "order": 5,
      "instruction": "Add chilli paste, coriander and curry powder. Stir and cook for 30 seconds."
    },
    {
      "order": 6,
      "instruction": "Add chicken broth and coconut milk. Stir and bring to simmer."
    },
    {
      "order": 7,
      "instruction": "Simmer for 2 minutes, then add lime zest and return prawns into broth."
    },
    {
      "order": 8,
      "instruction": "Cook for 2 minutes just to reheat and finish cooking the prawns."
    },
    {
      "order": 9,
      "instruction": "Place noodles in bowl. Ladle over soup."
    },
    {
      "order": 10,
      "instruction": "Top with bean sprouts and coriander, plus toppings of choice (chilli, red onion, Asian fried shallots)."
    },
    {
      "order": 11,
      "instruction": "Squeeze over lime juice to taste. Slurp and be happy!"
    }
  ]
}