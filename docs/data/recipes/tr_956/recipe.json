  "steps": [
    {
      "order": 1,
      "instruction": "Marinate - Toss all the gazpacho ingredients together in a large bowl. Cover then set aside to marinate, preferably 12 to 24 hours, or at least 3 hours. (Note 3)"
    },
    {
      "order": 2,
      "instruction": "Blitz - Transfer everything into a blender and blitz on high until smooth. (Or use a tall jug with a hand blender). For 100% perfectly smooth, pass through a fine mesh strainer or food mill and discard solids (Note 2)"
    },
    {
      "order": 3,
      "instruction": "Serve - Pour into a bowl. Rest for 15 minutes to let the bubbles subside. Stir, then ladle into bowls."
    },
    {
      "order": 4,
      "instruction": "Garnish - Top with diced cucumber, if using, and a swish of olive oil. Serve with crusty bread!"
    }
  ]
