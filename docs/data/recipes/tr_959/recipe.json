  "steps": [
    {
      "order": 1,
      "instruction": "Place the Ham Broth ingredients in the slow cooker. Slow cook for 8 hours on low, or 4 hours on high."
    },
    {
      "order": 2,
      "instruction": "Remove ham bone. Shred meat and discard bone. Return half the ham to the slow cooker (remainder is pan fried)."
    },
    {
      "order": 3,
      "instruction": "Discard thyme sprig."
    },
    {
      "order": 4,
      "instruction": "Remove then chop carrot and celery, return to slow cooker."
    },
    {
      "order": 5,
      "instruction": "Melt 1 tbsp butter in a skillet over medium high heat. Add half the ham and cook until golden and crispy."
    },
    {
      "order": 6,
      "instruction": "Transfer most to slow cooker - hold back a few for garnish."
    },
    {
      "order": 7,
      "instruction": "In the same skillet, melt remaining butter. Add onion and garlic, cook 1 minute."
    },
    {
      "order": 8,
      "instruction": "Add celery and carrot, cook for 3 minutes until soft."
    },
    {
      "order": 9,
      "instruction": "Add 2 cups milk, stir."
    },
    {
      "order": 10,
      "instruction": "Mix cornflour and extra Milk. While stirring, pour into skillet. Mixture will thicken quickly."
    },
    {
      "order": 11,
      "instruction": "Once very thick and paste-like, scrape into slow cooker."
    },
    {
      "order": 12,
      "instruction": "Add Vegeta into slow cooker. Stir to dissolve paste."
    },
    {
      "order": 13,
      "instruction": "Add spinach, push down into liquid."
    },
    {
      "order": 14,
      "instruction": "Slow cook 30 minutes on low or 20 minutes on high until spinach is wilted and broth is heated and slightly thickened."
    },
    {
      "order": 15,
      "instruction": "Serve garnished with crispy ham and a sprinkle of parsley, if desired!"
    }
  ]
}