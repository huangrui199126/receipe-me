  "steps": [
    {
      "order": 1,
      "instruction": "Combine the sauce ingredients in a small bowl and mix well until there are no cornflour lumps."
    },
    {
      "order": 2,
      "instruction": "Bring water to boil and cook ramen per packet instructions, using the soup stock packet that comes with the ramen. (See Notes)"
    },
    {
      "order": 3,
      "instruction": "Heat oil in wok (or fry pan) over high heat. Add garlic and stir fry for 20 seconds until fragrant - be careful not to burn it."
    },
    {
      "order": 4,
      "instruction": "Add carrots and mushrooms and stir fry for 30 seconds, then Chinese cabbage and stir fry for another 30 seconds."
    },
    {
      "order": 5,
      "instruction": "Add sauce and cook for 30 seconds until it becomes thick and glossy."
    },
    {
      "order": 6,
      "instruction": "Remove from heat, immediately add the bean sprouts and give a quick stir to coat the bean sprouts in the sauce and use the residual heat to slightly cook the bean sprouts."
    },
    {
      "order": 7,
      "instruction": "Place noodles and soup in bowl, top with vegetables and garnish with shallots. Serve immediately."
    }
  ]
