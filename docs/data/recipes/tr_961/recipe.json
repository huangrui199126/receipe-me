  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F. Brush 4 Texas muffin tin holes with with butter. (Note 3)"
    },
    {
      "order": 2,
      "instruction": "Heat a non stick pan over high heat. Add bacon and fry until lightly browned. Remove onto a paper towel to drain the fat, then set aside."
    },
    {
      "order": 3,
      "instruction": "Place Dry Ingredients in a bowl and mix to combine."
    },
    {
      "order": 4,
      "instruction": "Whisk Wet Ingredients in a separate bowl."
    },
    {
      "order": 5,
      "instruction": "Pour the Wet Ingredients into the Dry Ingredients until flour is almost incorporated (limit to 8 stirs!) - don&#x27;t overmix (makes muffins hard)."
    },
    {
      "order": 6,
      "instruction": "Add green onion, bacon and cheese, stir 5 times."
    },
    {
      "order": 7,
      "instruction": "Place 1/4 cup batter into each of the 4 muffin tin holes."
    },
    {
      "order": 8,
      "instruction": "Use spoon to make a well in the batter, crack egg into each well."
    },
    {
      "order": 9,
      "instruction": "Divide the remaining batter between each hole to cover the egg - best way is to dollop batter around the yolk, then on top of the yolk, then spread to cover (see video)."
    },
    {
      "order": 10,
      "instruction": "Brush the muffins with melted butter, then bake for 25 minutes or until golden brown."
    },
    {
      "order": 11,
      "instruction": "Remove from oven and allow to rest for 5 minutes before turning out onto a cooling rack."
    },
    {
      "order": 12,
      "instruction": "Best served warm!"
    }
  ]
}