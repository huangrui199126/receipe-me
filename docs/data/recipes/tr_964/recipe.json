  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Place all ingredients except butter in a bowl. Mix to combine. Add butter and mix to incorporate."
    },
    {
      "order": 3,
      "instruction": "Hull / cut top off strawberries. Cut larger ones in half, leave small ones whole (2cm / 4/5\" height)."
    },
    {
      "order": 4,
      "instruction": "Place strawberries in bowl. Scatter over cornflour, toss well to coat evenly."
    },
    {
      "order": 5,
      "instruction": "Add sugar, water and vanilla. Mix well."
    },
    {
      "order": 6,
      "instruction": "Pour strawberries into a baking pan (Note 2). Crumble over topping, using your fingers to get some nice crumbly chunks."
    },
    {
      "order": 7,
      "instruction": "Bake for 30 to 40 minutes until the Topping is deep golden and the strawberry syrup is bubbling up energetically all around the edges - see video, this is a key sign that the strawberry sauce has thickened sufficiently."
    },
    {
      "order": 8,
      "instruction": "Stand for a few minutes before serving with ice cream or your choice of topping."
    }
  ]
