  "steps": [
    {
      "order": 1,
      "instruction": "Make Marinade: Whisk Marinade ingredients in a bowl."
    },
    {
      "order": 2,
      "instruction": "Marinade 24 hours: Place beef in a ziplock bag, glass or ceramic container. Pour over Marinade, mix well to coat. Cover and marinade for 24 hours."
    },
    {
      "order": 3,
      "instruction": "Remove beef from Marinade, discard Marinade."
    },
    {
      "order": 4,
      "instruction": "BBQ - Heat on high until smoking hot, then brush grills with vegetable oil. Lay beef on BBQ and cook for 2 minutes on one side until caramelised. Turn and cook the other side until caramelised. Remove, loosely cover with foil, cook remaining beef."
    },
    {
      "order": 5,
      "instruction": "Stove - Cut beef strips into pieces that will fit your skillet. Heat skillet with oil over high heat. Add beef and cook for 2 minutes until caramelised, then turn and cook the other side for 2 minutes."
    },
    {
      "order": 6,
      "instruction": "Garnish beef with sesame seeds and green onions if desired. You don&#039;t need a sauce for this one - it is literally dripping with flavour! Pictured in post with Kimchi Fried Rice and Ginger Smashed Cucumbers."
    }
  ]
