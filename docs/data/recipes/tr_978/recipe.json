  "steps": [
    {
      "order": 1,
      "instruction": "Toss the zucchini in oil then sprinkle with salt and toss to (roughly) coat all over."
    },
    {
      "order": 2,
      "instruction": "Cook - Heat a large non-stick pan over medium-high heat. Place half the zucchini cut side down and cook for 3 to 4 minutes until the surface is golden. Turn and cook the skin side for 3 minutes. Pile onto a serving plate and repeat with remaining zucchini."
    },
    {
      "order": 3,
      "instruction": "Sauce - cool the pan slightly then return to medium heat. Heat the oil then sauté the garlic until light golden. Add remaining Sauce ingredients, simmer for 30 seconds until syrupy."
    },
    {
      "order": 4,
      "instruction": "Serve - Pour over zucchini, pile on Crispy Asian Shallots and green onion. Eat!"
    }
