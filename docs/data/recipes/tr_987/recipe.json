  "steps": [
    {
      "order": 1,
      "instruction": "Bring a pot of water to the boil then cook potato for 12 - 15 minutes until very soft."
    },
    {
      "order": 2,
      "instruction": "Drain, mash and set aside."
    },
    {
      "order": 3,
      "instruction": "Sizzling spices: Heat oil in a dutch oven or pot over high heat. Add black mustard seeds, cumin and fennel seeds. Let them sizzle for 15 seconds - careful, they might pop!"
    },
    {
      "order": 4,
      "instruction": "Curry leaves: Then add curry leaves and stir for 15 seconds."
    },
    {
      "order": 5,
      "instruction": "Aromatics: Add garlic, ginger and onion. Cook for 4 to 5 minutes until onion is tinged with gold."
    },
    {
      "order": 6,
      "instruction": "Tomato: Add tomato paste and tomato, cook for 30 seconds."
    },
    {
      "order": 7,
      "instruction": "Spices: Add curry powder, turmeric and chilli. Cook for 30 seconds."
    },
    {
      "order": 8,
      "instruction": "Most Veg: Add zucchini, carrot and cauliflower. Stir well to coat in the spice paste."
    },
    {
      "order": 9,
      "instruction": "Water: Add water, salt and pepper. Stir, bring to a simmer then put the lid on and reduce heat to medium low (so it&#039;s simmer gently)."
    },
    {
      "order": 10,
      "instruction": "Cook &amp; reduce: Cook for 15 minutes until vegetables are soft. Then remove lid and simmer for 5 minutes to reduce liquid a bit."
    },
    {
      "order": 11,
      "instruction": "Add mash: Remove from stove. Add peas and potato, mix through well."
    },
    {
      "order": 12,
      "instruction": "Taste: Taste and add more salt and pepper if needed."
    },
    {
      "order": 13,
      "instruction": "Cool: Place lid on and cool for at least 30 minutes (even overnight is fine)."
    },
    {
      "order": 14,
      "instruction": "Preheat oven to 180°C/350°F (all oven types)."
    },
    {
      "order": 15,
      "instruction": "Grease a large pie dish with butter, or oil spray (Note 6). Drape in a puff pastry sheet.(I don&#039;t blind bake here - see Note 5)"
    },
    {
      "order": 16,
      "instruction": "Fill with Filling - slightly mounded is fine."
    },
    {
      "order": 17,
      "instruction": "Fold in the corners of the puff pastry sheet."
    },
    {
      "order": 18,
      "instruction": "Top with puff pastry sheet - turn 90 degrees to the base puff pastry sheet (see photo)."
    },
    {
      "order": 19,
      "instruction": "Fold the overhang puff pastry under itself - no need to be neat here, this is a rustic pie!"
    },
    {
      "order": 20,
      "instruction": "Egg wash: Brush with egg, cut a 2cm / 1&quot; cross in the middle (to let steam escape)."
    },
    {
      "order": 21,
      "instruction": "Bake 50 to 60 minutes, until the top is very deep golden and flaky."
    },
    {
      "order": 22,
      "instruction": "Stand 5 minutes then slice to serve. A dollop of plain yogurt goes well with this!"
    }
  ]
}