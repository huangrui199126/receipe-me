  "steps": [
    {
      "order": 1,
      "instruction": "Place Pattie ingredients in bowl, mix well with hands."
    },
    {
      "order": 2,
      "instruction": "Form 4 patties, 1.5cm / 3/5\" thick, slightly larger than the buns (shrinks slightly). If mixture is super sticky (Note 4), either refrigerate mixture for 30 minutes, or wet hands or lightly spray hands with oil (I do this)."
    },
    {
      "order": 3,
      "instruction": "Heat oil in skillet over medium high heat. Add patties, working in batches. Cook for 2 minutes or until deep golden, then flip."
    },
    {
      "order": 4,
      "instruction": "After 1 minute, top with a piece of cheese and place lid on to melt cheese."
    },
    {
      "order": 5,
      "instruction": "Once cheese is melted, remove patties from skillet."
    },
    {
      "order": 6,
      "instruction": "Split buns and lightly toast in oven or under broiler/grill."
    },
    {
      "order": 7,
      "instruction": "Cut avocado in half, scoop out a generous amount then \"smash\" it on the base of the bun with a fork. Sprinkle with salt and pepper."
    },
    {
      "order": 8,
      "instruction": "Top with Chicken Pattie, then rocket/arugula and tomato."
    },
    {
      "order": 9,
      "instruction": "Smear the top bun with mayonnaise (or relish, ketchup, other condiment of choice) and place lid on bun."
    },
    {
      "order": 10,
      "instruction": "Devour and be happy!"
    }
  ]
}