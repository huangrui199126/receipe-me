  "steps": [
    {
      "order": 1,
      "instruction": "Mix Sauce ingredients together."
    },
    {
      "order": 2,
      "instruction": "Prepare noodles according to packet directions. If it says to soak the noodles, you can do that while cooking the stir fry."
    },
    {
      "order": 3,
      "instruction": "Optional: Just before serving, toss the noodles with oil and vinegar.*"
    },
    {
      "order": 4,
      "instruction": "Heat oil in a wok or skillet over medium high heat. Add onions and cook for 1 minute. Add garlic and ginger and cook for 1 minute or until onion is translucent."
    },
    {
      "order": 5,
      "instruction": "Add pork and cook, breaking it up as you go, until browned."
    },
    {
      "order": 6,
      "instruction": "Add sauce and cook for 3 - 5 minutes, or until most of the sauce has reduced."
    },
    {
      "order": 7,
      "instruction": "Divide noodles between bowls. Top with pork, coriander and fresh cucumbers on the side."
    },
    {
      "order": 8,
      "instruction": "To eat, mix up the noodles and pork. I use chopsticks and a spoon - so it's easier to get the pork and noodles in one mouthful. Don't hold back on the chilli paste! It goes great with this dish!"
    }
  ]
