  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 180C/350F."
    },
    {
      "order": 2,
      "instruction": "Place onion, garlic and olive oil in a (approx) 30 x 25 cm / 12 x 10\" pan (Note 4). Mix, spread out, then bake for 8 minutes. (Start the meatballs)"
    },
    {
      "order": 3,
      "instruction": "Remove from oven, add remaining Sauce ingredients. Mix."
    },
    {
      "order": 4,
      "instruction": "Place rack on top of pan."
    },
    {
      "order": 5,
      "instruction": "Turn oven up to 200C/390F."
    },
    {
      "order": 6,
      "instruction": "Place the bread and onion in a large bowl. Mix to combine so the onion juice soaks the bread, set aside for 3 minutes. Bread should disintegrate into mush - if not, add a splash of milk or water to help it along."
    },
    {
      "order": 7,
      "instruction": "Add all the remaining Meatball ingredients except oil spray. Use you hands to mix well."
    },
    {
      "order": 8,
      "instruction": "Measure out very generously heaped tablespoons and roll into firm balls. It should make around 20 - don't make them too small, they will cook too quickly."
    },
    {
      "order": 9,
      "instruction": "Place meatballs on the rack, ensuring they are positioned over the pan so the juices will drip into the Sauce."
    },
    {
      "order": 10,
      "instruction": "Spray generously with oil."
    },
    {
      "order": 11,
      "instruction": "Bake for 20 minutes. Optional: flick to grill/broil on high for 2 minutes at the end, to get better browning."
    },
    {
      "order": 12,
      "instruction": "Transfer meatballs from rack into the Sauce. Stir to coat meatballs in Sauce."
    },
    {
      "order": 13,
      "instruction": "Serve with spaghetti or other pasta of choice, garnished with fresh parsley and parmesan."
    }
  ]
}