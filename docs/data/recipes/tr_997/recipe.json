  "steps": [
    {
      "order": 1,
      "instruction": "Preheat oven to 200C/390F (standard) / 180C/350F (fan / convection)."
    },
    {
      "order": 2,
      "instruction": "Mix Spice Mix in a small bowl."
    },
    {
      "order": 3,
      "instruction": "Place Rice ingredients in a baking dish (including the carrots), about 23 x 30 cm / &nbsp;9 x 13\". Add 1 1/2 tsp Spice Mix. Stir, cover with foil, bake for 20 minutes."
    },
    {
      "order": 4,
      "instruction": "Meanwhile, place Roasting Vegetable ingredients in a large bowl, drizzle with 1/4 cup olive oil. Sprinkle over remaining Spice Mix. Mix well - hands are best for this."
    },
    {
      "order": 5,
      "instruction": "Remove rice from oven."
    },
    {
      "order": 6,
      "instruction": "Turn oven UP to 220C/430F (standard) / 200C/390F (fan / convection)."
    },
    {
      "order": 7,
      "instruction": "Take off foil. Spread the Roasting Vegetables on top of the rice. Make sure there's a bit of each type of vegetable on the surface. Push corn mostly under."
    },
    {
      "order": 8,
      "instruction": "Drizzle with more oil (optional), sprinkle with more pepper."
    },
    {
      "order": 9,
      "instruction": "Bake for 30 minutes. Remove from oven, rest for 5 - 10 minutes."
    },
    {
      "order": 10,
      "instruction": "Sprinkle with parsley if desired. Push vegetables aside, fluff rice and toss it through the vegetables a bit (rice gets more flavour). Serve!"
    }
  ]
}